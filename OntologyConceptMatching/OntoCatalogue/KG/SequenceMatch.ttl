# Metric Resource: SequenceMatchRatio
<https://w3id.org/soel/metric/SequenceMatchRatio> a dqv:Metric ;

    dcterms:identifier "https://w3id.org/soel/metric/SequenceMatchRatio" ;
    dcterms:title "Token-level string similarity comparison"@en ;
    rdfs:label "SequenceMatchRatio: Token-level string similarity comparison"^^xsd:string ;
    vivo:abbreviation "sequence_match"^^xsd:string ;
    dcat:version "0.0.1"^^xsd:string ;
    ftr:status "Active"@en ;
    dcat:landingPage <https://w3id.org/soel/metric/SequenceMatchRatio> ;

    # Descriptive Content
    dcterms:description """
Uses token-level similarity via difflib SequenceMatcher to capture partially matching or reordered labels. 
""" ;
    dcat:keyword "Ontology Concept Matching"@en ;
    dcat:keyword "Metric"@en ;
    dcat:keyword "Classes"@en ;
    
    # Relationships and Provenance
    dpv:isApplicableFor <https://www.wikidata.org/wiki/Q184754> ;
    ftr:hasBenchmark <https://w3id.org/soel/benchmark/ALL> ;
    <http://semanticscience.org/resource/SIO_000234> <https://w3id.org/soel/test/SequenceMatchRatio> ; # Has Implementation
    ftr:supportedBy <https://w3id.org/soel/> ;
    dqv:inDimension  "Ontology Engineering"^^xsd:string ;
    
    # Provenance
    dcterms:creator <https://orcid.org/0009-0001-9475-8159> ;
    dcat:contactPoint <https://orcid.org/0009-0001-9475-8159> ;
    dcterms:publisher <https://oeg.fi.upm.es> ;
    dcterms:publisher <https://ror.org/03n6nwv02> ;
    dcterms:license <http://creativecommons.org/licenses/by/4.0/> .

