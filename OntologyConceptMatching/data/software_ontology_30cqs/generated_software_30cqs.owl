<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#hasVersion">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Version"/>
    <rdfs:comment>Links a software to its version information. Answers 'What is the version of this software?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#hasPotentialUser">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Agent"/>
    <rdfs:comment>Relates a software to its potential users. Answers 'Who are the potential users of software we develop?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#implementedIn">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#ProgrammingLanguage"/>
    <rdfs:comment>Specifies the programming language used to implement the software. Answers 'In what language was it implemented?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#developedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Agent"/>
    <rdfs:comment>Relates a software to its developer(s). Answers 'Who developed it?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#supportsStandard">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Standard"/>
    <rdfs:comment>Relates a software to a standard it supports. Answers 'To what extent does the software support appropriate open standards?' and 'Does this software meet the ISO-4 standard?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#homepage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
    <rdfs:comment>The official homepage of the software. Answers 'What is the homepage of the software?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#hasOutput">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Data"/>
    <rdfs:comment>Specifies the output data of a software. Answers 'What are the primary inputs and outputs?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Screenshot">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Documentation"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#releaseDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Version"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
    <rdfs:comment>The release date of a specific software version. Answers 'When was the 1.0 version released?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#hasDocumentation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Documentation"/>
    <rdfs:comment>Links software to its documentation. Answers 'Are there any usage examples/test data/screen shots/videos?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Version">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment>Represents a specific version of a software.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#createdBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Data"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Software"/>
    <rdfs:comment>Relates data to the software that created it. Answers 'Which software tool created this data?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Hardware">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment>Represents a hardware component or system requirement.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#extensionMechanism">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment>Describes how the software can be extended (e.g., API, plugins). Answers 'How can I extend the software to include a new function?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#cost">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment>Describes the cost of using the software. Answers 'Does cost of using it make sense for my project? Is it cost effective?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#hasInput">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Data"/>
    <rdfs:comment>Specifies the input data for a software. Answers 'What are the primary inputs and outputs?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#citation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment>Provides the citation information for the software. Answers 'How do I cite the software?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#hasSupportOption">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Support"/>
    <rdfs:comment>Links software to its support options. Answers 'How can I get problems fixed?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#licenseRequirement">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment>Describes licensing requirements like passwords or keys. Answers 'Do I need a password/license key to use it?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#downloadURL">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
    <rdfs:comment>The URL where the software can be downloaded. Answers 'Where can I get the software?' and 'Which URL can I get it from?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#WebService">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Software"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#requiresHardware">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Hardware"/>
    <rdfs:comment>Specifies the hardware requirements for the software. Answers 'What hardware do I need to run this software?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Task">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment>Represents a function or capability of a software.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#ProgrammingLanguage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment>Represents a programming language.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Agent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment>Represents a person or an organization.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#developmentModel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment>Describes the development model (e.g., open source, community). Answers 'Is the software open source development? Is there a community development?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#versionNumber">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Version"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment>The version number or identifier (e.g., '1.0', '2.3.1-beta').</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Platform">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment>Represents an operating system or execution environment.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#qualityMetric">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment>A property to describe quality aspects like speed, robustness, etc. Answers 'Which is the best/fastest/most robust...'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#UsageExample">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Documentation"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#hasUser">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Person"/>
    <rdfs:comment>Relates a software to a person who has used it. Answers 'Do I know anyone who has used this software?' and 'Who else has used tool x today?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#canPerform">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Task"/>
    <rdfs:comment>Relates a software to a task it can perform. Answers 'What software can perform task x?' and 'Does this software provide XML editing?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#TestData">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Documentation"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#runsOn">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Platform"/>
    <rdfs:comment>Specifies the platform(s) the software runs on. Answers 'What platform does the software run on?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#usesAlgorithm">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Algorithm"/>
    <rdfs:comment>Relates a software to the algorithm it uses for processing. Answers 'What is the algorithm used to process this data?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#hasCopyrightHolder">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Agent"/>
    <rdfs:comment>Relates a software to its copyright holder. Answers 'Who owns the copyright?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#DesktopApplication">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Software"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Person">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Agent"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Software">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment>The central class representing a software tool, application, or library.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Support">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment>Represents a mechanism for getting support for a software.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#API">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Software"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Standard">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment>Represents a standard, such as an ISO or W3C standard.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Organization">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Agent"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Algorithm">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment>Represents a computational algorithm used by a software.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Documentation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment>Represents supporting materials for a software.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Data">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment>Represents data that can be an input to or output from a software.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Video">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/user/ontologies/2024/3/software-ontology#Documentation"/>
  </rdf:Description>
</rdf:RDF>
