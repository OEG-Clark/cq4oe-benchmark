<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>
  <rdf:Description rdf:about="http://www.example.org/odrl-ontology#obligation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/odrl-ontology#Policy"/>
    <rdfs:range rdf:resource="http://www.example.org/odrl-ontology#Duty"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/odrl-ontology#isFulfilled">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/odrl-ontology#Duty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:comment>Indicates if a duty has been fulfilled (CQ8).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/odrl-ontology#Policy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/odrl-ontology#unit">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/odrl-ontology#Constraint"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
    <rdfs:comment>The unit for the right operand of a constraint, e.g., currency or measurement (CQ7).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/odrl-ontology#permission">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/odrl-ontology#Policy"/>
    <rdfs:range rdf:resource="http://www.example.org/odrl-ontology#Permission"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/odrl-ontology#Prohibition">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.example.org/odrl-ontology#Rule"/>
    <rdfs:comment>A prohibition or restriction.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/odrl-ontology#constraint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/odrl-ontology#Rule"/>
    <rdfs:range rdf:resource="http://www.example.org/odrl-ontology#Constraint"/>
    <rdfs:comment>Associates a Rule with a Constraint.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/odrl-ontology#hasMember">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/odrl-ontology#AssetCollection"/>
    <rdfs:range rdf:resource="http://www.example.org/odrl-ontology#Asset"/>
    <rdfs:comment>Links a collection to its members (CQ11).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/odrl-ontology#Rule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/odrl-ontology#Offer">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.example.org/odrl-ontology#Policy"/>
    <rdfs:comment>A policy representing an offer in a negotiation (CQ4).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/odrl-ontology#assignee">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/odrl-ontology#Rule"/>
    <rdfs:range rdf:resource="http://www.example.org/odrl-ontology#Party"/>
    <rdfs:comment>The party to whom a rule is assigned (CQ5, CQ6).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/odrl-ontology#prohibition">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/odrl-ontology#Policy"/>
    <rdfs:range rdf:resource="http://www.example.org/odrl-ontology#Prohibition"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/odrl-ontology#action">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/odrl-ontology#Rule"/>
    <rdfs:range rdf:resource="http://www.example.org/odrl-ontology#Action"/>
    <rdfs:comment>Associates a Rule with an Action.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/odrl-ontology#hasStatus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/odrl-ontology#Policy"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment>The status of a policy or agreement (CQ3).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/odrl-ontology#inheritsFrom">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/odrl-ontology#Policy"/>
    <rdfs:range rdf:resource="http://www.example.org/odrl-ontology#Policy"/>
    <rdfs:comment>Indicates that a policy inherits rules from another policy (CQ12).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/odrl-ontology#hasSucceededBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/odrl-ontology#Rule"/>
    <rdfs:range rdf:resource="http://www.example.org/odrl-ontology#Rule"/>
    <rdfs:comment>Indicates the next rights or duties that follow the current one (CQ1).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/odrl-ontology#isResponseTo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/odrl-ontology#Policy"/>
    <rdfs:range rdf:resource="http://www.example.org/odrl-ontology#Policy"/>
    <rdfs:comment>Links policies in a negotiation process (CQ4).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/odrl-ontology#Party">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/odrl-ontology#Transfer">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.example.org/odrl-ontology#Action"/>
    <rdfs:comment>A type of action that involves transferring rights (CQ2).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/odrl-ontology#consequence">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/odrl-ontology#Duty"/>
    <rdfs:range rdf:resource="http://www.example.org/odrl-ontology#Rule"/>
    <rdfs:comment>A rule to be enforced if a duty is not fulfilled (CQ9).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/odrl-ontology#operator">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/odrl-ontology#Constraint"/>
    <rdfs:comment>The operator of a constraint expression.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/odrl-ontology#Aggregate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.example.org/odrl-ontology#Transfer"/>
    <rdfs:comment>The action of aggregating content (CQ2).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/odrl-ontology#target">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/odrl-ontology#Rule"/>
    <rdfs:range rdf:resource="http://www.example.org/odrl-ontology#Asset"/>
    <rdfs:comment>The asset to which a rule applies.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/odrl-ontology#rightOperand">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/odrl-ontology#Constraint"/>
    <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
    <rdfs:comment>The right operand (literal value) of a constraint expression (CQ7).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/odrl-ontology#Disaggregate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.example.org/odrl-ontology#Transfer"/>
    <rdfs:comment>The action of disaggregating content (CQ2).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/odrl-ontology#assigner">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/odrl-ontology#Rule"/>
    <rdfs:range rdf:resource="http://www.example.org/odrl-ontology#Party"/>
    <rdfs:comment>The party who assigns a rule (CQ5, CQ6).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/odrl-ontology#AssetCollection">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.example.org/odrl-ontology#Asset"/>
    <rdfs:comment>A collection of assets (CQ11).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/odrl-ontology#Duty">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.example.org/odrl-ontology#Rule"/>
    <rdfs:comment>An obligation or requirement.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/odrl-ontology#Action">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/odrl-ontology#leftOperand">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/odrl-ontology#Constraint"/>
    <rdfs:comment>The left operand of a constraint expression.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/odrl-ontology#Permission">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.example.org/odrl-ontology#Rule"/>
    <rdfs:comment>A permission or right granted.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/odrl-ontology#Agreement">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.example.org/odrl-ontology#Policy"/>
    <rdfs:comment>A policy representing a formal agreement (CQ4).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/odrl-ontology#Asset">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/odrl-ontology">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/odrl-ontology#Constraint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
</rdf:RDF>
