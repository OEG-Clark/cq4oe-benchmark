<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:odrl="http://example.org/odrl-ontology#">
    <owl:Ontology rdf:about="http://example.org/odrl-ontology">
        <rdfs:label>ODRL Ontology Based on Competency Questions</rdfs:label>
    </owl:Ontology>

    <!-- Define Classes -->
    <owl:Class rdf:ID="Policy">
        <rdfs:label>Policy</rdfs:label>
    </owl:Class>
    <owl:Class rdf:ID="Rule">
        <rdfs:subClassOf rdf:resource="#Policy"/>
        <rdfs:label>Rule</rdfs:label>
    </owl:Class>
    <owl:Class rdf:ID="Permission">
        <rdfs:subClassOf rdf:resource="#Rule"/>
        <rdfs:label>Permission</rdfs:label>
    </owl:Class>
    <owl:Class rdf:ID="Duty">
        <rdfs:subClassOf rdf:resource="#Rule"/>
        <rdfs:label>Duty</rdfs:label>
    </owl:Class>
    <owl:Class rdf:ID="Prohibition">
        <rdfs:subClassOf rdf:resource="#Rule"/>
        <rdfs:label>Prohibition</rdfs:label>
    </owl:Class>
    <owl:Class rdf:ID="Constraint">
        <rdfs:label>Constraint</rdfs:label>
    </owl:Class>
    <owl:Class rdf:ID="Party">
        <rdfs:label>Party</rdfs:label>
    </owl:Class>
    <owl:Class rdf:ID="Asset">
        <rdfs:label>Asset</rdfs:label>
    </owl:Class>
    <owl:Class rdf:ID="Action">
        <rdfs:label>Action</rdfs:label>
    </owl:Class>
    <owl:Class rdf:ID="TransferRight">
        <rdfs:subClassOf rdf:resource="#Action"/>
        <rdfs:label>Transfer Right</rdfs:label>
    </owl:Class>
    <owl:Class rdf:ID="Aggregation">
        <rdfs:subClassOf rdf:resource="#TransferRight"/>
        <rdfs:label>Aggregation</rdfs:label>
    </owl:Class>
    <owl:Class rdf:ID="Disaggregation">
        <rdfs:subClassOf rdf:resource="#TransferRight"/>
        <rdfs:label>Disaggregation</rdfs:label>
    </owl:Class>
    <owl:Class rdf:ID="Status">
        <rdfs:label>Status</rdfs:label>
    </owl:Class>
    <owl:Class rdf:ID="DocumentType">
        <rdfs:label>Document Type</rdfs:label>
    </owl:Class>
    <owl:Class rdf:ID="NegotiationProcess">
        <rdfs:label>Negotiation Process</rdfs:label>
    </owl:Class>
    <owl:Class rdf:ID="PaymentRequirement">
        <rdfs:subClassOf rdf:resource="#Duty"/>
        <rdfs:label>Payment Requirement</rdfs:label>
    </owl:Class>
    <owl:Class rdf:ID="FairUse">
        <rdfs:subClassOf rdf:resource="#Constraint"/>
        <rdfs:label>Fair Use</rdfs:label>
    </owl:Class>
    <owl:Class rdf:ID="Container">
        <rdfs:label>Container</rdfs:label>
    </owl:Class>
    <owl:Class rdf:ID="Meter">
        <rdfs:label>Meter</rdfs:label>
    </owl:Class>
    <owl:Class rdf:ID="Role">
        <rdfs:label>Role</rdfs:label>
    </owl:Class>

    <!-- Define Properties -->
    <owl:ObjectProperty rdf:ID="hasPermission">
        <rdfs:domain rdf:resource="#Policy"/>
        <rdfs:range rdf:resource="#Permission"/>
        <rdfs:label>has Permission</rdfs:label>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:ID="hasDuty">
        <rdfs:domain rdf:resource="#Policy"/>
        <rdfs:range rdf:resource="#Duty"/>
        <rdfs:label>has Duty</rdfs:label>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:ID="hasConstraint">
        <rdfs:domain rdf:resource="#Rule"/>
        <rdfs:range rdf:resource="#Constraint"/>
        <rdfs:label>has Constraint</rdfs:label>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:ID="hasParty">
        <rdfs:domain rdf:resource="#Rule"/>
        <rdfs:range rdf:resource="#Party"/>
        <rdfs:label>has Party</rdfs:label>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:ID="hasAsset">
        <rdfs:domain rdf:resource="#Rule"/>
        <rdfs:range rdf:resource="#Asset"/>
        <rdfs:label>has Asset</rdfs:label>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:ID="hasAction">
        <rdfs:domain rdf:resource="#Rule"/>
        <rdfs:range rdf:resource="#Action"/>
        <rdfs:label>has Action</rdfs:label>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:ID="hasStatus">
        <rdfs:domain rdf:resource="#Policy"/>
        <rdfs:range rdf:resource="#Status"/>
        <rdfs:label>has Status</rdfs:label>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:ID="hasDocumentLink">
        <rdfs:domain rdf:resource="#NegotiationProcess"/>
        <rdfs:range rdf:resource="#DocumentType"/>
        <rdfs:label>has Document Link</rdfs:label>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:ID="hasRole">
        <rdfs:domain rdf:resource="#Party"/>
        <rdfs:range rdf:resource="#Role"/>
        <rdfs:label>has Role</rdfs:label>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:ID="isTypeOf">
        <rdfs:domain rdf:resource="#Meter"/>
        <rdfs:range rdf:resource="#Constraint"/>
        <rdfs:label>is Type Of</rdfs:label>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:ID="fulfilledBy">
        <rdfs:domain rdf:resource="#Duty"/>
        <rdfs:range rdf:resource="#Constraint"/>
        <rdfs:label>fulfilled By</rdfs:label>
    </owl:ObjectProperty>
    <owl:DatatypeProperty rdf:ID="hasLatePaymentDate">
        <rdfs:domain rdf:resource="#PaymentRequirement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:label>has Late Payment Date</rdfs:label>
    </owl:DatatypeProperty>
    <owl:ObjectProperty rdf:ID="nextRights">
        <rdfs:domain rdf:resource="#Permission"/>
        <rdfs:range rdf:resource="#Permission"/>
        <rdfs:label>next Rights</rdfs:label>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:ID="expressesInheritance">
        <rdfs:domain rdf:resource="#Policy"/>
        <rdfs:range rdf:resource="#Policy"/>
        <rdfs:label>expresses Inheritance</rdfs:label>
    </owl:ObjectProperty>
</rdf:RDF>