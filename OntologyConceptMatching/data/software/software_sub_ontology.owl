        <obo:IAO_0000111>year</obo:IAO_0000111>
        <obo:IAO_0000115>A time unit which is equal to 12 months which is science is taken to be equal to 365.25 days.</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/uo.owl"/>
        <rdfs:label>year</rdfs:label>
    </owl:NamedIndividual>
    


