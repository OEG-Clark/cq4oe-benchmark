        <obo:IAO_0000111>day</obo:IAO_0000111>
        <obo:IAO_0000115>A time unit which is equal to 24 hours.</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/uo.owl"/>
        <rdfs:label>day</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://purl.obolibrary.org/obo/UO_0000034 -->

    <owl:NamedIndividual rdf:about="http://purl.obolibrary.org/obo/UO_0000034">
        <obo:IAO_0000111>week</obo:IAO_0000111>
        <obo:IAO_0000115>A time unit which is equal to 7 days.</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/uo.owl"/>
        <rdfs:label>week</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://purl.obolibrary.org/obo/UO_0000035 -->

    <owl:NamedIndividual rdf:about="http://purl.obolibrary.org/obo/UO_0000035">
        <obo:IAO_0000111>month</obo:IAO_0000111>
        <obo:IAO_0000115>A time unit which is approximately equal to the length of time of one of cycle of the moon&apos;s phases which in science is taken to be equal to 30 days.</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/uo.owl"/>
        <rdfs:label>month</rdfs:label>
    </owl:NamedIndividual>
    


