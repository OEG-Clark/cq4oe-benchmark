    <!-- http://purl.obolibrary.org/obo/OBI_0002327 -->

    <owl:NamedIndividual rdf:about="http://purl.obolibrary.org/obo/OBI_0002327">
        <obo:IAO_0000111>Stage IA (FIGO)</obo:IAO_0000111>
        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000120"/>
        <obo:IAO_0000115>An International Federation of Gynecology and Obstetrics cervical cancer stage value specification indicating invasive carcinoma which can be diagnosed only by microscopy, with deepest invasion &lt;5 mm and the largest extension &lt;7 mm.</obo:IAO_0000115>
        <obo:IAO_0000117>Chris Stoeckert, Helena Ellis</obo:IAO_0000117>
        <obo:IAO_0000118>Stage IA</obo:IAO_0000118>
        <obo:IAO_0000119>https://en.wikipedia.org/wiki/Cervical_cancer_staging</obo:IAO_0000119>
        <obo:IAO_0000234>NCI BBRB</obo:IAO_0000234>
        <rdfs:label>Stage IA (FIGO)</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0002328 -->

    <owl:NamedIndividual rdf:about="http://purl.obolibrary.org/obo/OBI_0002328">
        <obo:IAO_0000111>Stage IA1 (FIGO)</obo:IAO_0000111>
        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000120"/>
        <obo:IAO_0000115>An International Federation of Gynecology and Obstetrics cervical cancer stage value specification indicating measured stromal invasion of &lt;3.0 mm in depth and extension of &lt;7.0 mm.</obo:IAO_0000115>
        <obo:IAO_0000117>Chris Stoeckert, Helena Ellis</obo:IAO_0000117>
        <obo:IAO_0000118>Stage IA1</obo:IAO_0000118>
        <obo:IAO_0000119>https://en.wikipedia.org/wiki/Cervical_cancer_staging</obo:IAO_0000119>
        <obo:IAO_0000234>NCI BBRB</obo:IAO_0000234>
        <rdfs:label>Stage IA1 (FIGO)</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0002329 -->

    <owl:NamedIndividual rdf:about="http://purl.obolibrary.org/obo/OBI_0002329">
        <obo:IAO_0000111>Stage IA2 (FIGO)</obo:IAO_0000111>
        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000120"/>
        <obo:IAO_0000115>An International Federation of Gynecology and Obstetrics cervical cancer stage value specification indicating measured stromal invasion of &gt;3.0 mm and not &gt;5.0 mm with an extension of not &gt;7.0 mm.</obo:IAO_0000115>
        <obo:IAO_0000117>Chris Stoeckert, Helena Ellis</obo:IAO_0000117>
        <obo:IAO_0000118>Stage IA2</obo:IAO_0000118>
