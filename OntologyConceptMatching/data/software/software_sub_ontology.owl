                            <rdf:Description rdf:about="http://www.ebi.ac.uk/swo/organization/SWO_9000056"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000057"/>
