        <obo:IAO_0000118>Stage IIIC</obo:IAO_0000118>
        <obo:IAO_0000119>https://en.wikipedia.org/wiki/Cancer_staging</obo:IAO_0000119>
        <obo:IAO_0000234>NCI BBRB</obo:IAO_0000234>
        <rdfs:label>Stage IIIC (AJCC 7th)</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0002324 -->

    <owl:NamedIndividual rdf:about="http://purl.obolibrary.org/obo/OBI_0002324">
        <obo:IAO_0000111>Stage IVA (AJCC 7th)</obo:IAO_0000111>
        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000120"/>
        <obo:IAO_0000115>A clinical tumor stage group according to AJCC 7th edition indicating cancers in patients who present with distant metastases at diagnosis and with differing characteristics from IVB.</obo:IAO_0000115>
        <obo:IAO_0000117>Chris Stoeckert, Helena Ellis</obo:IAO_0000117>
        <obo:IAO_0000118>Stage IVA</obo:IAO_0000118>
