<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#hasOutput">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.example.org/software-ontology#Data"/>
    <rdfs:comment>Defines the primary output data of the software. Answers: 'What are the primary inputs and outputs?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#hasInput">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.example.org/software-ontology#Data"/>
    <rdfs:comment>Defines the primary input data for the software. Answers: 'What are the primary inputs and outputs?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#versionNumber">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/software-ontology#Version"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment>The version identifier, e.g., '1.0'. Answers: 'What is the version of this software?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#Person">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.example.org/software-ontology#Agent"/>
    <rdfs:comment>An individual person, such as a developer or user.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#Example">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.example.org/software-ontology#Resource"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#createsData">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.example.org/software-ontology#Data"/>
    <rdfs:comment>Indicates that a software tool produces or authors a specific data entity. Answers: 'Which software tool created this data?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#Resource">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment>An external resource related to the software.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#releaseDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/software-ontology#Version"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    <rdfs:comment>The release date of a specific software version. Answers: 'When was the 1.0 version released?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#runsOnPlatform">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.example.org/software-ontology#Platform"/>
    <rdfs:comment>Specifies the platform (e.g., operating system) the software runs on. Answers: 'What platform does the software run on?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#Repository">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.example.org/software-ontology#Resource"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#hasResource">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.example.org/software-ontology#Resource"/>
    <rdfs:comment>A general property to link software to an external resource.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#hasSupportContact">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.example.org/software-ontology#Agent"/>
    <rdfs:comment>Specifies who to contact for support. Answers: 'How can I get problems fixed?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#extensibilityNotes">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment>Notes on how the software can be extended. Answers: 'How can I extend the software to include a new function?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#ProprietaryLicense">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.example.org/software-ontology#License"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#conformsToStandard">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.example.org/software-ontology#Standard"/>
    <rdfs:comment>Links software to a standard it complies with. Answers: 'Does this software meet the ISO-4 standard?', 'To what extent does the software support appropriate open standards?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#performanceMetric">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment>Stores qualitative or quantitative performance metrics. Answers: 'Which is the best/fastest/most robust...'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#requiresKey">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/software-ontology#License"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:comment>Indicates if a license key or password is required. Answers: 'Do I need a password/license key to use it?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#Platform">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment>The environment on which software runs.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#Standard">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment>A standard to which software may conform.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#processesData">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.example.org/software-ontology#Data"/>
    <rdfs:comment>Indicates that the software can read, edit, or otherwise process a type of data. Answers: 'Which is the best/fastest/most robust concretizes to read/edit this data?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#performsTask">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.example.org/software-ontology#Task"/>
    <rdfs:comment>Describes a task that the software can perform. Answers: 'What software can perform task x?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#requiresHardware">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.example.org/software-ontology#Hardware"/>
    <rdfs:comment>Specifies the hardware requirements for the software. Answers: 'What hardware do I need to run this software?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#hasVersion">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.example.org/software-ontology#Version"/>
    <rdfs:comment>Links a software product to its specific versions. Answers: 'What is the version of this software?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#License">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment>The license under which software is distributed.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#Organization">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.example.org/software-ontology#Agent"/>
    <rdfs:comment>An organization, such as a company or foundation.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#OperatingSystem">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.example.org/software-ontology#Platform"/>
    <rdfs:comment>An operating system on which the software runs.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#hasCitationInfo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://www.example.org/software-ontology#hasResource"/>
    <rdfs:range rdf:resource="http://www.example.org/software-ontology#Publication"/>
    <rdfs:comment>Links to a publication or resource on how to cite the software. Answers: 'How do I cite the software?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#cost">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment>The cost of the software. Answers: 'Does cost of using it make sense for my project?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#hasCommunity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.example.org/software-ontology#Community"/>
    <rdfs:comment>Links software to its development community. Answers: 'Is there a community development?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#hasLicense">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.example.org/software-ontology#License"/>
    <rdfs:comment>Links software to its license. Answers: 'Do I need a password/license key to use it?', 'Is the software open source development?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#Task">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment>A task or function that can be performed by software.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#hasOwner">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.example.org/software-ontology#Agent"/>
    <rdfs:comment>Specifies the copyright owner of the software. Answers: 'Who owns the copyright?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#Hardware">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.example.org/software-ontology#Platform"/>
    <rdfs:comment>A piece of hardware required to run the software.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#isCostEffective">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:comment>A boolean indicating if the software is considered cost-effective for a project. Answers: 'Is it cost effective?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#Homepage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.example.org/software-ontology#Resource"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#hasExample">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://www.example.org/software-ontology#hasResource"/>
    <rdfs:range rdf:resource="http://www.example.org/software-ontology#Example"/>
    <rdfs:comment>Links to usage examples, test data, screenshots, etc. Answers: 'Are there any usage examples/test data/screen shots/videos?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#usesAlgorithm">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.example.org/software-ontology#Algorithm"/>
    <rdfs:comment>Specifies an algorithm used by the software. Answers: 'What is the algorithm used to process this data?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#hasRepository">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://www.example.org/software-ontology#hasResource"/>
    <rdfs:range rdf:resource="http://www.example.org/software-ontology#Repository"/>
    <rdfs:comment>Links to the software's source code repository. Answers: 'Where can I get the software?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#providesFeature">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment>Describes a specific feature, like 'XML editing'. Answers: 'Does this software provide XML editing?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#implementationLanguage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment>The programming language the software is written in. Answers: 'In what language was it implemented?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#Version">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment>A specific version of a piece of software.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#url">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/software-ontology#Resource"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
    <rdfs:comment>The URL for a resource. Answers: 'Which URL can I get it from?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#Publication">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.example.org/software-ontology#Resource"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#Agent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment>A person or organization.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#hasDeveloper">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.example.org/software-ontology#Agent"/>
    <rdfs:comment>Specifies the person or organization that developed the software. Answers: 'Who developed it?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#Community">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment>A development community around a software project.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#WebService">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.example.org/software-ontology#Software"/>
    <rdfs:comment>Answers: 'What type of software is it?', 'Is this software available as a web service?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#API">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.example.org/software-ontology#Software"/>
    <rdfs:comment>Answers: 'What type of software is it?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#hasUser">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/software-ontology#Software"/>
    <rdfs:range rdf:resource="http://www.example.org/software-ontology#Person"/>
    <rdfs:comment>Identifies a user of the software. Answers: 'Do I know anyone who has used this software?', 'Who are the potential users of software we develop?', 'Who else has used tool x today?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#DesktopApplication">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.example.org/software-ontology#Software"/>
    <rdfs:comment>Answers: 'What type of software is it?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#Algorithm">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment>An algorithm used by a piece of software.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#hasHomepage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://www.example.org/software-ontology#hasResource"/>
    <rdfs:range rdf:resource="http://www.example.org/software-ontology#Homepage"/>
    <rdfs:comment>Links to the software's homepage. Answers: 'What is the homepage of the software?'.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#Software">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment>The central class representing a software tool, application, or library.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#Data">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment>Represents input, output, or processed data.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/software-ontology#OpenSourceLicense">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.example.org/software-ontology#License"/>
  </rdf:Description>
</rdf:RDF>
