<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/software.owl#"
     xml:base="http://example.org/software.owl"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://example.org/software.owl"/>
    
    <!-- Define Classes -->
    <owl:Class rdf:ID="Software"/>
    <owl:Class rdf:ID="Data"/>
    <owl:Class rdf:ID="Algorithm"/>
    <owl:Class rdf:ID="Feature"/>
    <owl:Class rdf:ID="SoftwareType"/>
    <owl:Class rdf:ID="Task"/>
    <owl:Class rdf:ID="Input"/>
    <owl:Class rdf:ID="Output"/>
    <owl:Class rdf:ID="Standard"/>
    <owl:Class rdf:ID="Source"/>
    <owl:Class rdf:ID="Support"/>
    <owl:Class rdf:ID="Developer"/>
    <owl:Class rdf:ID="User"/>
    <owl:Class rdf:ID="CopyrightHolder"/>
    <owl:Class rdf:ID="Version"/>
    <owl:Class rdf:ID="DevelopmentModel"/>
    <owl:Class rdf:ID="AccessControl"/>
    <owl:Class rdf:ID="Cost"/>
    <owl:Class rdf:ID="Documentation"/>
    <owl:Class rdf:ID="Citation"/>
    <owl:Class rdf:ID="Extension"/>
    <owl:Class rdf:ID="HardwareRequirement"/>
    <owl:Class rdf:ID="ImplementationLanguage"/>
    <owl:Class rdf:ID="Platform"/>
    <owl:Class rdf:ID="PerformanceMetric"/>
    
    <!-- Define Object Properties -->
    <owl:ObjectProperty rdf:ID="usesAlgorithm">
        <rdfs:domain rdf:resource="#Software"/>
        <rdfs:range rdf:resource="#Algorithm"/>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:ID="hasFeature">
        <rdfs:domain rdf:resource="#Software"/>
        <rdfs:range rdf:resource="#Feature"/>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:ID="hasType">
        <rdfs:domain rdf:resource="#Software"/>
        <rdfs:range rdf:resource="#SoftwareType"/>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:ID="canPerform">
        <rdfs:domain rdf:resource="#Software"/>
        <rdfs:range rdf:resource="#Task"/>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:ID="hasInput">
        <rdfs:domain rdf:resource="#Software"/>
        <rdfs:range rdf:resource="#Input"/>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:ID="hasOutput">
        <rdfs:domain rdf:resource="#Software"/>
        <rdfs:range rdf:resource="#Output"/>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:ID="createdBy">
        <rdfs:domain rdf:resource="#Data"/>
        <rdfs:range rdf:resource="#Software"/>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:ID="supportsStandard">
        <rdfs:domain rdf:resource="#Software"/>
        <rdfs:range rdf:resource="#Standard"/>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:ID="availableAt">
        <rdfs:domain rdf:resource="#Software"/>
        <rdfs:range rdf:resource="#Source"/>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:ID="hasSupport">
        <rdfs:domain rdf:resource="#Software"/>
        <rdfs:range rdf:resource="#Support"/>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:ID="hasHomepage">
        <rdfs:domain rdf:resource="#Software"/>
        <rdfs:range rdf:resource="#Source"/>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:ID="developedBy">
        <rdfs:domain rdf:resource="#Software"/>
        <rdfs:range rdf:resource="#Developer"/>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:ID="downloadURL">
        <rdfs:domain rdf:resource="#Software"/>
        <rdfs:range rdf:resource="#Source"/>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:ID="bestFor">
        <rdfs:domain rdf:resource="#Software"/>
        <rdfs:range rdf:resource="#Data"/>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:ID="meetsStandard">
        <rdfs:domain rdf:resource="#Software"/>
        <rdfs:range rdf:resource="#Standard"/>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:ID="hasUsed">
        <rdfs:domain rdf:resource="#User"/>
        <rdfs:range rdf:resource="#Software"/>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:ID="intendedFor">
        <rdfs:domain rdf:resource="#Software"/>
        <rdfs:range rdf:resource="#User"/>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:ID="usedToday">
        <rdfs:domain rdf:resource="#User"/>
        <rdfs:range rdf:resource="#Software"/>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:ID="availableAs">
        <rdfs:domain rdf:resource="#Software"/>
        <rdfs:range rdf:resource="#SoftwareType"/>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:ID="hasVersion">
        <rdfs:domain rdf:resource="#Software"/>
        <rdfs:range rdf:resource="#Version"/>
    </owl:ObjectProperty>
    
    <!-- Data Properties -->
    <owl:DatatypeProperty rdf:ID="releaseDate">
        <rdfs:domain rdf:resource="#Version"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
    </owl:DatatypeProperty>
    
    <owl:ObjectProperty rdf:ID="hasDevelopmentModel">
        <rdfs:domain rdf:resource="#Software"/>
        <rdfs:range rdf:resource="#DevelopmentModel"/>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:ID="hasCopyright">
        <rdfs:domain rdf:resource="#Software"/>
        <rdfs:range rdf:resource="#CopyrightHolder"/>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:ID="requiresLicense">
        <rdfs:domain rdf:resource="#Software"/>
        <rdfs:range rdf:resource="#AccessControl"/>
    </owl:ObjectProperty>
    
    <owl:DatatypeProperty rdf:ID="hasCost">
        <rdfs:domain rdf:resource="#Software"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>
    
    <owl:ObjectProperty rdf:ID="hasDocumentation">
        <rdfs:domain rdf:resource="#Software"/>
        <rdfs:range rdf:resource="#Documentation"/>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:ID="hasCitation">
        <rdfs:domain rdf:resource="#Software"/>
        <rdfs:range rdf:resource="#Citation"/>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:ID="canBeExtended">
        <rdfs:domain rdf:resource="#Software"/>
        <rdfs:range rdf:resource="#Extension"/>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:ID="requiresHardware">
        <rdfs:domain rdf:resource="#Software"/>
        <rdfs:range rdf:resource="#HardwareRequirement"/>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:ID="implementedIn">
        <rdfs:domain rdf:resource="#Software"/>
        <rdfs:range rdf:resource="#ImplementationLanguage"/>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:ID="runsOn">
        <rdfs:domain rdf:resource="#Software"/>
        <rdfs:range rdf:resource="#Platform"/>
    </owl:ObjectProperty>
</rdf:RDF>