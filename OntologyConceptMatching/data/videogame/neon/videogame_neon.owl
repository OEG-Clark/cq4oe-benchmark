<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/ontology#"
     xml:base="http://www.semanticweb.org/ontology"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/ontology"/>

    <!-- Classes -->
    <owl:Class rdf:about="http://www.semanticweb.org/ontology#Player"/>
    <owl:Class rdf:about="http://www.semanticweb.org/ontology#Game"/>
    <owl:Class rdf:about="http://www.semanticweb.org/ontology#Achievement"/>
    <owl:Class rdf:about="http://www.semanticweb.org/ontology#Item"/>
    <owl:Class rdf:about="http://www.semanticweb.org/ontology#Ability"/>
    <owl:Class rdf:about="http://www.semanticweb.org/ontology#Creator"/>
    <owl:Class rdf:about="http://www.semanticweb.org/ontology#Map"/>
    <owl:Class rdf:about="http://www.semanticweb.org/ontology#Purchase"/>
    <owl:Class rdf:about="http://www.semanticweb.org/ontology#Ad"/>
    <owl:Class rdf:about="http://www.semanticweb.org/ontology#Genre"/>
    <owl:Class rdf:about="http://www.semanticweb.org/ontology#DifficultyLevel"/>
    <owl:Class rdf:about="http://www.semanticweb.org/ontology#Location"/>

    <!-- Object Properties -->
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontology#hasFriend">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontology#Player"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontology#Player"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontology#playsWith">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontology#Player"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontology#Player"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontology#hasAchievement">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontology#Player"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontology#Achievement"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontology#hasItem">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontology#Player"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontology#Item"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontology#hasEquipment">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontology#Player"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontology#Item"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontology#ownsGame">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontology#Player"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontology#Game"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontology#hasCreator">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontology#Game"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontology#Creator"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontology#hasGenre">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontology#Game"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontology#Genre"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontology#hasMap">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontology#Game"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontology#Map"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontology#hasAbility">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontology#Item"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontology#Ability"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontology#madePurchase">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontology#Player"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontology#Purchase"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontology#clickedAd">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontology#Player"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontology#Ad"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontology#livesIn">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontology#Player"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontology#Location"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontology#hasDifficultyLevel">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontology#Player"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontology#DifficultyLevel"/>
    </owl:ObjectProperty>

    <!-- Data Properties -->
    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontology#username">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontology#Player"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontology#totalHoursPlayed">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontology#Game"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontology#killCount">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontology#Player"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontology#deathCount">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontology#Player"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontology#releaseDate">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontology#Game"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontology#moneySpent">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontology#Purchase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontology#purchaseTime">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontology#Purchase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontology#percentageWithItem">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontology#Game"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontology#skipCutscenePercentage">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontology#Game"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontology#numPlayersWithPurchase">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontology#Game"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontology#averageMoneySpent">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontology#Game"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontology#achievementType">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontology#Achievement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontology#itemType">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontology#Item"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontology#coordinates">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontology#Location"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

</rdf:RDF>