<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/gaming.ontology#"
     xml:base="http://example.org/gaming.ontology"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">

  <owl:Ontology rdf:about="http://example.org/gaming.ontology">
    <rdfs:label>Gaming Ontology</rdfs:label>
    <rdfs:comment>An ontology for modeling gaming concepts based on competency questions.</rdfs:comment>
  </owl:Ontology>

  <!-- Classes -->
  <owl:Class rdf:ID="Player">
    <rdfs:label>Player</rdfs:label>
  </owl:Class>

  <owl:Class rdf:ID="Game">
    <rdfs:label>Game</rdfs:label>
  </owl:Class>

  <owl:Class rdf:ID="Achievement">
    <rdfs:label>Achievement</rdfs:label>
  </owl:Class>

  <owl:Class rdf:ID="Item">
    <rdfs:label>Item</rdfs:label>
  </owl:Class>

  <owl:Class rdf:ID="Genre">
    <rdfs:label>Genre</rdfs:label>
  </owl:Class>

  <owl:Class rdf:ID="Ability">
    <rdfs:label>Ability</rdfs:label>
  </owl:Class>

  <owl:Class rdf:ID="Map">
    <rdfs:label>Map</rdfs:label>
  </owl:Class>

  <owl:Class rdf:ID="DifficultyLevel">
    <rdfs:label>DifficultyLevel</rdfs:label>
  </owl:Class>

  <owl:Class rdf:ID="Location">
    <rdfs:label>Location</rdfs:label>
  </owl:Class>

  <owl:Class rdf:ID="Advertisement">
    <rdfs:label>Advertisement</rdfs:label>
  </owl:Class>

  <owl:Class rdf:ID="CharacterClass">
    <rdfs:label>CharacterClass</rdfs:label>
  </owl:Class>

  <owl:Class rdf:ID="AchievementType">
    <rdfs:label>AchievementType</rdfs:label>
  </owl:Class>

  <!-- Object Properties -->
  <owl:ObjectProperty rdf:ID="hasAchievement">
    <rdfs:domain rdf:resource="#Player"/>
    <rdfs:range rdf:resource="#Achievement"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:ID="playsWith">
    <rdfs:domain rdf:resource="#Player"/>
    <rdfs:range rdf:resource="#Player"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:ID="hasItem">
    <rdfs:domain rdf:resource="#Player"/>
    <rdfs:range rdf:resource="#Item"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:ID="itemInGame">
    <rdfs:domain rdf:resource="#Item"/>
    <rdfs:range rdf:resource="#Game"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:ID="hasAbility">
    <rdfs:domain rdf:resource="#Item"/>
    <rdfs:range rdf:resource="#Ability"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:ID="hasGenre">
    <rdfs:domain rdf:resource="#Game"/>
    <rdfs:range rdf:resource="#Genre"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:ID="hasAchievementType">
    <rdfs:domain rdf:resource="#Achievement"/>
    <rdfs:range rdf:resource="#AchievementType"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:ID="hasMapPlayed">
    <rdfs:domain rdf:resource="#Player"/>
    <rdfs:range rdf:resource="#Map"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:ID="usesDifficultyLevel">
    <rdfs:domain rdf:resource="#Player"/>
    <rdfs:range rdf:resource="#DifficultyLevel"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:ID="livesIn">
    <rdfs:domain rdf:resource="#Player"/>
    <rdfs:range rdf:resource="#Location"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:ID="hasClickedAdvertisement">
    <rdfs:domain rdf:resource="#Player"/>
    <rdfs:range rdf:resource="#Advertisement"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:ID="hasCharacterClass">
    <rdfs:domain rdf:resource="#Player"/>
    <rdfs:range rdf:resource="#CharacterClass"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:ID="hasPreferredWeapon">
    <rdfs:domain rdf:resource="#Player"/>
    <rdfs:range rdf:resource="#Item"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:ID="hasDeathLocation">
    <rdfs:domain rdf:resource="#Player"/>
    <rdfs:range rdf:resource="#Location"/>
  </owl:ObjectProperty>

  <!-- Data Properties -->
  <owl:DatatypeProperty rdf:ID="hasUsername">
    <rdfs:domain rdf:resource="#Player"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:ID="hasTotalHoursPlayed">
    <rdfs:domain rdf:resource="#Game"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:ID="hasReleaseDate">
    <rdfs:domain rdf:resource="#Game"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:ID="createdBy">
    <rdfs:domain rdf:resource="#Game"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:ID="hasKillCount">
    <rdfs:domain rdf:resource="#Player"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:ID="hasLastPlayedDate">
    <rdfs:domain rdf:resource="#Player"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:ID="hasCompletedGameCount">
    <rdfs:domain rdf:resource="#Player"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:ID="skipsCutscenes">
    <rdfs:domain rdf:resource="#Player"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:ID="hasDeathCount">
    <rdfs:domain rdf:resource="#Player"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:ID="hasMadeInAppPurchase">
    <rdfs:domain rdf:resource="#Player"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:ID="hasAverageSpending">
    <rdfs:domain rdf:resource="#Player"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:ID="hasPurchaseTime">
    <rdfs:domain rdf:resource="#Player"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#time"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:ID="hasCoordinates">
    <rdfs:domain rdf:resource="#Location"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

</rdf:RDF>