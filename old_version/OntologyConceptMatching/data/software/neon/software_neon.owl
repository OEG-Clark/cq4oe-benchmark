<?xml version="1.0"?>
<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#">
    
    <owl:Ontology rdf:about="http://example.org/software-ontology"/>
    
    <!-- Classes -->
    <owl:Class rdf:about="http://example.org/Software">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/Data">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/Task">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/Standard">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/Organization">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/Person">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/License">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/Version">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/Platform">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/Language">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/Hardware">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/Feature">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/Algorithm">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/Cost">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/Example">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/Citation">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ExtensionMethod">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/SupportMethod">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/Community">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/URL">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>
    
    <!-- Subclasses for SoftwareType -->
    <owl:Class rdf:about="http://example.org/SoftwareType">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/DesktopApplication">
        <rdfs:subClassOf rdf:resource="http://example.org/SoftwareType"/>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/API">
        <rdfs:subClassOf rdf:resource="http://example.org/SoftwareType"/>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/WebService">
        <rdfs:subClassOf rdf:resource="http://example.org/SoftwareType"/>
    </owl:Class>
    
    <!-- Object Properties (unchanged) -->
    <owl:ObjectProperty rdf:about="http://example.org/hasAlgorithm">
        <rdfs:domain rdf:resource="http://example.org/Software"/>
        <rdfs:range rdf:resource="http://example.org/Algorithm"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/providesFeature">
        <rdfs:domain rdf:resource="http://example.org/Software"/>
        <rdfs:range rdf:resource="http://example.org/Feature"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/hasSoftwareType">
        <rdfs:domain rdf:resource="http://example.org/Software"/>
        <rdfs:range rdf:resource="http://example.org/SoftwareType"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/performsTask">
        <rdfs:domain rdf:resource="http://example.org/Software"/>
        <rdfs:range rdf:resource="http://example.org/Task"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/hasInput">
        <rdfs:domain rdf:resource="http://example.org/Software"/>
        <rdfs:range rdf:resource="http://example.org/Data"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/hasOutput">
        <rdfs:domain rdf:resource="http://example.org/Software"/>
        <rdfs:range rdf:resource="http://example.org/Data"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/createdBy">
        <rdfs:domain rdf:resource="http://example.org/Data"/>
        <rdfs:range rdf:resource="http://example.org/Software"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/supportsStandard">
        <rdfs:domain rdf:resource="http://example.org/Software"/>
        <rdfs:range rdf:resource="http://example.org/Standard"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/availableAt">
        <rdfs:domain rdf:resource="http://example.org/Software"/>
        <rdfs:range rdf:resource="http://example.org/URL"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/hasHomepage">
        <rdfs:domain rdf:resource="http://example.org/Software"/>
        <rdfs:range rdf:resource="http://example.org/URL"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/developedBy">
        <rdfs:domain rdf:resource="http://example.org/Software"/>
        <rdfs:range rdf:resource="http://example.org/Organization"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/hasVersion">
        <rdfs:domain rdf:resource="http://example.org/Software"/>
        <rdfs:range rdf:resource="http://example.org/Version"/>
    </owl:ObjectProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/isOpenSource">
        <rdfs:domain rdf:resource="http://example.org/Software"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    <owl:ObjectProperty rdf:about="http://example.org/ownedBy">
        <rdfs:domain rdf:resource="http://example.org/Software"/>
        <rdfs:range rdf:resource="http://example.org/Organization"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/requiresLicense">
        <rdfs:domain rdf:resource="http://example.org/Software"/>
        <rdfs:range rdf:resource="http://example.org/License"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/hasCost">
        <rdfs:domain rdf:resource="http://example.org/Software"/>
        <rdfs:range rdf:resource="http://example.org/Cost"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/hasExample">
        <rdfs:domain rdf:resource="http://example.org/Software"/>
        <rdfs:range rdf:resource="http://example.org/Example"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/citableAs">
        <rdfs:domain rdf:resource="http://example.org/Software"/>
        <rdfs:range rdf:resource="http://example.org/Citation"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/extendableBy">
        <rdfs:domain rdf:resource="http://example.org/Software"/>
        <rdfs:range rdf:resource="http://example.org/ExtensionMethod"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/requiresHardware">
        <rdfs:domain rdf:resource="http://example.org/Software"/>
        <rdfs:range rdf:resource="http://example.org/Hardware"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/implementedIn">
        <rdfs:domain rdf:resource="http://example.org/Software"/>
        <rdfs:range rdf:resource="http://example.org/Language"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/runsOn">
        <rdfs:domain rdf:resource="http://example.org/Software"/>
        <rdfs:range rdf:resource="http://example.org/Platform"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/usedBy">
        <rdfs:domain rdf:resource="http://example.org/Software"/>
        <rdfs:range rdf:resource="http://example.org/Person"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/potentialUser">
        <rdfs:domain rdf:resource="http://example.org/Software"/>
        <rdfs:range rdf:resource="http://example.org/Person"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/usedTodayBy">
        <rdfs:domain rdf:resource="http://example.org/Software"/>
        <rdfs:range rdf:resource="http://example.org/Person"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/hasCommunity">
        <rdfs:domain rdf:resource="http://example.org/Software"/>
        <rdfs:range rdf:resource="http://example.org/Community"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/hasSupportMethod">
        <rdfs:domain rdf:resource="http://example.org/Software"/>
        <rdfs:range rdf:resource="http://example.org/SupportMethod"/>
    </owl:ObjectProperty>
    
    <!-- Datatype Properties (unchanged) -->
    <owl:DatatypeProperty rdf:about="http://example.org/versionNumber">
        <rdfs:domain rdf:resource="http://example.org/Version"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/releaseDate">
        <rdfs:domain rdf:resource="http://example.org/Version"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/costEffective">
        <rdfs:domain rdf:resource="http://example.org/Software"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
</rdf:RDF>