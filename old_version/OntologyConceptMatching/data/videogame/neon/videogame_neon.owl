<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/ontologies/gaming#"
     xml:base="http://www.semanticweb.org/ontologies/gaming"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/ontologies/gaming"/>

    <!-- Classes -->
    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/gaming#Player"/>
    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/gaming#Game"/>
    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/gaming#Achievement"/>
    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/gaming#Item"/>
    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/gaming#Creator"/>
    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/gaming#Genre"/>
    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/gaming#Map"/>
    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/gaming#Ability"/>
    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/gaming#CharacterClass"/>
    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/gaming#DifficultyLevel"/>
    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/gaming#Purchase"/>
    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/gaming#Location"/>
    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/gaming#Advertisement"/>
    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/gaming#AchievementType"/>

    <!-- Object Properties -->
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologies/gaming#hasAchievement">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/gaming#Player"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontologies/gaming#Achievement"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologies/gaming#hasItem">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/gaming#Player"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontologies/gaming#Item"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologies/gaming#playsWith">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/gaming#Player"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontologies/gaming#Player"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologies/gaming#hasCreator">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/gaming#Game"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontologies/gaming#Creator"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologies/gaming#hasGenre">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/gaming#Game"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontologies/gaming#Genre"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologies/gaming#hasAbility">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/gaming#Item"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontologies/gaming#Ability"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologies/gaming#hasMap">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/gaming#Game"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontologies/gaming#Map"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologies/gaming#usesDifficulty">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/gaming#Player"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontologies/gaming#DifficultyLevel"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologies/gaming#madePurchase">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/gaming#Player"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontologies/gaming#Purchase"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologies/gaming#clickedAdvertisement">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/gaming#Player"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontologies/gaming#Advertisement"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologies/gaming#diedAt">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/gaming#Player"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontologies/gaming#Location"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologies/gaming#hasAchievementType">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/gaming#Achievement"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontologies/gaming#AchievementType"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologies/gaming#hasCharacterClass">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/gaming#Player"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontologies/gaming#CharacterClass"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologies/gaming#preferredWeapon">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/gaming#Player"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontologies/gaming#Item"/>
    </owl:ObjectProperty>

    <!-- Data Properties -->
    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/gaming#username">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/gaming#Player"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/gaming#totalPlayHours">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/gaming#Game"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/gaming#releaseDate">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/gaming#Game"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/gaming#killCount">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/gaming#Player"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/gaming#lastPlayTime">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/gaming#Player"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/gaming#deathCount">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/gaming#Player"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/gaming#purchaseAmount">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/gaming#Purchase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/gaming#purchaseTime">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/gaming#Purchase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/gaming#playerLocation">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/gaming#Player"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/gaming#adClickCount">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/gaming#Player"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/gaming#coordinates">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/gaming#Location"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
</rdf:RDF>