<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/odrl-ontology#"
     xml:base="http://example.org/odrl-ontology"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

<owl:Ontology rdf:about="http://example.org/odrl-ontology"/>

<!-- Classes -->
<owl:Class rdf:ID="Right"/>
<owl:Class rdf:ID="Duty"/>
<owl:Class rdf:ID="Permission">
    <rdfs:subClassOf rdf:resource="#Right"/>
</owl:Class>
<owl:Class rdf:ID="TransferRight">
    <rdfs:subClassOf rdf:resource="#Permission"/>
</owl:Class>
<owl:Class rdf:ID="ContractParty"/>
<owl:Class rdf:ID="Role"/>
<owl:Class rdf:ID="Constraint"/>
<owl:Class rdf:ID="FairUseConstraint">
    <rdfs:subClassOf rdf:resource="#Constraint"/>
</owl:Class>
<owl:Class rdf:ID="Meter"/>
<owl:Class rdf:ID="Document"/>
<owl:Class rdf:ID="Container"/>

<!-- Disjointness Axioms -->
<owl:AllDisjointClasses>
    <owl:members rdf:parseType="Collection">
        <owl:Class rdf:about="#Right"/>
        <owl:Class rdf:about="#Duty"/>
        <owl:Class rdf:about="#ContractParty"/>
        <owl:Class rdf:about="#Role"/>
        <owl:Class rdf:about="#Constraint"/>
        <owl:Class rdf:about="#Meter"/>
        <owl:Class rdf:about="#Document"/>
        <owl:Class rdf:about="#Container"/>
    </owl:members>
</owl:AllDisjointClasses>

<!-- Object Properties -->
<owl:ObjectProperty rdf:ID="hasPermission">
    <rdfs:domain rdf:resource="#ContractParty"/>
    <rdfs:range rdf:resource="#Permission"/>
</owl:ObjectProperty>
<owl:ObjectProperty rdf:ID="hasDuty">
    <rdfs:domain rdf:resource="#ContractParty"/>
    <rdfs:range rdf:resource="#Duty"/>
</owl:ObjectProperty>
<owl:ObjectProperty rdf:ID="hasRole">
    <rdfs:domain rdf:resource="#ContractParty"/>
    <rdfs:range rdf:resource="#Role"/>
</owl:ObjectProperty>
<owl:ObjectProperty rdf:ID="hasConstraint">
    <rdfs:domain rdf:resource="#Duty"/>
    <rdfs:range rdf:resource="#Constraint"/>
</owl:ObjectProperty>
<owl:ObjectProperty rdf:ID="hasMeter">
    <rdfs:domain rdf:resource="#Right"/>
    <rdfs:range rdf:resource="#Meter"/>
</owl:ObjectProperty>
<owl:ObjectProperty rdf:ID="linksToDocument">
    <rdfs:domain rdf:resource="#Document"/>
    <rdfs:range rdf:resource="#Document"/>
</owl:ObjectProperty>
<owl:ObjectProperty rdf:ID="supportsInheritance">
    <rdfs:domain rdf:resource="#Right"/>
    <rdfs:range rdf:resource="#Right"/>
</owl:ObjectProperty>

<!-- Data Properties -->
<owl:DatatypeProperty rdf:ID="hasStatus">
    <rdfs:domain rdf:resource="#Duty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>
<owl:DatatypeProperty rdf:ID="hasLateDate">
    <rdfs:domain rdf:resource="#Duty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
</owl:DatatypeProperty>

</rdf:RDF>