  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usesAlgorithm">
  <rdfs:comment xml:lang="en">Relates software to an algorithm it uses.</rdfs:comment>
  <rdfs:label xml:lang="en">uses algorithm</rdfs:label>
  <dc:source>(competency_question) CQ04: Which of the named and published algorithms does this tool use?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#performsTask">
  <rdfs:comment xml:lang="en">Relates software to a task it can perform.</rdfs:comment>
  <rdfs:label xml:lang="en">performs task</rdfs:label>
  <dc:source>(competency_question) CQ08: What software can perform task x?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Task"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasInputFormat">
  <rdfs:comment xml:lang="en">Specifies an input data format accepted by the software.</rdfs:comment>
  <rdfs:label xml:lang="en">has input format</rdfs:label>
  <dc:source>(competency_question) CQ17: What are the input and output formats for this software?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#versionHasInputFormat">
  <rdfs:comment xml:lang="en">Specifies an input data format for a particular version.</rdfs:comment>
  <rdfs:label xml:lang="en">version has input format</rdfs:label>
  <dc:source>(competency_question) CQ29: Given input x, what are the data exports for this version?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Version"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasOutputFormat">
  <rdfs:comment xml:lang="en">Specifies an output data format produced by the software.</rdfs:comment>
  <rdfs:label xml:lang="en">has output format</rdfs:label>
  <dc:source>(competency_question) CQ17: What are the input and output formats for this software?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#versionHasOutputFormat">
  <rdfs:comment xml:lang="en">Specifies an output data format for a particular version.</rdfs:comment>
  <rdfs:label xml:lang="en">version has output format</rdfs:label>
  <dc:source>(competency_question) CQ29: Given input x, what are the data exports for this version?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Version"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#exportsToFormat">
  <rdfs:comment xml:lang="en">Specifies a format to which the software can export.</rdfs:comment>
  <rdfs:label xml:lang="en">exports to format</rdfs:label>
  <dc:source>(competency_question) CQ22: Can this software export from its proprietary data format to an open format such as csv, txt?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
  <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/myontology#hasOutputFormat"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasVersion">
  <rdfs:comment xml:lang="en">Relates software to one of its versions.</rdfs:comment>
  <rdfs:label xml:lang="en">has version</rdfs:label>
  <dc:source>(competency_question) CQ54: What is the version of this software?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Version"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#versionOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#versionOf">
  <rdfs:comment xml:lang="en">Inverse of hasVersion. Relates a version to the software it belongs to.</rdfs:comment>
  <rdfs:label xml:lang="en">version of</rdfs:label>
  <dc:source>(competency_question) CQ54</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Version"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasVersion"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#createdBy">
  <rdfs:comment xml:lang="en">Relates data to the software that created it.</rdfs:comment>
  <rdfs:label xml:lang="en">created by</rdfs:label>
  <dc:source>(competency_question) CQ15: Which software tool created this data?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Data"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Software"/>
</owl:ObjectProperty>

