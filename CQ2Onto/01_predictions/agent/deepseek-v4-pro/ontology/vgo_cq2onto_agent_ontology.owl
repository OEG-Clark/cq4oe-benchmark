<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Player">
  <rdfs:comment xml:lang="en">A person who plays games.</rdfs:comment>
  <rdfs:label xml:lang="en">Player</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created class Player: From competency questions
    [Pitfall Resolution Agent] Added disjointness axioms with other top-level classes: OOPS pitfall: missing disjointness</vaem:rationale>
  <dc:source>(competency_question) CQ01, CQ02, CQ03, CQ24, CQ25, CQ26, CQ35, CQ52, CQ55, CQ56, CQ57, CQ63, CQ64, CQ65, CQ66</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Game"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayerGame"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Genre"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Item"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Ability"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Game">
  <rdfs:comment xml:lang="en">A video game.</rdfs:comment>
  <rdfs:label xml:lang="en">Game</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created class Game: From competency questions
    [Pitfall Resolution Agent] Added disjointness axioms with other top-level classes: OOPS pitfall: missing disjointness</vaem:rationale>
  <dc:source>(competency_question) CQ08, CQ09, CQ12, CQ13, CQ15, CQ17, CQ22, CQ35, CQ55, CQ64, New CQ1</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Player"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayerGame"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Genre"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Item"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Ability"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Achievement">
  <rdfs:comment xml:lang="en">An achievement that can be earned in a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Achievement</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created class Achievement: From competency questions
    [Pitfall Resolution Agent] Added disjointness axioms with other top-level classes: OOPS pitfall: missing disjointness</vaem:rationale>
  <dc:source>(competency_question) CQ05, CQ07, CQ08, CQ10, CQ11, CQ24, CQ27, CQ35</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Player"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Game"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayerGame"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Genre"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Item"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Ability"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayerGame">
  <rdfs:comment xml:lang="en">Statistics for a player's progression in a specific game, including kill count, hours played, start time, first IAP time, and whether all achievements are obtained.</rdfs:comment>
  <rdfs:label xml:lang="en">PlayerGame</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created class PlayerGame: From competency questions
    [Pitfall Resolution Agent] Added disjointness axioms with other top-level classes: OOPS pitfall: missing disjointness</vaem:rationale>
  <dc:source>(competency_question) CQ09, CQ22, CQ35, CQ64</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Player"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Game"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Genre"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Item"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Ability"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#InAppPurchase">
  <rdfs:comment xml:lang="en">An in-app purchase made by a player.</rdfs:comment>
  <rdfs:label xml:lang="en">InAppPurchase</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created class InAppPurchase: From competency questions
    [Pitfall Resolution Agent] Added disjointness axioms with other top-level classes: OOPS pitfall: missing disjointness</vaem:rationale>
  <dc:source>(competency_question) CQ56, CQ57, CQ62, CQ63, CQ64</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Player"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Game"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayerGame"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Genre"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Item"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Ability"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Genre">
  <rdfs:comment xml:lang="en">The genre of a game, e.g., action, RPG.</rdfs:comment>
  <rdfs:label xml:lang="en">Genre</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created class Genre: From competency questions
    [Pitfall Resolution Agent] Added disjointness axioms with other top-level classes: OOPS pitfall: missing disjointness</vaem:rationale>
  <dc:source>(competency_question) CQ12, CQ17</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Player"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Game"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayerGame"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Item"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Ability"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Item">
  <rdfs:comment xml:lang="en">An in-game item that can be owned or used by a player.</rdfs:comment>
  <rdfs:label xml:lang="en">Item</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created class Item: From competency questions
    [Pitfall Resolution Agent] Added disjointness axioms with other top-level classes (except Equipment, which is a subclass): OOPS pitfall: missing disjointness</vaem:rationale>
  <dc:source>(competency_question) CQ13, CQ19, CQ26, CQ55</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Player"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Game"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayerGame"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Genre"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Ability"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Equipment">
  <rdfs:comment xml:lang="en">A type of item that represents equipment a player can have.</rdfs:comment>
  <rdfs:label xml:lang="en">Equipment</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created class Equipment as subclass of Item: From competency questions
    [Pitfall Resolution Agent] Added disjointness axioms with all top-level classes except Item: OOPS pitfall: missing disjointness</vaem:rationale>
  <dc:source>(competency_question) CQ52</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Item"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Player"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Game"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayerGame"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Genre"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Ability"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#AchievementType">
  <rdfs:comment xml:lang="en">A category or type of achievement in a game.</rdfs:comment>
  <rdfs:label xml:lang="en">AchievementType</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created class AchievementType: From competency questions
    [Pitfall Resolution Agent] Added disjointness axioms with other top-level classes: OOPS pitfall: missing disjointness</vaem:rationale>
  <dc:source>(competency_question) CQ10, CQ11, CQ27</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Player"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Game"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayerGame"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Genre"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Item"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Ability"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayingArea">
  <rdfs:comment xml:lang="en">A specific area or map within a game where players can play.</rdfs:comment>
  <rdfs:label xml:lang="en">PlayingArea</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created class PlayingArea: From competency questions
    [Pitfall Resolution Agent] Added disjointness axioms with other top-level classes: OOPS pitfall: missing disjointness</vaem:rationale>
  <dc:source>(competency_question) New CQ1</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Player"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Game"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayerGame"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Genre"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Item"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Ability"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Ability">
  <rdfs:comment xml:lang="en">An ability provided by an item, e.g., fire-resistance.</rdfs:comment>
  <rdfs:label xml:lang="en">Ability</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created class Ability: From competency questions
    [Pitfall Resolution Agent] Added disjointness axioms with other top-level classes: OOPS pitfall: missing disjointness</vaem:rationale>
  <dc:source>(competency_question) CQ19</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Player"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Game"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayerGame"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Genre"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Item"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasFriend">
  <rdfs:comment xml:lang="en">Indicates that a player has another player as a friend.</rdfs:comment>
  <rdfs:label xml:lang="en">has friend</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created object property hasFriend: From competency questions</vaem:rationale>
  <dc:source>(competency_question) CQ02, CQ03, CQ05, CQ07</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#playsGame">
  <rdfs:comment xml:lang="en">Indicates that a player has played a game.</rdfs:comment>
  <rdfs:label xml:lang="en">plays game</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created object property playsGame: From competency questions</vaem:rationale>
  <dc:source>(competency_question) CQ03, CQ25</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#obtainsAchievement">
  <rdfs:comment xml:lang="en">Indicates that a player has obtained an achievement.</rdfs:comment>
  <rdfs:label xml:lang="en">obtains achievement</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created object property obtainsAchievement: From competency questions</vaem:rationale>
  <dc:source>(competency_question) CQ24, CQ27</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#achievementBelongsToGame">
  <rdfs:comment xml:lang="en">Links an achievement to the game it belongs to.</rdfs:comment>
  <rdfs:label xml:lang="en">belongs to game</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created object property achievementBelongsToGame: From competency questions</vaem:rationale>
  <dc:source>(competency_question) CQ08, CQ10, CQ11</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#achievementHasType">
  <rdfs:comment xml:lang="en">Links an achievement to its type.</rdfs:comment>
  <rdfs:label xml:lang="en">has achievement type</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created object property achievementHasType: From competency questions</vaem:rationale>
  <dc:source>(competency_question) CQ10, CQ11, CQ27</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#itemBelongsToGame">
  <rdfs:comment xml:lang="en">Links an item to the game it exists in.</rdfs:comment>
  <rdfs:label xml:lang="en">belongs to game</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created object property itemBelongsToGame: From competency questions</vaem:rationale>
  <dc:source>(competency_question) CQ13, CQ55</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Item"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#playerHasItem">
  <rdfs:comment xml:lang="en">Indicates a player owns an item.</rdfs:comment>
  <rdfs:label xml:lang="en">has item</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created object property playerHasItem: From competency questions</vaem:rationale>
  <dc:source>(competency_question) CQ26, CQ55</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#playerHasEquipment">
  <rdfs:comment xml:lang="en">Indicates a player has a piece of equipment. Equipment is linked to a game via itemBelongsToGame.</rdfs:comment>
  <rdfs:label xml:lang="en">has equipment</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created object property playerHasEquipment: From competency questions</vaem:rationale>
  <dc:source>(competency_question) CQ52</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Equipment"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#gameHasGenre">
  <rdfs:comment xml:lang="en">Links a game to its genre.</rdfs:comment>
  <rdfs:label xml:lang="en">has genre</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created object property gameHasGenre: From competency questions</vaem:rationale>
  <dc:source>(competency_question) CQ12, CQ17</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Genre"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#gameHasItem">
  <rdfs:comment xml:lang="en">Links a game to the items that exist within it (inverse of itemBelongsToGame).</rdfs:comment>
  <rdfs:label xml:lang="en">has item</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created object property gameHasItem with inverse: From competency questions</vaem:rationale>
  <dc:source>(competency_question) CQ13</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#itemBelongsToGame"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#gameHasAchievement">
  <rdfs:comment xml:lang="en">Links a game to its available achievements (inverse of achievementBelongsToGame).</rdfs:comment>
  <rdfs:label xml:lang="en">has achievement</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created object property gameHasAchievement with inverse: From competency questions</vaem:rationale>
  <dc:source>(competency_question) CQ08</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#achievementBelongsToGame"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#gameHasPlayingArea">
  <rdfs:comment xml:lang="en">Links a game to its playing areas.</rdfs:comment>
  <rdfs:label xml:lang="en">has playing area</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created object property gameHasPlayingArea: From competency questions</vaem:rationale>
  <dc:source>(competency_question) New CQ1</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#itemHasAbility">
  <rdfs:comment xml:lang="en">Links an item to an ability it provides.</rdfs:comment>
  <rdfs:label xml:lang="en">has ability</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created object property itemHasAbility: From competency questions</vaem:rationale>
  <dc:source>(competency_question) CQ19</dc:source>
