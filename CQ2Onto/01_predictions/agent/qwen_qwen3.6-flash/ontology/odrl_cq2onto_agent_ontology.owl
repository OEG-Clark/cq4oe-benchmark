<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isInheritanceOf">
  <rdfs:comment xml:lang="en">Inverse of hasInheritance. Links an inheritance mechanism to the policy it applies to.</rdfs:comment>
  <rdfs:label xml:lang="en">is inheritance of</rdfs:label>
