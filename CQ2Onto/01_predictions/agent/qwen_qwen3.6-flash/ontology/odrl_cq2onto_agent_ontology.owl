</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isConflictResolutionOf">
  <rdfs:comment xml:lang="en">Inverse of hasConflictResolution. Links a conflict resolution strategy to the policy it belongs to.</rdfs:comment>
