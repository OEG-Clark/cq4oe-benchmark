  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasInheritance"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasConflictResolution">
  <rdfs:comment xml:lang="en">Links a policy to a conflict resolution strategy.</rdfs:comment>
  <rdfs:label xml:lang="en">has conflict resolution</rdfs:label>
