<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Policy">
  <rdfs:comment xml:lang="en">A set of rules that define how an asset can be used, managed, or distributed.</rdfs:comment>
  <rdfs:label xml:lang="en">Policy</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Core entity for policy management, addresses New CQ1
    [Pitfall Resolution Agent] Created class: Core entity for policy management, addresses New CQ1</vaem:rationale>
  <dc:source>(competency_question) New CQ1: Which policy is directly linked to a given asset?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Rule">
  <rdfs:comment xml:lang="en">A policy statement that defines permissions, prohibitions, and duties applicable to parties.</rdfs:comment>
  <rdfs:label xml:lang="en">Rule</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Central construct for rights and duties, addresses CQ10
    [Pitfall Resolution Agent] Created class: Central construct for rights and duties, addresses CQ10</vaem:rationale>
  <dc:source>(competency_question) CQ10: How are rights and duties supported for all contract parties?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Permission">
  <rdfs:comment xml:lang="en">A rule that allows a party to perform an action on a target asset.</rdfs:comment>
  <rdfs:label xml:lang="en">Permission</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Represents allowed actions, addresses CQ03, CQ10
    [Pitfall Resolution Agent] Created class: Represents allowed actions, addresses CQ03, CQ10
    [Pitfall Resolution Agent] Added disjoint axioms: OOPS pitfall: lacks disjoint axioms between mutually exclusive rule types</vaem:rationale>
  <dc:source>(competency_question) CQ03: Shall the permissions 'Aggregation' and 'Disaggregation' be of the type Transfer Rights?
    (competency_question) CQ10: How are rights and duties supported for all contract parties?
    (pitfall) The ontology lacks disjoint axioms between classes or between properties that should be defined as disjoint.</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Prohibition"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Duty"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Prohibition">
  <rdfs:comment xml:lang="en">A rule that forbids a party from performing an action on a target asset.</rdfs:comment>
  <rdfs:label xml:lang="en">Prohibition</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Represents forbidden actions, addresses New CQ3, New CQ6
    [Pitfall Resolution Agent] Created class: Represents forbidden actions, addresses New CQ3, New CQ6
    [Pitfall Resolution Agent] Added disjoint axioms: OOPS pitfall: lacks disjoint axioms between mutually exclusive rule types</vaem:rationale>
  <dc:source>(competency_question) New CQ3: What duty is specified as a remedy for the violation of a prohibition?
    (competency_question) New CQ6: What operator is used in the constraints of a prohibition?
    (pitfall) The ontology lacks disjoint axioms between classes or between properties that should be defined as disjoint.</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Permission"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Duty"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Duty">
  <rdfs:comment xml:lang="en">A rule that requires a party to perform an action or fulfill an obligation.</rdfs:comment>
  <rdfs:label xml:lang="en">Duty</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Represents required actions, addresses CQ06, CQ10, New CQ5
    [Pitfall Resolution Agent] Created class: Represents required actions, addresses CQ06, CQ10, New CQ5
    [Pitfall Resolution Agent] Added disjoint axioms: OOPS pitfall: lacks disjoint axioms between mutually exclusive rule types</vaem:rationale>
  <dc:source>(competency_question) CQ06: Expressing the various roles of contract parties within the Permission/Duty element.
    (competency_question) CQ10: How are rights and duties supported for all contract parties?
    (competency_question) New CQ5: What duty is specified as a consequence of another duty?
    (pitfall) The ontology lacks disjoint axioms between classes or between properties that should be defined as disjoint.</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Permission"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Prohibition"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Action">
  <rdfs:comment xml:lang="en">An operation that can be performed on an asset, such as copying or distributing.</rdfs:comment>
  <rdfs:label xml:lang="en">Action</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Base class for operations, addresses CQ03
    [Pitfall Resolution Agent] Created class: Base class for operations, addresses CQ03</vaem:rationale>
  <dc:source>(competency_question) CQ03: Shall the permissions 'Aggregation' and 'Disaggregation' be of the type Transfer Rights?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Asset">
  <rdfs:comment xml:lang="en">A resource that is subject to a policy or rule.</rdfs:comment>
  <rdfs:label xml:lang="en">Asset</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Core entity for policy linkage, addresses New CQ1
    [Pitfall Resolution Agent] Created class: Core entity for policy linkage, addresses New CQ1</vaem:rationale>
  <dc:source>(competency_question) New CQ1: Which policy is directly linked to a given asset?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Party">
  <rdfs:comment xml:lang="en">An entity that participates in a policy, such as a user, provider, or assignee.</rdfs:comment>
  <rdfs:label xml:lang="en">Party</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Represents contract participants, addresses CQ06, CQ10
    [Pitfall Resolution Agent] Created class: Represents contract participants, addresses CQ06, CQ10</vaem:rationale>
  <dc:source>(competency_question) CQ06: Expressing the various roles of contract parties within the Permission/Duty element.
    (competency_question) CQ10: How are rights and duties supported for all contract parties?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Role">
  <rdfs:comment xml:lang="en">A function or position assumed by a party within a policy context.</rdfs:comment>
  <rdfs:label xml:lang="en">Role</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Models party functions, addresses CQ06
    [Pitfall Resolution Agent] Created class: Models party functions, addresses CQ06</vaem:rationale>
  <dc:source>(competency_question) CQ06: Expressing the various roles of contract parties within the Permission/Duty element.</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Function">
  <rdfs:comment xml:lang="en">A specific task or responsibility assigned to a party.</rdfs:comment>
  <rdfs:label xml:lang="en">Function</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Models party responsibilities, addresses CQ06
    [Pitfall Resolution Agent] Created class: Models party responsibilities, addresses CQ06
    [Pitfall Resolution Agent] Added equivalent class axiom: OOPS pitfall: missing equivalent classes for duplicated concepts (Function/Role)</vaem:rationale>
  <dc:source>(competency_question) CQ06: Expressing the various roles of contract parties within the Permission/Duty element.
    (pitfall) This pitfall consists in missing the definition of equivalent classes (owl:equivalentClass) in case of duplicated concepts.</dc:source>
  <owl:equivalentClass rdf:resource="http://www.semanticweb.org/myontology#Role"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Constraint">
  <rdfs:comment xml:lang="en">A condition that limits the application of a rule or defines operational boundaries.</rdfs:comment>
  <rdfs:label xml:lang="en">Constraint</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Base class for rule limitations, addresses CQ13, CQ14, CQ21, CQ26, New CQ6
    [Pitfall Resolution Agent] Created class: Base class for rule limitations, addresses CQ13, CQ14, CQ21, CQ26, New CQ6</vaem:rationale>
  <dc:source>(competency_question) CQ13: Shall ODRLv2 allow for nested constraints?
    (competency_question) CQ14: How do we express 'and', 'or', 'xor' constraints?
    (competency_question) CQ21: How to express constraints on requirements?
    (competency_question) CQ26: How to express Condition via Constraints?
    (competency_question) New CQ6: What operator is used in the constraints of a prohibition?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#LogicalConstraint">
  <rdfs:comment xml:lang="en">A constraint that combines other constraints using logical operators.</rdfs:comment>
  <rdfs:label xml:lang="en">LogicalConstraint</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class with subclass axiom: Models logical combinations, addresses CQ14
    [Pitfall Resolution Agent] Created class with subclass axiom: Models logical combinations, addresses CQ14</vaem:rationale>
  <dc:source>(competency_question) CQ14: How do we express 'and', 'or', 'xor' constraints?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Operator">
  <rdfs:comment xml:lang="en">A symbol or keyword used in constraints to define relationships or logic.</rdfs:comment>
  <rdfs:label xml:lang="en">Operator</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Models constraint operators, addresses CQ08, CQ14, New CQ6
    [Pitfall Resolution Agent] Created class: Models constraint operators, addresses CQ08, CQ14, New CQ6</vaem:rationale>
  <dc:source>(competency_question) CQ08: How to provide a 'NOT' expression?
    (competency_question) CQ14: How do we express 'and', 'or', 'xor' constraints?
    (competency_question) New CQ6: What operator is used in the constraints of a prohibition?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Container">
  <rdfs:comment xml:lang="en">A grouping mechanism for policies or rules to manage scope and hierarchy.</rdfs:comment>
  <rdfs:label xml:lang="en">Container</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Models policy grouping, addresses CQ30
    [Pitfall Resolution Agent] Created class: Models policy grouping, addresses CQ30</vaem:rationale>
  <dc:source>(competency_question) CQ30: What do we lose if containers are no longer part of ODRL?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#SequencingPolicy">
  <rdfs:comment xml:lang="en">Defines the order of execution or evaluation for rules within a policy.</rdfs:comment>
  <rdfs:label xml:lang="en">Sequencing Policy</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Renamed from Sequencing: OOPS pitfall: naming convention violation
    [Pitfall Resolution Agent] Created class: Models rule ordering, addresses CQ31</vaem:rationale>
  <dc:source>(competency_question) CQ31: Do we need 'Sequencing' as part of the REL?
    (pitfall) The ontology elements are not named following the same convention</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Inheritance">
  <rdfs:comment xml:lang="en">Defines how policies or rules inherit properties, constraints, or permissions from parent entities.</rdfs:comment>
  <rdfs:label xml:lang="en">Inheritance</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Models property inheritance, addresses CQ33
    [Pitfall Resolution Agent] Created class: Models property inheritance, addresses CQ33</vaem:rationale>
  <dc:source>(competency_question) CQ33: Can the new data model express inheritance?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Condition">
  <rdfs:comment xml:lang="en">A prerequisite that must be satisfied for a rule to become active or applicable.</rdfs:comment>
  <rdfs:label xml:lang="en">Condition</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Models rule prerequisites, addresses CQ26
    [Pitfall Resolution Agent] Created class: Models rule prerequisites, addresses CQ26</vaem:rationale>
  <dc:source>(competency_question) CQ26: How to express Condition via Constraints?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Requirement">
  <rdfs:comment xml:lang="en">A specific need or demand that can be subject to constraints.</rdfs:comment>
  <rdfs:label xml:lang="en">Requirement</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Models constrained demands, addresses CQ21
    [Pitfall Resolution Agent] Created class: Models constrained demands, addresses CQ21
    [Pitfall Resolution Agent] Added subclass axiom: OOPS pitfall: class created isolated with no relation to the rest of the ontology</vaem:rationale>
  <dc:source>(competency_question) CQ21: How to express constraints on requirements?
    (pitfall) Ontology elements (classes, object properties and datatype properties) are created isolated, with no relation to the rest of the ontology.</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Conflict">
  <rdfs:comment xml:lang="en">A situation where rules or policies contradict each other, requiring resolution.</rdfs:comment>
  <rdfs:label xml:lang="en">Conflict</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Models policy contradictions, addresses New CQ2
    [Pitfall Resolution Agent] Created class: Models policy contradictions, addresses New CQ2</vaem:rationale>
  <dc:source>(competency_question) New CQ2: What conflict resolution strategy is specified by a policy?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Remedy">
  <rdfs:comment xml:lang="en">A duty specified as a consequence for violating a prohibition.</rdfs:comment>
  <rdfs:label xml:lang="en">Remedy</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Models violation consequences, addresses New CQ3
    [Pitfall Resolution Agent] Created class: Models violation consequences, addresses New CQ3</vaem:rationale>
  <dc:source>(competency_question) New CQ3: What duty is specified as a remedy for the violation of a prohibition?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Trigger">
  <rdfs:comment xml:lang="en">An event or condition that activates a rule upon the failure of another rule.</rdfs:comment>
  <rdfs:label xml:lang="en">Trigger</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Models rule activation on failure, addresses New CQ4
    [Pitfall Resolution Agent] Created class: Models rule activation on failure, addresses New CQ4</vaem:rationale>
  <dc:source>(competency_question) New CQ4: Which rule is activated upon the failure of another rule?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Consequence">
  <rdfs:comment xml:lang="en">A duty or action that follows from the fulfillment or violation of another duty.</rdfs:comment>
  <rdfs:label xml:lang="en">Consequence</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Models duty dependencies, addresses New CQ5
    [Pitfall Resolution Agent] Created class: Models duty dependencies, addresses New CQ5</vaem:rationale>
  <dc:source>(competency_question) New CQ5: What duty is specified as a consequence of another duty?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#TransferRight">
  <rdfs:comment xml:lang="en">A type of permission that involves transferring rights or ownership.</rdfs:comment>
  <rdfs:label xml:lang="en">TransferRight</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class with subclass axiom: Models transfer permissions, addresses CQ03
    [Pitfall Resolution Agent] Created class with subclass axiom: Models transfer permissions, addresses CQ03</vaem:rationale>
  <dc:source>(competency_question) CQ03: Shall the permissions 'Aggregation' and 'Disaggregation' be of the type Transfer Rights?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Permission"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Aggregation">
  <rdfs:comment xml:lang="en">An action that combines multiple assets into a single entity.</rdfs:comment>
  <rdfs:label xml:lang="en">Aggregation</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class with subclass axiom: Models combining actions, addresses CQ03
    [Pitfall Resolution Agent] Created class with subclass axiom: Models combining actions, addresses CQ03</vaem:rationale>
  <dc:source>(competency_question) CQ03: Shall the permissions 'Aggregation' and 'Disaggregation' be of the type Transfer Rights?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Action"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Disaggregation">
  <rdfs:comment xml:lang="en">An action that separates an asset into its constituent components.</rdfs:comment>
  <rdfs:label xml:lang="en">Disaggregation</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class with subclass axiom: Models separating actions, addresses CQ03
    [Pitfall Resolution Agent] Created class with subclass axiom: Models separating actions, addresses CQ03</vaem:rationale>
  <dc:source>(competency_question) CQ03: Shall the permissions 'Aggregation' and 'Disaggregation' be of the type Transfer Rights?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Action"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ExclusivePermission">
  <rdfs:comment xml:lang="en">A permission that cannot be granted to multiple parties simultaneously.</rdfs:comment>
  <rdfs:label xml:lang="en">ExclusivePermission</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Models exclusive rights, addresses CQ24
    [Pitfall Resolution Agent] Created class: Models exclusive rights, addresses CQ24</vaem:rationale>
  <dc:source>(competency_question) CQ24: How to express exclusive permissions?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#NotOperator">
  <rdfs:comment xml:lang="en">Logical NOT operator used in constraints to negate conditions.</rdfs:comment>
  <rdfs:label xml:lang="en">NOT</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Renamed from not: OOPS pitfall: naming convention violation and ambiguous keyword
    [Pitfall Resolution Agent] Created class with subclass axiom: Models negation operator, addresses CQ08</vaem:rationale>
  <dc:source>(competency_question) CQ08: How to provide a 'NOT' expression?
    (pitfall) The ontology elements are not named following the same convention</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Operator"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#AndOperator">
  <rdfs:comment xml:lang="en">Logical AND operator used in constraints to combine conditions.</rdfs:comment>
  <rdfs:label xml:lang="en">AND</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Renamed from and: OOPS pitfall: class name refers to two or more different concepts
    [Pitfall Resolution Agent] Created class with subclass axiom: Models conjunction operator, addresses CQ14</vaem:rationale>
  <dc:source>(competency_question) CQ14: How do we express 'and', 'or', 'xor' constraints?
    (pitfall) A class whose name refers to two or more different concepts is created.</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Operator"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#or">
  <rdfs:comment xml:lang="en">Logical OR operator used in constraints to provide alternative conditions.</rdfs:comment>
  <rdfs:label xml:lang="en">OR</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class with subclass axiom: Models disjunction operator, addresses CQ14
    [Pitfall Resolution Agent] Created class with subclass axiom: Models disjunction operator, addresses CQ14</vaem:rationale>
  <dc:source>(competency_question) CQ14: How do we express 'and', 'or', 'xor' constraints?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Operator"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#xor">
  <rdfs:comment xml:lang="en">Logical XOR operator used in constraints to enforce mutual exclusivity.</rdfs:comment>
  <rdfs:label xml:lang="en">XOR</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class with subclass axiom: Models exclusive disjunction operator, addresses CQ14
    [Pitfall Resolution Agent] Created class with subclass axiom: Models exclusive disjunction operator, addresses CQ14</vaem:rationale>
  <dc:source>(competency_question) CQ14: How do we express 'and', 'or', 'xor' constraints?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Operator"/>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAsset">
  <rdfs:comment xml:lang="en">Links a policy to the asset it governs.</rdfs:comment>
  <rdfs:label xml:lang="en">has asset</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property: Addresses New CQ1
    [Pitfall Resolution Agent] Created object property: Addresses New CQ1
    [Pitfall Resolution Agent] Added inverse axiom: OOPS pitfall: missing inverse relationship</vaem:rationale>
  <dc:source>(competency_question) New CQ1: Which policy is directly linked to a given asset?
    (pitfall) This pitfall appears when any relationship does not have an inverse relationship defined</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Asset"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isAssetOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isAssetOf">
  <rdfs:comment xml:lang="en">Inverse of hasAsset. Links an asset to the policy that governs it.</rdfs:comment>
  <rdfs:label xml:lang="en">is asset of</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property: OOPS pitfall: missing inverse relationship</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship does not have an inverse relationship defined</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Asset"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasAsset"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasRule">
  <rdfs:comment xml:lang="en">Links a policy to a rule contained within it.</rdfs:comment>
  <rdfs:label xml:lang="en">has rule</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property: Structures policy-rule relationship
    [Pitfall Resolution Agent] Created object property: Structures policy-rule relationship
    [Pitfall Resolution Agent] Added inverse axiom: OOPS pitfall: missing inverse relationship</vaem:rationale>
  <dc:source>(competency_question) CQ10: How are rights and duties supported for all contract parties?
    (pitfall) This pitfall appears when any relationship does not have an inverse relationship defined</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isRuleOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isRuleOf">
  <rdfs:comment xml:lang="en">Inverse of hasRule. Links a rule to the policy containing it.</rdfs:comment>
  <rdfs:label xml:lang="en">is rule of</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property: OOPS pitfall: missing inverse relationship</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship does not have an inverse relationship defined</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasRule"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPermission">
  <rdfs:comment xml:lang="en">Links a rule to a permission it grants.</rdfs:comment>
  <rdfs:label xml:lang="en">has permission</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property: Models permission assignment
