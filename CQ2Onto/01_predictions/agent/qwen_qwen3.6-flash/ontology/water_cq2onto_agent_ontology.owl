  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure">
  <rdfs:comment xml:lang="en">Represents the physical and logical components that make up a water distribution network.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Distribution Infrastructure</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Derived from CQ01 to model the main system being queried.
    [Pitfall Resolution Agent] Added source tracking for OOPS fixes: Addressed isolated elements and missing inverses</vaem:rationale>
  <dc:source>(competency_question) CQ01: Which assets compose a water distribution infrastructure?
    (pitfall) OOPS: Ontology elements are created isolated, with no relation to the rest of the ontology.</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Asset">
  <rdfs:comment xml:lang="en">A physical component or resource within the water infrastructure.</rdfs:comment>
  <rdfs:label xml:lang="en">Asset</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Derived from CQ01 to represent infrastructure components.
    [Pitfall Resolution Agent] Established as superclass for Device and Tariff: Resolves OOPS pitfall regarding isolated elements by integrating Device and Tariff into the class hierarchy.</vaem:rationale>
  <dc:source>(competency_question) CQ01: Which assets compose a water distribution infrastructure?
    (pitfall) OOPS: Ontology elements are created isolated, with no relation to the rest of the ontology.</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Sensor">
  <rdfs:comment xml:lang="en">A device used to detect or measure physical properties within the infrastructure.</rdfs:comment>
  <rdfs:label xml:lang="en">Sensor</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Derived from CQ04 to model sensing devices.
    [Pitfall Resolution Agent] Added inverse property linkage: Addresses OOPS pitfall regarding missing inverse relationships.</vaem:rationale>
  <dc:source>(competency_question) CQ04: Which types of sensors are used in water infrastructures?
    (pitfall) OOPS: Missing inverse relationship for hasSensor.</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Actuator">
  <rdfs:comment xml:lang="en">A device used to control or regulate a physical process within the infrastructure.</rdfs:comment>
  <rdfs:label xml:lang="en">Actuator</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Derived from CQ05 to model control devices.
    [Pitfall Resolution Agent] Added inverse property linkage: Addresses OOPS pitfall regarding missing inverse relationships.</vaem:rationale>
  <dc:source>(competency_question) CQ05: Which types of actuators are used in water infrastructures?
    (pitfall) OOPS: Missing inverse relationship for hasActuator.</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Device">
  <rdfs:comment xml:lang="en">A general class for technical equipment used in the water infrastructure.</rdfs:comment>
  <rdfs:label xml:lang="en">Device</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Derived from CQ06 to serve as a superclass for WaterMeter.
    [Pitfall Resolution Agent] Added subclass relationship to Asset: Resolves OOPS pitfall regarding isolated elements by linking Device to the Asset hierarchy.</vaem:rationale>
  <dc:source>(competency_question) CQ06: A water meter is a device that measures different aspects of a water infrastructure.
    (pitfall) OOPS: Ontology elements are created isolated, with no relation to the rest of the ontology.</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Asset"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterMeter">
  <rdfs:comment xml:lang="en">A specific device that measures water usage and related parameters.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Meter</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Derived from CQ06 and subsequent CQs focusing on meter attributes.
    [Pitfall Resolution Agent] No structural changes required: Already properly integrated into the hierarchy.</vaem:rationale>
  <dc:source>(competency_question) CQ06, CQ08-CQ12, CQ18-CQ20, CQ25, CQ38-CQ43</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Water">
  <rdfs:comment xml:lang="en">The chemical substance H2O, central to the domain.</rdfs:comment>
  <rdfs:label xml:lang="en">Water</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Derived from CQ33 and CQ34 to model the substance being measured.
    [Pitfall Resolution Agent] Added inverse property linkage: Addresses OOPS pitfall regarding missing inverse relationships.</vaem:rationale>
  <dc:source>(competency_question) CQ33: What are the physical properties of water? CQ34: What are the chemical properties of water?
    (pitfall) OOPS: Missing inverse relationship for measures.</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PhysicalProperty">
  <rdfs:comment xml:lang="en">Properties related to the physical state of water (e.g., temperature, pressure, flow rate).</rdfs:comment>
  <rdfs:label xml:lang="en">Physical Property</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Derived from CQ33 to categorize physical attributes.
    [Pitfall Resolution Agent] Added disjoint axiom with ChemicalProperty: Resolves OOPS pitfall regarding missing disjoint axioms between mutually exclusive classes.</vaem:rationale>
  <dc:source>(competency_question) CQ33: What are the physical properties of water?
    (pitfall) OOPS: The ontology lacks disjoint axioms between classes or between properties that should be defined as disjoint.</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#ChemicalProperty"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ChemicalProperty">
  <rdfs:comment xml:lang="en">Properties related to the chemical composition of water (e.g., pH, chlorine, turbidity).</rdfs:comment>
  <rdfs:label xml:lang="en">Chemical Property</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Derived from CQ34 to categorize chemical attributes.
    [Pitfall Resolution Agent] Added disjoint axiom with PhysicalProperty: Resolves OOPS pitfall regarding missing disjoint axioms between mutually exclusive classes.</vaem:rationale>
  <dc:source>(competency_question) CQ34: What are the chemical properties of water?
    (pitfall) OOPS: The ontology lacks disjoint axioms between classes or between properties that should be defined as disjoint.</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PhysicalProperty"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterIndicator">
  <rdfs:comment xml:lang="en">Metrics or indicators used to assess water quality or usage in a specific location.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Indicator</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Derived from CQ37 to model location-specific metrics.
    [Pitfall Resolution Agent] Added inverse property linkage: Addresses OOPS pitfall regarding missing inverse relationships.</vaem:rationale>
  <dc:source>(competency_question) CQ37: Which water indicators are defined for Burgos?
    (pitfall) OOPS: Missing inverse relationship for hasWaterIndicator.</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Location">
  <rdfs:comment xml:lang="en">A geographical place where water infrastructure or indicators are defined.</rdfs:comment>
  <rdfs:label xml:lang="en">Location</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Derived from CQ37 to model geographical context.
    [Pitfall Resolution Agent] No structural changes required: Properly integrated via hasWaterIndicator.</vaem:rationale>
  <dc:source>(competency_question) CQ37: Which water indicators are defined for Burgos?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#City">
  <rdfs:comment xml:lang="en">A type of location representing an urban area.</rdfs:comment>
  <rdfs:label xml:lang="en">City</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Derived from CQ37 to specialize Location for urban contexts like Burgos.
    [Pitfall Resolution Agent] No structural changes required: Properly integrated via subclass of Location.</vaem:rationale>
  <dc:source>(competency_question) CQ37: Which water indicators are defined for Burgos?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Tariff">
  <rdfs:comment xml:lang="en">A pricing scheme or rate structure applied to water usage.</rdfs:comment>
  <rdfs:label xml:lang="en">Tariff</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Derived from CQ38-CQ40 to model billing structures.
    [Pitfall Resolution Agent] Added subclass relationship to Asset: Resolves OOPS pitfall regarding isolated elements by linking Tariff to the Asset hierarchy.</vaem:rationale>
  <dc:source>(competency_question) CQ38: What is the start date and time of the tariff in use in the water meter? CQ39: What is the duration of the current tariff of the water meter? CQ40: What is the tariff period of the water meter?
    (pitfall) OOPS: Ontology elements are created isolated, with no relation to the rest of the ontology.</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Asset"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#BillingPeriod">
  <rdfs:comment xml:lang="en">A defined time interval for billing purposes.</rdfs:comment>
  <rdfs:label xml:lang="en">Billing Period</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Derived from CQ42-CQ43 to model billing timeframes.
    [Pitfall Resolution Agent] Added subclass relationship to TemporalSetting: Resolves OOPS pitfall regarding isolated elements by linking BillingPeriod to the TemporalSetting hierarchy.</vaem:rationale>
  <dc:source>(competency_question) CQ42: What is the billing date of the water meter? CQ43: What is the billing date period of the water meter?
    (pitfall) OOPS: Ontology elements are created isolated, with no relation to the rest of the ontology.</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#TemporalSetting"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#TemporalSetting">
  <rdfs:comment xml:lang="en">Configuration defining time intervals for measurements or operations.</rdfs:comment>
  <rdfs:label xml:lang="en">Temporal Setting</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Derived from CQ25 to model measurement scheduling.
    [Pitfall Resolution Agent] Added inverse property linkage: Addresses OOPS pitfall regarding missing inverse relationships.</vaem:rationale>
  <dc:source>(competency_question) CQ25: Water meters can provide measurements according to different temporal settings.
    (pitfall) OOPS: Missing inverse relationship for hasTemporalSetting.</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#string">
  <rdfs:comment xml:lang="en">Represents the XML Schema string datatype, used for textual attributes.</rdfs:comment>
  <rdfs:label xml:lang="en">string</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Declared as owl:Class: Resolves OOPS pitfall: element used as a class without explicit declaration.</vaem:rationale>
  <dc:source>(pitfall) OOPS: An ontology element is used as a class without having been explicitly declared as such using the primitives owl:Class or rdfs:Class.</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#dateTime">
  <rdfs:comment xml:lang="en">Represents the XML Schema dateTime datatype, used for temporal attributes.</rdfs:comment>
  <rdfs:label xml:lang="en">dateTime</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Declared as owl:Class: Resolves OOPS pitfall: element used as a class without explicit declaration.</vaem:rationale>
  <dc:source>(pitfall) OOPS: An ontology element is used as a class without having been explicitly declared as such using the primitives owl:Class or rdfs:Class.</dc:source>
</owl:Class>

