<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAsset">
  <rdfs:comment xml:lang="en">Links an infrastructure to its constituent assets.</rdfs:comment>
  <rdfs:label xml:lang="en">has asset</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Answers CQ01 by relating infrastructure to assets.
    [Pitfall Resolution Agent] Added inverse property linkage: Addresses OOPS pitfall regarding missing inverse relationships.</vaem:rationale>
  <dc:source>(competency_question) CQ01: Which assets compose a water distribution infrastructure?
    (pitfall) OOPS: Missing inverse relationship for hasAsset.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Asset"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isAssetOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isAssetOf">
  <rdfs:comment xml:lang="en">Inverse of hasAsset. Links an asset to the infrastructure it belongs to.</rdfs:comment>
