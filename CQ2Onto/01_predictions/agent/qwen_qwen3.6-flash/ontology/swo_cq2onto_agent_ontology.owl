</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isUsedBy">
  <rdfs:comment xml:lang="en">Inverse of usesAlgorithm. Links an algorithm to the software that implements it.</rdfs:comment>
  <rdfs:label xml:lang="en">is used by</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created isUsedBy inverse property: Addressed OOPS! pitfall: missing inverse relationship for usesAlgorithm.</vaem:rationale>
  <dc:source>(pitfall) Missing inverse property</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#usesAlgorithm"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isPerformedBy">
  <rdfs:comment xml:lang="en">Inverse of performsTask. Links a task to the software that executes it.</rdfs:comment>
  <rdfs:label xml:lang="en">is performed by</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created isPerformedBy inverse property: Addressed OOPS! pitfall: missing inverse relationship for performsTask.</vaem:rationale>
  <dc:source>(pitfall) Missing inverse property</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Task"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#performsTask"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isSupportedBy">
  <rdfs:comment xml:lang="en">Inverse of supportsFormat. Links a data format to the software that supports it.</rdfs:comment>
