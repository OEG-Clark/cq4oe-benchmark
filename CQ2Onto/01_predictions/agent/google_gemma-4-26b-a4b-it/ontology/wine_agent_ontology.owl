<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Wine">
  <rdfs:comment xml:lang="en">A fermented alcoholic beverage made from grapes.</rdfs:comment>
  <rdfs:label xml:lang="en">Wine</rdfs:label>
  <dc:source>(competency_question) CQ1: Which wine characteristics should I consider when choosing a wine?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Grape">
  <rdfs:comment xml:lang="en">The fruit used to produce wine.</rdfs:comment>
  <rdfs:label xml:lang="en">Grape</rdfs:label>
  <dc:source>(competency_question) CQnew1: What grapes are used to make Bordeaux wine?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Vintage">
  <rdfs:comment xml:lang="en">A specific year or period of grape harvest.</rdfs:comment>
  <rdfs:label xml:lang="en">Vintage</rdfs:label>
  <dc:source>(competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WineCharacteristic">
  <rdfs:comment xml:lang="en">An attribute of wine such as body, bouquet, acidity, or tannins.</rdfs:comment>
  <rdfs:label xml:lang="en">Wine Characteristic</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjointness with WineType: To prevent an instance from being both a characteristic and a type simultaneously.</vaem:rationale>
  <dc:source>(competency_question) CQ1: Which wine characteristics should I consider when choosing a wine?</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#WineType"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WineType">
  <rdfs:comment xml:lang="en">The classification of wine by color or style, e.g., Red, White, Rosé.</rdfs:comment>
  <rdfs:label xml:lang="en">Wine Type</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjointness with WineCharacteristic: To ensure logical separation between types and characteristics.</vaem:rationale>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGrape">
  <rdfs:comment xml:lang="en">Relates a wine to the grape variety used to make it.</rdfs:comment>
  <rdfs:label xml:lang="en">has grape</rdfs:label>
  <dc:source>(competency_question) CQnew1: What grapes are used to make Bordeaux wine?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Grape"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isGrapeOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isGrapeOf">
  <rdfs:comment xml:lang="en">Relates a grape variety to the wine it is used in.</rdfs:comment>
  <rdfs:label xml:lang="en">is grape of</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Grape"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasType">
  <rdfs:comment xml:lang="en">Relates a wine to its type (e.g., Red or White).</rdfs:comment>
  <rdfs:label xml:lang="en">has type</rdfs:label>
  <dc:source>(competency_question) CQ2: Is Bordeaux a red or white wine?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WineType"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isTypeOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isTypeOf">
  <rdfs:comment xml:lang="en">Relates a wine type to the wine it describes.</rdfs:comment>
  <rdfs:label xml:lang="en">is type of</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WineType"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasVintage">
  <rdfs:comment xml:lang="en">Relates a specific wine instance or production to a vintage year.</rdfs:comment>
  <rdfs:label xml:lang="en">has vintage</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Vintage"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isVintageOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isVintageOf">
  <rdfs:comment xml:lang="en">Relates a vintage to the wine it belongs to.</rdfs:comment>
  <rdfs:label xml:lang="en">is vintage of</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Vintage"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasCharacteristic">
  <rdfs:comment xml:lang="en">Relates a wine (in a specific vintage) to a characteristic.</rdfs:comment>
  <rdfs:label xml:lang="en">has characteristic</rdfs:label>
  <dc:source>(competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WineCharacteristic"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isCharacteristicOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isCharacteristicOf">
  <rdfs:comment xml:lang="en">Relates a characteristic to the wine it describes.</rdfs:comment>
  <rdfs:label xml:lang="en">is characteristic of</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WineCharacteristic"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasYear">
  <rdfs:comment xml:lang="en">The integer value representing the year of a vintage.</rdfs:comment>
  <rdfs:label xml:lang="en">has year</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Vintage"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasIntensity">
  <rdfs:comment xml:lang="en">The level or measurement of a characteristic (e.g., high body, low acidity).</rdfs:comment>
  <rdfs:label xml:lang="en">has intensity</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WineCharacteristic"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

</rdf:RDF>