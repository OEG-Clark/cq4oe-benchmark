<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Software">
  <rdfs:comment xml:lang="en">A software tool or application.</rdfs:comment>
  <rdfs:label xml:lang="en">Software</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjointness axioms.: To address the 'Missing Disjoint Axioms' pitfall.</vaem:rationale>
  <dc:source>(competency_question) CQ07: What type of software (API, Desktop application etc) is it?</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Developer"/>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#License"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Algorithm">
  <rdfs:comment xml:lang="en">A named and published algorithm used by software.</rdfs:comment>
  <rdfs:label xml:lang="en">Algorithm</rdfs:label>
  <dc:source>(competency_question) CQ04: Which of the named and published algorithms does this tool use?</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Developer"/>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#License"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#DataFormat">
  <rdfs:comment xml:lang="en">A file format used for input or output.</rdfs:comment>
  <rdfs:label xml:lang="en">Data Format</rdfs:label>
  <dc:source>(competency_question) CQ17: What are the input and output formats for this software?</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Developer"/>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#License"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Developer">
  <rdfs:comment xml:lang="en">The entity or person that developed the software.</rdfs:comment>
  <rdfs:label xml:lang="en">Developer</rdfs:label>
  <dc:source>(competency_question) CQ36: Who developed it?</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#License"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#License">
  <rdfs:comment xml:lang="en">The legal license governing the software usage.</rdfs:comment>
  <rdfs:label xml:lang="en">License</rdfs:label>
  <dc:source>(competency_question) CQ59: What license and what is permissiveness?</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Developer"/>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usesAlgorithm">
  <rdfs:comment xml:lang="en">The algorithm used by the software.</rdfs:comment>
  <rdfs:label xml:lang="en">uses algorithm</rdfs:label>
  <dc:source>(competency_question) CQ04: Which of the named and published algorithms does this tool use?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isUsedByAlgorithm"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isUsedByAlgorithm">
  <rdfs:comment xml:lang="en">The software that uses the algorithm.</rdfs:comment>
  <rdfs:label xml:lang="en">is used by algorithm</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Software"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAlgorithmModification">
  <rdfs:comment xml:lang="en">Indicates if there are modifications to the used algorithm.</rdfs:comment>
  <rdfs:label xml:lang="en">has algorithm modification</rdfs:label>
  <dc:source>(competency_question) CQ05: Are there any modifications to the algorithm the tool uses?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasAlgorithmModificationInverse"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAlgorithmModificationInverse">
  <rdfs:comment xml:lang="en">Inverse of has algorithm modification.</rdfs:comment>
  <rdfs:label xml:lang="en">has algorithm modification inverse</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Software"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasInputFormat">
  <rdfs:comment xml:lang="en">The format the software can read.</rdfs:comment>
  <rdfs:label xml:lang="en">has input format</rdfs:label>
  <dc:source>(competency_question) CQ17: What are the input and output formats for this software?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isInputFormatFor"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isInputFormatFor">
  <rdfs:comment xml:lang="en">The software that uses this input format.</rdfs:comment>
  <rdfs:label xml:lang="en">is input format for</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Software"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasOutputFormat">
  <rdfs:comment xml:lang="en">The format the software can export.</rdfs:comment>
  <rdfs:label xml:lang="en">has output format</rdfs:label>
  <dc:source>(competency_question) CQ17: What are the input and output formats for this software?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isOutputFormatFor"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isOutputFormatFor">
  <rdfs:comment xml:lang="en">The software that uses this output format.</rdfs:comment>
  <rdfs:label xml:lang="en">is output format for</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Software"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#developedBy">
  <rdfs:comment xml:lang="en">The developer of the software.</rdfs:comment>
  <rdfs:label xml:lang="en">developed by</rdfs:label>
  <dc:source>(competency_question) CQ36: Who developed it?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Developer"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#develops"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#develops">
  <rdfs:comment xml:lang="en">The developer that develops the software.</rdfs:comment>
  <rdfs:label xml:lang="en">develops</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Developer"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Software"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasLicense">
  <rdfs:comment xml:lang="en">The license of the software.</rdfs:comment>
  <rdfs:label xml:lang="en">has license</rdfs:label>
  <dc:source>(competency_question) CQ59: What license and what is permissiveness?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#License"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isLicenseFor"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isLicenseFor">
  <rdfs:comment xml:lang="en">The software that is governed by the license.</rdfs:comment>
  <rdfs:label xml:lang="en">is license for</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#License"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Software"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#runsOnPlatform">
  <rdfs:comment xml:lang="en">The platform the software runs on.</rdfs:comment>
  <rdfs:label xml:lang="en">runs on platform</rdfs:label>
  <dc:source>(competency_question) CQ85: What platform does the software run on?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#owl:Thing"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isPlatformFor"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isPlatformFor">
  <rdfs:comment xml:lang="en">The software that runs on the platform.</rdfs:comment>
  <rdfs:label xml:lang="en">is platform for</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#owl:Thing"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Software"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#createdData">
  <rdfs:comment xml:lang="en">The software that was used to create a specific dataset.</rdfs:comment>
  <rdfs:label xml:lang="en">created data</rdfs:label>
  <dc:source>(competency_question) CQ15: Which software tool created this data?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#owl:Thing"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#wasCreatedBy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#wasCreatedBy">
  <rdfs:comment xml:lang="en">The software used to create the data.</rdfs:comment>
  <rdfs:label xml:lang="en">was created by</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#owl:Thing"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Software"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#canPerformTask">
  <rdfs:comment xml:lang="en">The task that the software can perform.</rdfs:comment>
  <rdfs:label xml:lang="en">can perform task</rdfs:label>
  <dc:source>(competency_question) CQ14: Does it do what I want or need it to do e.g. render a gif?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#owl:Thing"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isTaskOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isTaskOf">
  <rdfs:comment xml:lang="en">The software that can perform the task.</rdfs:comment>
  <rdfs:label xml:lang="en">is task of</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#owl:Thing"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Software"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasVersion">
  <rdfs:comment xml:lang="en">The version string of the software.</rdfs:comment>
  <rdfs:label xml:lang="en">has version</rdfs:label>
  <dc:source>(competency_question) CQ54: What is the version of this software?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasHomepageURL">
  <rdfs:comment xml:lang="en">The URL of the software's homepage.</rdfs:comment>
  <rdfs:label xml:lang="en">has homepage URL</rdfs:label>
  <dc:source>(competency_question) CQ37: What is the homepage of the software?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isWebservice">
  <rdfs:comment xml:lang="en">Whether the software is available as a web service.</rdfs:comment>
  <rdfs:label xml:lang="en">is web service</rdfs:label>
  <dc:source>(competency_question) CQ11: Is this software available as a web service?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isOpenSource">
  <rdfs:comment xml:lang="en">Whether the software is open source.</rdfs:comment>
  <rdfs:label xml:lang="en">is open source</rdfs:label>
  <dc:source>(competency_question) CQ60: Is it open source or not?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#implementationLanguage">
  <rdfs:comment xml:lang="en">The programming language used to implement the software.</rdfs:comment>
  <rdfs:label xml:lang="en">implementation language</rdfs:label>
  <dc:source>(competency_question) CQ84: In what language was it implemented?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

</rdf:RDF>