<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Player">
  <rdfs:comment xml:lang="en">A person who plays the games.</rdfs:comment>
  <rdfs:label xml:lang="en">Player</rdfs:label>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Game"/> <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Achievement"/> <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Item"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Game">
  <rdfs:comment xml:lang="en">A playable video game.</rdfs:comment>
  <rdfs:label xml:lang="en">Game</rdfs:label>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Player"/> <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Achievement">
  <rdfs:comment xml:lang="en">A milestone or reward earned within a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Achievement</rdfs:label>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Player"/> <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Item">
  <rdfs:comment xml:lang="en">An object or equipment used within a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Item</rdfs:label>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Genre">
  <rdfs:comment xml:lang="en">A category of games.</rdfs:comment>
  <rdfs:label xml:lang="en">Genre</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#AchievementType">
  <rdfs:comment xml:lang="en">The classification or type of an achievement.</rdfs:comment>
  <rdfs:label xml:lang="en">Achievement Type</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#InAppPurchase">
  <rdfs:comment xml:lang="en">A financial transaction made within the game.</rdfs:comment>
  <rdfs:label xml:lang="en">In-App Purchase</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayingArea">
  <rdfs:comment xml:lang="en">A specific area or zone within a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Playing Area</rdfs:label>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#playsGame">
  <rdfs:comment xml:lang="en">Relates a player to the games they have played.</rdfs:comment>
  <rdfs:label xml:lang="en">plays game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isPlayedBy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isPlayedBy">
  <rdfs:comment xml:lang="en">Relates a game to the players who play it.</rdfs:comment>
  <rdfs:label xml:lang="en">is played by</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#playsGame"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#gameHasAchievement">
  <rdfs:comment xml:lang="en">Relates a game to the achievements it contains.</rdfs:comment>
  <rdfs:label xml:lang="en">game has achievement</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isAchievementOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isAchievementOf">
  <rdfs:comment xml:lang="en">Relates an achievement to the game it belongs to.</rdfs:comment>
  <rdfs:label xml:lang="en">is achievement of</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#gameHasAchievement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasItem">
  <rdfs:comment xml:lang="en">Relates a player to the items they possess.</rdfs:comment>
  <rdfs:label xml:lang="en">has item</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isOwnedBy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isOwnedBy">
  <rdfs:comment xml:lang="en">Relates an item to the player who owns it.</rdfs:comment>
  <rdfs:label xml:lang="en">is owned by</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Item"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasItem"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isUsedIn">
  <rdfs:comment xml:lang="en">Relates an item to the game it can be used in.</rdfs:comment>
  <rdfs:label xml:lang="en">is used in</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Item"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#usesItem"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usesItem">
  <rdfs:comment xml:lang="en">Relates a game to the items used within it.</rdfs:comment>
  <rdfs:label xml:lang="en">uses item</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isUsedIn"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGenre">
  <rdfs:comment xml:lang="en">Relates a game to its genre.</rdfs:comment>
  <rdfs:label xml:lang="en">has genre</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Genre"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasGenreOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGenreOf">
  <rdfs:comment xml:lang="en">Relates a genre to the games that belong to it.</rdfs:comment>
  <rdfs:label xml:lang="en">has genre of</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Genre"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasGenre"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAchievementType">
  <rdfs:comment xml:lang="en">Relates an achievement to its type.</rdfs:comment>
  <rdfs:label xml:lang="en">has achievement type</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isTypeFor"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isTypeFor">
  <rdfs:comment xml:lang="en">Relates an achievement type to the achievements it classifies.</rdfs:comment>
  <rdfs:label xml:lang="en">is type for</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasAchievementType"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPlayingArea">
  <rdfs:comment xml:lang="en">Relates a game to its playing areas.</rdfs:comment>
  <rdfs:label xml:lang="en">has playing area</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isAreaIn"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isAreaIn">
  <rdfs:comment xml:lang="en">Relates a playing area to the game it belongs to.</rdfs:comment>
  <rdfs:label xml:lang="en">is area in</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasPlayingArea"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#madePurchase">
  <rdfs:comment xml:lang="en">Relates a player to their in-app purchases.</rdfs:comment>
  <rdfs:label xml:lang="en">made purchase</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isMadeBy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isMadeBy">
  <rdfs:comment xml:lang="en">Relates an in-app purchase to the player who made it.</rdfs:comment>
  <rdfs:label xml:lang="en">is made by</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#madePurchase"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#username">
  <rdfs:comment xml:lang="en">The unique username of the player.</rdfs:comment>
  <rdfs:label xml:lang="en">username</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Corrected range from myontology#xsd:string to xsd:string: To fix the pitfall where XSD datatypes were being treated as local ontology classes.</vaem:rationale>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#totalPlayTime">
  <rdfs:comment xml:lang="en">Total hours played in a game.</rdfs:comment>
  <rdfs:label xml:lang="en">total play time</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#releaseDate">
  <rdfs:comment xml:lang="en">The date the game was released.</rdfs:comment>
  <rdfs:label xml:lang="en">release date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:date"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#killCount">
  <rdfs:comment xml:lang="en">The number of kills recorded by a player.</rdfs:comment>
  <rdfs:label xml:lang="en">kill count</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#itemAbility">
  <rdfs:comment xml:lang="en">The ability provided by an item.</rdfs:comment>
  <rdfs:label xml:lang="en">item ability</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Item"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#playerLocation">
  <rdfs:comment xml:lang="en">The geographic location of a player.</rdfs:comment>
  <rdfs:label xml:lang="en">player location</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#purchaseTime">
  <rdfs:comment xml:lang="en">The timestamp of an in-app purchase.</rdfs:comment>
  <rdfs:label xml:lang="en">purchase time</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:dateTime"/>
</owl:DatatypeProperty>

</rdf:RDF>