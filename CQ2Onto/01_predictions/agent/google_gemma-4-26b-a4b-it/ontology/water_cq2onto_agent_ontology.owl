<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#InfrastructureAsset">
  <rdfs:comment xml:lang="en">A general component or asset within an infrastructure system.</rdfs:comment>
  <rdfs:label xml:lang="en">Infrastructure Asset</rdfs:label>
  <dc:source>(competency_question) CQ01: Which assets compose a water distribution infrastructure?
    (other) (competency_question) CQ01: Which assets compose a water distribution infrastructure?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterInfrastructure">
  <rdfs:comment xml:lang="en">The complete system for water distribution.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Infrastructure</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created WaterInfrastructure class: To represent the top-level system mentioned in CQ01.
    [Pitfall Resolution Agent] Created WaterInfrastructure class: To represent the top-level system mentioned in CQ01.</vaem:rationale>
  <dc:source>(competency_question) CQ01: Which assets compose a water distribution infrastructure?
    (other) (competency_question) CQ01: Which assets compose a water distribution infrastructure?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#InfrastructureAsset'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Sensor">
  <rdfs:comment xml:lang="en">A device used to detect or measure physical properties.</rdfs:comment>
  <rdfs:label xml:lang="en">Sensor</rdfs:label>
  <dc:source>(competency_question) CQ04: Which types of sensors are used in water infrastructures?
    (other) (competency_question) CQ04: Which types of sensors are used in water infrastructures?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#InfrastructureAsset'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Actuator">
  <rdfs:comment xml:lang="en">A device used to control or move a mechanism.</rdfs:comment>
  <rdfs:label xml:lang="en">Actuator</rdfs:label>
  <dc:source>(competency_question) CQ05: Which types of actuators are used in water infrastructures?
    (other) (competency_question) CQ05: Which types of actuators are used in water infrastructures?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#InfrastructureAsset'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterMeter">
  <rdfs:comment xml:lang="en">A device that measures different aspects of a water infrastructure.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Meter</rdfs:label>
  <dc:source>(competency_question) CQ06: A water meter is a device that measures different aspects of a water infrastructure.
    (other) (competency_question) CQ06: A water meter is a device that measures different aspects of a water infrastructure.</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#InfrastructureAsset'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterProperty">
  <rdfs:comment xml:lang="en">A characteristic of water.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Property</rdfs:label>
  <dc:source>(competency_question) CQ33: What are the physical properties of water?
    (other) (competency_question) CQ33: What are the physical properties of water?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PhysicalProperty">
  <rdfs:comment xml:lang="en">A physical characteristic of water.</rdfs:comment>
  <rdfs:label xml:lang="en">Physical Property</rdfs:label>
  <dc:source>(competency_question) CQ33: What are the physical properties of water?
    (other) (competency_question) CQ33: What are the physical properties of water?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#WaterProperty'/>
<owl:disjointWith rdf:resource='http://www.semanticweb.org/myontology#ChemicalProperty'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ChemicalProperty">
  <rdfs:comment xml:lang="en">A chemical characteristic of water.</rdfs:comment>
  <rdfs:label xml:lang="en">Chemical Property</rdfs:label>
  <dc:source>(competency_question) CQ34: What are the chemical properties of water?
    (other) (competency_question) CQ34: What are the chemical properties of water?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#WaterProperty'/>
<owl:disjointWith rdf:resource='http://www.semanticweb.org/myontology#PhysicalProperty'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Tariff">
  <rdfs:comment xml:lang="en">The pricing structure applied to water usage.</rdfs:comment>
  <rdfs:label xml:lang="en">Tariff</rdfs:label>
  <dc:source>(competency_question) CQ38: What is the start date and time of the tariff in use in the water meter?
    (other) (competency_question) CQ38: What is the start date and time of the tariff in use in the water meter?</dc:source>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#composes">
  <rdfs:comment xml:lang="en">Relates a water infrastructure to its constituent assets.</rdfs:comment>
  <rdfs:label xml:lang="en">composes</rdfs:label>
  <dc:source>(competency_question) CQ01: Which assets compose a water distribution infrastructure?
    (other) (competency_question) CQ01: Which assets compose a water distribution infrastructure?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterInfrastructure"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#InfrastructureAsset"/>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#isComposedOf'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isComposedOf">
  <rdfs:comment xml:lang="en">The inverse of composes. Relates an asset to the infrastructure it belongs to.</rdfs:comment>
  <rdfs:label xml:lang="en">is composed of</rdfs:label>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#composes'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasTariff">
  <rdfs:comment xml:lang="en">Relates a water meter to its current tariff.</rdfs:comment>
  <rdfs:label xml:lang="en">has tariff</rdfs:label>
  <dc:source>(competency_question) CQ38: What is the start date and time of the tariff in use in the water meter?
    (other) (competency_question) CQ38: What is the start date and time of the tariff in use in the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Tariff"/>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#isTariffOf'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isTariffOf">
  <rdfs:comment xml:lang="en">The inverse of hasTariff. Relates a tariff to the meter it applies to.</rdfs:comment>
  <rdfs:label xml:lang="en">is tariff of</rdfs:label>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#hasTariff'/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#fabricationNumber">
  <rdfs:comment xml:lang="en">The unique fabrication number of the meter.</rdfs:comment>
  <rdfs:label xml:lang="en">fabrication number</rdfs:label>
  <dc:source>(competency_question) CQ08: What is the fabrication number of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#manufacturer">
  <rdfs:comment xml:lang="en">The manufacturer of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">manufacturer</rdfs:label>
  <dc:source>(competency_question) CQ09: What are the manufacturer and the model of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#model">
  <rdfs:comment xml:lang="en">The model of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">model</rdfs:label>
  <dc:source>(competency_question) CQ09: What are the manufacturer and the model of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#version">
  <rdfs:comment xml:lang="en">The general version of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">version</rdfs:label>
  <dc:source>(competency_question) CQ10: What is the version of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hardwareVersion">
  <rdfs:comment xml:lang="en">The hardware version number of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">hardware version</rdfs:label>
  <dc:source>(competency_question) CQ11: What is the hardware version number of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#firmwareVersion">
  <rdfs:comment xml:lang="en">The firmware version used by the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">firmware version</rdfs:label>
  <dc:source>(competency_question) CQ12: What firmware version is the water meter using?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#power">
  <rdfs:comment xml:lang="en">The power consumption or rating of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">power</rdfs:label>
  <dc:source>(competency_question) CQ18: What is the power of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:float"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#radioFrequency">
  <rdfs:comment xml:lang="en">The radio frequency level of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">radio frequency</rdfs:label>
  <dc:source>(competency_question) CQ19: What is the radio frequency level of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:float"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#geolocation">
  <rdfs:comment xml:lang="en">The geolocation coordinates of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">geolocation</rdfs:label>
  <dc:source>(competency_question) CQ20: What is the geolocation of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#startDate">
  <rdfs:comment xml:lang="en">The start date and time of the tariff.</rdfs:comment>
  <rdfs:label xml:lang="en">start date</rdfs:label>
  <dc:source>(competency_question) CQ38: What is the start date and time of the tariff in use in the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tariff"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#duration">
  <rdfs:comment xml:lang="en">The duration of the current tariff.</rdfs:comment>
  <rdfs:label xml:lang="en">duration</rdfs:label>
  <dc:source>(competency_question) CQ39: What is the duration of the current tariff of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tariff"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:duration"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#tariffPeriod">
  <rdfs:comment xml:lang="en">The tariff period of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">tariff period</rdfs:label>
  <dc:source>(competency_question) CQ40: What is the tariff period of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tariff"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#billingDate">
  <rdfs:comment xml:lang="en">The billing date of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">billing date</rdfs:label>
  <dc:source>(competency_question) CQ42: What is the billing date of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tariff"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:date"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#billingDatePeriod">
  <rdfs:comment xml:lang="en">The billing date period of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">billing date period</rdfs:label>
  <dc:source>(competency_question) CQ43: What is the billing date period of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tariff"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

</rdf:RDF>