<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#SoftwareTool">
  <rdfs:comment xml:lang="en">A software application or tool used to perform specific tasks.</rdfs:comment>
  <rdfs:label xml:lang="en">Software Tool</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjointness axioms with other top-level classes: To resolve the pitfall regarding lack of disjoint axioms between classes.</vaem:rationale>
  <dc:source>(competency_question) CQ06, CQ07, CQ08, CQ11, CQ14, CQ15, CQ16, CQ17, CQ19, CQ21, CQ22, CQ23, CQ26, CQ29, CQ30, CQ32, CQ36, CQ37, CQ38, CQ40, CQ45, CQ46, CQ54, CQ55, CQ57, CQ58, CQ59, CQ60, CQ65, CQ68, CQ73, CQ84, CQ85
    (pitfall) The ontology lacks disjoint axioms between classes</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#SoftwareType"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Developer"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#License"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#SoftwareVersion"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Platform"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#SoftwareType">
  <rdfs:comment xml:lang="en">The category of software, such as API, Desktop application, or Web Service.</rdfs:comment>
  <rdfs:label xml:lang="en">Software Type</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjointness axioms: To resolve the pitfall regarding lack of disjoint axioms.</vaem:rationale>
  <dc:source>(competency_question) CQ07, CQ11
    (pitfall) The ontology lacks disjoint axioms between classes</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Algorithm">
  <rdfs:comment xml:lang="en">A named and published procedure used by the software to perform calculations or data processing.</rdfs:comment>
  <rdfs:label xml:lang="en">Algorithm</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjointness axioms: To resolve the pitfall regarding lack of disjoint axioms.</vaem:rationale>
  <dc:source>(competency_question) CQ04, CQ05
    (pitfall) The ontology lacks disjoint axioms between classes</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#DataFormat">
  <rdfs:comment xml:lang="en">A specific format for data input or output (e.g., XML, CSV, .cel).</rdfs:comment>
  <rdfs:label xml:lang="en">Data Format</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjointness axioms: To resolve the pitfall regarding lack of disjoint axioms.</vaem:rationale>
  <dc:source>(competency_question) CQ17, CQ19, CQ21, CQ22, CQ23, CQ26, CQ29
    (pitfall) The ontology lacks disjoint axioms between classes</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#OpenFormat">
  <rdfs:comment xml:lang="en">A data format that is non-proprietary and open.</rdfs:comment>
  <rdfs:label xml:lang="en">Open Format</rdfs:label>
  <dc:source>(competency_question) CQ22</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Developer">
  <rdfs:comment xml:lang="en">The person or organization that developed the software.</rdfs:comment>
  <rdfs:label xml:lang="en">Developer</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjointness axioms: To resolve the pitfall regarding lack of disjoint axioms.</vaem:rationale>
  <dc:source>(competency_question) CQ36, CQ38
    (pitfall) The ontology lacks disjoint axioms between classes</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#License">
  <rdfs:comment xml:lang="en">The legal license under which the software is distributed.</rdfs:comment>
  <rdfs:label xml:lang="en">License</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjointness axioms: To resolve the pitfall regarding lack of disjoint axioms.</vaem:rationale>
  <dc:source>(competency_question) CQ59, CQ60, CQ65, CQ68
    (pitfall) The ontology lacks disjoint axioms between classes</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#SoftwareVersion">
  <rdfs:comment xml:lang="en">A specific release version of the software.</rdfs:comment>
  <rdfs:label xml:lang="en">Software Version</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjointness axioms: To resolve the pitfall regarding lack of disjoint axioms.</vaem:rationale>
  <dc:source>(competency_question) CQ54, CQ55, CQ57
    (pitfall) The ontology lacks disjoint axioms between classes</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Platform">
  <rdfs:comment xml:lang="en">The operating system or environment the software runs on.</rdfs:comment>
  <rdfs:label xml:lang="en">Platform</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjointness axioms: To resolve the pitfall regarding lack of disjoint axioms.</vaem:rationale>
  <dc:source>(competency_question) CQ85
    (pitfall) The ontology lacks disjoint axioms between classes</dc:source>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasType">
  <rdfs:comment xml:lang="en">Links a software tool to its type (e.g., API).</rdfs:comment>
  <rdfs:label xml:lang="en">has type</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isTypeOf: To resolve the pitfall regarding missing inverse relationships.</vaem:rationale>
  <dc:source>(competency_question) CQ07
    (pitfall) Relationship does not have an inverse relationship</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareType"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isTypeOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isTypeOf">
  <rdfs:comment xml:lang="en">Inverse of hasType: Links a software type to the tools that belong to it.</rdfs:comment>
  <rdfs:label xml:lang="en">is type of</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareType"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasType"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usesAlgorithm">
  <rdfs:comment xml:lang="en">Links a software tool to the algorithm it employs.</rdfs:comment>
  <rdfs:label xml:lang="en">uses algorithm</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isUsedBySoftware: To resolve the pitfall regarding missing inverse relationships.</vaem:rationale>
  <dc:source>(competency_question) CQ04
    (pitfall) Relationship does not have an inverse relationship</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isUsedBySoftware"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isUsedBySoftware">
  <rdfs:comment xml:lang="en">Inverse of usesAlgorithm: Links an algorithm to the software tool that uses it.</rdfs:comment>
  <rdfs:label xml:lang="en">is used by software</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#usesAlgorithm"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#supportsInputFormat">
  <rdfs:comment xml:lang="en">The data formats the software can read as input.</rdfs:comment>
  <rdfs:label xml:lang="en">supports input format</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isInputFormatOf: To resolve the pitfall regarding missing inverse relationships.</vaem:rationale>
  <dc:source>(competency_question) CQ17, CQ19, CQ21
    (pitfall) Relationship does not have an inverse relationship</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isInputFormatOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isInputFormatOf">
  <rdfs:comment xml:lang="en">Inverse of supportsInputFormat: Links a data format to the software that supports it as input.</rdfs:comment>
  <rdfs:label xml:lang="en">is input format of</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#supportsInputFormat"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#supportsOutputFormat">
  <rdfs:comment xml:lang="en">The data formats the software can export.</rdfs:comment>
  <rdfs:label xml:lang="en">supports output format</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isOutputFormatOf: To resolve the pitfall regarding missing inverse relationships.</vaem:rationale>
  <dc:source>(competency_question) CQ17, CQ22, CQ29
    (pitfall) Relationship does not have an inverse relationship</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isOutputFormatOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isOutputFormatOf">
  <rdfs:comment xml:lang="en">Inverse of supportsOutputFormat: Links a data format to the software that supports it as output.</rdfs:comment>
  <rdfs:label xml:lang="en">is output format of</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#supportsOutputFormat"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#developedBy">
  <rdfs:comment xml:lang="en">Links the software to its developer.</rdfs:comment>
  <rdfs:label xml:lang="en">developed by</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property developed: To resolve the pitfall regarding missing inverse relationships.</vaem:rationale>
  <dc:source>(competency_question) CQ36
    (pitfall) Relationship does not have an inverse relationship</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Developer"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#developed"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#developed">
  <rdfs:comment xml:lang="en">Inverse of developedBy: Links a developer to the software they developed.</rdfs:comment>
  <rdfs:label xml:lang="en">developed</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Developer"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#developedBy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasLicense">
  <rdfs:comment xml:lang="en">Links the software to its license.</rdfs:comment>
  <rdfs:label xml:lang="en">has license</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isLicenseOf: To resolve the pitfall regarding missing inverse relationships.</vaem:rationale>
  <dc:source>(competency_question) CQ59
    (pitfall) Relationship does not have an inverse relationship</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#License"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isLicenseOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isLicenseOf">
  <rdfs:comment xml:lang="en">Inverse of hasLicense: Links a license to the software it governs.</rdfs:comment>
  <rdfs:label xml:lang="en">is license of</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#License"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasLicense"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#runsOn">
  <rdfs:comment xml:lang="en">The platform required to run the software.</rdfs:comment>
  <rdfs:label xml:lang="en">runs on</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isPlatformFor: To resolve the pitfall regarding missing inverse relationships.</vaem:rationale>
  <dc:source>(competency_question) CQ85
    (pitfall) Relationship does not have an inverse relationship</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Platform"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isPlatformFor"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isPlatformFor">
  <rdfs:comment xml:lang="en">Inverse of runsOn: Links a platform to the software that can run on it.</rdfs:comment>
  <rdfs:label xml:lang="en">is platform for</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Platform"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#runsOn"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasVersion">
  <rdfs:comment xml:lang="en">Links a software tool to its specific versions.</rdfs:comment>
  <rdfs:label xml:lang="en">has version</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isVersionOf: To resolve the pitfall regarding missing inverse relationships.</vaem:rationale>
  <dc:source>(competency_question) CQ54
    (pitfall) Relationship does not have an inverse relationship</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareVersion"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isVersionOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isVersionOf">
  <rdfs:comment xml:lang="en">Inverse of hasVersion: Links a software version to the software tool it belongs to.</rdfs:comment>
  <rdfs:label xml:lang="en">is version of</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareVersion"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasVersion"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasVersionNumber">
  <rdfs:comment xml:lang="en">The version string (e.g., '1.0.2').</rdfs:comment>
  <rdfs:label xml:lang="en">version number</rdfs:label>
  <dc:source>(competency_question) CQ54</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareVersion"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasHomepage">
  <rdfs:comment xml:lang="en">The URL of the software's homepage.</rdfs:comment>
  <rdfs:label xml:lang="en">homepage</rdfs:label>
  <dc:source>(competency_question) CQ37, CQ40</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#implementedIn">
  <rdfs:comment xml:lang="en">The programming language used to implement the software.</rdfs:comment>
  <rdfs:label xml:lang="en">implemented in</rdfs:label>
  <dc:source>(competency_question) CQ84</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#releaseDate">
  <rdfs:comment xml:lang="en">The date the version was released.</rdfs:comment>
  <rdfs:label xml:lang="en">release date</rdfs:label>
  <dc:source>(competency_question) CQ57</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareVersion"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasModification">
  <rdfs:comment xml:lang="en">Description of modifications made to the algorithm.</rdfs:comment>
  <rdfs:label xml:lang="en">has modification</rdfs:label>
  <dc:source>(competency_question) CQ05</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isOpenSource">
  <rdfs:comment xml:lang="en">Boolean indicating if the software is open source.</rdfs:comment>
  <rdfs:label xml:lang="en">is open source</rdfs:label>
  <dc:source>(competency_question) CQ58, CQ60, CQ65</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#documentationUrl">
  <rdfs:comment xml:lang="en">URL to the software documentation.</rdfs:comment>
  <rdfs:label xml:lang="en">documentation URL</rdfs:label>
  <dc:source>(competency_question) CQ73</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
</owl:DatatypeProperty>

</rdf:RDF>