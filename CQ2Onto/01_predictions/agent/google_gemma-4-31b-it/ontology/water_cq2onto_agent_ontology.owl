<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterInfrastructureAsset">
  <rdfs:comment xml:lang="en">Any physical asset that forms part of the water distribution infrastructure.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Infrastructure Asset</rdfs:label>
  <dc:source>(competency_question) CQ01: Which assets compose a water distribution infrastructure?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Sensor">
  <rdfs:comment xml:lang="en">A device used to detect or measure a physical property.</rdfs:comment>
  <rdfs:label xml:lang="en">Sensor</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjointWith Actuator: To resolve the missing disjoint axioms pitfall.</vaem:rationale>
  <dc:source>(competency_question) CQ04: Which types of sensors are used in water infrastructures?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#WaterInfrastructureAsset"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Actuator"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Actuator">
  <rdfs:comment xml:lang="en">A device responsible for moving or controlling a mechanism or system.</rdfs:comment>
  <rdfs:label xml:lang="en">Actuator</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjointWith Sensor: To resolve the missing disjoint axioms pitfall.</vaem:rationale>
  <dc:source>(competency_question) CQ05: Which types of actuators are used in water infrastructures?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#WaterInfrastructureAsset"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Sensor"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterMeter">
  <rdfs:comment xml:lang="en">A device that measures the volume or flow of water.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Meter</rdfs:label>
  <dc:source>(competency_question) CQ06: A water meter is a device that measures different aspects of a water infrastructure.</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Sensor"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterProperty">
  <rdfs:comment xml:lang="en">Characteristics of water being monitored.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Property</rdfs:label>
  <dc:source>(competency_question) CQ33: What are the physical properties of water?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PhysicalProperty">
  <rdfs:comment xml:lang="en">Physical characteristics of water (e.g., temperature, pressure).</rdfs:comment>
  <rdfs:label xml:lang="en">Physical Property</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjointWith ChemicalProperty: To resolve the missing disjoint axioms pitfall.</vaem:rationale>
  <dc:source>(competency_question) CQ33: What are the physical properties of water?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#WaterProperty"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#ChemicalProperty"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ChemicalProperty">
  <rdfs:comment xml:lang="en">Chemical characteristics of water (e.g., pH, chlorine levels).</rdfs:comment>
  <rdfs:label xml:lang="en">Chemical Property</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjointWith PhysicalProperty: To resolve the missing disjoint axioms pitfall.</vaem:rationale>
  <dc:source>(competency_question) CQ34: What are the chemical properties of water?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#WaterProperty"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PhysicalProperty"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Tariff">
  <rdfs:comment xml:lang="en">The pricing structure and temporal rules applied to water consumption.</rdfs:comment>
  <rdfs:label xml:lang="en">Tariff</rdfs:label>
  <dc:source>(competency_question) CQ38: What is the start date and time of the tariff in use in the water meter?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterIndicator">
  <rdfs:comment xml:lang="en">Specific indicators defined for a geographic region.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Indicator</rdfs:label>
  <dc:source>(competency_question) CQ37: Which water indicators are defined for Burgos?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Location">
  <rdfs:comment xml:lang="en">A geographic location or region.</rdfs:comment>
  <rdfs:label xml:lang="en">Location</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created Location class: To provide a domain for hasIndicator property based on CQ37.</vaem:rationale>
  <dc:source>(pitfall) Object and/or datatype properties without domain or range</dc:source>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasTariff">
  <rdfs:comment xml:lang="en">Links a water meter to its active tariff.</rdfs:comment>
  <rdfs:label xml:lang="en">has Tariff</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isTariffOf: To resolve the missing inverse relationship pitfall.</vaem:rationale>
  <dc:source>(competency_question) CQ38: What is the start date and time of the tariff in use in the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Tariff"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isTariffOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isTariffOf">
  <rdfs:comment xml:lang="en">Inverse of hasTariff.</rdfs:comment>
  <rdfs:label xml:lang="en">is Tariff Of</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property: To resolve the missing inverse relationship pitfall.</vaem:rationale>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tariff"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasTariff"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasIndicator">
  <rdfs:comment xml:lang="en">Links a location or entity to its defined water indicators.</rdfs:comment>
  <rdfs:label xml:lang="en">has Indicator</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added domain Location and inverse property isIndicatorOf: To resolve missing domain and missing inverse relationship pitfalls.</vaem:rationale>
  <dc:source>(competency_question) CQ37: Which water indicators are defined for Burgos?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Location"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WaterIndicator"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isIndicatorOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isIndicatorOf">
  <rdfs:comment xml:lang="en">Inverse of hasIndicator.</rdfs:comment>
  <rdfs:label xml:lang="en">is Indicator Of</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property: To resolve the missing inverse relationship pitfall.</vaem:rationale>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterIndicator"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Location"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasIndicator"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#monitorsProperty">
  <rdfs:comment xml:lang="en">Links a sensor to the water property it is designed to measure.</rdfs:comment>
  <rdfs:label xml:lang="en">monitors Property</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created property to link Sensor and WaterProperty: To resolve the isolated elements pitfall for WaterInfrastructureAsset and WaterProperty.</vaem:rationale>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Sensor"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WaterProperty"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasFabricationNumber">
  <rdfs:comment xml:lang="en">The unique fabrication number of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">Fabrication Number</rdfs:label>
  <dc:source>(competency_question) CQ08: What is the fabrication number of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasManufacturer">
  <rdfs:comment xml:lang="en">The company that manufactured the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">Manufacturer</rdfs:label>
  <dc:source>(competency_question) CQ09: What are the manufacturer and the model of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasModel">
  <rdfs:comment xml:lang="en">The model name/number of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">Model</rdfs:label>
  <dc:source>(competency_question) CQ09: What are the manufacturer and the model of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasVersion">
  <rdfs:comment xml:lang="en">The general version of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">Version</rdfs:label>
  <dc:source>(competency_question) CQ10: What is the version of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasHardwareVersion">
  <rdfs:comment xml:lang="en">The specific hardware version number.</rdfs:comment>
  <rdfs:label xml:lang="en">Hardware Version</rdfs:label>
  <dc:source>(competency_question) CQ11: What is the hardware version number of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasFirmwareVersion">
  <rdfs:comment xml:lang="en">The firmware version currently running on the device.</rdfs:comment>
  <rdfs:label xml:lang="en">Firmware Version</rdfs:label>
  <dc:source>(competency_question) CQ12: What firmware version is the water meter using?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasPower">
  <rdfs:comment xml:lang="en">The power consumption or power supply of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">Power</rdfs:label>
  <dc:source>(competency_question) CQ18: What is the power of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasRadioFrequencyLevel">
  <rdfs:comment xml:lang="en">The radio frequency level for communication.</rdfs:comment>
  <rdfs:label xml:lang="en">Radio Frequency Level</rdfs:label>
  <dc:source>(competency_question) CQ19: What is the radio frequency level of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasGeolocation">
  <rdfs:comment xml:lang="en">The geographic coordinates of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">Geolocation</rdfs:label>
  <dc:source>(competency_question) CQ20: What is the geolocation of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasTemporalSetting">
  <rdfs:comment xml:lang="en">The temporal settings for measurements.</rdfs:comment>
  <rdfs:label xml:lang="en">Temporal Setting</rdfs:label>
  <dc:source>(competency_question) CQ25: Water meters can provide measurements according to different temporal settings.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#tariffStartDate">
  <rdfs:comment xml:lang="en">The start date and time of the tariff.</rdfs:comment>
  <rdfs:label xml:lang="en">Tariff Start Date</rdfs:label>
  <dc:source>(competency_question) CQ38: What is the start date and time of the tariff in use in the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tariff"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#tariffDuration">
  <rdfs:comment xml:lang="en">The duration of the current tariff.</rdfs:comment>
  <rdfs:label xml:lang="en">Tariff Duration</rdfs:label>
  <dc:source>(competency_question) CQ39: What is the duration of the current tariff of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tariff"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#duration"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#tariffPeriod">
  <rdfs:comment xml:lang="en">The period associated with the tariff.</rdfs:comment>
  <rdfs:label xml:lang="en">Tariff Period</rdfs:label>
  <dc:source>(competency_question) CQ40: What is the tariff period of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tariff"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#billingDate">
  <rdfs:comment xml:lang="en">The date of billing for the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">Billing Date</rdfs:label>
  <vaem:rationale>[Logical Consistency Agent] Changed range from xsd:date to xsd:dateTime: HermiT does not support xsd:date as it is not part of the OWL 2 datatype map.
    [Pitfall Resolution Agent] Changed range from xsd:date to xsd:dateTime: HermiT does not support xsd:date as it is not part of the OWL 2 datatype map.</vaem:rationale>
  <dc:source>(competency_question) CQ42: What is the billing date of the water meter?
    (error_message) org.semanticweb.HermiT.datatypes.UnsupportedDatatypeException: The datatype 'http://www.w3.org/2001/XMLSchema#date' is not part of the OWL 2 datatype map</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#billingDatePeriod">
  <rdfs:comment xml:lang="en">The period of the billing date.</rdfs:comment>
  <rdfs:label xml:lang="en">Billing Date Period</rdfs:label>
  <dc:source>(competency_question) CQ43: What is the billing date period of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

</rdf:RDF>