<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Organism">
  <rdfs:comment xml:lang="en">A living system such as an animal, plant, fungus, or microorganism.</rdfs:comment>
  <rdfs:label xml:lang="en">Organism</rdfs:label>
  <dc:source>(competency_question) CQ1, CQ6</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Animal">
  <rdfs:comment xml:lang="en">A multicellular eukaryotic organism of the kingdom Animalia.</rdfs:comment>
  <rdfs:label xml:lang="en">Animal</rdfs:label>
  <dc:source>(competency_question) CQ1, CQ2, CQ7</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Organism"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Plant">
  <rdfs:comment xml:lang="en">A multicellular organism of the kingdom Plantae.</rdfs:comment>
  <rdfs:label xml:lang="en">Plant</rdfs:label>
  <dc:source>(competency_question) CQ4, CQ6</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Organism"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlantPart">
  <rdfs:comment xml:lang="en">A specific part of a plant, such as a leaf, root, or fruit.</rdfs:comment>
  <rdfs:label xml:lang="en">Plant Part</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added subClassOf relation to Consumable: To resolve the isolated element pitfall; plant parts are by definition consumable.</vaem:rationale>
  <dc:source>(competency_question) CQ3, CQ4, CQ14
    (pitfall) Isolated ontology elements</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Consumable"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Herbivore">
  <rdfs:comment xml:lang="en">An animal that feeds exclusively or mainly on plants.</rdfs:comment>
  <rdfs:label xml:lang="en">Herbivore</rdfs:label>
  <dc:source>(competency_question) CQ2, CQ3</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Carnivore">
  <rdfs:comment xml:lang="en">An animal that feeds on flesh.</rdfs:comment>
  <rdfs:label xml:lang="en">Carnivore</rdfs:label>
  <dc:source>(competency_question) CQ14</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Omnivore">
  <rdfs:comment xml:lang="en">An animal that eats both plants and animals.</rdfs:comment>
  <rdfs:label xml:lang="en">Omnivore</rdfs:label>
  <dc:source>(competency_question) CQ3</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Consumable">
  <rdfs:comment xml:lang="en">Anything that can be eaten, either another organism or a part of a plant.</rdfs:comment>
  <rdfs:label xml:lang="en">Consumable</rdfs:label>
  <dc:source>(competency_question) CQ1, CQ3</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Lion">
  <rdfs:comment xml:lang="en">A specific species of carnivore.</rdfs:comment>
  <rdfs:label xml:lang="en">Lion</rdfs:label>
  <dc:source>(competency_question) CQ4</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Carnivore"/>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#eats">
  <rdfs:comment xml:lang="en">Relates an organism to the organism or plant part it consumes.</rdfs:comment>
  <rdfs:label xml:lang="en">eats</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added owl:inverseOf relation to isEatenBy: To resolve the pitfall regarding missing inverse relationships.</vaem:rationale>
  <dc:source>(competency_question) CQ1, CQ3, CQ4, CQ6, CQ7, CQ14
    (pitfall) Missing inverse relationship</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Organism"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Consumable"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isEatenBy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isEatenBy">
  <rdfs:comment xml:lang="en">Relates a consumable entity to the organism that consumes it.</rdfs:comment>
  <rdfs:label xml:lang="en">is eaten by</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created new property isEatenBy: To provide the inverse relationship for the 'eats' property.</vaem:rationale>
  <dc:source>(pitfall) Missing inverse relationship for 'eats'</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Consumable"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Organism"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#eats"/>
</owl:ObjectProperty>

</rdf:RDF>