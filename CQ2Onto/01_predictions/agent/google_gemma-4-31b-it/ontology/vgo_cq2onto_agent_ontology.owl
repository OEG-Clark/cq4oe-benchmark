<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Player">
  <rdfs:comment xml:lang="en">A person who plays games within the system.</rdfs:comment>
  <rdfs:label xml:lang="en">Player</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjointness axioms with other primary classes: To resolve OOPS pitfall regarding lack of disjoint axioms.</vaem:rationale>
  <dc:source>(competency_question) CQ01, CQ02, CQ22, CQ24, CQ25, CQ26, CQ56, CQ63
    (pitfall) The ontology lacks disjoint axioms between classes</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Game"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Achievement"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Item"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Genre"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Game">
  <rdfs:comment xml:lang="en">A video game available in the system.</rdfs:comment>
  <rdfs:label xml:lang="en">Game</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjointness axioms with other primary classes: To resolve OOPS pitfall regarding lack of disjoint axioms.</vaem:rationale>
  <dc:source>(competency_question) CQ08, CQ09, CQ12, CQ13, CQ15, CQ17, New CQ1
    (pitfall) The ontology lacks disjoint axioms between classes</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Achievement"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Item"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Genre"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Achievement">
  <rdfs:comment xml:lang="en">A goal or milestone a player can reach in a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Achievement</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjointness axioms with other primary classes: To resolve OOPS pitfall regarding lack of disjoint axioms.</vaem:rationale>
  <dc:source>(competency_question) CQ05, CQ07, CQ08, CQ10, CQ11, CQ24, CQ27, CQ35
    (pitfall) The ontology lacks disjoint axioms between classes</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Item"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Genre"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Item">
  <rdfs:comment xml:lang="en">An object or piece of equipment that can exist in a game or be owned by a player.</rdfs:comment>
  <rdfs:label xml:lang="en">Item</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjointness axioms with other primary classes: To resolve OOPS pitfall regarding lack of disjoint axioms.</vaem:rationale>
  <dc:source>(competency_question) CQ13, CQ19, CQ26, CQ52, CQ55
    (pitfall) The ontology lacks disjoint axioms between classes</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Genre"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Genre">
  <rdfs:comment xml:lang="en">The category or style of a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Genre</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjointness axioms with other primary classes: To resolve OOPS pitfall regarding lack of disjoint axioms.</vaem:rationale>
  <dc:source>(competency_question) CQ12, CQ17
    (pitfall) The ontology lacks disjoint axioms between classes</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayingArea">
  <rdfs:comment xml:lang="en">A specific region or map within a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Playing Area</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjointness axioms with other primary classes: To resolve OOPS pitfall regarding lack of disjoint axioms.</vaem:rationale>
  <dc:source>(competency_question) New CQ1
    (pitfall) The ontology lacks disjoint axioms between classes</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#InAppPurchase">
  <rdfs:comment xml:lang="en">A financial transaction made by a player within a game.</rdfs:comment>
  <rdfs:label xml:lang="en">In-App Purchase</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjointness axioms with other primary classes: To resolve OOPS pitfall regarding lack of disjoint axioms.</vaem:rationale>
  <dc:source>(competency_question) CQ56, CQ57, CQ62, CQ64
    (pitfall) The ontology lacks disjoint axioms between classes</dc:source>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasFriend">
  <rdfs:comment xml:lang="en">Relates a player to their friends.</rdfs:comment>
  <rdfs:label xml:lang="en">has friend</rdfs:label>
  <dc:source>(competency_question) CQ02, CQ03</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <owl:SymmetricProperty rdf:resource="http://www.semanticweb.org/myontology#hasFriend"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#playsGame">
  <rdfs:comment xml:lang="en">Relates a player to the games they have played.</rdfs:comment>
  <rdfs:label xml:lang="en">plays game</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isPlayedBy: To resolve OOPS pitfall regarding missing inverse relationships.</vaem:rationale>
  <dc:source>(competency_question) CQ03, CQ25
    (pitfall) Relationship does not have an inverse relationship defined</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isPlayedBy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isPlayedBy">
  <rdfs:comment xml:lang="en">Relates a game to the players who have played it.</rdfs:comment>
  <rdfs:label xml:lang="en">is played by</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#playsGame"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAchievement">
  <rdfs:comment xml:lang="en">Relates a player to the achievements they have earned.</rdfs:comment>
  <rdfs:label xml:lang="en">has achievement</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isEarnedBy: To resolve OOPS pitfall regarding missing inverse relationships.</vaem:rationale>
  <dc:source>(competency_question) CQ05, CQ07, CQ24, CQ27, CQ35
    (pitfall) Relationship does not have an inverse relationship defined</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isEarnedBy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isEarnedBy">
  <rdfs:comment xml:lang="en">Relates an achievement to the player who earned it.</rdfs:comment>
  <rdfs:label xml:lang="en">is earned by</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasAchievement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#gameHasAchievement">
  <rdfs:comment xml:lang="en">Relates a game to the achievements it offers.</rdfs:comment>
  <rdfs:label xml:lang="en">game has achievement</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isOfferedBy: To resolve OOPS pitfall regarding missing inverse relationships.</vaem:rationale>
  <dc:source>(competency_question) CQ08, CQ10, CQ11
    (pitfall) Relationship does not have an inverse relationship defined</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isOfferedBy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isOfferedBy">
  <rdfs:comment xml:lang="en">Relates an achievement to the game that offers it.</rdfs:comment>
  <rdfs:label xml:lang="en">is offered by</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#gameHasAchievement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGenre">
  <rdfs:comment xml:lang="en">Relates a game to its genre.</rdfs:comment>
  <rdfs:label xml:lang="en">has genre</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isGenreOf: To resolve OOPS pitfall regarding missing inverse relationships.</vaem:rationale>
  <dc:source>(competency_question) CQ12, CQ17
    (pitfall) Relationship does not have an inverse relationship defined</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Genre"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isGenreOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isGenreOf">
  <rdfs:comment xml:lang="en">Relates a genre to the games that belong to it.</rdfs:comment>
  <rdfs:label xml:lang="en">is genre of</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Genre"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasGenre"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#gameHasItem">
  <rdfs:comment xml:lang="en">Relates a game to the items that exist within it.</rdfs:comment>
  <rdfs:label xml:lang="en">game has item</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isContainedInGame: To resolve OOPS pitfall regarding missing inverse relationships.</vaem:rationale>
  <dc:source>(competency_question) CQ13, CQ55
    (pitfall) Relationship does not have an inverse relationship defined</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isContainedInGame"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isContainedInGame">
  <rdfs:comment xml:lang="en">Relates an item to the game it exists within.</rdfs:comment>
  <rdfs:label xml:lang="en">is contained in game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Item"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#gameHasItem"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#playerHasItem">
  <rdfs:comment xml:lang="en">Relates a player to the items they possess.</rdfs:comment>
  <rdfs:label xml:lang="en">player has item</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isOwnedBy: To resolve OOPS pitfall regarding missing inverse relationships.</vaem:rationale>
  <dc:source>(competency_question) CQ26, CQ52
    (pitfall) Relationship does not have an inverse relationship defined</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isOwnedBy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isOwnedBy">
  <rdfs:comment xml:lang="en">Relates an item to the player who possesses it.</rdfs:comment>
  <rdfs:label xml:lang="en">is owned by</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Item"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#playerHasItem"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#gameHasArea">
  <rdfs:comment xml:lang="en">Relates a game to its playing areas.</rdfs:comment>
  <rdfs:label xml:lang="en">game has area</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isAreaOf: To resolve OOPS pitfall regarding missing inverse relationships.</vaem:rationale>
  <dc:source>(competency_question) New CQ1
    (pitfall) Relationship does not have an inverse relationship defined</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isAreaOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isAreaOf">
  <rdfs:comment xml:lang="en">Relates a playing area to the game it belongs to.</rdfs:comment>
  <rdfs:label xml:lang="en">is area of</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#gameHasArea"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#madePurchase">
  <rdfs:comment xml:lang="en">Relates a player to the in-app purchases they have made.</rdfs:comment>
  <rdfs:label xml:lang="en">made purchase</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isPurchaseOf: To resolve OOPS pitfall regarding missing inverse relationships.</vaem:rationale>
  <dc:source>(competency_question) CQ56, CQ57, CQ66
    (pitfall) Relationship does not have an inverse relationship defined</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isPurchaseOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isPurchaseOf">
  <rdfs:comment xml:lang="en">Relates an in-app purchase to the player who made it.</rdfs:comment>
  <rdfs:label xml:lang="en">is purchase of</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#madePurchase"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#username">
  <rdfs:comment xml:lang="en">The unique username of the player.</rdfs:comment>
  <rdfs:label xml:lang="en">username</rdfs:label>
  <dc:source>(competency_question) CQ01</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#killCount">
  <rdfs:comment xml:lang="en">The number of kills a player has achieved in a game.</rdfs:comment>
  <rdfs:label xml:lang="en">kill count</rdfs:label>
  <dc:source>(competency_question) CQ22</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#totalHoursPlayed">
  <rdfs:comment xml:lang="en">Total time spent playing a specific game.</rdfs:comment>
  <rdfs:label xml:lang="en">total hours played</rdfs:label>
  <dc:source>(competency_question) CQ09</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#releaseDate">
  <rdfs:comment xml:lang="en">The date the game was released.</rdfs:comment>
  <rdfs:label xml:lang="en">release date</rdfs:label>
  <vaem:rationale>[Logical Consistency Agent] Changed range from xsd:date to xsd:dateTime: HermiT does not support xsd:date; xsd:dateTime is the compatible OWL 2 datatype map equivalent.</vaem:rationale>
  <dc:source>(error_message) org.semanticweb.HermiT.datatypes.UnsupportedDatatypeException: The datatype 'http://www.w3.org/2001/XMLSchema#date' is not part of the OWL 2 datatype map
    (competency_question) CQ15</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#achievementType">
  <rdfs:comment xml:lang="en">The category or type of an achievement.</rdfs:comment>
  <rdfs:label xml:lang="en">achievement type</rdfs:label>
  <dc:source>(competency_question) CQ10, CQ11, CQ27</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#itemAbility">
  <rdfs:comment xml:lang="en">The special ability provided by an item.</rdfs:comment>
  <rdfs:label xml:lang="en">item ability</rdfs:label>
  <dc:source>(competency_question) CQ19</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Item"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#lastPlayedDate">
  <rdfs:comment xml:lang="en">The date the player last played a game.</rdfs:comment>
  <rdfs:label xml:lang="en">last played date</rdfs:label>
  <dc:source>(competency_question) CQ29</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#purchaseTimestamp">
  <rdfs:comment xml:lang="en">The exact time an in-app purchase was made.</rdfs:comment>
  <rdfs:label xml:lang="en">purchase timestamp</rdfs:label>
  <dc:source>(competency_question) CQ62</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#playerLocation">
  <rdfs:comment xml:lang="en">The geographic location of the player.</rdfs:comment>
  <rdfs:label xml:lang="en">player location</rdfs:label>
  <dc:source>(competency_question) CQ63, CQ65, CQ66</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

</rdf:RDF>