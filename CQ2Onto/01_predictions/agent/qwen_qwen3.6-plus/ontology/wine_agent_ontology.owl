<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Wine">
  <rdfs:comment xml:lang="en">A beverage produced by fermenting grapes, characterized by various attributes such as color, body, bouquet, and vintage.</rdfs:comment>
  <rdfs:label xml:lang="en">Wine</rdfs:label>
  <dc:source>(competency_question) CQ1: Which wine characteristics should I consider when choosing a wine?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Grape">
  <rdfs:comment xml:lang="en">A fruit variety used as the primary ingredient in wine production.</rdfs:comment>
  <rdfs:label xml:lang="en">Grape</rdfs:label>
  <dc:source>(competency_question) CQnew1: What grapes are used to make Bordeaux wine?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Vintage">
  <rdfs:comment xml:lang="en">The specific harvest year of grapes for a wine, along with its associated sensory characteristics and quality rating.</rdfs:comment>
  <rdfs:label xml:lang="en">Vintage</rdfs:label>
  <dc:source>(competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?
    (competency_question) CQ7: What were good vintages for Napa Zinfandel?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WineColor">
  <rdfs:comment xml:lang="en">The visual color classification of a wine, typically categorized as red, white, or rosé.</rdfs:comment>
  <rdfs:label xml:lang="en">Wine Color</rdfs:label>
  <dc:source>(competency_question) CQ2: Is Bordeaux a red or white wine?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#RedWine">
  <rdfs:comment xml:lang="en">A wine classification characterized by a red hue, typically produced from dark-skinned grape varieties.</rdfs:comment>
  <rdfs:label xml:lang="en">Red Wine</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added owl:disjointWith axiom pointing to WhiteWine: Resolve OOPS pitfall: Missing disjoint axioms between mutually exclusive classes</vaem:rationale>
  <dc:source>(competency_question) CQ2: Is Bordeaux a red or white wine?
    (pitfall) Missing disjoint axioms between classes</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#WhiteWine"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WhiteWine">
  <rdfs:comment xml:lang="en">A wine classification characterized by a pale yellow or straw color, typically produced from green-skinned grapes or red grapes with minimal skin contact.</rdfs:comment>
  <rdfs:label xml:lang="en">White Wine</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added owl:disjointWith axiom pointing to RedWine: Resolve OOPS pitfall: Missing disjoint axioms between mutually exclusive classes</vaem:rationale>
  <dc:source>(competency_question) CQ2: Is Bordeaux a red or white wine?
    (pitfall) Missing disjoint axioms between classes</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#RedWine"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Bordeaux">
  <rdfs:comment xml:lang="en">A wine produced in the Bordeaux region of France, predominantly known for its red blends.</rdfs:comment>
  <rdfs:label xml:lang="en">Bordeaux</rdfs:label>
  <dc:source>(competency_question) CQ2: Is Bordeaux a red or white wine?
    (competency_question) CQnew1: What grapes are used to make Bordeaux wine?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#NapaZinfandel">
  <rdfs:comment xml:lang="en">A Zinfandel wine produced in the Napa Valley region of California.</rdfs:comment>
  <rdfs:label xml:lang="en">Napa Zinfandel</rdfs:label>
  <dc:source>(competency_question) CQ7: What were good vintages for Napa Zinfandel?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGrape">
  <rdfs:comment xml:lang="en">Relates a wine to the grape variety or varieties used in its production.</rdfs:comment>
  <rdfs:label xml:lang="en">has grape</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added owl:inverseOf axiom pointing to isGrapeOf: Resolve OOPS pitfall: Missing inverse relationships for object properties</vaem:rationale>
  <dc:source>(competency_question) CQnew1: What grapes are used to make Bordeaux wine?
    (pitfall) Missing inverse relationships</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Grape"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isGrapeOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasVintage">
  <rdfs:comment xml:lang="en">Links a wine to its specific vintage year and associated characteristics.</rdfs:comment>
  <rdfs:label xml:lang="en">has vintage</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added owl:inverseOf axiom pointing to isVintageOf: Resolve OOPS pitfall: Missing inverse relationships for object properties</vaem:rationale>
  <dc:source>(competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?
    (competency_question) CQ7: What were good vintages for Napa Zinfandel?
    (pitfall) Missing inverse relationships</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Vintage"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isVintageOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasColor">
  <rdfs:comment xml:lang="en">Indicates the color classification of a wine.</rdfs:comment>
  <rdfs:label xml:lang="en">has color</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added owl:inverseOf axiom pointing to isColorOf: Resolve OOPS pitfall: Missing inverse relationships for object properties</vaem:rationale>
  <dc:source>(competency_question) CQ2: Is Bordeaux a red or white wine?
    (pitfall) Missing inverse relationships</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WineColor"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isColorOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isGrapeOf">
  <rdfs:comment xml:lang="en">Relates a grape variety to the wine(s) produced from it.</rdfs:comment>
  <rdfs:label xml:lang="en">is grape of</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created new inverse property for hasGrape: Resolve OOPS pitfall: Missing inverse relationships for object properties</vaem:rationale>
  <dc:source>(pitfall) Missing inverse relationships</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Grape"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasGrape"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isVintageOf">
  <rdfs:comment xml:lang="en">Relates a vintage to the wine(s) it belongs to.</rdfs:comment>
  <rdfs:label xml:lang="en">is vintage of</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created new inverse property for hasVintage: Resolve OOPS pitfall: Missing inverse relationships for object properties</vaem:rationale>
  <dc:source>(pitfall) Missing inverse relationships</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Vintage"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasVintage"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isColorOf">
  <rdfs:comment xml:lang="en">Relates a wine color classification to the wine(s) that exhibit it.</rdfs:comment>
  <rdfs:label xml:lang="en">is color of</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created new inverse property for hasColor: Resolve OOPS pitfall: Missing inverse relationships for object properties</vaem:rationale>
  <dc:source>(pitfall) Missing inverse relationships</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WineColor"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasColor"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasBody">
  <rdfs:comment xml:lang="en">Describes the weight, texture, and fullness of a wine in the mouth. Modeled on Vintage to reflect year-to-year variation.</rdfs:comment>
  <rdfs:label xml:lang="en">has body</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Corrected range URI from ontology namespace to standard XSD namespace: Resolve OOPS pitfall: Ontology element used as class without explicit declaration</vaem:rationale>
  <dc:source>(competency_question) CQ1: Which wine characteristics should I consider when choosing a wine?
    (competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?
    (pitfall) Ontology element used as class without declaration</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Vintage"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasBouquet">
  <rdfs:comment xml:lang="en">Describes the aroma profile and olfactory characteristics of a wine. Modeled on Vintage to reflect year-to-year variation.</rdfs:comment>
  <rdfs:label xml:lang="en">has bouquet</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Corrected range URI from ontology namespace to standard XSD namespace: Resolve OOPS pitfall: Ontology element used as class without explicit declaration</vaem:rationale>
  <dc:source>(competency_question) CQ1: Which wine characteristics should I consider when choosing a wine?
    (competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?
    (pitfall) Ontology element used as class without declaration</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Vintage"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasYear">
  <rdfs:comment xml:lang="en">The calendar year in which the grapes for a specific vintage were harvested.</rdfs:comment>
  <rdfs:label xml:lang="en">has year</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Corrected range URI from ontology namespace to standard XSD namespace: Resolve OOPS pitfall: Ontology element used as class without explicit declaration</vaem:rationale>
  <dc:source>(competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?
    (pitfall) Ontology element used as class without declaration</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Vintage"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isGoodVintage">
  <rdfs:comment xml:lang="en">A boolean indicator specifying whether a particular vintage year is considered high quality for a given wine.</rdfs:comment>
  <rdfs:label xml:lang="en">is good vintage</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Corrected range URI from ontology namespace to standard XSD namespace: Resolve OOPS pitfall: Ontology element used as class without explicit declaration</vaem:rationale>
  <dc:source>(competency_question) CQ7: What were good vintages for Napa Zinfandel?
    (pitfall) Ontology element used as class without declaration</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Vintage"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
</owl:DatatypeProperty>

</rdf:RDF>