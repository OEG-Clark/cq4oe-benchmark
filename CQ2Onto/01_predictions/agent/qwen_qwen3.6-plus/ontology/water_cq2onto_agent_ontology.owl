</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isActuatorOf">
  <rdfs:comment xml:lang="en">Relates an actuator to the water infrastructure or asset it is deployed in.</rdfs:comment>
  <rdfs:label xml:lang="en">is actuator of</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created new inverse property for hasActuator: Resolved OOPS pitfall: missing inverse relationship.</vaem:rationale>
  <dc:source>(pitfall) Relationship does not have an inverse relationship defined.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Actuator"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasActuator"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#providesMeasurement">
  <rdfs:comment xml:lang="en">Relates a water meter to the measurements it records.</rdfs:comment>
  <rdfs:label xml:lang="en">provides measurement</rdfs:label>
