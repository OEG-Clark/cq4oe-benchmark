</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasFirmwareVersion">
  <rdfs:comment xml:lang="en">The version of the embedded software or firmware running on the water meter.</rdfs:comment>
