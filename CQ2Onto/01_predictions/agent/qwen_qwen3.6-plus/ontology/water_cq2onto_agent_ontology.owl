<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isPropertyOf">
  <rdfs:comment xml:lang="en">Relates a water property to the measurement that quantifies it.</rdfs:comment>
  <rdfs:label xml:lang="en">is property of</rdfs:label>
