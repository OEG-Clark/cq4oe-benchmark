<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure">
  <rdfs:comment xml:lang="en">Represents the complete system responsible for the collection, treatment, storage, and distribution of water to consumers.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Distribution Infrastructure</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] No changes required: Class structure is valid</vaem:rationale>
  <dc:source>(competency_question) CQ01: Which assets compose a water distribution infrastructure?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Asset">
  <rdfs:comment xml:lang="en">A physical component or resource that forms part of a water distribution infrastructure.</rdfs:comment>
  <rdfs:label xml:lang="en">Asset</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] No changes required: Class structure is valid</vaem:rationale>
  <dc:source>(competency_question) CQ01: Which assets compose a water distribution infrastructure?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Device">
  <rdfs:comment xml:lang="en">An electronic or mechanical equipment installed within water infrastructure to monitor, control, or measure system parameters.</rdfs:comment>
  <rdfs:label xml:lang="en">Device</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added rdfs:subClassOf linking to Asset: Resolved OOPS pitfall: isolated class. Devices are physical assets in the infrastructure.</vaem:rationale>
  <dc:source>(competency_question) CQ06: A water meter is a device that measures different aspects of a water infrastructure.
    (pitfall) Ontology elements are created isolated, with no relation to the rest of the ontology.</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Asset"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterMeter">
  <rdfs:comment xml:lang="en">A specialized device that measures different aspects of a water infrastructure, primarily water consumption and flow characteristics.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Meter</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] No changes required: Class structure is valid</vaem:rationale>
  <dc:source>(competency_question) CQ06: A water meter is a device that measures different aspects of a water infrastructure.</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Device"/><rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Asset"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Sensor">
  <rdfs:comment xml:lang="en">A device that detects and responds to physical or chemical inputs in water systems, converting them into measurable signals.</rdfs:comment>
  <rdfs:label xml:lang="en">Sensor</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] No changes required: Class structure is valid</vaem:rationale>
  <dc:source>(competency_question) CQ04: Which types of sensors are used in water infrastructures?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Device"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Actuator"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Actuator">
  <rdfs:comment xml:lang="en">A device that controls or moves a mechanism in water infrastructure, such as valves or pumps, based on control signals.</rdfs:comment>
  <rdfs:label xml:lang="en">Actuator</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] No changes required: Class structure is valid</vaem:rationale>
  <dc:source>(competency_question) CQ05: Which types of actuators are used in water infrastructures?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Device"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Measurement">
  <rdfs:comment xml:lang="en">A recorded value representing a specific property of water or infrastructure at a given time, often collected by sensors or meters.</rdfs:comment>
  <rdfs:label xml:lang="en">Measurement</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] No changes required: Class structure is valid</vaem:rationale>
  <dc:source>(competency_question) CQ25: Water meters can provide measurements according to different temporal settings.</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Tariff">
  <rdfs:comment xml:lang="en">A pricing scheme or rate structure applied to water consumption over a specific period.</rdfs:comment>
  <rdfs:label xml:lang="en">Tariff</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] No changes required: Class structure is valid</vaem:rationale>
  <dc:source>(competency_question) CQ38: What is the start date and time of the tariff in use in the water meter?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterProperty">
  <rdfs:comment xml:lang="en">An abstract class representing measurable characteristics or qualities of water.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Property</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] No changes required: Class structure is valid</vaem:rationale>
  <dc:source>(competency_question) CQ33: What are the physical properties of water?
    (competency_question) CQ34: What are the chemical properties of water?
    (competency_question) CQ33: What are the physical properties of water? (competency_question) CQ34: What are the chemical properties of water?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PhysicalProperty">
  <rdfs:comment xml:lang="en">Physical characteristics of water that can be measured without changing its chemical composition, such as temperature, pressure, or flow rate.</rdfs:comment>
  <rdfs:label xml:lang="en">Physical Property</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] No changes required: Class structure is valid</vaem:rationale>
  <dc:source>(competency_question) CQ33: What are the physical properties of water?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#WaterProperty"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#ChemicalProperty"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ChemicalProperty">
  <rdfs:comment xml:lang="en">Chemical characteristics of water that describe its composition and reactivity, such as pH, chlorine level, or conductivity.</rdfs:comment>
  <rdfs:label xml:lang="en">Chemical Property</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] No changes required: Class structure is valid</vaem:rationale>
  <dc:source>(competency_question) CQ34: What are the chemical properties of water?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#WaterProperty"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterIndicator">
  <rdfs:comment xml:lang="en">A metric, index, or parameter used to evaluate water quality, system performance, or regulatory compliance.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Indicator</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] No changes required: Class structure is valid</vaem:rationale>
  <dc:source>(competency_question) CQ37: Which water indicators are defined for Burgos?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Location">
  <rdfs:comment xml:lang="en">A geographical place, area, or administrative region where water infrastructure or indicators are situated.</rdfs:comment>
  <rdfs:label xml:lang="en">Location</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] No changes required: Class structure is valid</vaem:rationale>
  <dc:source>(competency_question) CQ37: Which water indicators are defined for Burgos?</dc:source>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAsset">
  <rdfs:comment xml:lang="en">Relates a water distribution infrastructure to its constituent physical assets.</rdfs:comment>
  <rdfs:label xml:lang="en">has asset</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added owl:inverseOf linking to isAssetOf: Resolved OOPS pitfall: missing inverse relationship.</vaem:rationale>
  <dc:source>(competency_question) CQ01: Which assets compose a water distribution infrastructure?
    (pitfall) Relationship does not have an inverse relationship defined.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Asset"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isAssetOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isAssetOf">
  <rdfs:comment xml:lang="en">Relates a physical asset to the water distribution infrastructure it belongs to.</rdfs:comment>
  <rdfs:label xml:lang="en">is asset of</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created new inverse property for hasAsset: Resolved OOPS pitfall: missing inverse relationship.</vaem:rationale>
  <dc:source>(pitfall) Relationship does not have an inverse relationship defined.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Asset"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasAsset"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasSensor">
  <rdfs:comment xml:lang="en">Relates a water infrastructure or asset to the sensors deployed within it.</rdfs:comment>
  <rdfs:label xml:lang="en">has sensor</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added owl:inverseOf linking to isSensorOf: Resolved OOPS pitfall: missing inverse relationship.</vaem:rationale>
  <dc:source>(competency_question) CQ04: Which types of sensors are used in water infrastructures?
    (pitfall) Relationship does not have an inverse relationship defined.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Sensor"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isSensorOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isSensorOf">
  <rdfs:comment xml:lang="en">Relates a sensor to the water infrastructure or asset it is deployed in.</rdfs:comment>
  <rdfs:label xml:lang="en">is sensor of</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created new inverse property for hasSensor: Resolved OOPS pitfall: missing inverse relationship.</vaem:rationale>
  <dc:source>(pitfall) Relationship does not have an inverse relationship defined.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Sensor"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasSensor"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasActuator">
  <rdfs:comment xml:lang="en">Relates a water infrastructure or asset to the actuators deployed within it.</rdfs:comment>
  <rdfs:label xml:lang="en">has actuator</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added owl:inverseOf linking to isActuatorOf: Resolved OOPS pitfall: missing inverse relationship.</vaem:rationale>
