</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isProvidedBy">
  <rdfs:comment xml:lang="en">Relates a measurement to the water meter that recorded it.</rdfs:comment>
