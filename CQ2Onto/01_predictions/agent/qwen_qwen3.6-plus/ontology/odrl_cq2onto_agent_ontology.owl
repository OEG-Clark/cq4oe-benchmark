  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasFallbackRule"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasConsequenceDuty">
  <rdfs:comment xml:lang="en">Specifies a duty that is triggered as a direct consequence of fulfilling or failing another duty.</rdfs:comment>
  <rdfs:label xml:lang="en">has consequence duty</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added owl:inverseOf axiom pointing to isConsequenceDutyOf: OOPS pitfall: Relationship does not have an inverse relationship defined within the ontology.</vaem:rationale>
  <dc:source>(competency_question) New CQ5: What duty is specified as a consequence of another duty?
