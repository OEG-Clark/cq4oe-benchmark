<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Policy">
  <rdfs:comment xml:lang="en">A set of rules governing the usage, distribution, or management of an asset.</rdfs:comment>
  <rdfs:label xml:lang="en">Policy</rdfs:label>
  <dc:source>(competency_question) New CQ1: Which policy is directly linked to a given asset?
    (competency_question) New CQ2: What conflict resolution strategy is specified by a policy?
    (competency_question) CQ33: Can the new data model express inheritance?
    (competency_question) New CQ1: Which policy is directly linked to a given asset? New CQ2: What conflict resolution strategy is specified by a policy? CQ33: Can the new data model express inheritance?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Rule">
  <rdfs:comment xml:lang="en">A generic element that defines permissions, duties, or prohibitions within a policy.</rdfs:comment>
  <rdfs:label xml:lang="en">Rule</rdfs:label>
  <dc:source>(competency_question) New CQ4: Which rule is activated upon the failure of another rule?
    (competency_question) CQ31: Do we need 'Sequencing' as part of the REL?
    (competency_question) New CQ4: Which rule is activated upon the failure of another rule? CQ31: Do we need 'Sequencing' as part of the REL?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Permission">
  <rdfs:comment xml:lang="en">A rule that grants the ability to perform a specific action on an asset.</rdfs:comment>
  <rdfs:label xml:lang="en">Permission</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added owl:disjointWith axioms for Duty and Prohibition: OOPS pitfall: The ontology lacks disjoint axioms between classes that should be defined as disjoint. Permission, Duty, and Prohibition are mutually exclusive rule types.</vaem:rationale>
  <dc:source>(competency_question) CQ03: Shall the permissions 'Aggregation' and 'Disaggregation' be of the type Transfer Rights?
    (competency_question) CQ24: How to express exclusive permissions?
    (competency_question) CQ03: Shall the permissions 'Aggregation' and 'Disaggregation' be of the type Transfer Rights? CQ24: How to express exclusive permissions?
    (pitfall) The ontology lacks disjoint axioms between classes or between properties that should be defined as disjoint.</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Duty"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Prohibition"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Duty">
  <rdfs:comment xml:lang="en">A rule that specifies an obligation or requirement to perform an action.</rdfs:comment>
  <rdfs:label xml:lang="en">Duty</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added owl:disjointWith axioms for Permission and Prohibition: OOPS pitfall: The ontology lacks disjoint axioms between classes that should be defined as disjoint. Duty, Permission, and Prohibition are mutually exclusive rule types.</vaem:rationale>
  <dc:source>(competency_question) New CQ3: What duty is specified as a remedy for the violation of a prohibition?
    (competency_question) New CQ5: What duty is specified as a consequence of another duty?
    (competency_question) New CQ3: What duty is specified as a remedy for the violation of a prohibition? New CQ5: What duty is specified as a consequence of another duty?
    (pitfall) The ontology lacks disjoint axioms between classes or between properties that should be defined as disjoint.</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Permission"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Prohibition"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Prohibition">
  <rdfs:comment xml:lang="en">A rule that explicitly forbids performing an action on an asset.</rdfs:comment>
  <rdfs:label xml:lang="en">Prohibition</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added owl:disjointWith axioms for Permission and Duty: OOPS pitfall: The ontology lacks disjoint axioms between classes that should be defined as disjoint. Prohibition, Permission, and Duty are mutually exclusive rule types.</vaem:rationale>
  <dc:source>(competency_question) New CQ3: What duty is specified as a remedy for the violation of a prohibition?
    (competency_question) New CQ6: What operator is used in the constraints of a prohibition?
    (competency_question) New CQ3: What duty is specified as a remedy for the violation of a prohibition? New CQ6: What operator is used in the constraints of a prohibition?
    (pitfall) The ontology lacks disjoint axioms between classes or between properties that should be defined as disjoint.</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Permission"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Duty"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#TransferRight">
  <rdfs:comment xml:lang="en">A specialized permission that allows the transfer, delegation, or redistribution of rights.</rdfs:comment>
  <rdfs:label xml:lang="en">Transfer Right</rdfs:label>
  <dc:source>(competency_question) CQ03: Shall the permissions 'Aggregation' and 'Disaggregation' be of the type Transfer Rights?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Aggregation">
  <rdfs:comment xml:lang="en">Permission to combine or aggregate multiple assets or rights.</rdfs:comment>
  <rdfs:label xml:lang="en">Aggregation</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added owl:disjointWith axiom for Disaggregation: OOPS pitfall: The ontology lacks disjoint axioms between classes that should be defined as disjoint. Aggregation and Disaggregation are mutually exclusive transfer rights.</vaem:rationale>
  <dc:source>(competency_question) CQ03: Shall the permissions 'Aggregation' and 'Disaggregation' be of the type Transfer Rights?
    (pitfall) The ontology lacks disjoint axioms between classes or between properties that should be defined as disjoint.</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Disaggregation"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Disaggregation">
  <rdfs:comment xml:lang="en">Permission to split, separate, or disaggregate assets or rights.</rdfs:comment>
  <rdfs:label xml:lang="en">Disaggregation</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added owl:disjointWith axiom for Aggregation: OOPS pitfall: The ontology lacks disjoint axioms between classes that should be defined as disjoint. Disaggregation and Aggregation are mutually exclusive transfer rights.</vaem:rationale>
  <dc:source>(competency_question) CQ03: Shall the permissions 'Aggregation' and 'Disaggregation' be of the type Transfer Rights?
    (pitfall) The ontology lacks disjoint axioms between classes or between properties that should be defined as disjoint.</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Aggregation"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ExclusivePermission">
  <rdfs:comment xml:lang="en">A permission granted exclusively to a specific party, preventing others from exercising it.</rdfs:comment>
  <rdfs:label xml:lang="en">Exclusive Permission</rdfs:label>
  <dc:source>(competency_question) CQ24: How to express exclusive permissions?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Party">
  <rdfs:comment xml:lang="en">An entity (person, organization, or system) that can be assigned rights, duties, or prohibitions.</rdfs:comment>
  <rdfs:label xml:lang="en">Party</rdfs:label>
  <dc:source>(competency_question) CQ06: Expressing the various roles of contract parties within the Permission/Duty element.
    (competency_question) CQ10: How are rights and duties supported for all contract parties?
    (competency_question) CQ06: Expressing the various roles of contract parties within the Permission/Duty element. CQ10: How are rights and duties supported for all contract parties?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ContractParty">
  <rdfs:comment xml:lang="en">A party explicitly involved in a contractual agreement or policy enforcement.</rdfs:comment>
  <rdfs:label xml:lang="en">Contract Party</rdfs:label>
  <dc:source>(competency_question) CQ06: Expressing the various roles of contract parties within the Permission/Duty element.</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Role">
  <rdfs:comment xml:lang="en">The specific function or capacity of a party within a policy or rule context.</rdfs:comment>
  <rdfs:label xml:lang="en">Role</rdfs:label>
  <dc:source>(competency_question) CQ06: Expressing the various roles of contract parties within the Permission/Duty element.</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Asset">
  <rdfs:comment xml:lang="en">A digital or physical resource that is subject to policy rules.</rdfs:comment>
  <rdfs:label xml:lang="en">Asset</rdfs:label>
  <dc:source>(competency_question) New CQ1: Which policy is directly linked to a given asset?
    (competency_question) CQ30: What do we lose if containers are no longer part of ODRL?
    (competency_question) New CQ1: Which policy is directly linked to a given asset? CQ30: What do we lose if containers are no longer part of ODRL?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Container">
  <rdfs:comment xml:lang="en">A logical grouping mechanism for organizing assets, policies, or rules.</rdfs:comment>
  <rdfs:label xml:lang="en">Container</rdfs:label>
  <dc:source>(competency_question) CQ30: What do we lose if containers are no longer part of ODRL?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Constraint">
  <rdfs:comment xml:lang="en">A restriction or condition applied to a rule, requirement, or condition.</rdfs:comment>
  <rdfs:label xml:lang="en">Constraint</rdfs:label>
  <dc:source>(competency_question) CQ13: Shall ODRLv2 allow for nested constraints?
    (competency_question) CQ21: How to express constraints on requirements?
    (competency_question) CQ26: How to express Condition via Constraints?
    (competency_question) New CQ6: What operator is used in the constraints of a prohibition?
    (competency_question) CQ13: Shall ODRLv2 allow for nested constraints? CQ21: How to express constraints on requirements? CQ26: How to express Condition via Constraints? New CQ6: What operator is used in the constraints of a prohibition?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#LogicalConstraint">
  <rdfs:comment xml:lang="en">A constraint that combines multiple sub-constraints using logical operators such as AND, OR, XOR, or NOT.</rdfs:comment>
  <rdfs:label xml:lang="en">Logical Constraint</rdfs:label>
  <dc:source>(competency_question) CQ08: How to provide a 'NOT' expression?
    (competency_question) CQ14: How do we express 'and', 'or', 'xor' constraints?
    (competency_question) CQ08: How to provide a 'NOT' expression? CQ14: How do we express 'and', 'or', 'xor' constraints?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Requirement">
  <rdfs:comment xml:lang="en">A prerequisite that must be satisfied before a rule can be exercised, often constrained by specific conditions.</rdfs:comment>
  <rdfs:label xml:lang="en">Requirement</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Connected to Rule via new hasRequirement property: OOPS pitfall: Ontology elements are created isolated, with no relation to the rest of the ontology.</vaem:rationale>
  <dc:source>(competency_question) CQ21: How to express constraints on requirements?
    (pitfall) Ontology elements (classes, object properties and datatype properties) are created isolated, with no relation to the rest of the ontology.</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Condition">
  <rdfs:comment xml:lang="en">A state or circumstance that must hold true, typically expressed via constraints.</rdfs:comment>
  <rdfs:label xml:lang="en">Condition</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Connected to Rule via new hasCondition property: OOPS pitfall: Ontology elements are created isolated, with no relation to the rest of the ontology.</vaem:rationale>
  <dc:source>(competency_question) CQ26: How to express Condition via Constraints?
    (pitfall) Ontology elements (classes, object properties and datatype properties) are created isolated, with no relation to the rest of the ontology.</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Sequence">
  <rdfs:comment xml:lang="en">An ordered arrangement of rules or actions that must be executed in a specific order.</rdfs:comment>
  <rdfs:label xml:lang="en">Sequence</rdfs:label>
  <dc:source>(competency_question) CQ31: Do we need 'Sequencing' as part of the REL?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ConflictResolutionStrategy">
  <rdfs:comment xml:lang="en">A defined approach for resolving conflicts when multiple policies or rules apply to the same asset or party.</rdfs:comment>
  <rdfs:label xml:lang="en">Conflict Resolution Strategy</rdfs:label>
  <dc:source>(competency_question) New CQ2: What conflict resolution strategy is specified by a policy?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Operator">
  <rdfs:comment xml:lang="en">A logical or mathematical operator used to evaluate constraints.</rdfs:comment>
  <rdfs:label xml:lang="en">Operator</rdfs:label>
  <dc:source>(competency_question) CQ08: How to provide a 'NOT' expression?
    (competency_question) CQ14: How do we express 'and', 'or', 'xor' constraints?
    (competency_question) New CQ6: What operator is used in the constraints of a prohibition?
    (competency_question) CQ08: How to provide a 'NOT' expression? CQ14: How do we express 'and', 'or', 'xor' constraints? New CQ6: What operator is used in the constraints of a prohibition?</dc:source>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPolicy">
  <rdfs:comment xml:lang="en">Links an asset directly to the policy that governs its usage.</rdfs:comment>
  <rdfs:label xml:lang="en">has policy</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added owl:inverseOf axiom pointing to governs: OOPS pitfall: Relationship does not have an inverse relationship defined within the ontology.</vaem:rationale>
  <dc:source>(competency_question) New CQ1: Which policy is directly linked to a given asset?
    (pitfall) This pitfall appears when any relationship does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Asset"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#governs"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#governs">
  <rdfs:comment xml:lang="en">Inverse of hasPolicy. Indicates that a policy governs a specific asset.</rdfs:comment>
  <rdfs:label xml:lang="en">governs</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property for hasPolicy: OOPS pitfall: Relationship does not have an inverse relationship defined within the ontology.</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Asset"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasPolicy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasRule">
  <rdfs:comment xml:lang="en">Associates a policy with its constituent rules (permissions, duties, prohibitions).</rdfs:comment>
  <rdfs:label xml:lang="en">has rule</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added owl:inverseOf axiom pointing to isRuleOf: OOPS pitfall: Relationship does not have an inverse relationship defined within the ontology.</vaem:rationale>
  <dc:source>(competency_question) CQ10: How are rights and duties supported for all contract parties?
    (pitfall) This pitfall appears when any relationship does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isRuleOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isRuleOf">
  <rdfs:comment xml:lang="en">Inverse of hasRule. Indicates that a rule belongs to a specific policy.</rdfs:comment>
  <rdfs:label xml:lang="en">is rule of</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property for hasRule: OOPS pitfall: Relationship does not have an inverse relationship defined within the ontology.</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasRule"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAssignee">
  <rdfs:comment xml:lang="en">Specifies the party to whom a permission or duty is assigned.</rdfs:comment>
  <rdfs:label xml:lang="en">has assignee</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added owl:inverseOf axiom pointing to isAssigneeOf: OOPS pitfall: Relationship does not have an inverse relationship defined within the ontology.</vaem:rationale>
  <dc:source>(competency_question) CQ06: Expressing the various roles of contract parties within the Permission/Duty element.
    (competency_question) CQ10: How are rights and duties supported for all contract parties?
    (competency_question) CQ06: Expressing the various roles of contract parties within the Permission/Duty element. CQ10: How are rights and duties supported for all contract parties?
    (pitfall) This pitfall appears when any relationship does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Party"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isAssigneeOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isAssigneeOf">
  <rdfs:comment xml:lang="en">Inverse of hasAssignee. Indicates that a party is the assignee of a specific rule.</rdfs:comment>
  <rdfs:label xml:lang="en">is assignee of</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property for hasAssignee: OOPS pitfall: Relationship does not have an inverse relationship defined within the ontology.</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Party"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasAssignee"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAssigner">
  <rdfs:comment xml:lang="en">Specifies the party that grants or assigns a rule.</rdfs:comment>
  <rdfs:label xml:lang="en">has assigner</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added owl:inverseOf axiom pointing to assigns: OOPS pitfall: Relationship does not have an inverse relationship defined within the ontology.</vaem:rationale>
  <dc:source>(competency_question) CQ06: Expressing the various roles of contract parties within the Permission/Duty element.
    (competency_question) CQ10: How are rights and duties supported for all contract parties?
    (competency_question) CQ06: Expressing the various roles of contract parties within the Permission/Duty element. CQ10: How are rights and duties supported for all contract parties?
    (pitfall) This pitfall appears when any relationship does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Party"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#assigns"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#assigns">
  <rdfs:comment xml:lang="en">Inverse of hasAssigner. Indicates that a party assigns a specific rule.</rdfs:comment>
  <rdfs:label xml:lang="en">assigns</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property for hasAssigner: OOPS pitfall: Relationship does not have an inverse relationship defined within the ontology.</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Party"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasAssigner"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasRole">
  <rdfs:comment xml:lang="en">Defines the specific role of a contract party within a permission or duty context.</rdfs:comment>
  <rdfs:label xml:lang="en">has role</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added owl:inverseOf axiom pointing to hasPartyWithRole: OOPS pitfall: Relationship does not have an inverse relationship defined within the ontology.</vaem:rationale>
  <dc:source>(competency_question) CQ06: Expressing the various roles of contract parties within the Permission/Duty element.
    (pitfall) This pitfall appears when any relationship does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Party"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Role"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasPartyWithRole"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPartyWithRole">
  <rdfs:comment xml:lang="en">Inverse of hasRole. Indicates that a role is held by a specific party.</rdfs:comment>
  <rdfs:label xml:lang="en">has party with role</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property for hasRole: OOPS pitfall: Relationship does not have an inverse relationship defined within the ontology.</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Role"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Party"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasRole"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasConstraint">
  <rdfs:comment xml:lang="en">Links a rule, requirement, or condition to its applicable constraints.</rdfs:comment>
  <rdfs:label xml:lang="en">has constraint</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added owl:inverseOf axiom pointing to constrains: OOPS pitfall: Relationship does not have an inverse relationship defined within the ontology.</vaem:rationale>
  <dc:source>(competency_question) CQ21: How to express constraints on requirements?
    (competency_question) CQ26: How to express Condition via Constraints?
    (competency_question) New CQ6: What operator is used in the constraints of a prohibition?
    (competency_question) CQ21: How to express constraints on requirements? CQ26: How to express Condition via Constraints? New CQ6: What operator is used in the constraints of a prohibition?
    (pitfall) This pitfall appears when any relationship does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#constrains"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#constrains">
  <rdfs:comment xml:lang="en">Inverse of hasConstraint. Indicates that a constraint applies to a specific rule.</rdfs:comment>
  <rdfs:label xml:lang="en">constrains</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property for hasConstraint: OOPS pitfall: Relationship does not have an inverse relationship defined within the ontology.</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
