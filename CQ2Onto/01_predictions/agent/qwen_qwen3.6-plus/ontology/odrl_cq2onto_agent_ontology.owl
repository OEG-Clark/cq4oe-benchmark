  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasConflictResolutionStrategy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#inheritsFrom">
  <rdfs:comment xml:lang="en">Establishes an inheritance relationship, allowing a policy or rule to inherit properties from another.</rdfs:comment>
  <rdfs:label xml:lang="en">inherits from</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added owl:inverseOf axiom pointing to isInheritedBy: OOPS pitfall: Relationship does not have an inverse relationship defined within the ontology.</vaem:rationale>
  <dc:source>(competency_question) CQ33: Can the new data model express inheritance?
    (pitfall) This pitfall appears when any relationship does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isInheritedBy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isInheritedBy">
  <rdfs:comment xml:lang="en">Inverse of inheritsFrom. Indicates that a policy is inherited by another policy.</rdfs:comment>
  <rdfs:label xml:lang="en">is inherited by</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property for inheritsFrom: OOPS pitfall: Relationship does not have an inverse relationship defined within the ontology.</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#inheritsFrom"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasContainer">
  <rdfs:comment xml:lang="en">Links an asset or policy to a logical container for organizational purposes.</rdfs:comment>
  <rdfs:label xml:lang="en">has container</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added owl:inverseOf axiom pointing to contains: OOPS pitfall: Relationship does not have an inverse relationship defined within the ontology.</vaem:rationale>
  <dc:source>(competency_question) CQ30: What do we lose if containers are no longer part of ODRL?
    (pitfall) This pitfall appears when any relationship does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Asset"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Container"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#contains"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#contains">
  <rdfs:comment xml:lang="en">Inverse of hasContainer. Indicates that a container holds a specific asset.</rdfs:comment>
  <rdfs:label xml:lang="en">contains</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property for hasContainer: OOPS pitfall: Relationship does not have an inverse relationship defined within the ontology.</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Container"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Asset"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasContainer"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasSequence">
  <rdfs:comment xml:lang="en">Associates a rule with a specific execution sequence.</rdfs:comment>
  <rdfs:label xml:lang="en">has sequence</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added owl:inverseOf axiom pointing to isSequenceOf: OOPS pitfall: Relationship does not have an inverse relationship defined within the ontology.</vaem:rationale>
  <dc:source>(competency_question) CQ31: Do we need 'Sequencing' as part of the REL?
    (pitfall) This pitfall appears when any relationship does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Sequence"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isSequenceOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isSequenceOf">
  <rdfs:comment xml:lang="en">Inverse of hasSequence. Indicates that a sequence is associated with a specific rule.</rdfs:comment>
  <rdfs:label xml:lang="en">is sequence of</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property for hasSequence: OOPS pitfall: Relationship does not have an inverse relationship defined within the ontology.</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Sequence"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasSequence"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#precedes">
  <rdfs:comment xml:lang="en">Defines the temporal or logical ordering relationship between rules within a sequence.</rdfs:comment>
  <rdfs:label xml:lang="en">precedes</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added owl:inverseOf axiom pointing to follows: OOPS pitfall: Relationship does not have an inverse relationship defined within the ontology.</vaem:rationale>
  <dc:source>(competency_question) CQ31: Do we need 'Sequencing' as part of the REL?
    (pitfall) This pitfall appears when any relationship does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#follows"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#follows">
  <rdfs:comment xml:lang="en">Inverse of precedes. Indicates that a rule follows another rule in a sequence.</rdfs:comment>
  <rdfs:label xml:lang="en">follows</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property for precedes: OOPS pitfall: Relationship does not have an inverse relationship defined within the ontology.</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#precedes"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasOperator">
  <rdfs:comment xml:lang="en">Specifies the logical or mathematical operator (e.g., AND, OR, XOR, NOT) used to evaluate a constraint.</rdfs:comment>
  <rdfs:label xml:lang="en">has operator</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added owl:inverseOf axiom pointing to operatesOn: OOPS pitfall: Relationship does not have an inverse relationship defined within the ontology.</vaem:rationale>
  <dc:source>(competency_question) CQ08: How to provide a 'NOT' expression?
    (competency_question) CQ14: How do we express 'and', 'or', 'xor' constraints?
    (competency_question) New CQ6: What operator is used in the constraints of a prohibition?
    (competency_question) CQ08: How to provide a 'NOT' expression? CQ14: How do we express 'and', 'or', 'xor' constraints? New CQ6: What operator is used in the constraints of a prohibition?
    (pitfall) This pitfall appears when any relationship does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Operator"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#operatesOn"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#operatesOn">
  <rdfs:comment xml:lang="en">Inverse of hasOperator. Indicates that an operator is used to evaluate a specific constraint.</rdfs:comment>
  <rdfs:label xml:lang="en">operates on</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property for hasOperator: OOPS pitfall: Relationship does not have an inverse relationship defined within the ontology.</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Operator"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasOperator"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasRequirement">
  <rdfs:comment xml:lang="en">Links a rule to a prerequisite requirement that must be satisfied before the rule can be exercised.</rdfs:comment>
  <rdfs:label xml:lang="en">has requirement</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created new property to connect isolated Requirement class to Rule: OOPS pitfall: Ontology elements are created isolated, with no relation to the rest of the ontology.</vaem:rationale>
  <dc:source>(pitfall) Ontology elements (classes, object properties and datatype properties) are created isolated, with no relation to the rest of the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Requirement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasCondition">
  <rdfs:comment xml:lang="en">Links a rule to a condition that must hold true for the rule to be applicable.</rdfs:comment>
  <rdfs:label xml:lang="en">has condition</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created new property to connect isolated Condition class to Rule: OOPS pitfall: Ontology elements are created isolated, with no relation to the rest of the ontology.</vaem:rationale>
  <dc:source>(pitfall) Ontology elements (classes, object properties and datatype properties) are created isolated, with no relation to the rest of the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Condition"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasValue">
  <rdfs:comment xml:lang="en">The literal or data value associated with a constraint for evaluation.</rdfs:comment>
  <rdfs:label xml:lang="en">has value</rdfs:label>
  <dc:source>(competency_question) CQ21: How to express constraints on requirements?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isExclusive">
  <rdfs:comment xml:lang="en">A boolean flag indicating whether a permission is granted exclusively to a single party.</rdfs:comment>
  <rdfs:label xml:lang="en">is exclusive</rdfs:label>
  <dc:source>(competency_question) CQ24: How to express exclusive permissions?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ExclusivePermission"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
</owl:DatatypeProperty>

</rdf:RDF>