</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isRemedyDutyFor">
  <rdfs:comment xml:lang="en">Inverse of hasRemedyDuty. Indicates that a duty serves as a remedy for a specific prohibition.</rdfs:comment>
  <rdfs:label xml:lang="en">is remedy duty for</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property for hasRemedyDuty: OOPS pitfall: Relationship does not have an inverse relationship defined within the ontology.</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Duty"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Prohibition"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasRemedyDuty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasFallbackRule">
  <rdfs:comment xml:lang="en">Indicates a rule that is automatically activated upon the failure or violation of another rule.</rdfs:comment>
  <rdfs:label xml:lang="en">has fallback rule</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added owl:inverseOf axiom pointing to isFallbackRuleOf: OOPS pitfall: Relationship does not have an inverse relationship defined within the ontology.</vaem:rationale>
