  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasSubConstraint"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasRemedyDuty">
  <rdfs:comment xml:lang="en">Specifies a duty that must be performed as a remedy for violating a prohibition.</rdfs:comment>
  <rdfs:label xml:lang="en">has remedy duty</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added owl:inverseOf axiom pointing to isRemedyDutyFor: OOPS pitfall: Relationship does not have an inverse relationship defined within the ontology.</vaem:rationale>
  <dc:source>(competency_question) New CQ3: What duty is specified as a remedy for the violation of a prohibition?
    (pitfall) This pitfall appears when any relationship does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Prohibition"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Duty"/>
