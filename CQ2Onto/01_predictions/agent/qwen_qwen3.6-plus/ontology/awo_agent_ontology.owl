<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Organism">
  <rdfs:comment xml:lang="en">A living entity capable of metabolic processes and consumption of nutrients.</rdfs:comment>
  <rdfs:label xml:lang="en">Organism</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Animal">
  <rdfs:comment xml:lang="en">A multicellular eukaryotic organism that typically consumes organic material for energy.</rdfs:comment>
  <rdfs:label xml:lang="en">Animal</rdfs:label>
  <dc:source>(competency_question) CQ1: Which animal eats which other animal?
    (competency_question) CQ2: Is [this animal] a herbivore?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Organism"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Plant"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Plant">
  <rdfs:comment xml:lang="en">A multicellular eukaryotic organism that typically produces its own food via photosynthesis, though some species consume animals.</rdfs:comment>
  <rdfs:label xml:lang="en">Plant</rdfs:label>
  <dc:source>(competency_question) CQ6: Which plants eat animals?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Organism"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlantPart">
  <rdfs:comment xml:lang="en">A structural component or portion of a plant, such as leaves, roots, stems, or fruits.</rdfs:comment>
  <rdfs:label xml:lang="en">Plant Part</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added rdfs:subClassOf Plant: Resolved OOPS pitfall: Isolated elements. PlantPart is now explicitly related to Plant.</vaem:rationale>
  <dc:source>(competency_question) CQ3: Which plant parts does [this omnivorous or herbivorourus animal] eat?
    (pitfall) Ontology elements (classes, object properties and datatype properties) are created isolated, with no relation to the rest of the ontology.</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Plant"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Herbivore">
  <rdfs:comment xml:lang="en">An animal that primarily consumes plants or plant parts.</rdfs:comment>
  <rdfs:label xml:lang="en">Herbivore</rdfs:label>
  <dc:source>(competency_question) CQ2: Is [this animal] a herbivore?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Carnivore">
  <rdfs:comment xml:lang="en">An animal that primarily consumes other animals, though some may occasionally consume plants or plant parts.</rdfs:comment>
  <rdfs:label xml:lang="en">Carnivore</rdfs:label>
  <dc:source>(competency_question) CQ14: Are there animals that are carnivore but still eat some plants or parts of plants?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Omnivore">
  <rdfs:comment xml:lang="en">An animal that regularly consumes both plants/plant parts and other animals.</rdfs:comment>
  <rdfs:label xml:lang="en">Omnivore</rdfs:label>
  <dc:source>(competency_question) CQ3: Which plant parts does [this omnivorous or herbivorourus animal] eat?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Lion">
  <rdfs:comment xml:lang="en">A large carnivorous feline species.</rdfs:comment>
  <rdfs:label xml:lang="en">Lion</rdfs:label>
  <dc:source>(competency_question) CQ4: Does a lion eat plants or plant parts?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Carnivore"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Thing">
  <rdfs:comment xml:lang="en">The universal class containing all individuals in the ontology.</rdfs:comment>
  <rdfs:label xml:lang="en">Thing</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Declared as owl:Class: Resolved OOPS pitfall: Undeclared class used. Thing is now explicitly declared.</vaem:rationale>
  <dc:source>(pitfall) An ontology element is used as a class without having been explicitly declared as such using the primitives owl:Class or rdfs:Class.</dc:source>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#eats">
  <rdfs:comment xml:lang="en">A relationship indicating that one organism consumes another organism or a part of a plant.</rdfs:comment>
  <rdfs:label xml:lang="en">eats</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added owl:inverseOf isEatenBy: Resolved OOPS pitfall: Missing inverse property.</vaem:rationale>
  <dc:source>(competency_question) CQ1: Which animal eats which other animal?
    (competency_question) CQ6: Which plants eat animals?
    (pitfall) This pitfall appears when any relationship does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Organism"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Thing"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isEatenBy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isEatenBy">
  <rdfs:comment xml:lang="en">A relationship indicating that an organism or plant part is consumed by another organism.</rdfs:comment>
  <rdfs:label xml:lang="en">is eaten by</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created new object property isEatenBy: Provides inverse for eats to resolve OOPS pitfall: Missing inverse property.</vaem:rationale>
  <dc:source>(pitfall) Missing inverse relationship for eats property.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Thing"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Organism"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#eats"/>
</owl:ObjectProperty>

</rdf:RDF>