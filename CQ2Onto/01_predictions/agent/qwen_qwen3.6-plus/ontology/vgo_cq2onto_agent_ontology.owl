<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Player">
  <rdfs:comment xml:lang="en">A user or participant in the gaming ecosystem.</rdfs:comment>
  <rdfs:label xml:lang="en">Player</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjoint axioms with Game, Achievement, AchievementType, Item, Genre, InAppPurchase, Location, PlayingArea: Resolved OOPS pitfall: Missing disjoint axioms between classes</vaem:rationale>
  <dc:source>(competency_question) CQ01
    (competency_question) CQ02
    (competency_question) CQ03
    (competency_question) CQ05
    (competency_question) CQ07
    (competency_question) CQ22
    (competency_question) CQ24
    (competency_question) CQ25
    (competency_question) CQ26
    (competency_question) CQ27
    (competency_question) CQ29
    (competency_question) CQ35
    (competency_question) CQ52
    (competency_question) CQ55
    (competency_question) CQ56
    (competency_question) CQ57
    (competency_question) CQ62
    (competency_question) CQ63
    (competency_question) CQ64
    (competency_question) CQ65
    (competency_question) CQ66
    (pitfall) The ontology lacks disjoint axioms between classes or between properties that should be defined as disjoint.</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Game"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Achievement"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Item"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Genre"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Location"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Game">
  <rdfs:comment xml:lang="en">A software application or title that players interact with.</rdfs:comment>
  <rdfs:label xml:lang="en">Game</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjoint axioms with Player, Achievement, AchievementType, Item, Genre, InAppPurchase, Location, PlayingArea: Resolved OOPS pitfall: Missing disjoint axioms between classes</vaem:rationale>
  <dc:source>(competency_question) CQ03
    (competency_question) CQ08
    (competency_question) CQ09
    (competency_question) CQ10
    (competency_question) CQ11
    (competency_question) CQ12
    (competency_question) CQ13
    (competency_question) CQ15
    (competency_question) CQ17
    (competency_question) CQ22
    (competency_question) CQ25
    (competency_question) CQ29
    (competency_question) CQ35
    (competency_question) CQ52
    (competency_question) CQ55
    (competency_question) New CQ1
    (pitfall) The ontology lacks disjoint axioms between classes or between properties that should be defined as disjoint.</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Player"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Achievement"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Item"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Genre"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Location"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Achievement">
  <rdfs:comment xml:lang="en">A specific milestone or reward unlocked within a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Achievement</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjoint axioms with Player, Game, AchievementType, Item, Genre, InAppPurchase, Location, PlayingArea: Resolved OOPS pitfall: Missing disjoint axioms between classes</vaem:rationale>
  <dc:source>(competency_question) CQ05
    (competency_question) CQ07
    (competency_question) CQ08
    (competency_question) CQ10
    (competency_question) CQ11
    (competency_question) CQ24
    (competency_question) CQ27
    (competency_question) CQ35
    (pitfall) The ontology lacks disjoint axioms between classes or between properties that should be defined as disjoint.</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Player"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Game"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Item"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Genre"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Location"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#AchievementType">
  <rdfs:comment xml:lang="en">A category or classification of achievements (e.g., combat, exploration, collection).</rdfs:comment>
  <rdfs:label xml:lang="en">Achievement Type</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjoint axioms with Player, Game, Achievement, Item, Genre, InAppPurchase, Location, PlayingArea: Resolved OOPS pitfall: Missing disjoint axioms between classes</vaem:rationale>
  <dc:source>(competency_question) CQ10
    (competency_question) CQ11
    (competency_question) CQ27
    (pitfall) The ontology lacks disjoint axioms between classes or between properties that should be defined as disjoint.</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Player"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Game"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Achievement"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Item"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Genre"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Location"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Item">
  <rdfs:comment xml:lang="en">A virtual object or asset that exists within a game and can be owned or used by players.</rdfs:comment>
  <rdfs:label xml:lang="en">Item</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjoint axioms with Player, Game, Achievement, AchievementType, Genre, InAppPurchase, Location, PlayingArea: Resolved OOPS pitfall: Missing disjoint axioms between classes</vaem:rationale>
  <dc:source>(competency_question) CQ13
    (competency_question) CQ19
    (competency_question) CQ26
    (competency_question) CQ52
    (competency_question) CQ55
    (pitfall) The ontology lacks disjoint axioms between classes or between properties that should be defined as disjoint.</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Player"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Game"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Achievement"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Genre"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Location"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Equipment">
  <rdfs:comment xml:lang="en">A specialized type of item that players can equip for gameplay advantages.</rdfs:comment>
  <rdfs:label xml:lang="en">Equipment</rdfs:label>
  <dc:source>(competency_question) CQ52</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Item"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Genre">
  <rdfs:comment xml:lang="en">A category defining the style or theme of a game (e.g., RPG, FPS, Strategy).</rdfs:comment>
  <rdfs:label xml:lang="en">Genre</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjoint axioms with Player, Game, Achievement, AchievementType, Item, InAppPurchase, Location, PlayingArea: Resolved OOPS pitfall: Missing disjoint axioms between classes</vaem:rationale>
  <dc:source>(competency_question) CQ12
    (competency_question) CQ17
    (pitfall) The ontology lacks disjoint axioms between classes or between properties that should be defined as disjoint.</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Player"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Game"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Achievement"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Item"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Location"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#InAppPurchase">
  <rdfs:comment xml:lang="en">A transaction record representing a monetary purchase made within a game.</rdfs:comment>
  <rdfs:label xml:lang="en">In-App Purchase</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjoint axioms with Player, Game, Achievement, AchievementType, Item, Genre, Location, PlayingArea: Resolved OOPS pitfall: Missing disjoint axioms between classes</vaem:rationale>
  <dc:source>(competency_question) CQ56
    (competency_question) CQ57
    (competency_question) CQ62
    (competency_question) CQ63
    (competency_question) CQ64
    (competency_question) CQ65
    (competency_question) CQ66
    (pitfall) The ontology lacks disjoint axioms between classes or between properties that should be defined as disjoint.</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Player"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Game"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Achievement"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Item"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Genre"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Location"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Location">
  <rdfs:comment xml:lang="en">A geographical or virtual place where a player resides.</rdfs:comment>
  <rdfs:label xml:lang="en">Location</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjoint axioms with Player, Game, Achievement, AchievementType, Item, Genre, InAppPurchase, PlayingArea: Resolved OOPS pitfall: Missing disjoint axioms between classes</vaem:rationale>
  <dc:source>(competency_question) CQ63
    (competency_question) CQ65
    (competency_question) CQ66
    (pitfall) The ontology lacks disjoint axioms between classes or between properties that should be defined as disjoint.</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Player"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Game"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Achievement"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Item"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Genre"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayingArea">
  <rdfs:comment xml:lang="en">A specific zone, map, or environment within a game where gameplay occurs.</rdfs:comment>
  <rdfs:label xml:lang="en">Playing Area</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjoint axioms with Player, Game, Achievement, AchievementType, Item, Genre, InAppPurchase, Location: Resolved OOPS pitfall: Missing disjoint axioms between classes</vaem:rationale>
  <dc:source>(competency_question) New CQ1
    (pitfall) The ontology lacks disjoint axioms between classes or between properties that should be defined as disjoint.</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Player"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Game"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Achievement"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Item"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Genre"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Location"/>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasFriend">
  <rdfs:comment xml:lang="en">Links a player to another player who is designated as a friend.</rdfs:comment>
  <rdfs:label xml:lang="en">has friend</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isFriendOf: Resolved OOPS pitfall: Missing inverse relationships</vaem:rationale>
  <dc:source>(competency_question) CQ02
    (competency_question) CQ03
    (pitfall) This pitfall appears when any relationship does not have an inverse relationship defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isFriendOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isFriendOf">
  <rdfs:comment xml:lang="en">Inverse of hasFriend. Links a player to another player who considers them a friend.</rdfs:comment>
  <rdfs:label xml:lang="en">is friend of</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created new inverse property for hasFriend: Resolved OOPS pitfall: Missing inverse relationships</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship does not have an inverse relationship defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasFriend"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#playsGame">
  <rdfs:comment xml:lang="en">Indicates that a player has engaged with a specific game.</rdfs:comment>
  <rdfs:label xml:lang="en">plays game</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property playedBy: Resolved OOPS pitfall: Missing inverse relationships</vaem:rationale>
  <dc:source>(competency_question) CQ03
    (competency_question) CQ25
    (pitfall) This pitfall appears when any relationship does not have an inverse relationship defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#playedBy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#playedBy">
  <rdfs:comment xml:lang="en">Inverse of playsGame. Indicates which players have engaged with a specific game.</rdfs:comment>
  <rdfs:label xml:lang="en">played by</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created new inverse property for playsGame: Resolved OOPS pitfall: Missing inverse relationships</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship does not have an inverse relationship defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#playsGame"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAchievement">
  <rdfs:comment xml:lang="en">Links a player to an achievement they have successfully obtained.</rdfs:comment>
  <rdfs:label xml:lang="en">has achievement</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property achievedBy: Resolved OOPS pitfall: Missing inverse relationships</vaem:rationale>
  <dc:source>(competency_question) CQ05
    (competency_question) CQ07
    (competency_question) CQ24
    (competency_question) CQ27
    (competency_question) CQ35
    (pitfall) This pitfall appears when any relationship does not have an inverse relationship defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#achievedBy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#achievedBy">
  <rdfs:comment xml:lang="en">Inverse of hasAchievement. Links an achievement to the player who obtained it.</rdfs:comment>
  <rdfs:label xml:lang="en">achieved by</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created new inverse property for hasAchievement: Resolved OOPS pitfall: Missing inverse relationships</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship does not have an inverse relationship defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasAchievement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#offersAchievement">
  <rdfs:comment xml:lang="en">Links a game to the achievements that can be unlocked within it.</rdfs:comment>
  <rdfs:label xml:lang="en">offers achievement</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property offeredByGame: Resolved OOPS pitfall: Missing inverse relationships</vaem:rationale>
  <dc:source>(competency_question) CQ08
    (pitfall) This pitfall appears when any relationship does not have an inverse relationship defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#offeredByGame"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#offeredByGame">
  <rdfs:comment xml:lang="en">Inverse of offersAchievement. Links an achievement to the game that offers it.</rdfs:comment>
  <rdfs:label xml:lang="en">offered by game</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created new inverse property for offersAchievement: Resolved OOPS pitfall: Missing inverse relationships</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship does not have an inverse relationship defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#offersAchievement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasType">
  <rdfs:comment xml:lang="en">Associates an achievement with its specific category or type.</rdfs:comment>
  <rdfs:label xml:lang="en">has type</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property typeOfAchievement: Resolved OOPS pitfall: Missing inverse relationships</vaem:rationale>
  <dc:source>(competency_question) CQ10
    (competency_question) CQ11
    (competency_question) CQ27
    (pitfall) This pitfall appears when any relationship does not have an inverse relationship defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#typeOfAchievement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#typeOfAchievement">
  <rdfs:comment xml:lang="en">Inverse of hasType. Associates an achievement type with the achievements belonging to it.</rdfs:comment>
  <rdfs:label xml:lang="en">type of achievement</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created new inverse property for hasType: Resolved OOPS pitfall: Missing inverse relationships</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship does not have an inverse relationship defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasType"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGenre">
  <rdfs:comment xml:lang="en">Associates a game with its primary genre classification.</rdfs:comment>
  <rdfs:label xml:lang="en">has genre</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property genreOf: Resolved OOPS pitfall: Missing inverse relationships</vaem:rationale>
  <dc:source>(competency_question) CQ12
    (competency_question) CQ17
    (pitfall) This pitfall appears when any relationship does not have an inverse relationship defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Genre"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#genreOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#genreOf">
  <rdfs:comment xml:lang="en">Inverse of hasGenre. Associates a genre with the games classified under it.</rdfs:comment>
  <rdfs:label xml:lang="en">genre of</rdfs:label>
