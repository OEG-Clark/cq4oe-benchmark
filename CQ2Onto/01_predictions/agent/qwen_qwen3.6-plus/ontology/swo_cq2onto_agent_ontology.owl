</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasSoftwareType">
  <rdfs:comment xml:lang="en">Indicates the deployment category or architectural type of a software tool.</rdfs:comment>
