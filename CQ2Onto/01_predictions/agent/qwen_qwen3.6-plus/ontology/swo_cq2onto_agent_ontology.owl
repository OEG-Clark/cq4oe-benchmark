<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#SoftwareTool">
  <rdfs:comment xml:lang="en">A software application, library, or program designed to perform specific computational or user tasks.</rdfs:comment>
  <rdfs:label xml:lang="en">Software Tool</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjoint axioms with other top-level classes.: OOPS pitfall: Missing disjoint axioms between classes.</vaem:rationale>
  <dc:source>(competency_question) CQ04, CQ05, CQ06, CQ07, CQ08, CQ11, CQ14, CQ15, CQ16, CQ17, CQ19, CQ21, CQ22, CQ23, CQ26, CQ29, CQ30, CQ32, CQ36, CQ37, CQ38, CQ40, CQ45, CQ46, CQ54, CQ55, CQ57, CQ58, CQ59, CQ60, CQ65, CQ68, CQ73, CQ84, CQ85
    (pitfall) The ontology lacks disjoint axioms between classes or between properties that should be defined as disjoint.</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#SoftwareVersion"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Task"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Feature"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#SoftwareType"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Developer"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#License"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Platform"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#ProgrammingLanguage"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Dataset"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#SoftwareVersion">
  <rdfs:comment xml:lang="en">A specific release or iteration of a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Software Version</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Retained original definition.: No direct changes required for this entity.</vaem:rationale>
  <dc:source>(competency_question) CQ29, CQ54, CQ55, CQ57</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Algorithm">
  <rdfs:comment xml:lang="en">A defined computational procedure or method used by a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Algorithm</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Retained original definition.: No direct changes required for this entity.</vaem:rationale>
  <dc:source>(competency_question) CQ04, CQ05</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Task">
  <rdfs:comment xml:lang="en">A specific operation, function, or goal that a software tool can perform.</rdfs:comment>
  <rdfs:label xml:lang="en">Task</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Retained original definition.: No direct changes required for this entity.</vaem:rationale>
  <dc:source>(competency_question) CQ08, CQ14, CQ16</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#DataFormat">
  <rdfs:comment xml:lang="en">A standardized structure or encoding for storing or transmitting data, including file extensions.</rdfs:comment>
  <rdfs:label xml:lang="en">Data Format</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Retained original definition.: No direct changes required for this entity.</vaem:rationale>
  <dc:source>(competency_question) CQ17, CQ19, CQ22, CQ23, CQ26, CQ29</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Feature">
  <rdfs:comment xml:lang="en">A specific capability or functionality provided by a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Feature</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Retained original definition.: No direct changes required for this entity.</vaem:rationale>
  <dc:source>(competency_question) CQ06, CQ55</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#SoftwareType">
  <rdfs:comment xml:lang="en">The category or deployment model of a software tool, such as API, Desktop Application, or Web Service.</rdfs:comment>
  <rdfs:label xml:lang="en">Software Type</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Retained original definition.: No direct changes required for this entity.</vaem:rationale>
  <dc:source>(competency_question) CQ07, CQ11</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Developer">
  <rdfs:comment xml:lang="en">An individual, organization, or community responsible for creating or maintaining a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Developer</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Retained original definition.: No direct changes required for this entity.</vaem:rationale>
  <dc:source>(competency_question) CQ36, CQ38</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#License">
  <rdfs:comment xml:lang="en">A legal agreement governing the use, modification, and distribution of a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">License</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Retained original definition.: No direct changes required for this entity.</vaem:rationale>
  <dc:source>(competency_question) CQ59</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Platform">
  <rdfs:comment xml:lang="en">An operating system or hardware environment on which a software tool can execute.</rdfs:comment>
  <rdfs:label xml:lang="en">Platform</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Retained original definition.: No direct changes required for this entity.</vaem:rationale>
  <dc:source>(competency_question) CQ85</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ProgrammingLanguage">
  <rdfs:comment xml:lang="en">A formal language used to implement the source code of a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Programming Language</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Retained original definition.: No direct changes required for this entity.</vaem:rationale>
  <dc:source>(competency_question) CQ84</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Dataset">
  <rdfs:comment xml:lang="en">A collection of data that can be processed, created, or exported by a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Dataset</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Retained original definition.: No direct changes required for this entity.</vaem:rationale>
  <dc:source>(competency_question) CQ15, CQ16, CQ23</dc:source>
</owl:Class>

