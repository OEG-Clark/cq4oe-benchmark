</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#implementedIn">
  <rdfs:comment xml:lang="en">Specifies the programming language used to write the software's source code.</rdfs:comment>
  <rdfs:label xml:lang="en">implemented in</rdfs:label>
