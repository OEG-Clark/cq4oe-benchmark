<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usesAlgorithm">
  <rdfs:comment xml:lang="en">Relates a software tool to the algorithm it employs for processing.</rdfs:comment>
  <rdfs:label xml:lang="en">uses algorithm</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added owl:inverseOf axiom.: OOPS pitfall: Missing inverse relationships for object properties.</vaem:rationale>
  <dc:source>(competency_question) CQ04
    (pitfall) This pitfall appears when any relationship does not have an inverse relationship defined.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#usedBy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usedBy">
  <rdfs:comment xml:lang="en">Relates an algorithm to the software tool that employs it.</rdfs:comment>
