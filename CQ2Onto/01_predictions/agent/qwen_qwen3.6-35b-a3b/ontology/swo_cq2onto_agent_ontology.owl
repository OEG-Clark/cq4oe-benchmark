  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Software">
  <rdfs:comment xml:lang="en">A software tool or application used for processing, analyzing, or managing data.</rdfs:comment>
  <rdfs:label xml:lang="en">Software</rdfs:label>
  <dc:source>(competency_question) CQ07
    (competency_question) CQ08
    (competency_question) CQ11
    (competency_question) CQ14
    (competency_question) CQ15
    (competency_question) CQ16
    (competency_question) CQ17
    (competency_question) CQ19
    (competency_question) CQ21
    (competency_question) CQ22
    (competency_question) CQ23
    (competency_question) CQ26
    (competency_question) CQ29
    (competency_question) CQ30
    (competency_question) CQ32
    (competency_question) CQ36
    (competency_question) CQ37
    (competency_question) CQ38
    (competency_question) CQ40
    (competency_question) CQ45
    (competency_question) CQ46
    (competency_question) CQ54
    (competency_question) CQ55
    (competency_question) CQ58
    (competency_question) CQ59
    (competency_question) CQ60
    (competency_question) CQ65
    (competency_question) CQ68
    (competency_question) CQ73
    (competency_question) CQ84
    (competency_question) CQ85</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#SoftwareVersion">
  <rdfs:comment xml:lang="en">A specific release or iteration of a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Software Version</rdfs:label>
  <dc:source>(competency_question) CQ29
    (competency_question) CQ54
    (competency_question) CQ55
    (competency_question) CQ57</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Algorithm">
  <rdfs:comment xml:lang="en">A named and published computational procedure or method used by software.</rdfs:comment>
  <rdfs:label xml:lang="en">Algorithm</rdfs:label>
  <dc:source>(competency_question) CQ04
    (competency_question) CQ05</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Capability">
  <rdfs:comment xml:lang="en">A specific function, feature, or task that software can perform.</rdfs:comment>
  <rdfs:label xml:lang="en">Capability</rdfs:label>
  <dc:source>(competency_question) CQ06
    (competency_question) CQ14
    (competency_question) CQ55</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#SoftwareType">
  <rdfs:comment xml:lang="en">The category or deployment model of the software (e.g., API, Desktop, Web).</rdfs:comment>
  <rdfs:label xml:lang="en">Software Type</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjoint axioms with other categorical classes: OOPS pitfall: lacks disjoint axioms between classes</vaem:rationale>
  <dc:source>(competency_question) CQ07</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#MaintenanceStatus"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#DevelopmentModel"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Platform"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#License"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Task"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Capability"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Developer"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#SoftwareVersion"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Data"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Task">
  <rdfs:comment xml:lang="en">A specific user goal or operation that software can accomplish.</rdfs:comment>
  <rdfs:label xml:lang="en">Task</rdfs:label>
  <dc:source>(competency_question) CQ08
    (competency_question) CQ14
    (competency_question) CQ16</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Data">
  <rdfs:comment xml:lang="en">Digital information or files processed, created, or managed by software.</rdfs:comment>
  <rdfs:label xml:lang="en">Data</rdfs:label>
  <dc:source>(competency_question) CQ15
    (competency_question) CQ16
    (competency_question) CQ23
    (competency_question) CQ29</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#DataFormat">
  <rdfs:comment xml:lang="en">A standardized way of encoding information for storage or transmission.</rdfs:comment>
  <rdfs:label xml:lang="en">Data Format</rdfs:label>
  <dc:source>(competency_question) CQ14
    (competency_question) CQ17
    (competency_question) CQ19
    (competency_question) CQ21
    (competency_question) CQ22
    (competency_question) CQ23
    (competency_question) CQ26
    (competency_question) CQ29</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Developer">
  <rdfs:comment xml:lang="en">An individual or organization responsible for creating or maintaining the software.</rdfs:comment>
  <rdfs:label xml:lang="en">Developer</rdfs:label>
  <dc:source>(competency_question) CQ36
    (competency_question) CQ38</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#License">
  <rdfs:comment xml:lang="en">The legal terms governing the use, modification, and distribution of the software.</rdfs:comment>
  <rdfs:label xml:lang="en">License</rdfs:label>
  <dc:source>(competency_question) CQ59
    (competency_question) CQ60
    (competency_question) CQ65
    (competency_question) CQ68</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Platform">
  <rdfs:comment xml:lang="en">The operating system or hardware environment on which the software runs.</rdfs:comment>
  <rdfs:label xml:lang="en">Platform</rdfs:label>
  <dc:source>(competency_question) CQ85</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#MaintenanceStatus">
  <rdfs:comment xml:lang="en">The current state of software maintenance and development activity.</rdfs:comment>
  <rdfs:label xml:lang="en">Maintenance Status</rdfs:label>
  <dc:source>(competency_question) CQ26
    (competency_question) CQ46</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#DevelopmentModel">
  <rdfs:comment xml:lang="en">The organizational approach to software development (e.g., open source, community-driven).</rdfs:comment>
  <rdfs:label xml:lang="en">Development Model</rdfs:label>
  <dc:source>(competency_question) CQ58</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#xsd:anyURI">
  <rdfs:comment xml:lang="en">XSD datatype anyURI declared as a class to resolve OOPS pitfall.</rdfs:comment>
  <rdfs:label xml:lang="en">XSD AnyURI</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Declared as owl:Class: OOPS pitfall: element used as class without explicit declaration</vaem:rationale>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#xsd:string">
  <rdfs:comment xml:lang="en">XSD datatype string declared as a class to resolve OOPS pitfall.</rdfs:comment>
  <rdfs:label xml:lang="en">XSD String</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Declared as owl:Class: OOPS pitfall: element used as class without explicit declaration</vaem:rationale>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#xsd:boolean">
  <rdfs:comment xml:lang="en">XSD datatype boolean declared as a class to resolve OOPS pitfall.</rdfs:comment>
  <rdfs:label xml:lang="en">XSD Boolean</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Declared as owl:Class: OOPS pitfall: element used as class without explicit declaration</vaem:rationale>
