<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usesAlgorithm">
  <rdfs:comment xml:lang="en">Relates software to the algorithm it implements.</rdfs:comment>
  <rdfs:label xml:lang="en">Uses Algorithm</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property: OOPS pitfall: missing inverse relationship</vaem:rationale>
  <dc:source>(competency_question) CQ04</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#algorithmUsedBy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#algorithmUsedBy">
