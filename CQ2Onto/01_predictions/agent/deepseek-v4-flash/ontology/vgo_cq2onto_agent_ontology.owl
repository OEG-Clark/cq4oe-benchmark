<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isPurchaseMadeBy">
  <rdfs:comment xml:lang="en">Indicates the player who made an in-app purchase. Inverse of makesPurchase.</rdfs:comment>
