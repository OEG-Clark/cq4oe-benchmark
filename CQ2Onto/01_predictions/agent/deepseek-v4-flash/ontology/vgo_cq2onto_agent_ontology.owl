</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasKillCount">
  <rdfs:comment xml:lang="en">The kill count of a player in a specific game, associated via PlayerGameStat.</rdfs:comment>
