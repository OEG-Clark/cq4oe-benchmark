<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isPlayingAreaOf">
  <rdfs:comment xml:lang="en">Indicates the game that contains a playing area. Inverse of hasPlayingArea.</rdfs:comment>
