<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isGameOfPurchase">
  <rdfs:comment xml:lang="en">Indicates the game for which an in-app purchase is made. Inverse of purchaseForGame.</rdfs:comment>
