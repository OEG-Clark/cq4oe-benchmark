<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Player">
  <rdfs:comment xml:lang="en">A person who plays video games.</rdfs:comment>
  <rdfs:label xml:lang="en">Player</rdfs:label>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Game"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Achievement"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Item"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Ability"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Genre"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Location"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayerGameStat"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Game">
  <rdfs:comment xml:lang="en">A video game that can be played by players.</rdfs:comment>
  <rdfs:label xml:lang="en">Game</rdfs:label>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Player"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Achievement"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Item"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Ability"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Genre"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Location"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayerGameStat"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Achievement">
  <rdfs:comment xml:lang="en">An accomplishment or reward in a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Achievement</rdfs:label>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Player"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Game"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Item"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Ability"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Genre"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Location"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayerGameStat"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#AchievementType">
  <rdfs:comment xml:lang="en">A category or type of achievement, e.g., bronze, silver, gold.</rdfs:comment>
  <rdfs:label xml:lang="en">Achievement type</rdfs:label>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Player"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Game"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Achievement"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Item"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Ability"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Genre"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Location"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayerGameStat"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Item">
  <rdfs:comment xml:lang="en">An object or item that exists in a game and can be owned by a player.</rdfs:comment>
  <rdfs:label xml:lang="en">Item</rdfs:label>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Player"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Game"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Achievement"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Ability"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Genre"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Location"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayerGameStat"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Ability">
  <rdfs:comment xml:lang="en">An ability or power that an item grants.</rdfs:comment>
  <rdfs:label xml:lang="en">Ability</rdfs:label>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Player"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Game"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Achievement"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Item"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Genre"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Location"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayerGameStat"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Genre">
  <rdfs:comment xml:lang="en">A category of game based on gameplay style, e.g., action, adventure.</rdfs:comment>
  <rdfs:label xml:lang="en">Genre</rdfs:label>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Player"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Game"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Achievement"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Item"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Ability"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Location"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayerGameStat"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayingArea">
  <rdfs:comment xml:lang="en">An area or level within a game where gameplay occurs.</rdfs:comment>
  <rdfs:label xml:lang="en">Playing area</rdfs:label>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Player"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Game"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Achievement"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Item"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Ability"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Genre"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Location"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayerGameStat"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#InAppPurchase">
  <rdfs:comment xml:lang="en">An in-app purchase made by a player, possibly within a specific game.</rdfs:comment>
  <rdfs:label xml:lang="en">In-app purchase</rdfs:label>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Player"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Game"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Achievement"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Item"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Ability"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Genre"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Location"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayerGameStat"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Location">
  <rdfs:comment xml:lang="en">A geographical location where a player lives, e.g., city, country.</rdfs:comment>
  <rdfs:label xml:lang="en">Location</rdfs:label>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Player"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Game"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Achievement"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Item"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Ability"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Genre"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayerGameStat"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayerGameStat">
  <rdfs:comment xml:lang="en">Statistics for a player in a specific game, such as kill count and play time.</rdfs:comment>
  <rdfs:label xml:lang="en">Player game stat</rdfs:label>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Player"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Game"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Achievement"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Item"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Ability"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Genre"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Location"/>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasFriend">
  <rdfs:comment xml:lang="en">Links a player to another player who is a friend.</rdfs:comment>
  <rdfs:label xml:lang="en">has friend</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added symmetric property type to satisfy inverse requirement.: Pitfall: missing inverse for hasFriend. Made it symmetric so inverse is itself.</vaem:rationale>
  <dc:source>(pitfall) Missing inverse for hasFriend</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#playsGame">
  <rdfs:comment xml:lang="en">Indicates that a player plays a particular game.</rdfs:comment>
  <rdfs:label xml:lang="en">plays game</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isPlayedBy.: Pitfall: missing inverse for playsGame.</vaem:rationale>
  <dc:source>(pitfall) Missing inverse for playsGame</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isPlayedBy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAchievement">
  <rdfs:comment xml:lang="en">Connects a player or a game to an achievement.</rdfs:comment>
  <rdfs:label xml:lang="en">has achievement</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added domain as union of Player and Game, added inverse isAchievementOf.: Pitfall: missing domain and missing inverse for hasAchievement.</vaem:rationale>
  <dc:source>(pitfall) Missing domain for hasAchievement
    (pitfall) Missing inverse for hasAchievement</dc:source>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
  <rdfs:domain><owl:Class><owl:unionOf rdf:parseType="Collection"><owl:Class rdf:about="http://www.semanticweb.org/myontology#Player"/><owl:Class rdf:about="http://www.semanticweb.org/myontology#Game"/></owl:unionOf></owl:Class></rdfs:domain><owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isAchievementOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasItem">
  <rdfs:comment xml:lang="en">Connects a player or a game to an item.</rdfs:comment>
  <rdfs:label xml:lang="en">has item</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added domain as union of Player and Game, added inverse isItemOf.: Pitfall: missing domain and missing inverse for hasItem.</vaem:rationale>
  <dc:source>(pitfall) Missing domain for hasItem
    (pitfall) Missing inverse for hasItem</dc:source>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
  <rdfs:domain><owl:Class><owl:unionOf rdf:parseType="Collection"><owl:Class rdf:about="http://www.semanticweb.org/myontology#Player"/><owl:Class rdf:about="http://www.semanticweb.org/myontology#Game"/></owl:unionOf></owl:Class></rdfs:domain><owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isItemOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGenre">
  <rdfs:comment xml:lang="en">Indicates the genre of a game.</rdfs:comment>
  <rdfs:label xml:lang="en">has genre</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isGenreOf.: Pitfall: missing inverse for hasGenre.</vaem:rationale>
  <dc:source>(pitfall) Missing inverse for hasGenre</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Genre"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isGenreOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPlayingArea">
  <rdfs:comment xml:lang="en">Indicates a playing area within a game.</rdfs:comment>
  <rdfs:label xml:lang="en">has playing area</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isPlayingAreaOf.: Pitfall: missing inverse for hasPlayingArea.</vaem:rationale>
  <dc:source>(pitfall) Missing inverse for hasPlayingArea</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isPlayingAreaOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAbility">
  <rdfs:comment xml:lang="en">Indicates that an item possesses an ability.</rdfs:comment>
  <rdfs:label xml:lang="en">has ability</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isAbilityOf.: Pitfall: missing inverse for hasAbility.</vaem:rationale>
  <dc:source>(pitfall) Missing inverse for hasAbility</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Item"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Ability"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isAbilityOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasType">
  <rdfs:comment xml:lang="en">Indicates the type of an achievement.</rdfs:comment>
  <rdfs:label xml:lang="en">has type</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isTypeOf.: Pitfall: missing inverse for hasType.</vaem:rationale>
  <dc:source>(pitfall) Missing inverse for hasType</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isTypeOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasLocation">
  <rdfs:comment xml:lang="en">Indicates the geographical location of a player.</rdfs:comment>
  <rdfs:label xml:lang="en">has location</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isLocationOf.: Pitfall: missing inverse for hasLocation.</vaem:rationale>
  <dc:source>(pitfall) Missing inverse for hasLocation</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Location"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isLocationOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#makesPurchase">
  <rdfs:comment xml:lang="en">Indicates that a player made an in-app purchase.</rdfs:comment>
  <rdfs:label xml:lang="en">makes purchase</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isPurchaseMadeBy.: Pitfall: missing inverse for makesPurchase.</vaem:rationale>
  <dc:source>(pitfall) Missing inverse for makesPurchase</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isPurchaseMadeBy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#purchaseForGame">
  <rdfs:comment xml:lang="en">Indicates the game for which an in-app purchase was made.</rdfs:comment>
  <rdfs:label xml:lang="en">purchase for game</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isGameOfPurchase.: Pitfall: missing inverse for purchaseForGame.</vaem:rationale>
  <dc:source>(pitfall) Missing inverse for purchaseForGame</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isGameOfPurchase"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usedInGame">
  <rdfs:comment xml:lang="en">Indicates a game where an item can be used.</rdfs:comment>
  <rdfs:label xml:lang="en">used in game</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property hasUsableItem.: Pitfall: missing inverse for usedInGame.</vaem:rationale>
  <dc:source>(pitfall) Missing inverse for usedInGame</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Item"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasUsableItem"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPlayer">
  <rdfs:comment xml:lang="en">Links a PlayerGameStat to the player.</rdfs:comment>
  <rdfs:label xml:lang="en">has player</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isPlayerInStat.: Pitfall: missing inverse for hasPlayer.</vaem:rationale>
  <dc:source>(pitfall) Missing inverse for hasPlayer</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameStat"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isPlayerInStat"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGame">
  <rdfs:comment xml:lang="en">Links a PlayerGameStat to the game.</rdfs:comment>
  <rdfs:label xml:lang="en">has game</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isGameInStat.: Pitfall: missing inverse for hasGame.</vaem:rationale>
  <dc:source>(pitfall) Missing inverse for hasGame</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameStat"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isGameInStat"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isPlayedBy">
  <rdfs:comment xml:lang="en">Indicates the player who plays a game. Inverse of playsGame.</rdfs:comment>
  <rdfs:label xml:lang="en">is played by</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created as inverse of playsGame.: Required for inverse pitfall resolution.</vaem:rationale>
  <dc:source>(pitfall) Inverse property for playsGame</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#playsGame"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isAchievementOf">
  <rdfs:comment xml:lang="en">Indicates the player or game that owns an achievement. Inverse of hasAchievement.</rdfs:comment>
