  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasPlayTime">
  <rdfs:comment xml:lang="en">The play time of a player in a specific game, associated via PlayerGameStat.</rdfs:comment>
