<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#SoftwareTool">
  <rdfs:comment xml:lang="en">A software tool or application.</rdfs:comment>
  <rdfs:label xml:lang="en">Software Tool</rdfs:label>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Task"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#SoftwareType"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Version"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Developer"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#License"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#ProgrammingLanguage"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Platform"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Capability"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#DataArtifact"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Algorithm">
  <rdfs:comment xml:lang="en">A named and published algorithm used by a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Algorithm</rdfs:label>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Task"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#SoftwareType"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Version"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Developer"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#License"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#ProgrammingLanguage"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Platform"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Capability"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#DataArtifact"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Task">
  <rdfs:comment xml:lang="en">A task that a software tool can perform.</rdfs:comment>
  <rdfs:label xml:lang="en">Task</rdfs:label>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#SoftwareType"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Version"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Developer"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#License"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#ProgrammingLanguage"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Platform"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Capability"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#DataArtifact"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#DataFormat">
  <rdfs:comment xml:lang="en">A data format used for input or output.</rdfs:comment>
  <rdfs:label xml:lang="en">Data Format</rdfs:label>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Task"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#SoftwareType"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Version"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Developer"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#License"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#ProgrammingLanguage"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Platform"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Capability"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#DataArtifact"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#FileFormat">
  <rdfs:comment xml:lang="en">A file format, typically identified by a file extension.</rdfs:comment>
  <rdfs:label xml:lang="en">File Format</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#SoftwareType">
  <rdfs:comment xml:lang="en">The type of software, e.g., API, Desktop application, Web Service.</rdfs:comment>
  <rdfs:label xml:lang="en">Software Type</rdfs:label>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Task"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Version"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Developer"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#License"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#ProgrammingLanguage"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Platform"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Capability"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#DataArtifact"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Version">
  <rdfs:comment xml:lang="en">A specific version of a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Version</rdfs:label>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Task"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#SoftwareType"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Developer"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#License"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#ProgrammingLanguage"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Platform"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Capability"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#DataArtifact"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Developer">
  <rdfs:comment xml:lang="en">A person or organization that develops software.</rdfs:comment>
  <rdfs:label xml:lang="en">Developer</rdfs:label>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Task"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#SoftwareType"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Version"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#License"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#ProgrammingLanguage"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Platform"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Capability"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#DataArtifact"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#License">
  <rdfs:comment xml:lang="en">A software license.</rdfs:comment>
  <rdfs:label xml:lang="en">License</rdfs:label>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Task"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#SoftwareType"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Version"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Developer"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#ProgrammingLanguage"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Platform"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Capability"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#DataArtifact"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ProgrammingLanguage">
  <rdfs:comment xml:lang="en">A programming language used to implement software.</rdfs:comment>
  <rdfs:label xml:lang="en">Programming Language</rdfs:label>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Task"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#SoftwareType"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Version"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Developer"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#License"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Platform"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Capability"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#DataArtifact"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Platform">
  <rdfs:comment xml:lang="en">An operating system or platform software runs on.</rdfs:comment>
  <rdfs:label xml:lang="en">Platform</rdfs:label>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Task"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#SoftwareType"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Version"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Developer"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#License"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#ProgrammingLanguage"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Capability"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#DataArtifact"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Capability">
  <rdfs:comment xml:lang="en">A capability of a software tool, such as editing or rendering.</rdfs:comment>
  <rdfs:label xml:lang="en">Capability</rdfs:label>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Task"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#SoftwareType"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Version"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Developer"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#License"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#ProgrammingLanguage"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Platform"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#DataArtifact"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#DataArtifact">
  <rdfs:comment xml:lang="en">A data artifact created by a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Data Artifact</rdfs:label>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Task"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#SoftwareType"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Version"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Developer"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#License"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#ProgrammingLanguage"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Platform"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Capability"/>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usesAlgorithm">
  <rdfs:comment xml:lang="en">Indicates that a software tool uses a particular algorithm.</rdfs:comment>
  <rdfs:label xml:lang="en">uses algorithm</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isUsedBy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#canPerformTask">
  <rdfs:comment xml:lang="en">Links a software tool to a task it can perform.</rdfs:comment>
  <rdfs:label xml:lang="en">can perform task</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Task"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isPerformedBy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasSoftwareType">
  <rdfs:comment xml:lang="en">Associates a software tool with its type (e.g., API, Desktop application).</rdfs:comment>
  <rdfs:label xml:lang="en">has software type</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareType"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isSoftwareTypeOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasCapability">
  <rdfs:comment xml:lang="en">Links a software tool to a capability it provides.</rdfs:comment>
  <rdfs:label xml:lang="en">has capability</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Capability"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isCapabilityOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#createdData">
  <rdfs:comment xml:lang="en">Relates a software tool to a data artifact it created.</rdfs:comment>
  <rdfs:label xml:lang="en">created data</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DataArtifact"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#createdBy">
  <rdfs:comment xml:lang="en">Indicates the software tool that created a data artifact.</rdfs:comment>
  <rdfs:label xml:lang="en">created by</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#DataArtifact"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasInputFormat">
  <rdfs:comment xml:lang="en">Specifies a data format that a software tool can accept as input.</rdfs:comment>
  <rdfs:label xml:lang="en">has input format</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isInputFormatOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasOutputFormat">
  <rdfs:comment xml:lang="en">Specifies a data format that a software tool can produce as output.</rdfs:comment>
  <rdfs:label xml:lang="en">has output format</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isOutputFormatOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#canReadFormat">
  <rdfs:comment xml:lang="en">Indicates that a software tool can read a specific data format.</rdfs:comment>
  <rdfs:label xml:lang="en">can read format</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isReadableBy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#canWriteFormat">
  <rdfs:comment xml:lang="en">Indicates that a software tool can write a specific data format.</rdfs:comment>
  <rdfs:label xml:lang="en">can write format</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isWritableBy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#canWorkWithOutputOf">
  <rdfs:comment xml:lang="en">States that a software tool can work with data that are output from another software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">can work with output of</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isOutputWorkedWithBy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasVersion">
  <rdfs:comment xml:lang="en">Associates a software tool with a specific version.</rdfs:comment>
  <rdfs:label xml:lang="en">has version</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Version"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isVersionOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasDeveloper">
  <rdfs:comment xml:lang="en">Links a software tool to its developer (person or organization).</rdfs:comment>
  <rdfs:label xml:lang="en">has developer</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Developer"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isDeveloperOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#implementedIn">
  <rdfs:comment xml:lang="en">Indicates the programming language used to implement a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">implemented in</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#ProgrammingLanguage"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isImplementationOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#runsOnPlatform">
  <rdfs:comment xml:lang="en">Specifies the platform (e.g., Windows, Linux) that a software tool runs on.</rdfs:comment>
  <rdfs:label xml:lang="en">runs on platform</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Platform"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isPlatformFor"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasLicense">
  <rdfs:comment xml:lang="en">Associates a software tool with its license.</rdfs:comment>
  <rdfs:label xml:lang="en">has license</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#License"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isLicenseOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#versionHasExportFormat">
  <rdfs:comment xml:lang="en">Relates a version to an export data format it supports.</rdfs:comment>
  <rdfs:label xml:lang="en">version has export format</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Version"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isExportFormatOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isUsedBy">
  <rdfs:comment xml:lang="en">Inverse of usesAlgorithm. Indicates that an algorithm is used by a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">is used by</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isPerformedBy">
  <rdfs:comment xml:lang="en">Inverse of canPerformTask. Indicates that a task is performed by a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">is performed by</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Task"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isSoftwareTypeOf">
  <rdfs:comment xml:lang="en">Inverse of hasSoftwareType. Indicates that a software type is associated with a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">is software type of</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareType"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isCapabilityOf">
  <rdfs:comment xml:lang="en">Inverse of hasCapability. Indicates that a capability is provided by a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">is capability of</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Capability"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isInputFormatOf">
  <rdfs:comment xml:lang="en">Inverse of hasInputFormat. Indicates that a data format is accepted as input by a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">is input format of</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isOutputFormatOf">
  <rdfs:comment xml:lang="en">Inverse of hasOutputFormat. Indicates that a data format is produced as output by a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">is output format of</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isReadableBy">
  <rdfs:comment xml:lang="en">Inverse of canReadFormat. Indicates that a data format can be read by a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">is readable by</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isWritableBy">
  <rdfs:comment xml:lang="en">Inverse of canWriteFormat. Indicates that a data format can be written by a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">is writable by</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isOutputWorkedWithBy">
  <rdfs:comment xml:lang="en">Inverse of canWorkWithOutputOf. Indicates that a software tool's output can be worked with by another software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">is output worked with by</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isVersionOf">
  <rdfs:comment xml:lang="en">Inverse of hasVersion. Indicates that a version is associated with a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">is version of</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Version"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isDeveloperOf">
  <rdfs:comment xml:lang="en">Inverse of hasDeveloper. Indicates that a developer is associated with a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">is developer of</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Developer"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isImplementationOf">
  <rdfs:comment xml:lang="en">Inverse of implementedIn. Indicates that a programming language is used to implement a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">is implementation of</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ProgrammingLanguage"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isPlatformFor">
  <rdfs:comment xml:lang="en">Inverse of runsOnPlatform. Indicates that a platform is used by a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">is platform for</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Platform"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isLicenseOf">
  <rdfs:comment xml:lang="en">Inverse of hasLicense. Indicates that a license is associated with a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">is license of</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#License"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isExportFormatOf">
  <rdfs:comment xml:lang="en">Inverse of versionHasExportFormat. Indicates that a data format is an export format of a version.</rdfs:comment>
  <rdfs:label xml:lang="en">is export format of</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Version"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasAlgorithmModification">
  <rdfs:comment xml:lang="en">Indicates whether a software tool has modifications to its algorithm.</rdfs:comment>
  <rdfs:label xml:lang="en">has algorithm modification</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#supportsXMLEditing">
  <rdfs:comment xml:lang="en">Indicates whether the software provides XML editing capabilities.</rdfs:comment>
  <rdfs:label xml:lang="en">supports XML editing</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isWebService">
  <rdfs:comment xml:lang="en">Indicates whether the software is available as a web service.</rdfs:comment>
  <rdfs:label xml:lang="en">is web service</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#canExportToOpenFormat">
  <rdfs:comment xml:lang="en">Indicates whether the software can export to an open format (e.g., CSV, TXT).</rdfs:comment>
  <rdfs:label xml:lang="en">can export to open format</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isOpenSource">
  <rdfs:comment xml:lang="en">Indicates whether the software is open source.</rdfs:comment>
  <rdfs:label xml:lang="en">is open source</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isFOSS">
  <rdfs:comment xml:lang="en">Indicates whether the software is Free and Open Source Software (FOSS).</rdfs:comment>
  <rdfs:label xml:lang="en">is FOSS</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isFree">
  <rdfs:comment xml:lang="en">Indicates whether the software is free of charge.</rdfs:comment>
  <rdfs:label xml:lang="en">is free</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isMaintained">
  <rdfs:comment xml:lang="en">Indicates whether the software is actively maintained.</rdfs:comment>
  <rdfs:label xml:lang="en">is maintained</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#allowsCollaboration">
  <rdfs:comment xml:lang="en">Indicates whether it is possible to collaborate with the developers of the software.</rdfs:comment>
  <rdfs:label xml:lang="en">allows collaboration</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasCommunitySupport">
  <rdfs:comment xml:lang="en">Indicates whether there is community support for the software.</rdfs:comment>
  <rdfs:label xml:lang="en">has community support</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#downloadURL">
  <rdfs:comment xml:lang="en">URL from which the software can be downloaded.</rdfs:comment>
  <rdfs:label xml:lang="en">download URL</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#homepageURL">
  <rdfs:comment xml:lang="en">URL of the software's homepage.</rdfs:comment>
  <rdfs:label xml:lang="en">homepage URL</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#helpURL">
  <rdfs:comment xml:lang="en">URL for help or support for the software.</rdfs:comment>
  <rdfs:label xml:lang="en">help URL</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#documentationURL">
  <rdfs:comment xml:lang="en">URL of the software's documentation.</rdfs:comment>
  <rdfs:label xml:lang="en">documentation URL</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#supportEmail">
  <rdfs:comment xml:lang="en">Email address for support.</rdfs:comment>
  <rdfs:label xml:lang="en">support email</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#creationDate">
  <rdfs:comment xml:lang="en">Date when the software was first created or released.</rdfs:comment>
  <rdfs:label xml:lang="en">creation date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#lastReleaseDate">
  <rdfs:comment xml:lang="en">Date of the most recent release of the software.</rdfs:comment>
  <rdfs:label xml:lang="en">last release date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#versionNumber">
  <rdfs:comment xml:lang="en">The version number string (e.g., 1.0, 2.3.1).</rdfs:comment>
  <rdfs:label xml:lang="en">version number</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Version"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#versionReleaseDate">
  <rdfs:comment xml:lang="en">The release date of a specific version.</rdfs:comment>
  <rdfs:label xml:lang="en">version release date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Version"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#newFeatures">
  <rdfs:comment xml:lang="en">Description of new features in a version.</rdfs:comment>
  <rdfs:label xml:lang="en">new features</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Version"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#fileExtension">
  <rdfs:comment xml:lang="en">The file extension associated with a file format (e.g., .cel).</rdfs:comment>
  <rdfs:label xml:lang="en">file extension</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#FileFormat"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isProprietary">
  <rdfs:comment xml:lang="en">Indicates whether a data format is proprietary.</rdfs:comment>
  <rdfs:label xml:lang="en">is proprietary</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#name">
  <rdfs:comment xml:lang="en">The name of a developer (person or organization).</rdfs:comment>
  <rdfs:label xml:lang="en">name</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Developer"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#email">
  <rdfs:comment xml:lang="en">Email address of a developer.</rdfs:comment>
  <rdfs:label xml:lang="en">email</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Developer"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#licenseName">
  <rdfs:comment xml:lang="en">The name of the license (e.g., MIT, GPL).</rdfs:comment>
  <rdfs:label xml:lang="en">license name</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#License"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#licensePermissiveness">
  <rdfs:comment xml:lang="en">The permissiveness level of the license (e.g., permissive, copyleft).</rdfs:comment>
  <rdfs:label xml:lang="en">license permissiveness</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#License"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

</rdf:RDF>