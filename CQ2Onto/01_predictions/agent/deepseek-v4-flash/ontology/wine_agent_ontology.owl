<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Wine">
  <rdfs:comment xml:lang="en">A beverage made from fermented grapes.</rdfs:comment>
  <rdfs:label xml:lang="en">Wine</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#RedWine">
  <rdfs:comment xml:lang="en">Wine with a red color.</rdfs:comment>
  <rdfs:label xml:lang="en">Red Wine</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjointness with WhiteWine: Resolving pitfall 'Lack of disjoint axioms' - RedWine and WhiteWine should be disjoint.</vaem:rationale>
  <dc:source>(pitfall) The ontology lacks disjoint axioms between classes or between properties that should be defined as disjoint.</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#WhiteWine"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WhiteWine">
  <rdfs:comment xml:lang="en">Wine with a white or pale color.</rdfs:comment>
  <rdfs:label xml:lang="en">White Wine</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjointness with RedWine: Resolving pitfall 'Lack of disjoint axioms' - RedWine and WhiteWine should be disjoint.</vaem:rationale>
  <dc:source>(pitfall) The ontology lacks disjoint axioms between classes or between properties that should be defined as disjoint.</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#RedWine"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#BordeauxWine">
  <rdfs:comment xml:lang="en">Wine produced in the Bordeaux region of France, typically red.</rdfs:comment>
  <rdfs:label xml:lang="en">Bordeaux Wine</rdfs:label>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#RedWine"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#NapaZinfandelWine">
  <rdfs:comment xml:lang="en">Zinfandel wine produced in the Napa Valley region.</rdfs:comment>
  <rdfs:label xml:lang="en">Napa Zinfandel Wine</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added declarations for NapaRegion and Zinfandel classes used in equivalent class definition: Resolving pitfall 'Undefined entities used as classes' - NapaRegion and Zinfandel must be declared.</vaem:rationale>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
<owl:equivalentClass>
  <owl:Class>
    <owl:intersectionOf rdf:parseType="Collection">
      <rdf:Description rdf:about="http://www.semanticweb.org/myontology#Wine"/>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://www.semanticweb.org/myontology#producedIn"/>
        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/myontology#NapaRegion"/>
      </owl:Restriction>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://www.semanticweb.org/myontology#madeFromGrape"/>
        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/myontology#Zinfandel"/>
      </owl:Restriction>
    </owl:intersectionOf>
  </owl:Class>
</owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Color">
  <rdfs:comment xml:lang="en">Color of wine.</rdfs:comment>
  <rdfs:label xml:lang="en">Color</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Grape">
  <rdfs:comment xml:lang="en">Grape variety used for winemaking.</rdfs:comment>
  <rdfs:label xml:lang="en">Grape</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Region">
  <rdfs:comment xml:lang="en">Wine-producing region.</rdfs:comment>
  <rdfs:label xml:lang="en">Region</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#NapaRegion">
  <rdfs:comment xml:lang="en">The Napa Valley region.</rdfs:comment>
  <rdfs:label xml:lang="en">Napa Region</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Declared NapaRegion as a subclass of Region: Resolving pitfall 'Undefined entities used as classes' - NapaRegion was used as a class in restrictions without declaration.</vaem:rationale>
  <dc:source>(pitfall) An ontology element is used as a class without having been explicitly declared as such.</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Region"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Zinfandel">
  <rdfs:comment xml:lang="en">Zinfandel grape variety.</rdfs:comment>
  <rdfs:label xml:lang="en">Zinfandel</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Declared Zinfandel as a subclass of Grape: Resolving pitfall 'Undefined entities used as classes' - Zinfandel was used as a class in restrictions without declaration.</vaem:rationale>
  <dc:source>(pitfall) An ontology element is used as a class without having been explicitly declared as such.</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Grape"/>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasColor">
  <rdfs:comment xml:lang="en">Indicates the color of a wine.</rdfs:comment>
  <rdfs:label xml:lang="en">has color</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isColorOf: Resolving pitfall 'Missing inverse relationships' - hasColor should have an inverse.</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Color"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isColorOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#producedIn">
  <rdfs:comment xml:lang="en">Indicates the region where a wine is produced.</rdfs:comment>
  <rdfs:label xml:lang="en">produced in</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property produces: Resolving pitfall 'Missing inverse relationships' - producedIn should have an inverse.</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Region"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#produces"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#madeFromGrape">
  <rdfs:comment xml:lang="en">Indicates the grape variety used to make a wine.</rdfs:comment>
  <rdfs:label xml:lang="en">made from grape</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isGrapeOf: Resolving pitfall 'Missing inverse relationships' - madeFromGrape should have an inverse.</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Grape"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isGrapeOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isColorOf">
  <rdfs:comment xml:lang="en">Inverse of hasColor: indicates that a color is the color of a wine.</rdfs:comment>
  <rdfs:label xml:lang="en">is color of</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property for hasColor: Resolving pitfall 'Missing inverse relationships'.</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Color"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasColor"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#produces">
  <rdfs:comment xml:lang="en">Inverse of producedIn: indicates that a region produces a wine.</rdfs:comment>
  <rdfs:label xml:lang="en">produces</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property for producedIn: Resolving pitfall 'Missing inverse relationships'.</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Region"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#producedIn"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isGrapeOf">
  <rdfs:comment xml:lang="en">Inverse of madeFromGrape: indicates that a grape is used to make a wine.</rdfs:comment>
  <rdfs:label xml:lang="en">is grape of</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property for madeFromGrape: Resolving pitfall 'Missing inverse relationships'.</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Grape"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#madeFromGrape"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasBouquet">
  <rdfs:comment xml:lang="en">The bouquet (aroma) of the wine.</rdfs:comment>
  <rdfs:label xml:lang="en">has bouquet</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Corrected range to proper XSD datatype URI: Resolving pitfall 'Undefined entities used as classes' - xsd:string was incorrectly referenced under the ontology namespace.</vaem:rationale>
  <dc:source>(pitfall) An ontology element is used as a class without having been explicitly declared as such.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasBody">
  <rdfs:comment xml:lang="en">The body (mouthfeel) of the wine.</rdfs:comment>
  <rdfs:label xml:lang="en">has body</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Corrected range to proper XSD datatype URI: Resolving pitfall 'Undefined entities used as classes' - xsd:string was incorrectly referenced under the ontology namespace.</vaem:rationale>
  <dc:source>(pitfall) An ontology element is used as a class without having been explicitly declared as such.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasVintageYear">
  <rdfs:comment xml:lang="en">The vintage year of the wine.</rdfs:comment>
  <rdfs:label xml:lang="en">has vintage year</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Corrected range to proper XSD datatype URI: Resolving pitfall 'Undefined entities used as classes' - xsd:gYear was incorrectly referenced under the ontology namespace.</vaem:rationale>
  <dc:source>(pitfall) An ontology element is used as a class without having been explicitly declared as such.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isGoodVintage">
  <rdfs:comment xml:lang="en">Indicates whether the vintage is considered good.</rdfs:comment>
  <rdfs:label xml:lang="en">is good vintage</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Corrected range to proper XSD datatype URI: Resolving pitfall 'Undefined entities used as classes' - xsd:boolean was incorrectly referenced under the ontology namespace.</vaem:rationale>
  <dc:source>(pitfall) An ontology element is used as a class without having been explicitly declared as such.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
</owl:DatatypeProperty>

</rdf:RDF>