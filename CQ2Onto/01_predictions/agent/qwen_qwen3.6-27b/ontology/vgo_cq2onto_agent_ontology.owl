<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasFriend">
  <rdfs:comment xml:lang="en">Links a player to their friends within the gaming network.</rdfs:comment>
  <rdfs:label xml:lang="en">has Friend</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property hasFriend: Required by CQ02, CQ03, CQ05, CQ07
    [Pitfall Resolution Agent] Added inverse property isFriendOf: Resolves OOPS pitfall: Missing inverse relationships</vaem:rationale>
  <dc:source>(competency_question) CQ02, CQ03, CQ05, CQ07
    (pitfall) Missing inverse relationships</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isFriendOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isFriendOf">
  <rdfs:comment xml:lang="en">Inverse of hasFriend. Links a player to their friends.</rdfs:comment>
  <rdfs:label xml:lang="en">is Friend Of</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property for hasFriend: Resolves OOPS pitfall: Missing inverse relationships</vaem:rationale>
  <dc:source>(pitfall) Missing inverse relationships</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasFriend"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPlayedGame">
  <rdfs:comment xml:lang="en">Indicates a game that a player has played at some point.</rdfs:comment>
  <rdfs:label xml:lang="en">has Played Game</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property hasPlayedGame: Required by CQ03, CQ25, CQ35
    [Pitfall Resolution Agent] Added inverse property isPlayedBy: Resolves OOPS pitfall: Missing inverse relationships</vaem:rationale>
  <dc:source>(competency_question) CQ03, CQ25, CQ35
    (pitfall) Missing inverse relationships</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isPlayedBy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isPlayedBy">
  <rdfs:comment xml:lang="en">Inverse of hasPlayedGame. Links a game to players who have played it.</rdfs:comment>
  <rdfs:label xml:lang="en">is Played By</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property for hasPlayedGame: Resolves OOPS pitfall: Missing inverse relationships</vaem:rationale>
  <dc:source>(pitfall) Missing inverse relationships</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasPlayedGame"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasObtainedAchievement">
  <rdfs:comment xml:lang="en">Links a player to achievements they have successfully earned.</rdfs:comment>
  <rdfs:label xml:lang="en">has Obtained Achievement</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property hasObtainedAchievement: Required by CQ05, CQ07, CQ24, CQ27, CQ35
    [Pitfall Resolution Agent] Added inverse property isObtainedBy: Resolves OOPS pitfall: Missing inverse relationships</vaem:rationale>
