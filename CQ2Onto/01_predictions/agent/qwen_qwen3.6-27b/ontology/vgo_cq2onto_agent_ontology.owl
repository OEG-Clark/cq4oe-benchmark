<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usableInGame">
  <rdfs:comment xml:lang="en">Links an item to games where it can be utilized or equipped.</rdfs:comment>
  <rdfs:label xml:lang="en">usable In Game</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property usableInGame: Required by CQ55
    [Pitfall Resolution Agent] Linked as inverse of containsItem: Resolves OOPS pitfall: Missing inverse relationships</vaem:rationale>
  <dc:source>(competency_question) CQ55
    (pitfall) Missing inverse relationships</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Item"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#containsItem"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#ownsItem">
  <rdfs:comment xml:lang="en">Links a player to items they currently possess or have collected.</rdfs:comment>
  <rdfs:label xml:lang="en">owns Item</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property ownsItem: Required by CQ26
    [Pitfall Resolution Agent] Added inverse property isOwnedBy: Resolves OOPS pitfall: Missing inverse relationships</vaem:rationale>
  <dc:source>(competency_question) CQ26
    (pitfall) Missing inverse relationships</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isOwnedBy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isOwnedBy">
  <rdfs:comment xml:lang="en">Inverse of ownsItem. Links an item to the player who owns it.</rdfs:comment>
  <rdfs:label xml:lang="en">is Owned By</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property for ownsItem: Resolves OOPS pitfall: Missing inverse relationships</vaem:rationale>
  <dc:source>(pitfall) Missing inverse relationships</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Item"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#ownsItem"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAbility">
  <rdfs:comment xml:lang="en">Links an item to the abilities or effects it grants.</rdfs:comment>
  <rdfs:label xml:lang="en">has Ability</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property hasAbility: Required by CQ19
    [Pitfall Resolution Agent] Added inverse property isGrantedBy: Resolves OOPS pitfall: Missing inverse relationships</vaem:rationale>
  <dc:source>(competency_question) CQ19
