</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isObtainedBy">
  <rdfs:comment xml:lang="en">Inverse of hasObtainedAchievement. Links an achievement to the player who earned it.</rdfs:comment>
  <rdfs:label xml:lang="en">is Obtained By</rdfs:label>
