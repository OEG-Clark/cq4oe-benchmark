  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Item"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Ability"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isGrantedBy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isGrantedBy">
  <rdfs:comment xml:lang="en">Inverse of hasAbility. Links an ability to the item that grants it.</rdfs:comment>
  <rdfs:label xml:lang="en">is Granted By</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property for hasAbility: Resolves OOPS pitfall: Missing inverse relationships</vaem:rationale>
  <dc:source>(pitfall) Missing inverse relationships</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Ability"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasAbility"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasLastPlayedGame">
  <rdfs:comment xml:lang="en">Indicates the most recent game a player has played.</rdfs:comment>
  <rdfs:label xml:lang="en">has Last Played Game</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property hasLastPlayedGame: Required by CQ29
    [Pitfall Resolution Agent] Added inverse property isLastPlayedBy: Resolves OOPS pitfall: Missing inverse relationships</vaem:rationale>
  <dc:source>(competency_question) CQ29
    (pitfall) Missing inverse relationships</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isLastPlayedBy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isLastPlayedBy">
  <rdfs:comment xml:lang="en">Inverse of hasLastPlayedGame. Links a game to the player who last played it.</rdfs:comment>
