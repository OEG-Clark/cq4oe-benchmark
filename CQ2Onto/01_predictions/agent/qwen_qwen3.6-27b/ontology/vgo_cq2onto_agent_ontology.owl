<owl:Class rdf:about="http://www.semanticweb.org/myontology#Player">
  <rdfs:comment xml:lang="en">A user who plays games and interacts with the gaming ecosystem.</rdfs:comment>
  <rdfs:label xml:lang="en">Player</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Player: Required by CQ01, CQ02, CQ03, CQ22, CQ24, CQ25, CQ26, CQ27, CQ29, CQ35, CQ52, CQ56, CQ57, CQ63, CQ64, CQ65, CQ66
    [Pitfall Resolution Agent] Added disjoint axioms with other top-level classes: Resolves OOPS pitfall: Missing disjoint axioms between classes</vaem:rationale>
  <dc:source>(competency_question) CQ01, CQ02, CQ03, CQ22, CQ24, CQ25, CQ26, CQ27, CQ29, CQ35, CQ52, CQ56, CQ57, CQ63, CQ64, CQ65, CQ66
    (pitfall) Missing disjoint axioms between classes</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Game"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Item"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Ability"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Location"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Genre"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Game">
  <rdfs:comment xml:lang="en">A digital game that can be played, contains items, achievements, and playing areas.</rdfs:comment>
  <rdfs:label xml:lang="en">Game</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Game: Required by CQ03, CQ08, CQ09, CQ10, CQ11, CQ12, CQ13, CQ15, CQ17, CQ22, CQ25, CQ29, CQ35, CQ55, CQ64, New CQ1
    [Pitfall Resolution Agent] Added disjoint axioms with other top-level classes: Resolves OOPS pitfall: Missing disjoint axioms between classes</vaem:rationale>
  <dc:source>(competency_question) CQ03, CQ08, CQ09, CQ10, CQ11, CQ12, CQ13, CQ15, CQ17, CQ22, CQ25, CQ29, CQ35, CQ55, CQ64, New CQ1
    (pitfall) Missing disjoint axioms between classes</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Item"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Ability"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Location"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Genre"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Achievement">
  <rdfs:comment xml:lang="en">A reward, milestone, or badge that can be obtained by a player or defined in a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Achievement</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Achievement: Required by CQ05, CQ07, CQ08, CQ10, CQ11, CQ24, CQ27, CQ35
    [Pitfall Resolution Agent] Added disjoint axioms with other top-level classes: Resolves OOPS pitfall: Missing disjoint axioms between classes</vaem:rationale>
  <dc:source>(competency_question) CQ05, CQ07, CQ08, CQ10, CQ11, CQ24, CQ27, CQ35
    (pitfall) Missing disjoint axioms between classes</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Item"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Ability"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Location"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Genre"/>
