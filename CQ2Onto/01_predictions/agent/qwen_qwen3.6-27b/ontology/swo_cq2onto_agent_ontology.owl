<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#SoftwareTool">
  <rdfs:comment xml:lang="en">A software application, library, or service designed to perform specific computational tasks.</rdfs:comment>
  <rdfs:label xml:lang="en">Software Tool</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created core class representing software entities: Central entity referenced across nearly all competency questions
    [Pitfall Resolution Agent] Created core class representing software entities: Central entity referenced across nearly all competency questions: Initial ontology generation
    [Pitfall Resolution Agent] Added disjoint axioms with all other top-level classes: Fixes OOPS pitfall regarding missing disjoint axioms between classes</vaem:rationale>
  <dc:source>(competency_question) CQ04, CQ05, CQ06, CQ07, CQ08, CQ11, CQ14, CQ15, CQ16, CQ17, CQ19, CQ21, CQ22, CQ23, CQ26, CQ29, CQ30, CQ32, CQ36, CQ37, CQ38, CQ40, CQ45, CQ46, CQ54, CQ58, CQ59, CQ60, CQ65, CQ68, CQ73, CQ84, CQ85
    (pitfall) Missing disjoint axioms between classes</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Task"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#License"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#ProgrammingLanguage"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Platform"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Developer"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Data"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#SoftwareVersion"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#AlgorithmModification"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Feature"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#SoftwareType"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#SoftwareVersion">
  <rdfs:comment xml:lang="en">A specific release or iteration of a software tool, identified by a version string and release date.</rdfs:comment>
  <rdfs:label xml:lang="en">Software Version</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to model versioned releases of software: Required to answer questions about version history, features, and release dates
    [Pitfall Resolution Agent] Created to model versioned releases of software: Required to answer questions about version history, features, and release dates: Initial ontology generation</vaem:rationale>
  <dc:source>(competency_question) CQ29, CQ54, CQ55, CQ57</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Algorithm">
  <rdfs:comment xml:lang="en">A named, published computational procedure or method used by software.</rdfs:comment>
  <rdfs:label xml:lang="en">Algorithm</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to represent computational methods: Needed to track which algorithms a tool uses and their modifications
    [Pitfall Resolution Agent] Created to represent computational methods: Needed to track which algorithms a tool uses and their modifications: Initial ontology generation</vaem:rationale>
  <dc:source>(competency_question) CQ04, CQ05</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#AlgorithmModification">
  <rdfs:comment xml:lang="en">A change, adaptation, or extension applied to a base algorithm.</rdfs:comment>
  <rdfs:label xml:lang="en">Algorithm Modification</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to capture deviations from standard algorithms: Addresses CQ05 regarding modifications to used algorithms
    [Pitfall Resolution Agent] Created to capture deviations from standard algorithms: Addresses CQ05 regarding modifications to used algorithms: Initial ontology generation</vaem:rationale>
  <dc:source>(competency_question) CQ05</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#DataFormat">
  <rdfs:comment xml:lang="en">A standardized or proprietary structure for encoding data, e.g., CSV, XML, .cel.</rdfs:comment>
  <rdfs:label xml:lang="en">Data Format</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to model input/output data structures: Essential for tracking software compatibility, imports, and exports
    [Pitfall Resolution Agent] Created to model input/output data structures: Essential for tracking software compatibility, imports, and exports: Initial ontology generation</vaem:rationale>
  <dc:source>(competency_question) CQ06, CQ17, CQ19, CQ21, CQ22, CQ26, CQ29</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Task">
  <rdfs:comment xml:lang="en">A specific computational or analytical objective that software can perform.</rdfs:comment>
  <rdfs:label xml:lang="en">Task</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to represent functional capabilities: Needed to match software capabilities with user requirements
    [Pitfall Resolution Agent] Created to represent functional capabilities: Needed to match software capabilities with user requirements: Initial ontology generation</vaem:rationale>
  <dc:source>(competency_question) CQ08, CQ14, CQ16</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#SoftwareType">
  <rdfs:comment xml:lang="en">A classification of software delivery or execution model, e.g., API, Desktop, WebService.</rdfs:comment>
  <rdfs:label xml:lang="en">Software Type</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to categorize software deployment models: Addresses CQ07 and CQ11 regarding application types and web services
    [Pitfall Resolution Agent] Created to categorize software deployment models: Addresses CQ07 and CQ11 regarding application types and web services: Initial ontology generation</vaem:rationale>
  <dc:source>(competency_question) CQ07, CQ11</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#License">
  <rdfs:comment xml:lang="en">A legal instrument governing the use, modification, and distribution of software.</rdfs:comment>
  <rdfs:label xml:lang="en">License</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to model software licensing terms: Required to answer questions about open source status, FOSS, and permissiveness
    [Pitfall Resolution Agent] Created to model software licensing terms: Required to answer questions about open source status, FOSS, and permissiveness: Initial ontology generation</vaem:rationale>
  <dc:source>(competency_question) CQ58, CQ59, CQ60, CQ65</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ProgrammingLanguage">
  <rdfs:comment xml:lang="en">A formal language comprising a set of instructions used to produce various kinds of output.</rdfs:comment>
  <rdfs:label xml:lang="en">Programming Language</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to track implementation languages: Addresses CQ84 regarding the language used to implement the software
    [Pitfall Resolution Agent] Created to track implementation languages: Addresses CQ84 regarding the language used to implement the software: Initial ontology generation</vaem:rationale>
  <dc:source>(competency_question) CQ84</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Platform">
  <rdfs:comment xml:lang="en">A computing environment or operating system on which software can run.</rdfs:comment>
  <rdfs:label xml:lang="en">Platform</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to model execution environments: Addresses CQ85 regarding supported operating systems and architectures
    [Pitfall Resolution Agent] Created to model execution environments: Addresses CQ85 regarding supported operating systems and architectures: Initial ontology generation</vaem:rationale>
  <dc:source>(competency_question) CQ85</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Developer">
  <rdfs:comment xml:lang="en">An individual or organization responsible for creating or maintaining software.</rdfs:comment>
  <rdfs:label xml:lang="en">Developer</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to represent software authors and maintainers: Addresses CQ36 and CQ38 regarding authorship and collaboration
    [Pitfall Resolution Agent] Created to represent software authors and maintainers: Addresses CQ36 and CQ38 regarding authorship and collaboration: Initial ontology generation</vaem:rationale>
  <dc:source>(competency_question) CQ36, CQ38</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Feature">
  <rdfs:comment xml:lang="en">A distinct capability or functionality introduced in a software version.</rdfs:comment>
  <rdfs:label xml:lang="en">Feature</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to track version-specific capabilities: Addresses CQ55 regarding new features in specific versions
    [Pitfall Resolution Agent] Created to track version-specific capabilities: Addresses CQ55 regarding new features in specific versions: Initial ontology generation</vaem:rationale>
  <dc:source>(competency_question) CQ55</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Data">
  <rdfs:comment xml:lang="en">A digital artifact or dataset that can be created, processed, or exchanged by software.</rdfs:comment>
  <rdfs:label xml:lang="en">Data</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to represent digital artifacts: Addresses CQ15 regarding which software created specific data
    [Pitfall Resolution Agent] Created to represent digital artifacts: Addresses CQ15 regarding which software created specific data: Initial ontology generation</vaem:rationale>
  <dc:source>(competency_question) CQ15</dc:source>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usesAlgorithm">
  <rdfs:comment xml:lang="en">Relates a software tool to the computational algorithms it implements.</rdfs:comment>
  <rdfs:label xml:lang="en">Uses Algorithm</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to link software to algorithms: Directly answers CQ04
    [Pitfall Resolution Agent] Created to link software to algorithms: Directly answers CQ04: Initial ontology generation
    [Pitfall Resolution Agent] Added inverseOf axiom pointing to isUsedBy: Fixes OOPS pitfall regarding missing inverse relationships</vaem:rationale>
  <dc:source>(competency_question) CQ04
    (pitfall) Missing inverse relationship for usesAlgorithm</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isUsedBy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isUsedBy">
  <rdfs:comment xml:lang="en">Inverse of usesAlgorithm: Relates an algorithm to the software tools that implement it.</rdfs:comment>
  <rdfs:label xml:lang="en">Is Used By</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created as inverse property for usesAlgorithm: Fixes OOPS pitfall regarding missing inverse relationships</vaem:rationale>
  <dc:source>(pitfall) Missing inverse relationship for usesAlgorithm</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#usesAlgorithm"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasModification">
  <rdfs:comment xml:lang="en">Relates an algorithm to its specific modifications or adaptations.</rdfs:comment>
  <rdfs:label xml:lang="en">Has Modification</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to track algorithm changes: Directly answers CQ05
    [Pitfall Resolution Agent] Created to track algorithm changes: Directly answers CQ05: Initial ontology generation
    [Pitfall Resolution Agent] Added inverseOf axiom pointing to modifies: Fixes OOPS pitfall regarding missing inverse relationships</vaem:rationale>
  <dc:source>(competency_question) CQ05
    (pitfall) Missing inverse relationship for hasModification</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#AlgorithmModification"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#modifies"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#modifies">
  <rdfs:comment xml:lang="en">Inverse of hasModification: Relates a modification to the base algorithm it adapts.</rdfs:comment>
  <rdfs:label xml:lang="en">Modifies</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created as inverse property for hasModification: Fixes OOPS pitfall regarding missing inverse relationships</vaem:rationale>
  <dc:source>(pitfall) Missing inverse relationship for hasModification</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#AlgorithmModification"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasModification"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasType">
  <rdfs:comment xml:lang="en">Classifies a software tool by its deployment or execution model.</rdfs:comment>
  <rdfs:label xml:lang="en">Has Type</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to categorize software delivery models: Answers CQ07 and CQ11
    [Pitfall Resolution Agent] Created to categorize software delivery models: Answers CQ07 and CQ11: Initial ontology generation
    [Pitfall Resolution Agent] Added inverseOf axiom pointing to isTypeOf: Fixes OOPS pitfall regarding missing inverse relationships</vaem:rationale>
  <dc:source>(competency_question) CQ07, CQ11
    (pitfall) Missing inverse relationship for hasType</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareType"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isTypeOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isTypeOf">
  <rdfs:comment xml:lang="en">Inverse of hasType: Relates a software type to the tools classified under it.</rdfs:comment>
  <rdfs:label xml:lang="en">Is Type Of</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created as inverse property for hasType: Fixes OOPS pitfall regarding missing inverse relationships</vaem:rationale>
  <dc:source>(pitfall) Missing inverse relationship for hasType</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareType"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasType"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#performsTask">
  <rdfs:comment xml:lang="en">Indicates the computational tasks a software tool is capable of executing.</rdfs:comment>
  <rdfs:label xml:lang="en">Performs Task</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to map software to functional capabilities: Answers CQ08, CQ14, CQ16
    [Pitfall Resolution Agent] Created to map software to functional capabilities: Answers CQ08, CQ14, CQ16: Initial ontology generation
    [Pitfall Resolution Agent] Added inverseOf axiom pointing to isPerformedBy: Fixes OOPS pitfall regarding missing inverse relationships</vaem:rationale>
  <dc:source>(competency_question) CQ08, CQ14, CQ16
    (pitfall) Missing inverse relationship for performsTask</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Task"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isPerformedBy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isPerformedBy">
  <rdfs:comment xml:lang="en">Inverse of performsTask: Relates a task to the software tools that can execute it.</rdfs:comment>
  <rdfs:label xml:lang="en">Is Performed By</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created as inverse property for performsTask: Fixes OOPS pitfall regarding missing inverse relationships</vaem:rationale>
  <dc:source>(pitfall) Missing inverse relationship for performsTask</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Task"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#performsTask"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#acceptsInputFormat">
  <rdfs:comment xml:lang="en">Specifies the data formats a software tool can read or process as input.</rdfs:comment>
  <rdfs:label xml:lang="en">Accepts Input Format</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to model input compatibility: Answers CQ17, CQ19, CQ21, CQ26
    [Pitfall Resolution Agent] Created to model input compatibility: Answers CQ17, CQ19, CQ21, CQ26: Initial ontology generation
    [Pitfall Resolution Agent] Added inverseOf axiom pointing to isAcceptedBy: Fixes OOPS pitfall regarding missing inverse relationships</vaem:rationale>
  <dc:source>(competency_question) CQ17, CQ19, CQ21, CQ26
    (pitfall) Missing inverse relationship for acceptsInputFormat</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isAcceptedBy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isAcceptedBy">
  <rdfs:comment xml:lang="en">Inverse of acceptsInputFormat: Relates a data format to the software tools that can read it.</rdfs:comment>
  <rdfs:label xml:lang="en">Is Accepted By</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created as inverse property for acceptsInputFormat: Fixes OOPS pitfall regarding missing inverse relationships</vaem:rationale>
  <dc:source>(pitfall) Missing inverse relationship for acceptsInputFormat</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#acceptsInputFormat"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#producesOutputFormat">
  <rdfs:comment xml:lang="en">Specifies the data formats a software tool can generate or export.</rdfs:comment>
  <rdfs:label xml:lang="en">Produces Output Format</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to model output compatibility: Answers CQ17, CQ22, CQ23, CQ29
    [Pitfall Resolution Agent] Created to model output compatibility: Answers CQ17, CQ22, CQ23, CQ29: Initial ontology generation
    [Pitfall Resolution Agent] Added inverseOf axiom pointing to isProducedBy: Fixes OOPS pitfall regarding missing inverse relationships</vaem:rationale>
  <dc:source>(competency_question) CQ17, CQ22, CQ23, CQ29
    (pitfall) Missing inverse relationship for producesOutputFormat</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isProducedBy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isProducedBy">
  <rdfs:comment xml:lang="en">Inverse of producesOutputFormat: Relates a data format to the software tools that can generate it.</rdfs:comment>
  <rdfs:label xml:lang="en">Is Produced By</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created as inverse property for producesOutputFormat: Fixes OOPS pitfall regarding missing inverse relationships</vaem:rationale>
  <dc:source>(pitfall) Missing inverse relationship for producesOutputFormat</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#producesOutputFormat"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#compatibleWithOutputOf">
  <rdfs:comment xml:lang="en">Indicates that a software tool can process data generated by another software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Compatible With Output Of</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to model inter-software data compatibility: Answers CQ23
    [Pitfall Resolution Agent] Created to model inter-software data compatibility: Answers CQ23: Initial ontology generation
    [Pitfall Resolution Agent] Added inverseOf axiom pointing to outputCompatibleWith: Fixes OOPS pitfall regarding missing inverse relationships</vaem:rationale>
  <dc:source>(competency_question) CQ23
    (pitfall) Missing inverse relationship for compatibleWithOutputOf</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#outputCompatibleWith"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#outputCompatibleWith">
  <rdfs:comment xml:lang="en">Inverse of compatibleWithOutputOf: Indicates that a software tool's output can be processed by another tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Output Compatible With</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created as inverse property for compatibleWithOutputOf: Fixes OOPS pitfall regarding missing inverse relationships</vaem:rationale>
  <dc:source>(pitfall) Missing inverse relationship for compatibleWithOutputOf</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#compatibleWithOutputOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasVersion">
  <rdfs:comment xml:lang="en">Links a software tool to its specific released versions.</rdfs:comment>
  <rdfs:label xml:lang="en">Has Version</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to track version history: Answers CQ29, CQ54
    [Pitfall Resolution Agent] Created to track version history: Answers CQ29, CQ54: Initial ontology generation
    [Pitfall Resolution Agent] Added inverseOf axiom pointing to isVersionOf: Fixes OOPS pitfall regarding missing inverse relationships</vaem:rationale>
  <dc:source>(competency_question) CQ29, CQ54
    (pitfall) Missing inverse relationship for hasVersion</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareVersion"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isVersionOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isVersionOf">
  <rdfs:comment xml:lang="en">Inverse of hasVersion: Relates a software version to the tool it belongs to.</rdfs:comment>
  <rdfs:label xml:lang="en">Is Version Of</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created as inverse property for hasVersion: Fixes OOPS pitfall regarding missing inverse relationships</vaem:rationale>
  <dc:source>(pitfall) Missing inverse relationship for hasVersion</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareVersion"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasVersion"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasFeature">
  <rdfs:comment xml:lang="en">Associates a software version with the new capabilities it introduces.</rdfs:comment>
  <rdfs:label xml:lang="en">Has Feature</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to track version-specific capabilities: Answers CQ55
    [Pitfall Resolution Agent] Created to track version-specific capabilities: Answers CQ55: Initial ontology generation
    [Pitfall Resolution Agent] Added inverseOf axiom pointing to isFeatureOf: Fixes OOPS pitfall regarding missing inverse relationships</vaem:rationale>
  <dc:source>(competency_question) CQ55
    (pitfall) Missing inverse relationship for hasFeature</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareVersion"/>
