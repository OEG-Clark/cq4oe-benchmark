  <rdfs:label xml:lang="en">Provides XML Editing</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to track specific editing capabilities: Answers CQ06
    [Pitfall Resolution Agent] Created to track specific editing capabilities: Answers CQ06: Initial ontology generation</vaem:rationale>
  <dc:source>(competency_question) CQ06</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isWebService">
