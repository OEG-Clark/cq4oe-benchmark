<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Policy">
  <rdfs:comment xml:lang="en">A set of rules and metadata governing the use of an asset.</rdfs:comment>
  <rdfs:label xml:lang="en">Policy</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created Policy class: Required by CQ30, CQ31, CQ33, New CQ1, New CQ2
    [Pitfall Resolution Agent] Created Policy class: Required by CQ30, CQ31, CQ33, New CQ1, New CQ2</vaem:rationale>
  <dc:source>(competency_question) CQ30, CQ31, CQ33, New CQ1, New CQ2</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Asset">
  <rdfs:comment xml:lang="en">A digital or physical item to which a policy applies.</rdfs:comment>
  <rdfs:label xml:lang="en">Asset</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created Asset class: Required by New CQ1
    [Pitfall Resolution Agent] Created Asset class: Required by New CQ1</vaem:rationale>
  <dc:source>(competency_question) New CQ1</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ContractParty">
  <rdfs:comment xml:lang="en">An entity that participates in a contract or policy.</rdfs:comment>
  <rdfs:label xml:lang="en">Contract Party</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created ContractParty class: Required by CQ06, CQ10
    [Pitfall Resolution Agent] Created ContractParty class: Required by CQ06, CQ10</vaem:rationale>
  <dc:source>(competency_question) CQ06, CQ10</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Rule">
  <rdfs:comment xml:lang="en">A generic class for permissions, duties, prohibitions, and other policy directives.</rdfs:comment>
  <rdfs:label xml:lang="en">Rule</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created Rule class as superclass: Required by CQ06, CQ10, CQ21, CQ24, CQ26, CQ31, New CQ3, New CQ4, New CQ5, New CQ6
    [Pitfall Resolution Agent] Created Rule class as superclass: Required by CQ06, CQ10, CQ21, CQ24, CQ26, CQ31, New CQ3, New CQ4, New CQ5, New CQ6</vaem:rationale>
  <dc:source>(competency_question) CQ06, CQ10, CQ21, CQ24, CQ26, CQ31, New CQ3, New CQ4, New CQ5, New CQ6</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Permission">
  <rdfs:comment xml:lang="en">A rule that grants a right to perform an action.</rdfs:comment>
  <rdfs:label xml:lang="en">Permission</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created Permission class: Required by CQ03, CQ06, CQ10, CQ24
    [Pitfall Resolution Agent] Created Permission class: Required by CQ03, CQ06, CQ10, CQ24
    [Pitfall Resolution Agent] Added disjointWith axioms to sibling Rule subclasses: Resolved OOPS pitfall: Lack of disjoint axioms between mutually exclusive classes</vaem:rationale>
  <dc:source>(competency_question) CQ03, CQ06, CQ10, CQ24
    (pitfall) Lack of disjoint axioms between classes</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Rule'/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Duty"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Prohibition"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Requirement"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Condition"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Sequencing"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Duty">
  <rdfs:comment xml:lang="en">A rule that imposes an obligation to perform an action.</rdfs:comment>
  <rdfs:label xml:lang="en">Duty</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created Duty class: Required by CQ06, CQ10, New CQ3, New CQ5
    [Pitfall Resolution Agent] Created Duty class: Required by CQ06, CQ10, New CQ3, New CQ5
    [Pitfall Resolution Agent] Added disjointWith axioms to sibling Rule subclasses: Resolved OOPS pitfall: Lack of disjoint axioms between mutually exclusive classes</vaem:rationale>
  <dc:source>(competency_question) CQ06, CQ10, New CQ3, New CQ5
    (pitfall) Lack of disjoint axioms between classes</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Rule'/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Permission"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Prohibition"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Requirement"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Condition"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Sequencing"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Prohibition">
  <rdfs:comment xml:lang="en">A rule that forbids the performance of an action.</rdfs:comment>
  <rdfs:label xml:lang="en">Prohibition</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created Prohibition class: Required by New CQ3, New CQ6
    [Pitfall Resolution Agent] Created Prohibition class: Required by New CQ3, New CQ6
    [Pitfall Resolution Agent] Added disjointWith axioms to sibling Rule subclasses: Resolved OOPS pitfall: Lack of disjoint axioms between mutually exclusive classes</vaem:rationale>
  <dc:source>(competency_question) New CQ3, New CQ6
    (pitfall) Lack of disjoint axioms between classes</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Rule'/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Permission"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Duty"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Requirement"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Condition"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Sequencing"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Requirement">
  <rdfs:comment xml:lang="en">A rule that specifies a necessary condition or action.</rdfs:comment>
  <rdfs:label xml:lang="en">Requirement</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created Requirement class: Required by CQ21
    [Pitfall Resolution Agent] Created Requirement class: Required by CQ21
    [Pitfall Resolution Agent] Added disjointWith axioms to sibling Rule subclasses: Resolved OOPS pitfall: Lack of disjoint axioms between mutually exclusive classes</vaem:rationale>
  <dc:source>(competency_question) CQ21
    (pitfall) Lack of disjoint axioms between classes</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Rule'/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Permission"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Duty"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Prohibition"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Condition"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Sequencing"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Condition">
  <rdfs:comment xml:lang="en">A rule that specifies a prerequisite for a permission or duty.</rdfs:comment>
  <rdfs:label xml:lang="en">Condition</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created Condition class: Required by CQ26
    [Pitfall Resolution Agent] Created Condition class: Required by CQ26
    [Pitfall Resolution Agent] Added disjointWith axioms to sibling Rule subclasses: Resolved OOPS pitfall: Lack of disjoint axioms between mutually exclusive classes</vaem:rationale>
  <dc:source>(competency_question) CQ26
    (pitfall) Lack of disjoint axioms between classes</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Rule'/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Permission"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Duty"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Prohibition"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Requirement"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Sequencing"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Sequencing">
  <rdfs:comment xml:lang="en">A rule that specifies the order of execution for other rules.</rdfs:comment>
  <rdfs:label xml:lang="en">Sequencing</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created Sequencing class: Required by CQ31
    [Pitfall Resolution Agent] Created Sequencing class: Required by CQ31
    [Pitfall Resolution Agent] Added disjointWith axioms to sibling Rule subclasses: Resolved OOPS pitfall: Lack of disjoint axioms between mutually exclusive classes</vaem:rationale>
  <dc:source>(competency_question) CQ31
    (pitfall) Lack of disjoint axioms between classes</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Rule'/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Permission"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Duty"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Prohibition"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Requirement"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Condition"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#TransferRight">
  <rdfs:comment xml:lang="en">A permission that allows the transfer of rights.</rdfs:comment>
  <rdfs:label xml:lang="en">Transfer Right</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created TransferRight class: Required by CQ03
    [Pitfall Resolution Agent] Created TransferRight class: Required by CQ03</vaem:rationale>
  <dc:source>(competency_question) CQ03</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Permission'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Aggregation">
  <rdfs:comment xml:lang="en">A transfer right allowing aggregation of assets.</rdfs:comment>
  <rdfs:label xml:lang="en">Aggregation</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created Aggregation class: Required by CQ03
    [Pitfall Resolution Agent] Created Aggregation class: Required by CQ03
    [Pitfall Resolution Agent] Added disjointWith axiom to sibling TransferRight subclass: Resolved OOPS pitfall: Lack of disjoint axioms between mutually exclusive classes</vaem:rationale>
  <dc:source>(competency_question) CQ03
    (pitfall) Lack of disjoint axioms between classes</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#TransferRight'/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Disaggregation"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Disaggregation">
  <rdfs:comment xml:lang="en">A transfer right allowing disaggregation of assets.</rdfs:comment>
  <rdfs:label xml:lang="en">Disaggregation</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created Disaggregation class: Required by CQ03
    [Pitfall Resolution Agent] Created Disaggregation class: Required by CQ03
    [Pitfall Resolution Agent] Added disjointWith axiom to sibling TransferRight subclass: Resolved OOPS pitfall: Lack of disjoint axioms between mutually exclusive classes</vaem:rationale>
  <dc:source>(competency_question) CQ03
    (pitfall) Lack of disjoint axioms between classes</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#TransferRight'/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Aggregation"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ExclusivePermission">
  <rdfs:comment xml:lang="en">A permission that excludes other permissions.</rdfs:comment>
  <rdfs:label xml:lang="en">Exclusive Permission</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created ExclusivePermission class: Required by CQ24
    [Pitfall Resolution Agent] Created ExclusivePermission class: Required by CQ24</vaem:rationale>
  <dc:source>(competency_question) CQ24</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Permission'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Constraint">
  <rdfs:comment xml:lang="en">A condition that limits or qualifies a rule.</rdfs:comment>
  <rdfs:label xml:lang="en">Constraint</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created Constraint class: Required by CQ13, CQ14, CQ21, CQ26, New CQ6
    [Pitfall Resolution Agent] Created Constraint class: Required by CQ13, CQ14, CQ21, CQ26, New CQ6</vaem:rationale>
  <dc:source>(competency_question) CQ13, CQ14, CQ21, CQ26, New CQ6</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Operator">
  <rdfs:comment xml:lang="en">A logical or arithmetic operator used in constraints.</rdfs:comment>
  <rdfs:label xml:lang="en">Operator</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created Operator class: Required by CQ08, CQ14, New CQ6
    [Pitfall Resolution Agent] Created Operator class: Required by CQ08, CQ14, New CQ6</vaem:rationale>
  <dc:source>(competency_question) CQ08, CQ14, New CQ6</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#LogicalOperator">
  <rdfs:comment xml:lang="en">An operator that combines constraints logically.</rdfs:comment>
  <rdfs:label xml:lang="en">Logical Operator</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created LogicalOperator class: Required by CQ08, CQ14
    [Pitfall Resolution Agent] Created LogicalOperator class: Required by CQ08, CQ14</vaem:rationale>
  <dc:source>(competency_question) CQ08, CQ14</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Operator'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#NotOperator">
  <rdfs:comment xml:lang="en">A logical operator representing negation.</rdfs:comment>
  <rdfs:label xml:lang="en">Not Operator</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created NotOperator class: Required by CQ08
    [Pitfall Resolution Agent] Created NotOperator class: Required by CQ08
    [Pitfall Resolution Agent] Added disjointWith axioms to sibling LogicalOperator subclasses: Resolved OOPS pitfall: Lack of disjoint axioms between mutually exclusive classes</vaem:rationale>
  <dc:source>(competency_question) CQ08
    (pitfall) Lack of disjoint axioms between classes</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#LogicalOperator'/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#AndOperator"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#OrOperator"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#XorOperator"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#AndOperator">
  <rdfs:comment xml:lang="en">A logical operator representing conjunction, specifically used to combine policy constraints.</rdfs:comment>
  <rdfs:label xml:lang="en">And Operator</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created AndOperator class: Required by CQ14
    [Pitfall Resolution Agent] Created AndOperator class: Required by CQ14
    [Pitfall Resolution Agent] Clarified comment to resolve ambiguous name pitfall and added disjointWith axioms: Resolved OOPS pitfalls: Ambiguous class name and Lack of disjoint axioms</vaem:rationale>
  <dc:source>(competency_question) CQ14
    (pitfall) Ambiguous class name
    (pitfall) Lack of disjoint axioms between classes</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#LogicalOperator'/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#NotOperator"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#OrOperator"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#XorOperator"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#OrOperator">
  <rdfs:comment xml:lang="en">A logical operator representing disjunction, specifically used to combine policy constraints.</rdfs:comment>
  <rdfs:label xml:lang="en">Or Operator</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created OrOperator class: Required by CQ14
    [Pitfall Resolution Agent] Created OrOperator class: Required by CQ14
    [Pitfall Resolution Agent] Clarified comment to resolve ambiguous name pitfall and added disjointWith axioms: Resolved OOPS pitfalls: Ambiguous class name and Lack of disjoint axioms</vaem:rationale>
  <dc:source>(competency_question) CQ14
    (pitfall) Ambiguous class name
    (pitfall) Lack of disjoint axioms between classes</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#LogicalOperator'/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#NotOperator"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#AndOperator"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#XorOperator"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#XorOperator">
  <rdfs:comment xml:lang="en">A logical operator representing exclusive disjunction.</rdfs:comment>
  <rdfs:label xml:lang="en">Xor Operator</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created XorOperator class: Required by CQ14
    [Pitfall Resolution Agent] Created XorOperator class: Required by CQ14
    [Pitfall Resolution Agent] Added disjointWith axioms to sibling LogicalOperator subclasses: Resolved OOPS pitfall: Lack of disjoint axioms between mutually exclusive classes</vaem:rationale>
  <dc:source>(competency_question) CQ14
    (pitfall) Lack of disjoint axioms between classes</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#LogicalOperator'/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#NotOperator"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#AndOperator"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#OrOperator"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Container">
  <rdfs:comment xml:lang="en">A grouping mechanism for policies or rules.</rdfs:comment>
  <rdfs:label xml:lang="en">Container</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created Container class: Required by CQ30
    [Pitfall Resolution Agent] Created Container class: Required by CQ30</vaem:rationale>
  <dc:source>(competency_question) CQ30</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ConflictResolutionStrategy">
  <rdfs:comment xml:lang="en">A strategy to resolve conflicts between rules.</rdfs:comment>
  <rdfs:label xml:lang="en">Conflict Resolution Strategy</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created ConflictResolutionStrategy class: Required by New CQ2
    [Pitfall Resolution Agent] Created ConflictResolutionStrategy class: Required by New CQ2</vaem:rationale>
  <dc:source>(competency_question) New CQ2</dc:source>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasParty">
  <rdfs:comment xml:lang="en">Links a rule to a contract party.</rdfs:comment>
  <rdfs:label xml:lang="en">has Party</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created hasParty property: Required by CQ06, CQ10
    [Pitfall Resolution Agent] Created hasParty property: Required by CQ06, CQ10</vaem:rationale>
  <dc:source>(competency_question) CQ06, CQ10</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#ContractParty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isPartyIn">
  <rdfs:comment xml:lang="en">Inverse of hasParty. Links a contract party to a rule.</rdfs:comment>
  <rdfs:label xml:lang="en">is Party In</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property for hasParty: Resolved OOPS pitfall: Missing inverse relationships</vaem:rationale>
  <dc:source>(pitfall) Missing inverse relationship for hasParty</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ContractParty"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasParty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasConstraint">
  <rdfs:comment xml:lang="en">Links a rule to a constraint.</rdfs:comment>
  <rdfs:label xml:lang="en">has Constraint</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created hasConstraint property: Required by CQ21, CQ26, New CQ6
    [Pitfall Resolution Agent] Created hasConstraint property: Required by CQ21, CQ26, New CQ6</vaem:rationale>
  <dc:source>(competency_question) CQ21, CQ26, New CQ6</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#constrains">
  <rdfs:comment xml:lang="en">Inverse of hasConstraint. Links a constraint to a rule.</rdfs:comment>
  <rdfs:label xml:lang="en">constrains</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property for hasConstraint: Resolved OOPS pitfall: Missing inverse relationships</vaem:rationale>
  <dc:source>(pitfall) Missing inverse relationship for hasConstraint</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasConstraint"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasNestedConstraint">
  <rdfs:comment xml:lang="en">Links a constraint to a nested constraint.</rdfs:comment>
  <rdfs:label xml:lang="en">has Nested Constraint</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created hasNestedConstraint property: Required by CQ13
    [Pitfall Resolution Agent] Created hasNestedConstraint property: Required by CQ13</vaem:rationale>
  <dc:source>(competency_question) CQ13</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isNestedIn">
  <rdfs:comment xml:lang="en">Inverse of hasNestedConstraint. Links a nested constraint to its parent constraint.</rdfs:comment>
  <rdfs:label xml:lang="en">is Nested In</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property for hasNestedConstraint: Resolved OOPS pitfall: Missing inverse relationships</vaem:rationale>
  <dc:source>(pitfall) Missing inverse relationship for hasNestedConstraint</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasNestedConstraint"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasOperator">
