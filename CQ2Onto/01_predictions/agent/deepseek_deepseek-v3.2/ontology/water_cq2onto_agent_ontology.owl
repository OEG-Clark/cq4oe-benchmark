<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#composes">
  <rdfs:comment xml:lang="en">Relates a water distribution infrastructure to the assets that compose it.</rdfs:comment>
  <rdfs:label xml:lang="en">composes</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property composes: Required by CQ01 to link infrastructure to its assets.
    [Logical Consistency Agent] Created object property composes: Required by CQ01 to link infrastructure to its assets.: Initial creation
    [Pitfall Resolution Agent] Created object property composes: Required by CQ01 to link infrastructure to its assets.: Initial creation
    [Pitfall Resolution Agent] Added inverse property relationship with composedBy.: To address missing inverse properties pitfall; all non-symmetric properties should have inverses.</vaem:rationale>
  <dc:source>(competency_question) CQ01: Which assets compose a water distribution infrastructure?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Asset"/>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#composedBy'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#composedBy">
  <rdfs:comment xml:lang="en">Inverse of composes: relates an asset to the water distribution infrastructure it composes.</rdfs:comment>
  <rdfs:label xml:lang="en">composed by</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property composedBy for composes property.: To address missing inverse properties pitfall; all non-symmetric properties should have inverses.</vaem:rationale>
  <dc:source>(pitfall) Missing inverse relationship for property: http://www.semanticweb.org/myontology#composes</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Asset"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure"/>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#composes'/>
</owl:ObjectProperty>

