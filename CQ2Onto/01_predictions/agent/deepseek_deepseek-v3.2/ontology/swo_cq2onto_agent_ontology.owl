<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#SoftwareTool">
  <rdfs:comment xml:lang="en">A software application, tool, or system that performs specific tasks.</rdfs:comment>
  <rdfs:label xml:lang="en">Software Tool</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class SoftwareTool: Central concept for all competency questions about software.
    [Logical Consistency Agent] Created class SoftwareTool: Central concept for all competency questions about software.: Initial creation
    [Pitfall Resolution Agent] Created class SoftwareTool: Central concept for all competency questions about software.: Initial creation
    [Pitfall Resolution Agent] Created class SoftwareTool: Central concept for all competency questions about software.: Initial creation</vaem:rationale>
  <dc:source>(competency_question) CQ07: What type of software (API, Desktop application etc) is it?
    (competency_question) CQ08: What software can perform task x?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Algorithm">
  <rdfs:comment xml:lang="en">A named and published computational procedure or method.</rdfs:comment>
  <rdfs:label xml:lang="en">Algorithm</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Algorithm: Needed to answer questions about algorithms used by software.
    [Logical Consistency Agent] Created class Algorithm: Needed to answer questions about algorithms used by software.: Initial creation
    [Pitfall Resolution Agent] Created class Algorithm: Needed to answer questions about algorithms used by software.: Initial creation
    [Pitfall Resolution Agent] Created class Algorithm: Needed to answer questions about algorithms used by software.: Initial creation</vaem:rationale>
  <dc:source>(competency_question) CQ04: Which of the named and published algorithms does this tool use?
    (competency_question) CQ05: Are there any modifications to the algorithm the tool uses?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Task">
  <rdfs:comment xml:lang="en">A specific function or operation that software can perform.</rdfs:comment>
  <rdfs:label xml:lang="en">Task</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Task: To model what software can do, e.g., render a GIF, edit XML.
    [Logical Consistency Agent] Created class Task: To model what software can do, e.g., render a GIF, edit XML.: Initial creation
    [Pitfall Resolution Agent] Created class Task: To model what software can do, e.g., render a GIF, edit XML.: Initial creation
    [Pitfall Resolution Agent] Created class Task: To model what software can do, e.g., render a GIF, edit XML.: Initial creation</vaem:rationale>
  <dc:source>(competency_question) CQ08: What software can perform task x?
    (competency_question) CQ14: Does it do what I want or need it to do e.g. render a gif?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#DataFormat">
  <rdfs:comment xml:lang="en">A format for data, such as file formats or data structures.</rdfs:comment>
  <rdfs:label xml:lang="en">Data Format</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class DataFormat: To represent input/output formats, proprietary vs open formats.
    [Logical Consistency Agent] Created class DataFormat: To represent input/output formats, proprietary vs open formats.: Initial creation
    [Pitfall Resolution Agent] Created class DataFormat: To represent input/output formats, proprietary vs open formats.: Initial creation
    [Pitfall Resolution Agent] Created class DataFormat: To represent input/output formats, proprietary vs open formats.: Initial creation</vaem:rationale>
  <dc:source>(competency_question) CQ17: What are the input and output formats for this software?
    (competency_question) CQ19: What software can read a .cel file?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Version">
  <rdfs:comment xml:lang="en">A specific release version of a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Version</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Version: To track software versions, features, and release dates.
    [Logical Consistency Agent] Created class Version: To track software versions, features, and release dates.: Initial creation
    [Pitfall Resolution Agent] Created class Version: To track software versions, features, and release dates.: Initial creation
    [Pitfall Resolution Agent] Created class Version: To track software versions, features, and release dates.: Initial creation</vaem:rationale>
  <dc:source>(competency_question) CQ54: What is the version of this software?
    (competency_question) CQ55: What new features are in this version?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#License">
  <rdfs:comment xml:lang="en">A legal license under which software is distributed.</rdfs:comment>
  <rdfs:label xml:lang="en">License</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class License: To model software licensing, open source, FOSS, permissiveness.
    [Logical Consistency Agent] Created class License: To model software licensing, open source, FOSS, permissiveness.: Initial creation
    [Pitfall Resolution Agent] Created class License: To model software licensing, open source, FOSS, permissiveness.: Initial creation
    [Pitfall Resolution Agent] Created class License: To model software licensing, open source, FOSS, permissiveness.: Initial creation</vaem:rationale>
  <dc:source>(competency_question) CQ59: What license and what is permissiveness?
    (competency_question) CQ60: Is it open source or not?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Developer">
  <rdfs:comment xml:lang="en">An individual or organization that develops software.</rdfs:comment>
  <rdfs:label xml:lang="en">Developer</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Developer: To answer questions about who developed the software and collaboration.
    [Logical Consistency Agent] Created class Developer: To answer questions about who developed the software and collaboration.: Initial creation
    [Pitfall Resolution Agent] Created class Developer: To answer questions about who developed the software and collaboration.: Initial creation
    [Pitfall Resolution Agent] Created class Developer: To answer questions about who developed the software and collaboration.: Initial creation</vaem:rationale>
  <dc:source>(competency_question) CQ36: Who developed it?
    (competency_question) CQ38: Can we collaborate with developers of software x?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#SoftwareType">
  <rdfs:comment xml:lang="en">A category of software such as API, Desktop application, Web service.</rdfs:comment>
  <rdfs:label xml:lang="en">Software Type</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class SoftwareType: To classify software as API, desktop app, web service, etc.
    [Logical Consistency Agent] Created class SoftwareType: To classify software as API, desktop app, web service, etc.: Initial creation
    [Pitfall Resolution Agent] Created class SoftwareType: To classify software as API, desktop app, web service, etc.: Initial creation
    [Pitfall Resolution Agent] Created class SoftwareType: To classify software as API, desktop app, web service, etc.: Initial creation</vaem:rationale>
  <dc:source>(competency_question) CQ07: What type of software (API, Desktop application etc) is it?
    (competency_question) CQ11: Is this software available as a web service?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Platform">
  <rdfs:comment xml:lang="en">The operating system or environment where software runs.</rdfs:comment>
  <rdfs:label xml:lang="en">Platform</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Platform: To answer questions about software platform compatibility.
    [Logical Consistency Agent] Created class Platform: To answer questions about software platform compatibility.: Initial creation
    [Pitfall Resolution Agent] Created class Platform: To answer questions about software platform compatibility.: Initial creation
    [Pitfall Resolution Agent] Created class Platform: To answer questions about software platform compatibility.: Initial creation</vaem:rationale>
  <dc:source>(competency_question) CQ85: What platform does the software run on?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ProgrammingLanguage">
  <rdfs:comment xml:lang="en">A programming language in which software is implemented.</rdfs:comment>
  <rdfs:label xml:lang="en">Programming Language</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class ProgrammingLanguage: To answer questions about implementation language.
    [Logical Consistency Agent] Created class ProgrammingLanguage: To answer questions about implementation language.: Initial creation
    [Pitfall Resolution Agent] Created class ProgrammingLanguage: To answer questions about implementation language.: Initial creation
    [Pitfall Resolution Agent] Created class ProgrammingLanguage: To answer questions about implementation language.: Initial creation</vaem:rationale>
  <dc:source>(competency_question) CQ84: In what language was it implemented?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#OpenSourceLicense">
  <rdfs:comment xml:lang="en">A license that qualifies as open source.</rdfs:comment>
  <rdfs:label xml:lang="en">Open Source License</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class OpenSourceLicense as subclass of License: To specifically model open source licenses for CQ58, CQ60, CQ65.
    [Logical Consistency Agent] Created class OpenSourceLicense as subclass of License: To specifically model open source licenses for CQ58, CQ60, CQ65.: Initial creation
    [Pitfall Resolution Agent] Created class OpenSourceLicense as subclass of License: To specifically model open source licenses for CQ58, CQ60, CQ65.: Initial creation
    [Pitfall Resolution Agent] Created class OpenSourceLicense as subclass of License: To specifically model open source licenses for CQ58, CQ60, CQ65.: Initial creation</vaem:rationale>
  <dc:source>(competency_question) CQ58: Is the software open source development? Is there a community development?
    (competency_question) CQ65: Is it FOSS?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#License'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ProprietaryLicense">
  <rdfs:comment xml:lang="en">A non-open source, proprietary license.</rdfs:comment>
  <rdfs:label xml:lang="en">Proprietary License</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class ProprietaryLicense as subclass of License: To distinguish proprietary licenses from open source.
    [Logical Consistency Agent] Created class ProprietaryLicense as subclass of License: To distinguish proprietary licenses from open source.: Initial creation
    [Pitfall Resolution Agent] Created class ProprietaryLicense as subclass of License: To distinguish proprietary licenses from open source.: Initial creation
    [Pitfall Resolution Agent] Created class ProprietaryLicense as subclass of License: To distinguish proprietary licenses from open source.: Initial creation</vaem:rationale>
  <dc:source>(competency_question) CQ60: Is it open source or not?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#License'/>
<owl:disjointWith rdf:resource='http://www.semanticweb.org/myontology#OpenSourceLicense'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Documentation">
  <rdfs:comment xml:lang="en">Documentation or help resources for software.</rdfs:comment>
  <rdfs:label xml:lang="en">Documentation</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Documentation: To model where documentation is located and how to get help.
    [Logical Consistency Agent] Created class Documentation: To model where documentation is located and how to get help.: Initial creation
    [Pitfall Resolution Agent] Created class Documentation: To model where documentation is located and how to get help.: Initial creation
    [Pitfall Resolution Agent] Created class Documentation: To model where documentation is located and how to get help.: Initial creation</vaem:rationale>
  <dc:source>(competency_question) CQ32: How do I get help?
    (competency_question) CQ73: Where is the documentation?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#URL">
  <rdfs:comment xml:lang="en">A Uniform Resource Locator (web address).</rdfs:comment>
  <rdfs:label xml:lang="en">URL</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created class URL: To serve as range for properties like availableAt and hasHomepage that link to web addresses.: Fix OOPS pitfall: Object properties without domain or range</vaem:rationale>
  <dc:source>(pitfall) Object and/or datatype properties without domain or range (or none of them) are included in the ontology: availableAt, hasHomepage</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Data">
  <rdfs:comment xml:lang="en">Data created or processed by software.</rdfs:comment>
  <rdfs:label xml:lang="en">Data</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created class Data as subclass of DataFormat: To serve as range for createdData property.: Fix OOPS pitfall: Object properties without domain or range</vaem:rationale>
  <dc:source>(pitfall) Object and/or datatype properties without domain or range (or none of them) are included in the ontology: createdData</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#DataFormat'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Modification">
  <rdfs:comment xml:lang="en">A modification made to an algorithm or other software component.</rdfs:comment>
  <rdfs:label xml:lang="en">Modification</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created class Modification: To serve as range for hasModification property.: Fix OOPS pitfall: Object properties without domain or range</vaem:rationale>
  <dc:source>(pitfall) Object and/or datatype properties without domain or range (or none of them) are included in the ontology: hasModification</dc:source>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usesAlgorithm">
  <rdfs:comment xml:lang="en">Links a software tool to an algorithm it uses.</rdfs:comment>
  <rdfs:label xml:lang="en">uses algorithm</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property usesAlgorithm: To answer CQ04 about which algorithms a tool uses.
    [Logical Consistency Agent] Created object property usesAlgorithm: To answer CQ04 about which algorithms a tool uses.: Initial creation
    [Pitfall Resolution Agent] Created object property usesAlgorithm: To answer CQ04 about which algorithms a tool uses.: Initial creation
    [Pitfall Resolution Agent] Created object property usesAlgorithm: To answer CQ04 about which algorithms a tool uses.: Initial creation</vaem:rationale>
  <dc:source>(competency_question) CQ04: Which of the named and published algorithms does this tool use?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#usedBy'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usedBy">
  <rdfs:comment xml:lang="en">Links an algorithm to software tools that use it.</rdfs:comment>
  <rdfs:label xml:lang="en">used by</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property for usesAlgorithm: To enable bidirectional navigation.: Fix OOPS pitfall: Missing inverse relationships</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship does not have an inverse relationship defined within the ontology: usesAlgorithm</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#usesAlgorithm'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasModification">
  <rdfs:comment xml:lang="en">Links an algorithm to modifications made to it by a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">has modification</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property hasModification: To answer CQ05 about modifications to algorithms.
    [Logical Consistency Agent] Created object property hasModification: To answer CQ05 about modifications to algorithms.: Initial creation
    [Pitfall Resolution Agent] Created object property hasModification: To answer CQ05 about modifications to algorithms.: Initial creation
    [Pitfall Resolution Agent] Created object property hasModification: To answer CQ05 about modifications to algorithms.: Initial creation
    [Pitfall Resolution Agent] Added range Modification to property.: Fix OOPS pitfall: Object properties without domain or range</vaem:rationale>
  <dc:source>(competency_question) CQ05: Are there any modifications to the algorithm the tool uses?
    (pitfall) Object and/or datatype properties without domain or range (or none of them) are included in the ontology: hasModification</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Modification"/>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#modificationOf'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#modificationOf">
  <rdfs:comment xml:lang="en">Links a modification to the algorithm it modifies.</rdfs:comment>
  <rdfs:label xml:lang="en">modification of</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property for hasModification: To enable bidirectional navigation.: Fix OOPS pitfall: Missing inverse relationships</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship does not have an inverse relationship defined within the ontology: hasModification</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Modification"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#hasModification'/>
</owl:ObjectProperty>

