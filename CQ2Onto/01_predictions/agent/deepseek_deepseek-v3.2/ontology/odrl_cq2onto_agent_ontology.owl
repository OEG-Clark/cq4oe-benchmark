  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#hasOperator'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isInvolvedInRule">
  <rdfs:comment xml:lang="en">Inverse of involvedParty: Links a party to the rule in which it is involved.</rdfs:comment>
  <rdfs:label xml:lang="en">is involved in rule</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property for involvedParty to fix P04 pitfall.: Fix missing inverse relationship for involvedParty property</vaem:rationale>
  <dc:source>(pitfall) P04: Creating unconnected ontology elements - missing inverse relationship for involvedParty</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Party"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#involvedParty'/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasTransferRight">
  <rdfs:comment xml:lang="en">Indicates whether a permission is of type transfer right (e.g., Aggregation, Disaggregation).</rdfs:comment>
  <rdfs:label xml:lang="en">has transfer right</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created datatype property hasTransferRight: To answer CQ3; permissions may be transfer rights.
