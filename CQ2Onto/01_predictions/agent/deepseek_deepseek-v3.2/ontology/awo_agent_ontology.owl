<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Animal">
  <rdfs:comment xml:lang="en">An organism of the kingdom Animalia.</rdfs:comment>
  <rdfs:label xml:lang="en">Animal</rdfs:label>
  <dc:source>(competency_question) CQ1: Which animal eats which other animal?
    (competency_question) CQ2: Is [this animal] a herbivore?
    (competency_question) CQ3: Which plant parts does [this omnivorous or herbivorourus animal] eat?
    (competency_question) CQ4: Does a lion eat plants or plant parts?
    (competency_question) CQ7: Which animals eat [these animals]?
    (competency_question) CQ14: Are there animals that are carnivore but still eat some plants or parts of plants?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Plant">
  <rdfs:comment xml:lang="en">An organism of the kingdom Plantae.</rdfs:comment>
  <rdfs:label xml:lang="en">Plant</rdfs:label>
  <dc:source>(competency_question) CQ3: Which plant parts does [this omnivorous or herbivorourus animal] eat?
    (competency_question) CQ4: Does a lion eat plants or plant parts?
    (competency_question) CQ6: Which plants eat animals?
    (competency_question) CQ14: Are there animals that are carnivore but still eat some plants or parts of plants?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlantPart">
  <rdfs:comment xml:lang="en">A part of a plant, such as leaf, fruit, stem, root, etc.</rdfs:comment>
  <rdfs:label xml:lang="en">Plant Part</rdfs:label>
  <dc:source>(competency_question) CQ3: Which plant parts does [this omnivorous or herbivorourus animal] eat?
    (competency_question) CQ4: Does a lion eat plants or plant parts?
    (competency_question) CQ14: Are there animals that are carnivore but still eat some plants or parts of plants?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Plant'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#CarnivorousPlant">
  <rdfs:comment xml:lang="en">A plant that consumes animals (e.g., Venus flytrap).</rdfs:comment>
  <rdfs:label xml:lang="en">Carnivorous Plant</rdfs:label>
  <dc:source>(competency_question) CQ6: Which plants eat animals?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Plant'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Herbivore">
  <rdfs:comment xml:lang="en">An animal that eats only plants or plant parts.</rdfs:comment>
  <rdfs:label xml:lang="en">Herbivore</rdfs:label>
  <dc:source>(competency_question) CQ2: Is [this animal] a herbivore?
    (competency_question) CQ3: Which plant parts does [this omnivorous or herbivorourus animal] eat?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Animal'/><owl:equivalentClass><owl:Class><owl:intersectionOf rdf:parseType='Collection'><rdf:Description rdf:about='http://www.semanticweb.org/myontology#Animal'/><owl:Restriction><owl:onProperty rdf:resource='http://www.semanticweb.org/myontology#eats'/><owl:allValuesFrom><owl:Class><owl:unionOf rdf:parseType='Collection'><rdf:Description rdf:about='http://www.semanticweb.org/myontology#Plant'/><rdf:Description rdf:about='http://www.semanticweb.org/myontology#PlantPart'/></owl:unionOf></owl:Class></owl:allValuesFrom></owl:Restriction></owl:intersectionOf></owl:Class></owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Carnivore">
  <rdfs:comment xml:lang="en">An animal that primarily eats other animals, but may occasionally eat plants or plant parts.</rdfs:comment>
  <rdfs:label xml:lang="en">Carnivore</rdfs:label>
  <dc:source>(competency_question) CQ1: Which animal eats which other animal?
    (competency_question) CQ4: Does a lion eat plants or plant parts?
    (competency_question) CQ7: Which animals eat [these animals]?
    (competency_question) CQ14: Are there animals that are carnivore but still eat some plants or parts of plants?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Animal'/><owl:disjointWith rdf:resource='http://www.semanticweb.org/myontology#Herbivore'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Omnivore">
  <rdfs:comment xml:lang="en">An animal that eats both animals and plants/plant parts.</rdfs:comment>
  <rdfs:label xml:lang="en">Omnivore</rdfs:label>
  <dc:source>(competency_question) CQ3: Which plant parts does [this omnivorous or herbivorourus animal] eat?
    (competency_question) CQ14: Are there animals that are carnivore but still eat some plants or parts of plants?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Animal'/><owl:disjointWith rdf:resource='http://www.semanticweb.org/myontology#Herbivore'/><owl:disjointWith rdf:resource='http://www.semanticweb.org/myontology#Carnivore'/>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#eats">
  <rdfs:comment xml:lang="en">Relates an animal (or carnivorous plant) to what it consumes.</rdfs:comment>
  <rdfs:label xml:lang="en">eats</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added domain and range to address OOPS pitfall 'Object and/or datatype properties without domain or range': The property lacked domain and range specification, which is considered a modeling pitfall
    [Pitfall Resolution Agent] Added inverse property relationship with 'eatenBy': To address OOPS pitfall about missing inverse relationships</vaem:rationale>
  <dc:source>(competency_question) CQ1: Which animal eats which other animal?
    (competency_question) CQ3: Which plant parts does [this omnivorous or herbivorourus animal] eat?
    (competency_question) CQ4: Does a lion eat plants or plant parts?
    (competency_question) CQ6: Which plants eat animals?
    (competency_question) CQ7: Which animals eat [these animals]?
    (competency_question) CQ14: Are there animals that are carnivore but still eat some plants or parts of plants?
    (pitfall) Object and/or datatype properties without domain or range (or none of them) are included in the ontology.
    (pitfall) This pitfall appears when any relationship (except for those that are defined as symmetric properties using owl:SymmetricProperty) does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#eatenBy'/><rdfs:domain><owl:Class><owl:unionOf rdf:parseType='Collection'><rdf:Description rdf:about='http://www.semanticweb.org/myontology#Animal'/><rdf:Description rdf:about='http://www.semanticweb.org/myontology#CarnivorousPlant'/></owl:unionOf></owl:Class></rdfs:domain><rdfs:range><owl:Class><owl:unionOf rdf:parseType='Collection'><rdf:Description rdf:about='http://www.semanticweb.org/myontology#Animal'/><rdf:Description rdf:about='http://www.semanticweb.org/myontology#Plant'/><rdf:Description rdf:about='http://www.semanticweb.org/myontology#PlantPart'/></owl:unionOf></owl:Class></rdfs:range>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#eatsAnimal">
  <rdfs:comment xml:lang="en">Subproperty of eats that specifically relates an animal (or carnivorous plant) to another animal it consumes.</rdfs:comment>
  <rdfs:label xml:lang="en">eats animal</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property relationship with 'eatenByAnimal': To address OOPS pitfall about missing inverse relationships</vaem:rationale>
  <dc:source>(competency_question) CQ1: Which animal eats which other animal?
    (competency_question) CQ7: Which animals eat [these animals]?
    (pitfall) This pitfall appears when any relationship (except for those that are defined as symmetric properties using owl:SymmetricProperty) does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
  <rdfs:subPropertyOf rdf:resource='http://www.semanticweb.org/myontology#eats'/><owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#eatenByAnimal'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#eatsPlant">
  <rdfs:comment xml:lang="en">Subproperty of eats that specifically relates an animal to a plant it consumes.</rdfs:comment>
  <rdfs:label xml:lang="en">eats plant</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property relationship with 'eatenByPlant': To address OOPS pitfall about missing inverse relationships</vaem:rationale>
  <dc:source>(competency_question) CQ3: Which plant parts does [this omnivorous or herbivorourus animal] eat?
    (competency_question) CQ4: Does a lion eat plants or plant parts?
    (competency_question) CQ14: Are there animals that are carnivore but still eat some plants or parts of plants?
    (pitfall) This pitfall appears when any relationship (except for those that are defined as symmetric properties using owl:SymmetricProperty) does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Plant"/>
  <rdfs:subPropertyOf rdf:resource='http://www.semanticweb.org/myontology#eats'/><owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#eatenByPlant'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#eatsPlantPart">
  <rdfs:comment xml:lang="en">Subproperty of eats that specifically relates an animal to a plant part it consumes.</rdfs:comment>
  <rdfs:label xml:lang="en">eats plant part</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property relationship with 'eatenByPlantPart': To address OOPS pitfall about missing inverse relationships</vaem:rationale>
  <dc:source>(competency_question) CQ3: Which plant parts does [this omnivorous or herbivorourus animal] eat?
    (competency_question) CQ4: Does a lion eat plants or plant parts?
    (competency_question) CQ14: Are there animals that are carnivore but still eat some plants or parts of plants?
    (pitfall) This pitfall appears when any relationship (except for those that are defined as symmetric properties using owl:SymmetricProperty) does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PlantPart"/>
  <rdfs:subPropertyOf rdf:resource='http://www.semanticweb.org/myontology#eats'/><owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#eatenByPlantPart'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#plantEatsAnimal">
  <rdfs:comment xml:lang="en">Subproperty of eats that specifically relates a carnivorous plant to an animal it consumes.</rdfs:comment>
  <rdfs:label xml:lang="en">plant eats animal</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property relationship with 'eatenByCarnivorousPlant': To address OOPS pitfall about missing inverse relationships</vaem:rationale>
  <dc:source>(competency_question) CQ6: Which plants eat animals?
    (pitfall) This pitfall appears when any relationship (except for those that are defined as symmetric properties using owl:SymmetricProperty) does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#CarnivorousPlant"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
  <rdfs:subPropertyOf rdf:resource='http://www.semanticweb.org/myontology#eats'/><owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#eatenByCarnivorousPlant'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#eatenBy">
  <rdfs:comment xml:lang="en">Inverse of eats. Relates what is consumed to the animal or carnivorous plant that consumes it.</rdfs:comment>
  <rdfs:label xml:lang="en">eaten by</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created new inverse property for 'eats': To address OOPS pitfall about missing inverse relationships</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship (except for those that are defined as symmetric properties using owl:SymmetricProperty) does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#eats'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#eatenByAnimal">
  <rdfs:comment xml:lang="en">Inverse of eatsAnimal. Relates an animal to another animal that eats it.</rdfs:comment>
  <rdfs:label xml:lang="en">eaten by animal</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created new inverse property for 'eatsAnimal': To address OOPS pitfall about missing inverse relationships</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship (except for those that are defined as symmetric properties using owl:SymmetricProperty) does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#eatsAnimal'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#eatenByPlant">
  <rdfs:comment xml:lang="en">Inverse of eatsPlant. Relates a plant to an animal that eats it.</rdfs:comment>
  <rdfs:label xml:lang="en">eaten by plant</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created new inverse property for 'eatsPlant': To address OOPS pitfall about missing inverse relationships</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship (except for those that are defined as symmetric properties using owl:SymmetricProperty) does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#eatsPlant'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#eatenByPlantPart">
  <rdfs:comment xml:lang="en">Inverse of eatsPlantPart. Relates a plant part to an animal that eats it.</rdfs:comment>
  <rdfs:label xml:lang="en">eaten by plant part</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created new inverse property for 'eatsPlantPart': To address OOPS pitfall about missing inverse relationships</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship (except for those that are defined as symmetric properties using owl:SymmetricProperty) does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#eatsPlantPart'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#eatenByCarnivorousPlant">
  <rdfs:comment xml:lang="en">Inverse of plantEatsAnimal. Relates an animal to a carnivorous plant that eats it.</rdfs:comment>
  <rdfs:label xml:lang="en">eaten by carnivorous plant</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created new inverse property for 'plantEatsAnimal': To address OOPS pitfall about missing inverse relationships</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship (except for those that are defined as symmetric properties using owl:SymmetricProperty) does not have an inverse relationship (owl:inverseOf) defined within the ontology.</dc:source>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#plantEatsAnimal'/>
</owl:ObjectProperty>

</rdf:RDF>