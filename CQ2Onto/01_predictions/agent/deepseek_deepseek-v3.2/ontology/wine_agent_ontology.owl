<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasCharacteristic">
  <rdfs:comment xml:lang="en">Links a wine to one of its characteristics.</rdfs:comment>
  <rdfs:label xml:lang="en">has characteristic</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property hasCharacteristic: Needed to answer CQ1; connects Wine to WineCharacteristic.
    [Pitfall Resolution Agent] Created property hasCharacteristic: Needed to answer CQ1; connects Wine to WineCharacteristic.: Initial creation
    [Pitfall Resolution Agent] Added inverse property relationship with isCharacteristicOf.: To address OOPS pitfall P08: Missing inverse relationships</vaem:rationale>
  <dc:source>(competency_question) CQ1: Which wine characteristics should I consider when choosing a wine?
    (pitfall) P08: Missing inverse relationships for hasCharacteristic</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WineCharacteristic"/>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#isCharacteristicOf'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isCharacteristicOf">
  <rdfs:comment xml:lang="en">Links a wine characteristic to the wine that has it.</rdfs:comment>
  <rdfs:label xml:lang="en">is characteristic of</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property for hasCharacteristic.: To address OOPS pitfall P08: Missing inverse relationships</vaem:rationale>
  <dc:source>(pitfall) P08: Missing inverse relationships for hasCharacteristic</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WineCharacteristic"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#hasCharacteristic'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasColor">
