  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WineColor"/>
  <rdfs:subPropertyOf rdf:resource='http://www.semanticweb.org/myontology#hasCharacteristic'/>
<owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#isColorOf'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isColorOf">
  <rdfs:comment xml:lang="en">Links a wine color to the wine that has it.</rdfs:comment>
  <rdfs:label xml:lang="en">is color of</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property for hasColor.: To address OOPS pitfall P08: Missing inverse relationships</vaem:rationale>
  <dc:source>(pitfall) P08: Missing inverse relationships for hasColor</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WineColor"/>
