<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Wine">
  <rdfs:comment xml:lang="en">A type of alcoholic beverage made from fermented grapes.</rdfs:comment>
  <rdfs:label xml:lang="en">Wine</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Wine: Core concept from all competency questions; needed as domain for many properties.
    [Pitfall Resolution Agent] Created class Wine: Core concept from all competency questions; needed as domain for many properties.: Initial creation</vaem:rationale>
  <dc:source>(competency_question) CQ1: Which wine characteristics should I consider when choosing a wine?
    (competency_question) CQ2: Is Bordeaux a red or white wine?
    (competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?
    (competency_question) CQ7: What were good vintages for Napa Zinfandel?
    (competency_question) CQnew1: What grapes are used to make Bordeaux wine?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WineCharacteristic">
  <rdfs:comment xml:lang="en">A characteristic or attribute of a wine, such as bouquet, body, or color.</rdfs:comment>
  <rdfs:label xml:lang="en">Wine Characteristic</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class WineCharacteristic: Needed to answer CQ1 about wine characteristics; serves as superclass for specific characteristics like Bouquet and Body.
    [Pitfall Resolution Agent] Created class WineCharacteristic: Needed to answer CQ1 about wine characteristics; serves as superclass for specific characteristics like Bouquet and Body.: Initial creation</vaem:rationale>
  <dc:source>(competency_question) CQ1: Which wine characteristics should I consider when choosing a wine?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WineColor">
  <rdfs:comment xml:lang="en">The color of a wine, such as red or white.</rdfs:comment>
  <rdfs:label xml:lang="en">Wine Color</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class WineColor: Needed to answer CQ2 about wine color; serves as superclass for RedWine and WhiteWine.
    [Pitfall Resolution Agent] Created class WineColor: Needed to answer CQ2 about wine color; serves as superclass for RedWine and WhiteWine.: Initial creation</vaem:rationale>
  <dc:source>(competency_question) CQ2: Is Bordeaux a red or white wine?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#WineCharacteristic'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#RedWine">
  <rdfs:comment xml:lang="en">A wine that is red in color.</rdfs:comment>
  <rdfs:label xml:lang="en">Red Wine</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class RedWine: Specific color type from CQ2; needed to classify wines as red.
    [Pitfall Resolution Agent] Created class RedWine: Specific color type from CQ2; needed to classify wines as red.: Initial creation</vaem:rationale>
  <dc:source>(competency_question) CQ2: Is Bordeaux a red or white wine?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#WineColor'/>
<owl:disjointWith rdf:resource='http://www.semanticweb.org/myontology#WhiteWine'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WhiteWine">
  <rdfs:comment xml:lang="en">A wine that is white in color.</rdfs:comment>
  <rdfs:label xml:lang="en">White Wine</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class WhiteWine: Specific color type from CQ2; needed to classify wines as white.
    [Pitfall Resolution Agent] Created class WhiteWine: Specific color type from CQ2; needed to classify wines as white.: Initial creation</vaem:rationale>
  <dc:source>(competency_question) CQ2: Is Bordeaux a red or white wine?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#WineColor'/>
<owl:disjointWith rdf:resource='http://www.semanticweb.org/myontology#RedWine'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Bouquet">
  <rdfs:comment xml:lang="en">The scent or aroma of a wine.</rdfs:comment>
  <rdfs:label xml:lang="en">Bouquet</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Bouquet: Specific characteristic from CQ6; needed to model how bouquet changes with vintage year.
    [Pitfall Resolution Agent] Created class Bouquet: Specific characteristic from CQ6; needed to model how bouquet changes with vintage year.: Initial creation</vaem:rationale>
  <dc:source>(competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#WineCharacteristic'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Body">
  <rdfs:comment xml:lang="en">The weight or fullness of a wine in the mouth.</rdfs:comment>
  <rdfs:label xml:lang="en">Body</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Body: Specific characteristic from CQ6; needed to model how body changes with vintage year.
    [Pitfall Resolution Agent] Created class Body: Specific characteristic from CQ6; needed to model how body changes with vintage year.: Initial creation</vaem:rationale>
  <dc:source>(competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#WineCharacteristic'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#VintageYear">
  <rdfs:comment xml:lang="en">The year in which the grapes used to make a wine were harvested.</rdfs:comment>
  <rdfs:label xml:lang="en">Vintage Year</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class VintageYear: Needed to answer CQ6 and CQ7; represents the year associated with a wine's production.
    [Pitfall Resolution Agent] Created class VintageYear: Needed to answer CQ6 and CQ7; represents the year associated with a wine's production.: Initial creation</vaem:rationale>
  <dc:source>(competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?
    (competency_question) CQ7: What were good vintages for Napa Zinfandel?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Grape">
  <rdfs:comment xml:lang="en">A type of fruit used to make wine.</rdfs:comment>
  <rdfs:label xml:lang="en">Grape</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Grape: Needed to answer CQnew1; represents the grapes used in wine production.
    [Pitfall Resolution Agent] Created class Grape: Needed to answer CQnew1; represents the grapes used in wine production.: Initial creation</vaem:rationale>
  <dc:source>(competency_question) CQnew1: What grapes are used to make Bordeaux wine?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#VintageQuality">
  <rdfs:comment xml:lang="en">The quality of a wine for a specific vintage year, such as good or poor.</rdfs:comment>
  <rdfs:label xml:lang="en">Vintage Quality</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class VintageQuality: Needed to answer CQ7; allows classifying vintages as good, poor, etc.
    [Pitfall Resolution Agent] Created class VintageQuality: Needed to answer CQ7; allows classifying vintages as good, poor, etc.: Initial creation</vaem:rationale>
  <dc:source>(competency_question) CQ7: What were good vintages for Napa Zinfandel?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#GoodVintage">
  <rdfs:comment xml:lang="en">A vintage year that is considered to produce high-quality wine.</rdfs:comment>
  <rdfs:label xml:lang="en">Good Vintage</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class GoodVintage: Specific quality type from CQ7; needed to identify good vintages for a wine.
    [Pitfall Resolution Agent] Created class GoodVintage: Specific quality type from CQ7; needed to identify good vintages for a wine.: Initial creation</vaem:rationale>
  <dc:source>(competency_question) CQ7: What were good vintages for Napa Zinfandel?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#VintageQuality'/>
</owl:Class>

