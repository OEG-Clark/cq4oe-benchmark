<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Animal">
  <rdfs:comment xml:lang="en">A living organism that is typically motile and consumes organic matter.</rdfs:comment>
  <rdfs:label xml:lang="en">Animal</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Plant">
  <rdfs:comment xml:lang="en">A living organism that typically photosynthesizes and has roots, stems, and leaves.</rdfs:comment>
  <rdfs:label xml:lang="en">Plant</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlantPart">
  <rdfs:comment xml:lang="en">A part of a plant, such as leaves, stems, roots, or fruits.</rdfs:comment>
  <rdfs:label xml:lang="en">Plant Part</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Herbivore">
  <rdfs:comment xml:lang="en">An animal that eats only plants or plant parts.</rdfs:comment>
  <rdfs:label xml:lang="en">Herbivore</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Herbivore: To answer CQ2: 'Is this animal a herbivore?'</vaem:rationale>
  <dc:source>(competency_question) CQ2: Is [this animal] a herbivore?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="http://www.semanticweb.org/myontology#Animal"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="http://www.semanticweb.org/myontology#eats"/>
          <owl:allValuesFrom>
            <owl:Class>
              <owl:unionOf rdf:parseType="Collection">
                <rdf:Description rdf:about="http://www.semanticweb.org/myontology#Plant"/>
                <rdf:Description rdf:about="http://www.semanticweb.org/myontology#PlantPart"/>
              </owl:unionOf>
            </owl:Class>
          </owl:allValuesFrom>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Carnivore">
  <rdfs:comment xml:lang="en">An animal that eats only animals.</rdfs:comment>
  <rdfs:label xml:lang="en">Carnivore</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Carnivore: To answer CQ1 and CQ14 about carnivores.</vaem:rationale>
  <dc:source>(competency_question) CQ1: Which animal eats which other animal?
    (competency_question) CQ14: Are there animals that are carnivore but still eat some plants or parts of plants?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="http://www.semanticweb.org/myontology#Animal"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="http://www.semanticweb.org/myontology#eats"/>
          <owl:allValuesFrom rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Omnivore">
  <rdfs:comment xml:lang="en">An animal that eats both animals and plants or plant parts.</rdfs:comment>
  <rdfs:label xml:lang="en">Omnivore</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Omnivore: To answer CQ3: 'Which plant parts does this omnivorous or herbivorous animal eat?'</vaem:rationale>
  <dc:source>(competency_question) CQ3: Which plant parts does [this omnivorous or herbivorous animal] eat?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="http://www.semanticweb.org/myontology#Animal"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="http://www.semanticweb.org/myontology#eats"/>
          <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="http://www.semanticweb.org/myontology#eats"/>
          <owl:someValuesFrom>
            <owl:Class>
              <owl:unionOf rdf:parseType="Collection">
                <rdf:Description rdf:about="http://www.semanticweb.org/myontology#Plant"/>
                <rdf:Description rdf:about="http://www.semanticweb.org/myontology#PlantPart"/>
              </owl:unionOf>
            </owl:Class>
          </owl:someValuesFrom>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#CarnivorousPlant">
  <rdfs:comment xml:lang="en">A plant that eats animals.</rdfs:comment>
  <rdfs:label xml:lang="en">Carnivorous Plant</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class CarnivorousPlant: To answer CQ6: 'Which plants eat animals?'</vaem:rationale>
  <dc:source>(competency_question) CQ6: Which plants eat animals?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Plant"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="http://www.semanticweb.org/myontology#Plant"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="http://www.semanticweb.org/myontology#eats"/>
          <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#eats">
  <rdfs:comment xml:lang="en">Indicates that the subject consumes the object as food.</rdfs:comment>
  <rdfs:label xml:lang="en">eats</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property eats: Core property for all feeding relationships.</vaem:rationale>
  <dc:source>(competency_question) CQ1: Which animal eats which other animal?
    (competency_question) CQ3: Which plant parts does this omnivorous or herbivorous animal eat?
    (competency_question) CQ4: Does a lion eat plants or plant parts?
    (competency_question) CQ6: Which plants eat animals?
    (competency_question) CQ7: Which animals eat [these animals]?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Thing"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Thing"/>
</owl:ObjectProperty>

</rdf:RDF>