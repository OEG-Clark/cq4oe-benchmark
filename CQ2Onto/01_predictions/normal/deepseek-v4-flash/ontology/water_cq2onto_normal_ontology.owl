<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure">
  <rdfs:comment xml:lang="en">A system of assets that compose a water distribution network.</rdfs:comment>
  <rdfs:label xml:lang="en">water distribution infrastructure</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Asset">
  <rdfs:comment xml:lang="en">Any component that is part of a water distribution infrastructure.</rdfs:comment>
  <rdfs:label xml:lang="en">asset</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Sensor">
  <rdfs:comment xml:lang="en">A device that detects or measures a physical property.</rdfs:comment>
  <rdfs:label xml:lang="en">sensor</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Actuator">
  <rdfs:comment xml:lang="en">A device that moves or controls a mechanism or system.</rdfs:comment>
  <rdfs:label xml:lang="en">actuator</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Device">
  <rdfs:comment xml:lang="en">An electronic or mechanical apparatus.</rdfs:comment>
  <rdfs:label xml:lang="en">device</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterMeter">
  <rdfs:comment xml:lang="en">A device that measures different aspects of a water infrastructure.</rdfs:comment>
  <rdfs:label xml:lang="en">water meter</rdfs:label>
  <dc:source>(competency_question) CQ06: A water meter is a device that measures different aspects of a water infrastructure.</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Device"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Water">
  <rdfs:comment xml:lang="en">The substance water, with physical and chemical properties.</rdfs:comment>
  <rdfs:label xml:lang="en">water</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PhysicalProperty">
  <rdfs:comment xml:lang="en">A physical property of water.</rdfs:comment>
  <rdfs:label xml:lang="en">physical property</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ChemicalProperty">
  <rdfs:comment xml:lang="en">A chemical property of water.</rdfs:comment>
  <rdfs:label xml:lang="en">chemical property</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterIndicator">
  <rdfs:comment xml:lang="en">An indicator defined for a specific location (e.g., Burgos).</rdfs:comment>
  <rdfs:label xml:lang="en">water indicator</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Location">
  <rdfs:comment xml:lang="en">A geographic location.</rdfs:comment>
  <rdfs:label xml:lang="en">location</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Tariff">
  <rdfs:comment xml:lang="en">A tariff structure applied to water usage.</rdfs:comment>
  <rdfs:label xml:lang="en">tariff</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#TariffPeriod">
  <rdfs:comment xml:lang="en">A period for which a tariff is effective.</rdfs:comment>
  <rdfs:label xml:lang="en">tariff period</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Billing">
  <rdfs:comment xml:lang="en">Billing information associated with a water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">billing</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Measurement">
  <rdfs:comment xml:lang="en">A measurement provided by a water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">measurement</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#TemporalSetting">
  <rdfs:comment xml:lang="en">A setting that defines the timing of measurements.</rdfs:comment>
  <rdfs:label xml:lang="en">temporal setting</rdfs:label>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAsset">
  <rdfs:comment xml:lang="en">Relates a water distribution infrastructure to its assets.</rdfs:comment>
  <rdfs:label xml:lang="en">has asset</rdfs:label>
  <dc:source>(competency_question) CQ01: Which assets compose a water distribution infrastructure?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Asset"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasSensor">
  <rdfs:comment xml:lang="en">Relates a water distribution infrastructure to its sensors.</rdfs:comment>
  <rdfs:label xml:lang="en">has sensor</rdfs:label>
  <dc:source>(competency_question) CQ04: Which types of sensors are used in water infrastructures?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Sensor"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasActuator">
  <rdfs:comment xml:lang="en">Relates a water distribution infrastructure to its actuators.</rdfs:comment>
  <rdfs:label xml:lang="en">has actuator</rdfs:label>
  <dc:source>(competency_question) CQ05: Which types of actuators are used in water infrastructures?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Actuator"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasMeasurement">
  <rdfs:comment xml:lang="en">Relates a water meter to its measurements.</rdfs:comment>
  <rdfs:label xml:lang="en">has measurement</rdfs:label>
  <dc:source>(competency_question) CQ25: Water meters can provide measurements according to different temporal settings.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Measurement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasTemporalSetting">
  <rdfs:comment xml:lang="en">Relates a water meter to its temporal settings.</rdfs:comment>
  <rdfs:label xml:lang="en">has temporal setting</rdfs:label>
  <dc:source>(competency_question) CQ25: Water meters can provide measurements according to different temporal settings.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#TemporalSetting"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPhysicalProperty">
  <rdfs:comment xml:lang="en">Relates water to its physical properties.</rdfs:comment>
  <rdfs:label xml:lang="en">has physical property</rdfs:label>
  <dc:source>(competency_question) CQ33: What are the physical properties of water?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Water"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PhysicalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasChemicalProperty">
  <rdfs:comment xml:lang="en">Relates water to its chemical properties.</rdfs:comment>
  <rdfs:label xml:lang="en">has chemical property</rdfs:label>
  <dc:source>(competency_question) CQ34: What are the chemical properties of water?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Water"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#ChemicalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#definedFor">
  <rdfs:comment xml:lang="en">Relates a water indicator to the location it is defined for.</rdfs:comment>
  <rdfs:label xml:lang="en">defined for</rdfs:label>
  <dc:source>(competency_question) CQ37: Which water indicators are defined for Burgos?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterIndicator"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Location"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasTariff">
  <rdfs:comment xml:lang="en">Relates a water meter to its tariff.</rdfs:comment>
  <rdfs:label xml:lang="en">has tariff</rdfs:label>
  <dc:source>(competency_question) CQ38: What is the start date and time of the tariff in use in the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Tariff"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasBilling">
  <rdfs:comment xml:lang="en">Relates a water meter to its billing information.</rdfs:comment>
  <rdfs:label xml:lang="en">has billing</rdfs:label>
  <dc:source>(competency_question) CQ42: What is the billing date of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Billing"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGeolocation">
  <rdfs:comment xml:lang="en">Relates a water meter to its geographic location.</rdfs:comment>
  <rdfs:label xml:lang="en">has geolocation</rdfs:label>
  <dc:source>(competency_question) CQ20: What is the geolocation of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Location"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#fabricationNumber">
  <rdfs:comment xml:lang="en">The fabrication number of a water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">fabrication number</rdfs:label>
  <dc:source>(competency_question) CQ08: What is the fabrication number of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#manufacturer">
  <rdfs:comment xml:lang="en">The manufacturer of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">manufacturer</rdfs:label>
  <dc:source>(competency_question) CQ09: What are the manufacturer and the model of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#model">
  <rdfs:comment xml:lang="en">The model of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">model</rdfs:label>
  <dc:source>(competency_question) CQ09: What are the manufacturer and the model of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#version">
  <rdfs:comment xml:lang="en">The version of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">version</rdfs:label>
  <dc:source>(competency_question) CQ10: What is the version of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hardwareVersion">
  <rdfs:comment xml:lang="en">The hardware version number of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">hardware version</rdfs:label>
  <dc:source>(competency_question) CQ11: What is the hardware version number of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#firmwareVersion">
  <rdfs:comment xml:lang="en">The firmware version used by the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">firmware version</rdfs:label>
  <dc:source>(competency_question) CQ12: What firmware version is the water meter using?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#power">
  <rdfs:comment xml:lang="en">The power of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">power</rdfs:label>
  <dc:source>(competency_question) CQ18: What is the power of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#radioFrequencyLevel">
  <rdfs:comment xml:lang="en">The radio frequency level of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">radio frequency level</rdfs:label>
  <dc:source>(competency_question) CQ19: What is the radio frequency level of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#startDateTime">
  <rdfs:comment xml:lang="en">The start date and time of the tariff in use.</rdfs:comment>
  <rdfs:label xml:lang="en">start date time</rdfs:label>
  <dc:source>(competency_question) CQ38: What is the start date and time of the tariff in use in the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tariff"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#duration">
  <rdfs:comment xml:lang="en">The duration of the current tariff.</rdfs:comment>
  <rdfs:label xml:lang="en">duration</rdfs:label>
  <dc:source>(competency_question) CQ39: What is the duration of the current tariff of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tariff"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:duration"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#tariffPeriod">
  <rdfs:comment xml:lang="en">The tariff period of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">tariff period</rdfs:label>
  <dc:source>(competency_question) CQ40: What is the tariff period of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tariff"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#billingDate">
  <rdfs:comment xml:lang="en">The billing date of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">billing date</rdfs:label>
  <dc:source>(competency_question) CQ42: What is the billing date of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Billing"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#billingDatePeriod">
  <rdfs:comment xml:lang="en">The billing date period of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">billing date period</rdfs:label>
  <dc:source>(competency_question) CQ43: What is the billing date period of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Billing"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

</rdf:RDF>