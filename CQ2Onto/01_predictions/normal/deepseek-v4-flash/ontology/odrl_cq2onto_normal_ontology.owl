<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Policy">
  <rdfs:comment xml:lang="en">A policy that governs the usage of assets.</rdfs:comment>
  <rdfs:label xml:lang="en">Policy</rdfs:label>
  <dc:source>(competency_question) CQ06: Expressing the various roles of contract parties within the Permission/Duty element.</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Asset">
  <rdfs:comment xml:lang="en">An asset that is the subject of a policy.</rdfs:comment>
  <rdfs:label xml:lang="en">Asset</rdfs:label>
  <dc:source>(competency_question) New CQ1: Which policy is directly linked to a given asset?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Party">
  <rdfs:comment xml:lang="en">A party involved in a policy (e.g., assignee, assigner).</rdfs:comment>
  <rdfs:label xml:lang="en">Party</rdfs:label>
  <dc:source>(competency_question) CQ06: Expressing the various roles of contract parties within the Permission/Duty element.</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Action">
  <rdfs:comment xml:lang="en">An action that can be performed on an asset.</rdfs:comment>
  <rdfs:label xml:lang="en">Action</rdfs:label>
  <dc:source>(competency_question) CQ03: Shall the permissions 'Aggregation' and 'Disaggregation' be of the type Transfer Rights?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Rule">
  <rdfs:comment xml:lang="en">A rule that defines permissions, duties, or prohibitions.</rdfs:comment>
  <rdfs:label xml:lang="en">Rule</rdfs:label>
  <dc:source>(competency_question) CQ10: How are rights and duties supported for all contract parties?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Permission">
  <rdfs:comment xml:lang="en">A permission to perform an action on an asset.</rdfs:comment>
  <rdfs:label xml:lang="en">Permission</rdfs:label>
  <dc:source>(competency_question) CQ03: Shall the permissions 'Aggregation' and 'Disaggregation' be of the type Transfer Rights?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Duty"/>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Prohibition"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Duty">
  <rdfs:comment xml:lang="en">A duty that must be fulfilled.</rdfs:comment>
  <rdfs:label xml:lang="en">Duty</rdfs:label>
  <dc:source>(competency_question) CQ10: How are rights and duties supported for all contract parties?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Permission"/>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Prohibition"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Prohibition">
  <rdfs:comment xml:lang="en">A prohibition against performing an action on an asset.</rdfs:comment>
  <rdfs:label xml:lang="en">Prohibition</rdfs:label>
  <dc:source>(competency_question) New CQ3: What duty is specified as a remedy for the violation of a prohibition?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Permission"/>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Duty"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Constraint">
  <rdfs:comment xml:lang="en">A constraint that restricts a rule.</rdfs:comment>
  <rdfs:label xml:lang="en">Constraint</rdfs:label>
  <dc:source>(competency_question) CQ13: Shall ODRLv2 allow for nested constraints?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#LogicalConstraint">
  <rdfs:comment xml:lang="en">A constraint that combines other constraints using a logical operator (and, or, xor).</rdfs:comment>
  <rdfs:label xml:lang="en">LogicalConstraint</rdfs:label>
  <dc:source>(competency_question) CQ14: How do we express 'and', 'or', 'xor' constraints?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#NegationConstraint">
  <rdfs:comment xml:lang="en">A constraint that negates another constraint (NOT).</rdfs:comment>
  <rdfs:label xml:lang="en">NegationConstraint</rdfs:label>
  <dc:source>(competency_question) CQ08: How to provide a 'NOT' expression?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Condition">
  <rdfs:comment xml:lang="en">A condition expressed as a constraint.</rdfs:comment>
  <rdfs:label xml:lang="en">Condition</rdfs:label>
  <dc:source>(competency_question) CQ26: How to express Condition via Constraints?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Operator">
  <rdfs:comment xml:lang="en">An operator used in constraints (e.g., eq, lt, gt).</rdfs:comment>
  <rdfs:label xml:lang="en">Operator</rdfs:label>
  <dc:source>(competency_question) New CQ6: What operator is used in the constraints of a prohibition?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#LogicalOperator">
  <rdfs:comment xml:lang="en">A logical operator used in logical constraints (and, or, xor).</rdfs:comment>
  <rdfs:label xml:lang="en">LogicalOperator</rdfs:label>
  <dc:source>(competency_question) CQ14: How do we express 'and', 'or', 'xor' constraints?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Operator"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#TransferRight">
  <rdfs:comment xml:lang="en">A right to transfer (aggregate or disaggregate) an asset.</rdfs:comment>
  <rdfs:label xml:lang="en">TransferRight</rdfs:label>
  <dc:source>(competency_question) CQ03: Shall the permissions 'Aggregation' and 'Disaggregation' be of the type Transfer Rights?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Permission"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#AggregationRight">
  <rdfs:comment xml:lang="en">A permission to aggregate an asset (a transfer right).</rdfs:comment>
  <rdfs:label xml:lang="en">AggregationRight</rdfs:label>
  <dc:source>(competency_question) CQ03: Shall the permissions 'Aggregation' and 'Disaggregation' be of the type Transfer Rights?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#TransferRight"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#DisaggregationRight">
  <rdfs:comment xml:lang="en">A permission to disaggregate an asset (a transfer right).</rdfs:comment>
  <rdfs:label xml:lang="en">DisaggregationRight</rdfs:label>
  <dc:source>(competency_question) CQ03: Shall the permissions 'Aggregation' and 'Disaggregation' be of the type Transfer Rights?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#TransferRight"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ExclusivePermission">
  <rdfs:comment xml:lang="en">A permission that is exclusive (no other permissions for the same action).</rdfs:comment>
  <rdfs:label xml:lang="en">ExclusivePermission</rdfs:label>
  <dc:source>(competency_question) CQ24: How to express exclusive permissions?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Permission"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Sequence">
  <rdfs:comment xml:lang="en">A sequence of actions that must be performed in order.</rdfs:comment>
  <rdfs:label xml:lang="en">Sequence</rdfs:label>
  <dc:source>(competency_question) CQ31: Do we need 'Sequencing' as part of the REL?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ConflictStrategy">
  <rdfs:comment xml:lang="en">A strategy for resolving conflicts between rules.</rdfs:comment>
  <rdfs:label xml:lang="en">ConflictStrategy</rdfs:label>
  <dc:source>(competency_question) New CQ2: What conflict resolution strategy is specified by a policy?</dc:source>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#relatesToPolicy">
  <rdfs:comment xml:lang="en">Links an asset to the policy that governs it.</rdfs:comment>
  <rdfs:label xml:lang="en">relatesToPolicy</rdfs:label>
  <dc:source>(competency_question) New CQ1: Which policy is directly linked to a given asset?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Asset"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasRule">
  <rdfs:comment xml:lang="en">A policy contains rules (permissions, duties, prohibitions).</rdfs:comment>
  <rdfs:label xml:lang="en">hasRule</rdfs:label>
  <dc:source>(competency_question) CQ10: How are rights and duties supported for all contract parties?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPermission">
  <rdfs:comment xml:lang="en">A policy contains a permission.</rdfs:comment>
  <rdfs:label xml:lang="en">hasPermission</rdfs:label>
  <dc:source>(competency_question) CQ03: Shall the permissions 'Aggregation' and 'Disaggregation' be of the type Transfer Rights?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Permission"/>
  <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/myontology#hasRule"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasDuty">
  <rdfs:comment xml:lang="en">A policy contains a duty.</rdfs:comment>
  <rdfs:label xml:lang="en">hasDuty</rdfs:label>
  <dc:source>(competency_question) CQ10: How are rights and duties supported for all contract parties?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Duty"/>
  <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/myontology#hasRule"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasProhibition">
  <rdfs:comment xml:lang="en">A policy contains a prohibition.</rdfs:comment>
  <rdfs:label xml:lang="en">hasProhibition</rdfs:label>
  <dc:source>(competency_question) New CQ3: What duty is specified as a remedy for the violation of a prohibition?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Prohibition"/>
  <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/myontology#hasRule"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAction">
  <rdfs:comment xml:lang="en">The action associated with a rule.</rdfs:comment>
  <rdfs:label xml:lang="en">hasAction</rdfs:label>
  <dc:source>(competency_question) CQ03: Shall the permissions 'Aggregation' and 'Disaggregation' be of the type Transfer Rights?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Action"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasConstraint">
  <rdfs:comment xml:lang="en">A constraint on a rule.</rdfs:comment>
  <rdfs:label xml:lang="en">hasConstraint</rdfs:label>
  <dc:source>(competency_question) CQ13: Shall ODRLv2 allow for nested constraints?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasOperator">
  <rdfs:comment xml:lang="en">The operator used in a constraint.</rdfs:comment>
  <rdfs:label xml:lang="en">hasOperator</rdfs:label>
  <dc:source>(competency_question) New CQ6: What operator is used in the constraints of a prohibition?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Operator"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasLeftOperand">
  <rdfs:comment xml:lang="en">Left operand of a logical constraint.</rdfs:comment>
  <rdfs:label xml:lang="en">hasLeftOperand</rdfs:label>
  <dc:source>(competency_question) CQ14: How do we express 'and', 'or', 'xor' constraints?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#LogicalConstraint"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasRightOperand">
  <rdfs:comment xml:lang="en">Right operand of a logical constraint.</rdfs:comment>
  <rdfs:label xml:lang="en">hasRightOperand</rdfs:label>
  <dc:source>(competency_question) CQ14: How do we express 'and', 'or', 'xor' constraints?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#LogicalConstraint"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasLogicalOperator">
  <rdfs:comment xml:lang="en">The logical operator (and, or, xor) of a logical constraint.</rdfs:comment>
  <rdfs:label xml:lang="en">hasLogicalOperator</rdfs:label>
  <dc:source>(competency_question) CQ14: How do we express 'and', 'or', 'xor' constraints?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#LogicalConstraint"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#LogicalOperator"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasNegatedConstraint">
  <rdfs:comment xml:lang="en">The constraint that is negated.</rdfs:comment>
  <rdfs:label xml:lang="en">hasNegatedConstraint</rdfs:label>
  <dc:source>(competency_question) CQ08: How to provide a 'NOT' expression?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#NegationConstraint"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasRemedy">
  <rdfs:comment xml:lang="en">A duty that is a remedy for violation of this prohibition.</rdfs:comment>
  <rdfs:label xml:lang="en">hasRemedy</rdfs:label>
  <dc:source>(competency_question) New CQ3: What duty is specified as a remedy for the violation of a prohibition?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Prohibition"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Duty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasConsequence">
  <rdfs:comment xml:lang="en">A duty that is a consequence of another duty.</rdfs:comment>
  <rdfs:label xml:lang="en">hasConsequence</rdfs:label>
  <dc:source>(competency_question) New CQ5: What duty is specified as a consequence of another duty?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Duty"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Duty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasFailureRule">
  <rdfs:comment xml:lang="en">A rule that is activated upon failure of another rule.</rdfs:comment>
  <rdfs:label xml:lang="en">hasFailureRule</rdfs:label>
  <dc:source>(competency_question) New CQ4: Which rule is activated upon the failure of another rule?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasConflictStrategy">
  <rdfs:comment xml:lang="en">The conflict resolution strategy specified by a policy.</rdfs:comment>
  <rdfs:label xml:lang="en">hasConflictStrategy</rdfs:label>
  <dc:source>(competency_question) New CQ2: What conflict resolution strategy is specified by a policy?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#ConflictStrategy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasParty">
  <rdfs:comment xml:lang="en">A party involved in a policy.</rdfs:comment>
  <rdfs:label xml:lang="en">hasParty</rdfs:label>
  <dc:source>(competency_question) CQ06: Expressing the various roles of contract parties within the Permission/Duty element.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Party"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAssignee">
  <rdfs:comment xml:lang="en">The party to whom the rule is assigned.</rdfs:comment>
  <rdfs:label xml:lang="en">hasAssignee</rdfs:label>
  <dc:source>(competency_question) CQ06: Expressing the various roles of contract parties within the Permission/Duty element.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Party"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAssigner">
  <rdfs:comment xml:lang="en">The party who assigns the rule.</rdfs:comment>
  <rdfs:label xml:lang="en">hasAssigner</rdfs:label>
  <dc:source>(competency_question) CQ06: Expressing the various roles of contract parties within the Permission/Duty element.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Party"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#subPolicyOf">
  <rdfs:comment xml:lang="en">A policy that is a child (sub-policy) of another policy.</rdfs:comment>
  <rdfs:label xml:lang="en">subPolicyOf</rdfs:label>
  <dc:source>(competency_question) CQ33: Can the new data model express inheritance?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasNextAction">
  <rdfs:comment xml:lang="en">The next action in a sequence (for ordered actions).</rdfs:comment>
  <rdfs:label xml:lang="en">hasNextAction</rdfs:label>
  <dc:source>(competency_question) CQ31: Do we need 'Sequencing' as part of the REL?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Action"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Action"/>
</owl:ObjectProperty>

</rdf:RDF>