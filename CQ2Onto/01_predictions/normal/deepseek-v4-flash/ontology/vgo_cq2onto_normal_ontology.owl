<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Player">
  <rdfs:comment xml:lang="en">A person who plays games.</rdfs:comment>
  <rdfs:label xml:lang="en">Player</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Game">
  <rdfs:comment xml:lang="en">A video game.</rdfs:comment>
  <rdfs:label xml:lang="en">Game</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Achievement">
  <rdfs:comment xml:lang="en">An achievement that can be earned in a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Achievement</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#AchievementType">
  <rdfs:comment xml:lang="en">A category of achievement.</rdfs:comment>
  <rdfs:label xml:lang="en">Achievement Type</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Item">
  <rdfs:comment xml:lang="en">An item that exists in a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Item</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Equipment">
  <rdfs:comment xml:lang="en">An item that can be equipped by a player.</rdfs:comment>
  <rdfs:label xml:lang="en">Equipment</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Item'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayingArea">
  <rdfs:comment xml:lang="en">An area within a game where gameplay occurs.</rdfs:comment>
  <rdfs:label xml:lang="en">Playing Area</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Genre">
  <rdfs:comment xml:lang="en">A genre of a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Genre</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#InAppPurchase">
  <rdfs:comment xml:lang="en">An in-app purchase made by a player.</rdfs:comment>
  <rdfs:label xml:lang="en">In-App Purchase</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayerGameStat">
  <rdfs:comment xml:lang="en">Statistics about a player's performance in a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Player Game Statistic</rdfs:label>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasFriend">
  <rdfs:comment xml:lang="en">Indicates that a player has another player as a friend.</rdfs:comment>
  <rdfs:label xml:lang="en">has friend</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#playsGame">
  <rdfs:comment xml:lang="en">Indicates that a player plays a game.</rdfs:comment>
  <rdfs:label xml:lang="en">plays game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAchievement">
  <rdfs:comment xml:lang="en">Indicates that a player has obtained an achievement.</rdfs:comment>
  <rdfs:label xml:lang="en">has achievement</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#belongsToGame">
  <rdfs:comment xml:lang="en">Indicates that an achievement belongs to a game.</rdfs:comment>
  <rdfs:label xml:lang="en">belongs to game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasType">
  <rdfs:comment xml:lang="en">Indicates the type of an achievement.</rdfs:comment>
  <rdfs:label xml:lang="en">has type</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasItem">
  <rdfs:comment xml:lang="en">Indicates that a game contains an item.</rdfs:comment>
  <rdfs:label xml:lang="en">has item</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPlayingArea">
  <rdfs:comment xml:lang="en">Indicates that a game has a playing area.</rdfs:comment>
  <rdfs:label xml:lang="en">has playing area</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGenre">
  <rdfs:comment xml:lang="en">Indicates the genre of a game.</rdfs:comment>
  <rdfs:label xml:lang="en">has genre</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Genre"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasTopPlayer">
  <rdfs:comment xml:lang="en">Indicates the player with the best kill count in a game.</rdfs:comment>
  <rdfs:label xml:lang="en">has top player</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasStat">
  <rdfs:comment xml:lang="en">Indicates that a player has a game statistic entry.</rdfs:comment>
  <rdfs:label xml:lang="en">has stat</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PlayerGameStat"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#forGame">
  <rdfs:comment xml:lang="en">Indicates the game to which a player game statistic belongs.</rdfs:comment>
  <rdfs:label xml:lang="en">for game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameStat"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasEquipment">
  <rdfs:comment xml:lang="en">Indicates that a player game statistic includes equipment.</rdfs:comment>
  <rdfs:label xml:lang="en">has equipment</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameStat"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Equipment"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasInAppPurchase">
  <rdfs:comment xml:lang="en">Indicates that a player made an in-app purchase.</rdfs:comment>
  <rdfs:label xml:lang="en">has in-app purchase</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#possessesItem">
  <rdfs:comment xml:lang="en">Indicates that a player possesses an item.</rdfs:comment>
  <rdfs:label xml:lang="en">possesses item</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasUsername">
  <rdfs:comment xml:lang="en">The username of a player.</rdfs:comment>
  <rdfs:label xml:lang="en">has username</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasHoursPlayedTotal">
  <rdfs:comment xml:lang="en">The total hours a game has been played.</rdfs:comment>
  <rdfs:label xml:lang="en">has hours played total</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#releaseDate">
  <rdfs:comment xml:lang="en">The release date of a game.</rdfs:comment>
  <rdfs:label xml:lang="en">release date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:date"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#abilityDescription">
  <rdfs:comment xml:lang="en">A description of an item's ability.</rdfs:comment>
  <rdfs:label xml:lang="en">ability description</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Item"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#killCount">
  <rdfs:comment xml:lang="en">The number of kills recorded in a player game statistic.</rdfs:comment>
  <rdfs:label xml:lang="en">kill count</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameStat"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hoursPlayed">
  <rdfs:comment xml:lang="en">The number of hours a player has spent in a game.</rdfs:comment>
  <rdfs:label xml:lang="en">hours played</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameStat"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#purchaseTime">
  <rdfs:comment xml:lang="en">The date and time of an in-app purchase.</rdfs:comment>
  <rdfs:label xml:lang="en">purchase time</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#purchaseAmount">
  <rdfs:comment xml:lang="en">The amount of an in-app purchase.</rdfs:comment>
  <rdfs:label xml:lang="en">purchase amount</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:float"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#livesIn">
  <rdfs:comment xml:lang="en">The location where a player lives.</rdfs:comment>
  <rdfs:label xml:lang="en">lives in</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

</rdf:RDF>