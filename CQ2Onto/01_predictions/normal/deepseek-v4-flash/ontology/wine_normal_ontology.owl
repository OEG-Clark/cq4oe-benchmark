<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Wine">
  <rdfs:comment xml:lang="en">The class of all wines.</rdfs:comment>
  <rdfs:label xml:lang="en">wine</rdfs:label>
  <dc:source>(competency_question) CQ1: Which wine characteristics should I consider when choosing a wine?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#RedWine">
  <rdfs:comment xml:lang="en">Red wine is a type of wine made from dark-colored grape varieties.</rdfs:comment>
  <rdfs:label xml:lang="en">red wine</rdfs:label>
  <dc:source>(competency_question) CQ2: Is Bordeaux a red or white wine?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#WhiteWine"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WhiteWine">
  <rdfs:comment xml:lang="en">White wine is a type of wine made from green or yellowish grape varieties.</rdfs:comment>
  <rdfs:label xml:lang="en">white wine</rdfs:label>
  <dc:source>(competency_question) CQ2: Is Bordeaux a red or white wine?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#RedWine"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Bordeaux">
  <rdfs:comment xml:lang="en">Bordeaux is a type of red wine produced in the Bordeaux region of France.</rdfs:comment>
  <rdfs:label xml:lang="en">Bordeaux</rdfs:label>
  <dc:source>(competency_question) CQ2: Is Bordeaux a red or white wine?
    (competency_question) CQnew1: What grapes are used to make Bordeaux wine?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#RedWine"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Zinfandel">
  <rdfs:comment xml:lang="en">Zinfandel is a variety of red wine grape, also used to produce a full-bodied red wine.</rdfs:comment>
  <rdfs:label xml:lang="en">Zinfandel</rdfs:label>
  <dc:source>(competency_question) CQ7: What were good vintages for Napa Zinfandel?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#RedWine"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#NapaZinfandel">
  <rdfs:comment xml:lang="en">Napa Zinfandel is a Zinfandel wine produced in the Napa Valley region.</rdfs:comment>
  <rdfs:label xml:lang="en">Napa Zinfandel</rdfs:label>
  <dc:source>(competency_question) CQ7: What were good vintages for Napa Zinfandel?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Zinfandel"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Grape">
  <rdfs:comment xml:lang="en">The class of grape varieties used for winemaking.</rdfs:comment>
  <rdfs:label xml:lang="en">grape</rdfs:label>
  <dc:source>(competency_question) CQnew1: What grapes are used to make Bordeaux wine?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Vintage">
  <rdfs:comment xml:lang="en">A vintage is a year in which a wine is produced, typically indicating the harvest year.</rdfs:comment>
  <rdfs:label xml:lang="en">vintage</rdfs:label>
  <dc:source>(competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?
    (competency_question) CQ7: What were good vintages for Napa Zinfandel?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WineCharacteristic">
  <rdfs:comment xml:lang="en">A characteristic of a wine, such as bouquet, body, or color.</rdfs:comment>
  <rdfs:label xml:lang="en">wine characteristic</rdfs:label>
  <dc:source>(competency_question) CQ1: Which wine characteristics should I consider when choosing a wine?
    (competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Bouquet">
  <rdfs:comment xml:lang="en">The bouquet is the complex aroma of a wine, often developing with age.</rdfs:comment>
  <rdfs:label xml:lang="en">bouquet</rdfs:label>
  <dc:source>(competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#WineCharacteristic"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Body">
  <rdfs:comment xml:lang="en">The body is the weight and texture of a wine on the palate, ranging from light to full.</rdfs:comment>
  <rdfs:label xml:lang="en">body</rdfs:label>
  <dc:source>(competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#WineCharacteristic"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Color">
  <rdfs:comment xml:lang="en">The color of a wine, such as red, white, or rosé.</rdfs:comment>
  <rdfs:label xml:lang="en">color</rdfs:label>
  <dc:source>(competency_question) CQ2: Is Bordeaux a red or white wine?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#WineCharacteristic"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Region">
  <rdfs:comment xml:lang="en">A wine-producing region.</rdfs:comment>
  <rdfs:label xml:lang="en">region</rdfs:label>
  <dc:source>(competency_question) CQ7: What were good vintages for Napa Zinfandel?</dc:source>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGrape">
  <rdfs:comment xml:lang="en">Relates a wine to a grape variety used in its production.</rdfs:comment>
  <rdfs:label xml:lang="en">has grape</rdfs:label>
  <dc:source>(competency_question) CQnew1: What grapes are used to make Bordeaux wine?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Grape"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasVintage">
  <rdfs:comment xml:lang="en">Relates a wine to its vintage year.</rdfs:comment>
  <rdfs:label xml:lang="en">has vintage</rdfs:label>
  <dc:source>(competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?
    (competency_question) CQ7: What were good vintages for Napa Zinfandel?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Vintage"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasCharacteristic">
  <rdfs:comment xml:lang="en">Relates a wine to one of its characteristics (e.g., bouquet, body, color).</rdfs:comment>
  <rdfs:label xml:lang="en">has characteristic</rdfs:label>
  <dc:source>(competency_question) CQ1: Which wine characteristics should I consider when choosing a wine?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WineCharacteristic"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasBouquet">
  <rdfs:comment xml:lang="en">Relates a wine to its bouquet characteristic.</rdfs:comment>
  <rdfs:label xml:lang="en">has bouquet</rdfs:label>
  <dc:source>(competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Bouquet"/>
  <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/myontology#hasCharacteristic"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasBody">
  <rdfs:comment xml:lang="en">Relates a wine to its body characteristic.</rdfs:comment>
  <rdfs:label xml:lang="en">has body</rdfs:label>
  <dc:source>(competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Body"/>
  <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/myontology#hasCharacteristic"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasColor">
  <rdfs:comment xml:lang="en">Relates a wine to its color characteristic.</rdfs:comment>
  <rdfs:label xml:lang="en">has color</rdfs:label>
  <dc:source>(competency_question) CQ2: Is Bordeaux a red or white wine?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Color"/>
  <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/myontology#hasCharacteristic"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#producedIn">
  <rdfs:comment xml:lang="en">Relates a wine to the region where it is produced.</rdfs:comment>
  <rdfs:label xml:lang="en">produced in</rdfs:label>
  <dc:source>(competency_question) CQ7: What were good vintages for Napa Zinfandel?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Region"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGoodVintage">
  <rdfs:comment xml:lang="en">Relates a wine to a vintage that is considered good for that wine.</rdfs:comment>
  <rdfs:label xml:lang="en">has good vintage</rdfs:label>
  <dc:source>(competency_question) CQ7: What were good vintages for Napa Zinfandel?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Vintage"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#vintageYear">
  <rdfs:comment xml:lang="en">The year of a vintage.</rdfs:comment>
  <rdfs:label xml:lang="en">vintage year</rdfs:label>
  <dc:source>(competency_question) CQ7: What were good vintages for Napa Zinfandel?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Vintage"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

</rdf:RDF>