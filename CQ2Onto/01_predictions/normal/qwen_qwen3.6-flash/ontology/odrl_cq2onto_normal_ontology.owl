<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Policy">
  <rdfs:comment xml:lang="en">A policy defines the rules, permissions, and prohibitions governing the use of assets.</rdfs:comment>
  <rdfs:label xml:lang="en">Policy</rdfs:label>
  <dc:source>(competency_question) New CQ1
    (competency_question) New CQ2
    (competency_question) CQ30</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Asset">
  <rdfs:comment xml:lang="en">The resource or object to which a policy applies.</rdfs:comment>
  <rdfs:label xml:lang="en">Asset</rdfs:label>
  <dc:source>(competency_question) New CQ1</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Rule">
  <rdfs:comment xml:lang="en">A logical statement or condition within a policy that dictates actions or restrictions.</rdfs:comment>
  <rdfs:label xml:lang="en">Rule</rdfs:label>
  <dc:source>(competency_question) CQ31
    (competency_question) CQ33
    (competency_question) New CQ4</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Permission">
  <rdfs:comment xml:lang="en">A rule that grants a right to perform an action.</rdfs:comment>
  <rdfs:label xml:lang="en">Permission</rdfs:label>
  <dc:source>(competency_question) CQ03
    (competency_question) CQ06
    (competency_question) CQ24</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Prohibition">
  <rdfs:comment xml:lang="en">A rule that forbids a specific action.</rdfs:comment>
  <rdfs:label xml:lang="en">Prohibition</rdfs:label>
  <dc:source>(competency_question) New CQ3
    (competency_question) New CQ6</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Duty">
  <rdfs:comment xml:lang="en">An obligation imposed on a contract party, often as a consequence or remedy.</rdfs:comment>
  <rdfs:label xml:lang="en">Duty</rdfs:label>
  <dc:source>(competency_question) CQ06
    (competency_question) CQ10
    (competency_question) New CQ3
    (competency_question) New CQ5</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#TransferRight">
  <rdfs:comment xml:lang="en">A category of rights involving the transfer of assets or permissions.</rdfs:comment>
  <rdfs:label xml:lang="en">Transfer Right</rdfs:label>
  <dc:source>(competency_question) CQ03</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Aggregation">
  <rdfs:comment xml:lang="en">The right to combine or aggregate assets or data.</rdfs:comment>
  <rdfs:label xml:lang="en">Aggregation</rdfs:label>
  <dc:source>(competency_question) CQ03</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#TransferRight'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Disaggregation">
  <rdfs:comment xml:lang="en">The right to separate or disaggregate assets or data.</rdfs:comment>
  <rdfs:label xml:lang="en">Disaggregation</rdfs:label>
  <dc:source>(competency_question) CQ03</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#TransferRight'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ExclusivePermission">
  <rdfs:comment xml:lang="en">A permission that excludes others from performing the same action.</rdfs:comment>
  <rdfs:label xml:lang="en">Exclusive Permission</rdfs:label>
  <dc:source>(competency_question) CQ24</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Permission'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ContractParty">
  <rdfs:comment xml:lang="en">An entity involved in a contract or policy agreement.</rdfs:comment>
  <rdfs:label xml:lang="en">Contract Party</rdfs:label>
  <dc:source>(competency_question) CQ06
    (competency_question) CQ10</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Role">
  <rdfs:comment xml:lang="en">A function or position assumed by a contract party.</rdfs:comment>
  <rdfs:label xml:lang="en">Role</rdfs:label>
  <dc:source>(competency_question) CQ06</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Constraint">
  <rdfs:comment xml:lang="en">A condition or limitation applied to rules, permissions, or duties.</rdfs:comment>
  <rdfs:label xml:lang="en">Constraint</rdfs:label>
  <dc:source>(competency_question) CQ08
    (competency_question) CQ13
    (competency_question) CQ14
    (competency_question) CQ21
    (competency_question) CQ26
    (competency_question) New CQ6</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#LogicalOperator">
  <rdfs:comment xml:lang="en">Operators used to combine or negate constraints (e.g., AND, OR, NOT, XOR).</rdfs:comment>
  <rdfs:label xml:lang="en">Logical Operator</rdfs:label>
  <dc:source>(competency_question) CQ08
    (competency_question) CQ14</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Condition">
  <rdfs:comment xml:lang="en">A prerequisite or state that must be met for a rule to apply.</rdfs:comment>
  <rdfs:label xml:lang="en">Condition</rdfs:label>
  <dc:source>(competency_question) CQ26</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Requirement">
  <rdfs:comment xml:lang="en">A mandatory condition or specification that must be satisfied.</rdfs:comment>
  <rdfs:label xml:lang="en">Requirement</rdfs:label>
  <dc:source>(competency_question) CQ21</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Container">
  <rdfs:comment xml:lang="en">A grouping mechanism for policies or rules.</rdfs:comment>
  <rdfs:label xml:lang="en">Container</rdfs:label>
  <dc:source>(competency_question) CQ30</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Sequence">
  <rdfs:comment xml:lang="en">An ordered list of rules or actions to be executed.</rdfs:comment>
  <rdfs:label xml:lang="en">Sequence</rdfs:label>
  <dc:source>(competency_question) CQ31</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ConflictResolutionStrategy">
  <rdfs:comment xml:lang="en">A method defined in a policy to resolve conflicts between rules.</rdfs:comment>
  <rdfs:label xml:lang="en">Conflict Resolution Strategy</rdfs:label>
  <dc:source>(competency_question) New CQ2</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Remedy">
  <rdfs:comment xml:lang="en">A corrective action or duty specified for policy violations.</rdfs:comment>
  <rdfs:label xml:lang="en">Remedy</rdfs:label>
  <dc:source>(competency_question) New CQ3</dc:source>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPolicy">
  <rdfs:comment xml:lang="en">Links an asset to its directly associated policy.</rdfs:comment>
  <rdfs:label xml:lang="en">has policy</rdfs:label>
  <dc:source>(competency_question) New CQ1</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Asset"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAsset">
  <rdfs:comment xml:lang="en">Links a policy to the assets it governs.</rdfs:comment>
  <rdfs:label xml:lang="en">has asset</rdfs:label>
  <dc:source>(competency_question) New CQ1</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Asset"/>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#hasPolicy'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasRule">
  <rdfs:comment xml:lang="en">Associates a policy with its constituent rules.</rdfs:comment>
  <rdfs:label xml:lang="en">has rule</rdfs:label>
  <dc:source>(competency_question) CQ31
    (competency_question) CQ33</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPermission">
  <rdfs:comment xml:lang="en">Associates a policy with its permissions.</rdfs:comment>
  <rdfs:label xml:lang="en">has permission</rdfs:label>
  <dc:source>(competency_question) CQ03
    (competency_question) CQ06</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Permission"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasProhibition">
  <rdfs:comment xml:lang="en">Associates a policy with its prohibitions.</rdfs:comment>
  <rdfs:label xml:lang="en">has prohibition</rdfs:label>
  <dc:source>(competency_question) New CQ3
    (competency_question) New CQ6</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Prohibition"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasDuty">
  <rdfs:comment xml:lang="en">Associates a policy with its duties.</rdfs:comment>
  <rdfs:label xml:lang="en">has duty</rdfs:label>
  <dc:source>(competency_question) CQ06
    (competency_question) CQ10</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Duty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasRole">
  <rdfs:comment xml:lang="en">Assigns a role to a contract party.</rdfs:comment>
  <rdfs:label xml:lang="en">has role</rdfs:label>
  <dc:source>(competency_question) CQ06</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ContractParty"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Role"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasContractParty">
  <rdfs:comment xml:lang="en">Assigns a contract party to a permission, prohibition, or duty.</rdfs:comment>
  <rdfs:label xml:lang="en">has contract party</rdfs:label>
  <dc:source>(competency_question) CQ06
    (competency_question) CQ10</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Permission"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#ContractParty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasConstraint">
  <rdfs:comment xml:lang="en">Links a rule, condition, or requirement to its constraints.</rdfs:comment>
  <rdfs:label xml:lang="en">has constraint</rdfs:label>
  <dc:source>(competency_question) CQ13
    (competency_question) CQ21
    (competency_question) CQ26
    (competency_question) New CQ6</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasLogicalOperator">
  <rdfs:comment xml:lang="en">Specifies the logical operator used in a constraint.</rdfs:comment>
  <rdfs:label xml:lang="en">has logical operator</rdfs:label>
  <dc:source>(competency_question) CQ08
    (competency_question) CQ14</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#LogicalOperator"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasConflictResolutionStrategy">
  <rdfs:comment xml:lang="en">Specifies the conflict resolution strategy for a policy.</rdfs:comment>
  <rdfs:label xml:lang="en">has conflict resolution strategy</rdfs:label>
  <dc:source>(competency_question) New CQ2</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#ConflictResolutionStrategy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasRemedyDuty">
  <rdfs:comment xml:lang="en">Links a prohibition to the duty that serves as a remedy for its violation.</rdfs:comment>
  <rdfs:label xml:lang="en">has remedy duty</rdfs:label>
  <dc:source>(competency_question) New CQ3</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Prohibition"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Duty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasFailureRule">
  <rdfs:comment xml:lang="en">Links a rule to another rule that is activated upon its failure.</rdfs:comment>
  <rdfs:label xml:lang="en">has failure rule</rdfs:label>
  <dc:source>(competency_question) New CQ4</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasConsequenceDuty">
  <rdfs:comment xml:lang="en">Links a duty to another duty that is specified as its consequence.</rdfs:comment>
  <rdfs:label xml:lang="en">has consequence duty</rdfs:label>
  <dc:source>(competency_question) New CQ5</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Duty"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Duty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#inheritsFrom">
  <rdfs:comment xml:lang="en">Links a rule to its parent rule in an inheritance hierarchy.</rdfs:comment>
  <rdfs:label xml:lang="en">inherits from</rdfs:label>
  <dc:source>(competency_question) CQ33</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasContainer">
  <rdfs:comment xml:lang="en">Links a policy to its container.</rdfs:comment>
  <rdfs:label xml:lang="en">has container</rdfs:label>
  <dc:source>(competency_question) CQ30</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Container"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasSequence">
  <rdfs:comment xml:lang="en">Links a policy to a sequence of rules.</rdfs:comment>
  <rdfs:label xml:lang="en">has sequence</rdfs:label>
  <dc:source>(competency_question) CQ31</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Sequence"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isPartOfSequence">
  <rdfs:comment xml:lang="en">Links a rule to the sequence it belongs to.</rdfs:comment>
  <rdfs:label xml:lang="en">is part of sequence</rdfs:label>
  <dc:source>(competency_question) CQ31</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Sequence"/>
</owl:ObjectProperty>

</rdf:RDF>