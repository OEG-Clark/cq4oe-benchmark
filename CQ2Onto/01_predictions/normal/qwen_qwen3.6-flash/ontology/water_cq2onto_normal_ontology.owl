<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure">
  <rdfs:comment xml:lang="en">Represents the physical and logical components that make up a water distribution network.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Distribution Infrastructure</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Derived from CQ01 to model the main system being queried.</vaem:rationale>
  <dc:source>(competency_question) CQ01: Which assets compose a water distribution infrastructure?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Asset">
  <rdfs:comment xml:lang="en">A physical component or resource within the water infrastructure.</rdfs:comment>
  <rdfs:label xml:lang="en">Asset</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Derived from CQ01 to represent infrastructure components.</vaem:rationale>
  <dc:source>(competency_question) CQ01: Which assets compose a water distribution infrastructure?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Sensor">
  <rdfs:comment xml:lang="en">A device used to detect or measure physical properties within the infrastructure.</rdfs:comment>
  <rdfs:label xml:lang="en">Sensor</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Derived from CQ04 to model sensing devices.</vaem:rationale>
  <dc:source>(competency_question) CQ04: Which types of sensors are used in water infrastructures?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Actuator">
  <rdfs:comment xml:lang="en">A device used to control or regulate a physical process within the infrastructure.</rdfs:comment>
  <rdfs:label xml:lang="en">Actuator</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Derived from CQ05 to model control devices.</vaem:rationale>
  <dc:source>(competency_question) CQ05: Which types of actuators are used in water infrastructures?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Device">
  <rdfs:comment xml:lang="en">A general class for technical equipment used in the water infrastructure.</rdfs:comment>
  <rdfs:label xml:lang="en">Device</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Derived from CQ06 to serve as a superclass for WaterMeter.</vaem:rationale>
  <dc:source>(competency_question) CQ06: A water meter is a device that measures different aspects of a water infrastructure.</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterMeter">
  <rdfs:comment xml:lang="en">A specific device that measures water usage and related parameters.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Meter</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Derived from CQ06 and subsequent CQs focusing on meter attributes.</vaem:rationale>
  <dc:source>(competency_question) CQ06, CQ08-CQ12, CQ18-CQ20, CQ25, CQ38-CQ43</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Device'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Water">
  <rdfs:comment xml:lang="en">The chemical substance H2O, central to the domain.</rdfs:comment>
  <rdfs:label xml:lang="en">Water</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Derived from CQ33 and CQ34 to model the substance being measured.</vaem:rationale>
  <dc:source>(competency_question) CQ33: What are the physical properties of water? CQ34: What are the chemical properties of water?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PhysicalProperty">
  <rdfs:comment xml:lang="en">Properties related to the physical state of water (e.g., temperature, pressure, flow rate).</rdfs:comment>
  <rdfs:label xml:lang="en">Physical Property</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Derived from CQ33 to categorize physical attributes.</vaem:rationale>
  <dc:source>(competency_question) CQ33: What are the physical properties of water?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ChemicalProperty">
  <rdfs:comment xml:lang="en">Properties related to the chemical composition of water (e.g., pH, chlorine, turbidity).</rdfs:comment>
  <rdfs:label xml:lang="en">Chemical Property</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Derived from CQ34 to categorize chemical attributes.</vaem:rationale>
  <dc:source>(competency_question) CQ34: What are the chemical properties of water?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterIndicator">
  <rdfs:comment xml:lang="en">Metrics or indicators used to assess water quality or usage in a specific location.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Indicator</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Derived from CQ37 to model location-specific metrics.</vaem:rationale>
  <dc:source>(competency_question) CQ37: Which water indicators are defined for Burgos?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Location">
  <rdfs:comment xml:lang="en">A geographical place where water infrastructure or indicators are defined.</rdfs:comment>
  <rdfs:label xml:lang="en">Location</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Derived from CQ37 to model geographical context.</vaem:rationale>
  <dc:source>(competency_question) CQ37: Which water indicators are defined for Burgos?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#City">
  <rdfs:comment xml:lang="en">A type of location representing an urban area.</rdfs:comment>
  <rdfs:label xml:lang="en">City</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Derived from CQ37 to specialize Location for urban contexts like Burgos.</vaem:rationale>
  <dc:source>(competency_question) CQ37: Which water indicators are defined for Burgos?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Location'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Tariff">
  <rdfs:comment xml:lang="en">A pricing scheme or rate structure applied to water usage.</rdfs:comment>
  <rdfs:label xml:lang="en">Tariff</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Derived from CQ38-CQ40 to model billing structures.</vaem:rationale>
  <dc:source>(competency_question) CQ38: What is the start date and time of the tariff in use in the water meter? CQ39: What is the duration of the current tariff of the water meter? CQ40: What is the tariff period of the water meter?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#BillingPeriod">
  <rdfs:comment xml:lang="en">A defined time interval for billing purposes.</rdfs:comment>
  <rdfs:label xml:lang="en">Billing Period</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Derived from CQ42-CQ43 to model billing timeframes.</vaem:rationale>
  <dc:source>(competency_question) CQ42: What is the billing date of the water meter? CQ43: What is the billing date period of the water meter?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#TemporalSetting">
  <rdfs:comment xml:lang="en">Configuration defining time intervals for measurements or operations.</rdfs:comment>
  <rdfs:label xml:lang="en">Temporal Setting</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Derived from CQ25 to model measurement scheduling.</vaem:rationale>
  <dc:source>(competency_question) CQ25: Water meters can provide measurements according to different temporal settings.</dc:source>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAsset">
  <rdfs:comment xml:lang="en">Links an infrastructure to its constituent assets.</rdfs:comment>
  <rdfs:label xml:lang="en">has asset</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Answers CQ01 by relating infrastructure to assets.</vaem:rationale>
  <dc:source>(competency_question) CQ01: Which assets compose a water distribution infrastructure?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Asset"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasSensor">
  <rdfs:comment xml:lang="en">Links an infrastructure to its sensors.</rdfs:comment>
  <rdfs:label xml:lang="en">has sensor</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Answers CQ04 by relating infrastructure to sensors.</vaem:rationale>
  <dc:source>(competency_question) CQ04: Which types of sensors are used in water infrastructures?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Sensor"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasActuator">
  <rdfs:comment xml:lang="en">Links an infrastructure to its actuators.</rdfs:comment>
  <rdfs:label xml:lang="en">has actuator</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Answers CQ05 by relating infrastructure to actuators.</vaem:rationale>
  <dc:source>(competency_question) CQ05: Which types of actuators are used in water infrastructures?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Actuator"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#measures">
  <rdfs:comment xml:lang="en">Indicates what a water meter measures.</rdfs:comment>
  <rdfs:label xml:lang="en">measures</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Answers CQ06 by linking WaterMeter to Water.</vaem:rationale>
  <dc:source>(competency_question) CQ06: A water meter is a device that measures different aspects of a water infrastructure.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Water"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasTemporalSetting">
  <rdfs:comment xml:lang="en">Links a water meter to its measurement temporal settings.</rdfs:comment>
  <rdfs:label xml:lang="en">has temporal setting</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Answers CQ25 by relating meters to temporal configurations.</vaem:rationale>
  <dc:source>(competency_question) CQ25: Water meters can provide measurements according to different temporal settings.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#TemporalSetting"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPhysicalProperty">
  <rdfs:comment xml:lang="en">Links water to its physical properties.</rdfs:comment>
  <rdfs:label xml:lang="en">has physical property</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Answers CQ33.</vaem:rationale>
  <dc:source>(competency_question) CQ33: What are the physical properties of water?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Water"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PhysicalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasChemicalProperty">
  <rdfs:comment xml:lang="en">Links water to its chemical properties.</rdfs:comment>
  <rdfs:label xml:lang="en">has chemical property</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Answers CQ34.</vaem:rationale>
  <dc:source>(competency_question) CQ34: What are the chemical properties of water?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Water"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#ChemicalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasWaterIndicator">
  <rdfs:comment xml:lang="en">Links a location to its defined water indicators.</rdfs:comment>
  <rdfs:label xml:lang="en">has water indicator</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Answers CQ37.</vaem:rationale>
  <dc:source>(competency_question) CQ37: Which water indicators are defined for Burgos?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Location"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WaterIndicator"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasFabricationNumber">
  <rdfs:comment xml:lang="en">The unique fabrication number assigned to a water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">has fabrication number</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Answers CQ08.</vaem:rationale>
  <dc:source>(competency_question) CQ08: What is the fabrication number of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasManufacturer">
  <rdfs:comment xml:lang="en">The manufacturer of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">has manufacturer</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Answers CQ09.</vaem:rationale>
  <dc:source>(competency_question) CQ09: What are the manufacturer and the model of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasModel">
  <rdfs:comment xml:lang="en">The model name or number of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">has model</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Answers CQ09.</vaem:rationale>
  <dc:source>(competency_question) CQ09: What are the manufacturer and the model of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasVersion">
  <rdfs:comment xml:lang="en">The general version of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">has version</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Answers CQ10.</vaem:rationale>
  <dc:source>(competency_question) CQ10: What is the version of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasHardwareVersion">
  <rdfs:comment xml:lang="en">The hardware version number of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">has hardware version</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Answers CQ11.</vaem:rationale>
  <dc:source>(competency_question) CQ11: What is the hardware version number of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasFirmwareVersion">
  <rdfs:comment xml:lang="en">The firmware version running on the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">has firmware version</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Answers CQ12.</vaem:rationale>
  <dc:source>(competency_question) CQ12: What firmware version is the water meter using?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasPower">
  <rdfs:comment xml:lang="en">The power consumption or rating of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">has power</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Answers CQ18.</vaem:rationale>
  <dc:source>(competency_question) CQ18: What is the power of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasRadioFrequencyLevel">
  <rdfs:comment xml:lang="en">The radio frequency level used by the water meter for communication.</rdfs:comment>
  <rdfs:label xml:lang="en">has radio frequency level</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Answers CQ19.</vaem:rationale>
  <dc:source>(competency_question) CQ19: What is the radio frequency level of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasGeolocation">
  <rdfs:comment xml:lang="en">The geographical coordinates or location of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">has geolocation</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Answers CQ20.</vaem:rationale>
  <dc:source>(competency_question) CQ20: What is the geolocation of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasTariffStartDate">
  <rdfs:comment xml:lang="en">The start date and time of the tariff in use.</rdfs:comment>
  <rdfs:label xml:lang="en">has tariff start date</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Answers CQ38.</vaem:rationale>
  <dc:source>(competency_question) CQ38: What is the start date and time of the tariff in use in the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasTariffDuration">
  <rdfs:comment xml:lang="en">The duration of the current tariff.</rdfs:comment>
  <rdfs:label xml:lang="en">has tariff duration</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Answers CQ39.</vaem:rationale>
  <dc:source>(competency_question) CQ39: What is the duration of the current tariff of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasTariffPeriod">
  <rdfs:comment xml:lang="en">The period of the tariff.</rdfs:comment>
  <rdfs:label xml:lang="en">has tariff period</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Answers CQ40.</vaem:rationale>
  <dc:source>(competency_question) CQ40: What is the tariff period of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasBillingDate">
  <rdfs:comment xml:lang="en">The billing date of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">has billing date</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Answers CQ42.</vaem:rationale>
  <dc:source>(competency_question) CQ42: What is the billing date of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasBillingDatePeriod">
  <rdfs:comment xml:lang="en">The billing date period of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">has billing date period</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Answers CQ43.</vaem:rationale>
  <dc:source>(competency_question) CQ43: What is the billing date period of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
