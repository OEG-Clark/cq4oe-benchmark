<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Software">
  <rdfs:comment xml:lang="en">A software tool, application, or service.</rdfs:comment>
  <rdfs:label xml:lang="en">Software</rdfs:label>
  <dc:source>(competency_question) CQ04-CQ85</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#SoftwareType">
  <rdfs:comment xml:lang="en">The category or deployment model of the software.</rdfs:comment>
  <rdfs:label xml:lang="en">Software Type</rdfs:label>
  <dc:source>(competency_question) CQ07
    (competency_question) CQ11</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Algorithm">
  <rdfs:comment xml:lang="en">A named and published computational procedure.</rdfs:comment>
  <rdfs:label xml:lang="en">Algorithm</rdfs:label>
  <dc:source>(competency_question) CQ04</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#DataFormat">
  <rdfs:comment xml:lang="en">A standardized structure for data input or output.</rdfs:comment>
  <rdfs:label xml:lang="en">Data Format</rdfs:label>
  <dc:source>(competency_question) CQ17
    (competency_question) CQ19
    (competency_question) CQ21
    (competency_question) CQ22
    (competency_question) CQ29</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#License">
  <rdfs:comment xml:lang="en">A legal instrument defining usage rights and restrictions.</rdfs:comment>
  <rdfs:label xml:lang="en">License</rdfs:label>
  <dc:source>(competency_question) CQ59
    (competency_question) CQ60
    (competency_question) CQ65
    (competency_question) CQ68</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Platform">
  <rdfs:comment xml:lang="en">A computing environment or operating system.</rdfs:comment>
  <rdfs:label xml:lang="en">Platform</rdfs:label>
  <dc:source>(competency_question) CQ85</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Developer">
  <rdfs:comment xml:lang="en">An individual or organization responsible for creating the software.</rdfs:comment>
  <rdfs:label xml:lang="en">Developer</rdfs:label>
  <dc:source>(competency_question) CQ36
    (competency_question) CQ38</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Version">
  <rdfs:comment xml:lang="en">A specific release iteration of the software.</rdfs:comment>
  <rdfs:label xml:lang="en">Version</rdfs:label>
  <dc:source>(competency_question) CQ54
    (competency_question) CQ55
    (competency_question) CQ57</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Task">
  <rdfs:comment xml:lang="en">A computational or data processing objective.</rdfs:comment>
  <rdfs:label xml:lang="en">Task</rdfs:label>
  <dc:source>(competency_question) CQ08
    (competency_question) CQ14
    (competency_question) CQ16</dc:source>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasType">
  <rdfs:comment xml:lang="en">Links a software to its deployment type.</rdfs:comment>
  <rdfs:label xml:lang="en">has Type</rdfs:label>
  <dc:source>(competency_question) CQ07</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareType"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usesAlgorithm">
  <rdfs:comment xml:lang="en">Links software to the algorithm it implements.</rdfs:comment>
  <rdfs:label xml:lang="en">uses Algorithm</rdfs:label>
  <dc:source>(competency_question) CQ04</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#supportsTask">
  <rdfs:comment xml:lang="en">Links software to tasks it can perform.</rdfs:comment>
  <rdfs:label xml:lang="en">supports Task</rdfs:label>
  <dc:source>(competency_question) CQ08
    (competency_question) CQ14
    (competency_question) CQ16</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Task"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasInputFormat">
  <rdfs:comment xml:lang="en">Specifies valid input data formats.</rdfs:comment>
  <rdfs:label xml:lang="en">has Input Format</rdfs:label>
  <dc:source>(competency_question) CQ17
    (competency_question) CQ19
    (competency_question) CQ21</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasOutputFormat">
  <rdfs:comment xml:lang="en">Specifies data export formats.</rdfs:comment>
  <rdfs:label xml:lang="en">has Output Format</rdfs:label>
  <dc:source>(competency_question) CQ17
    (competency_question) CQ29</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#canExportTo">
  <rdfs:comment xml:lang="en">Indicates export capability to specific formats.</rdfs:comment>
  <rdfs:label xml:lang="en">can Export To</rdfs:label>
  <dc:source>(competency_question) CQ22</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#interoperableWith">
  <rdfs:comment xml:lang="en">Indicates if software can process data from another software.</rdfs:comment>
  <rdfs:label xml:lang="en">interoperable With</rdfs:label>
  <dc:source>(competency_question) CQ23</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Software"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#developedBy">
  <rdfs:comment xml:lang="en">Links software to its creator.</rdfs:comment>
  <rdfs:label xml:lang="en">developed By</rdfs:label>
  <dc:source>(competency_question) CQ36</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Developer"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasVersion">
  <rdfs:comment xml:lang="en">Links software to a specific version.</rdfs:comment>
  <rdfs:label xml:lang="en">has Version</rdfs:label>
  <dc:source>(competency_question) CQ54</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Version"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasLicense">
  <rdfs:comment xml:lang="en">Links software to its governing license.</rdfs:comment>
  <rdfs:label xml:lang="en">has License</rdfs:label>
  <dc:source>(competency_question) CQ59</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#License"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#supportedPlatform">
  <rdfs:comment xml:lang="en">Links software to compatible computing platforms.</rdfs:comment>
  <rdfs:label xml:lang="en">supported Platform</rdfs:label>
  <dc:source>(competency_question) CQ85</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Platform"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasAlgorithmModification">
  <rdfs:comment xml:lang="en">Describes any customizations to the base algorithm.</rdfs:comment>
  <rdfs:label xml:lang="en">has Algorithm Modification</rdfs:label>
  <dc:source>(competency_question) CQ05</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#supportsXMLEditing">
  <rdfs:comment xml:lang="en">Indicates whether the software provides XML editing capabilities.</rdfs:comment>
  <rdfs:label xml:lang="en">supports XML Editing</rdfs:label>
  <dc:source>(competency_question) CQ06</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isAvailableAsWebService">
  <rdfs:comment xml:lang="en">Indicates if the software is accessible as a web service.</rdfs:comment>
  <rdfs:label xml:lang="en">is Available As Web Service</rdfs:label>
  <dc:source>(competency_question) CQ11</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasDownloadURL">
  <rdfs:comment xml:lang="en">URL where the software can be obtained.</rdfs:comment>
  <rdfs:label xml:lang="en">has Download URL</rdfs:label>
  <dc:source>(competency_question) CQ30
    (competency_question) CQ40</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:anyURI"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasDocumentationURL">
  <rdfs:comment xml:lang="en">URL pointing to documentation.</rdfs:comment>
  <rdfs:label xml:lang="en">has Documentation URL</rdfs:label>
  <dc:source>(competency_question) CQ73</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:anyURI"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasSupportURL">
  <rdfs:comment xml:lang="en">URL for obtaining help or support.</rdfs:comment>
  <rdfs:label xml:lang="en">has Support URL</rdfs:label>
  <dc:source>(competency_question) CQ32</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:anyURI"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasHomepage">
  <rdfs:comment xml:lang="en">Official homepage URL.</rdfs:comment>
  <rdfs:label xml:lang="en">has Homepage</rdfs:label>
  <dc:source>(competency_question) CQ37</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:anyURI"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#versionReleaseDate">
  <rdfs:comment xml:lang="en">Release date of a software version.</rdfs:comment>
  <rdfs:label xml:lang="en">version Release Date</rdfs:label>
  <dc:source>(competency_question) CQ57</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Version"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:date"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasNewFeatures">
  <rdfs:comment xml:lang="en">Describes new features introduced in a version.</rdfs:comment>
  <rdfs:label xml:lang="en">has New Features</rdfs:label>
  <dc:source>(competency_question) CQ55</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Version"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isOpenSource">
  <rdfs:comment xml:lang="en">Indicates if the software is open source.</rdfs:comment>
  <rdfs:label xml:lang="en">is Open Source</rdfs:label>
  <dc:source>(competency_question) CQ60</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isFOSS">
  <rdfs:comment xml:lang="en">Indicates if the software is Free and Open Source Software.</rdfs:comment>
  <rdfs:label xml:lang="en">is FOSS</rdfs:label>
  <dc:source>(competency_question) CQ65</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isFree">
  <rdfs:comment xml:lang="en">Indicates if the software is free of charge.</rdfs:comment>
  <rdfs:label xml:lang="en">is Free</rdfs:label>
  <dc:source>(competency_question) CQ68</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#licensePermissiveness">
  <rdfs:comment xml:lang="en">Describes the permissiveness level of a license.</rdfs:comment>
  <rdfs:label xml:lang="en">license Permissiveness</rdfs:label>
  <dc:source>(competency_question) CQ59</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#License"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#implementationLanguage">
  <rdfs:comment xml:lang="en">Programming language used to implement the software.</rdfs:comment>
  <rdfs:label xml:lang="en">implementation Language</rdfs:label>
  <dc:source>(competency_question) CQ84</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasDevelopmentActivity">
  <rdfs:comment xml:lang="en">Describes the development activity level or history.</rdfs:comment>
  <rdfs:label xml:lang="en">has Development Activity</rdfs:label>
  <dc:source>(competency_question) CQ46
    (competency_question) CQ45</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasCommunity">
  <rdfs:comment xml:lang="en">Indicates if there is an active community around the software.</rdfs:comment>
  <rdfs:label xml:lang="en">has Community</rdfs:label>
  <dc:source>(competency_question) CQ58</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#canCollaborate">
  <rdfs:comment xml:lang="en">Indicates if collaboration with developers is possible.</rdfs:comment>
  <rdfs:label xml:lang="en">can Collaborate</rdfs:label>
  <dc:source>(competency_question) CQ38</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:boolean"/>
</owl:DatatypeProperty>

</rdf:RDF>