<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Wine">
  <rdfs:comment xml:lang="en">A beverage produced by fermenting grapes.</rdfs:comment>
  <rdfs:label xml:lang="en">Wine</rdfs:label>
  <dc:source>(competency_question) CQ1
    (competency_question) CQ2
    (competency_question) CQ6
    (competency_question) CQ7
    (competency_question) CQnew1</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WineCharacteristic">
  <rdfs:comment xml:lang="en">A qualitative or sensory attribute of a wine.</rdfs:comment>
  <rdfs:label xml:lang="en">Wine Characteristic</rdfs:label>
  <dc:source>(competency_question) CQ1</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Bouquet">
  <rdfs:comment xml:lang="en">The aroma or scent profile of a wine.</rdfs:comment>
  <rdfs:label xml:lang="en">Bouquet</rdfs:label>
  <dc:source>(competency_question) CQ6</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#WineCharacteristic'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Body">
  <rdfs:comment xml:lang="en">The weight, texture, and mouthfeel of a wine.</rdfs:comment>
  <rdfs:label xml:lang="en">Body</rdfs:label>
  <dc:source>(competency_question) CQ6</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#WineCharacteristic'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WineType">
  <rdfs:comment xml:lang="en">The category or style of wine, such as red or white.</rdfs:comment>
  <rdfs:label xml:lang="en">Wine Type</rdfs:label>
  <dc:source>(competency_question) CQ2</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#RedWine">
  <rdfs:comment xml:lang="en">A type of wine made from dark-colored grape varieties.</rdfs:comment>
  <rdfs:label xml:lang="en">Red Wine</rdfs:label>
  <dc:source>(competency_question) CQ2</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#WineType'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WhiteWine">
  <rdfs:comment xml:lang="en">A type of wine made from light-colored grape varieties or without skins.</rdfs:comment>
  <rdfs:label xml:lang="en">White Wine</rdfs:label>
  <dc:source>(competency_question) CQ2</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#WineType'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#VintageYear">
  <rdfs:comment xml:lang="en">The year in which the grapes for a wine were harvested.</rdfs:comment>
  <rdfs:label xml:lang="en">Vintage Year</rdfs:label>
  <dc:source>(competency_question) CQ6
    (competency_question) CQ7</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Grape">
  <rdfs:comment xml:lang="en">The fruit used to produce wine.</rdfs:comment>
  <rdfs:label xml:lang="en">Grape</rdfs:label>
  <dc:source>(competency_question) CQ7
    (competency_question) CQnew1</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Region">
  <rdfs:comment xml:lang="en">A geographical area known for wine production.</rdfs:comment>
  <rdfs:label xml:lang="en">Region</rdfs:label>
  <dc:source>(competency_question) CQ7</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Bordeaux">
  <rdfs:comment xml:lang="en">A renowned wine region and type of wine from France.</rdfs:comment>
  <rdfs:label xml:lang="en">Bordeaux</rdfs:label>
  <dc:source>(competency_question) CQ2
    (competency_question) CQnew1</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Wine'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Napa">
  <rdfs:comment xml:lang="en">A famous wine-producing region in California.</rdfs:comment>
  <rdfs:label xml:lang="en">Napa</rdfs:label>
  <dc:source>(competency_question) CQ7</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Region'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Zinfandel">
  <rdfs:comment xml:lang="en">A variety of dark-skinned grape used to make red wine.</rdfs:comment>
  <rdfs:label xml:lang="en">Zinfandel</rdfs:label>
  <dc:source>(competency_question) CQ7
    (competency_question) CQnew1</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Grape'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#NapaZinfandel">
  <rdfs:comment xml:lang="en">A red wine made from Zinfandel grapes grown in the Napa region.</rdfs:comment>
  <rdfs:label xml:lang="en">Napa Zinfandel</rdfs:label>
  <dc:source>(competency_question) CQ7</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Wine'/>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasCharacteristic">
  <rdfs:comment xml:lang="en">Links a wine to its qualitative attributes.</rdfs:comment>
  <rdfs:label xml:lang="en">has characteristic</rdfs:label>
  <dc:source>(competency_question) CQ1</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WineCharacteristic"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasBouquet">
  <rdfs:comment xml:lang="en">Links a wine to its aroma profile.</rdfs:comment>
  <rdfs:label xml:lang="en">has bouquet</rdfs:label>
  <dc:source>(competency_question) CQ6</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Bouquet"/>
  <rdfs:subPropertyOf rdf:resource='http://www.semanticweb.org/myontology#hasCharacteristic'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasBody">
  <rdfs:comment xml:lang="en">Links a wine to its mouthfeel/weight.</rdfs:comment>
  <rdfs:label xml:lang="en">has body</rdfs:label>
  <dc:source>(competency_question) CQ6</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Body"/>
  <rdfs:subPropertyOf rdf:resource='http://www.semanticweb.org/myontology#hasCharacteristic'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasWineType">
  <rdfs:comment xml:lang="en">Links a wine to its type (e.g., red, white).</rdfs:comment>
  <rdfs:label xml:lang="en">has wine type</rdfs:label>
  <dc:source>(competency_question) CQ2</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WineType"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasVintage">
  <rdfs:comment xml:lang="en">Links a wine to the year its grapes were harvested.</rdfs:comment>
  <rdfs:label xml:lang="en">has vintage</rdfs:label>
  <dc:source>(competency_question) CQ6
    (competency_question) CQ7</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#VintageYear"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGrape">
  <rdfs:comment xml:lang="en">Links a wine to the grape variety used in its production.</rdfs:comment>
  <rdfs:label xml:lang="en">has grape</rdfs:label>
  <dc:source>(competency_question) CQ7
    (competency_question) CQnew1</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Grape"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#originatesFrom">
  <rdfs:comment xml:lang="en">Links a wine to its geographical region of origin.</rdfs:comment>
  <rdfs:label xml:lang="en">originates from</rdfs:label>
  <dc:source>(competency_question) CQ7</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Region"/>
</owl:ObjectProperty>

</rdf:RDF>