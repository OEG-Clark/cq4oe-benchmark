<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Player">
  <rdfs:comment xml:lang="en">A user who plays games and interacts with the system.</rdfs:comment>
  <rdfs:label xml:lang="en">Player</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Player: Central entity in multiple competency questions</vaem:rationale>
  <dc:source>(competency_question) CQ01: What is the username of the player?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Game">
  <rdfs:comment xml:lang="en">A digital game that players can play, which contains achievements, items, and genres.</rdfs:comment>
  <rdfs:label xml:lang="en">Game</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Game: Central entity for game-related queries</vaem:rationale>
  <dc:source>(competency_question) CQ08: What achievements does a game have?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Achievement">
  <rdfs:comment xml:lang="en">A reward or milestone that can be obtained by a player in a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Achievement</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Achievement: Required for tracking player progress and game content</vaem:rationale>
  <dc:source>(competency_question) CQ05: What are the achievements of my friends?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#AchievementType">
  <rdfs:comment xml:lang="en">A category or classification of an achievement.</rdfs:comment>
  <rdfs:label xml:lang="en">Achievement Type</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class AchievementType: Needed to classify achievements as per CQ10 and CQ11</vaem:rationale>
  <dc:source>(competency_question) CQ10: What are the types of achievements in this game?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Genre">
  <rdfs:comment xml:lang="en">A category of games based on gameplay style or theme.</rdfs:comment>
  <rdfs:label xml:lang="en">Genre</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Genre: Required for CQ12 and CQ17</vaem:rationale>
  <dc:source>(competency_question) CQ12: What is the genre of the game?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Item">
  <rdfs:comment xml:lang="en">An object that exists within a game and can be owned or used by players.</rdfs:comment>
  <rdfs:label xml:lang="en">Item</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Item: Required for CQ13, CQ19, CQ26, CQ55</vaem:rationale>
  <dc:source>(competency_question) CQ13: What items exist in a game?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Equipment">
  <rdfs:comment xml:lang="en">A specific type of item that a player can equip in a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Equipment</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Equipment as subclass of Item: Required for CQ52</vaem:rationale>
  <dc:source>(competency_question) CQ52: What equipment does a player have in a game?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Item"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Ability">
  <rdfs:comment xml:lang="en">A capability or power that an item can grant.</rdfs:comment>
  <rdfs:label xml:lang="en">Ability</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Ability: Required for CQ19</vaem:rationale>
  <dc:source>(competency_question) CQ19: What abilities does an item have?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#InAppPurchase">
  <rdfs:comment xml:lang="en">A transaction where a player spends money within a game.</rdfs:comment>
  <rdfs:label xml:lang="en">In-App Purchase</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class InAppPurchase: Required for CQ56, CQ57, CQ62, CQ64, CQ66</vaem:rationale>
  <dc:source>(competency_question) CQ56: How many players have made in app purchases?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Location">
  <rdfs:comment xml:lang="en">A geographical place where a player resides.</rdfs:comment>
  <rdfs:label xml:lang="en">Location</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Location: Required for CQ63, CQ65, CQ66</vaem:rationale>
  <dc:source>(competency_question) CQ63: Where do the most paying customers live?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayingArea">
  <rdfs:comment xml:lang="en">A specific zone or map within a game where gameplay occurs.</rdfs:comment>
  <rdfs:label xml:lang="en">Playing Area</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class PlayingArea: Required for New CQ1</vaem:rationale>
  <dc:source>(competency_question) New CQ1: What playing areas does a game have?</dc:source>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasFriend">
  <rdfs:comment xml:lang="en">Relates a player to their friends.</rdfs:comment>
  <rdfs:label xml:lang="en">has Friend</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property hasFriend: Required for CQ02</vaem:rationale>
  <dc:source>(competency_question) CQ02: Who are the friends of the player?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#playsWith">
  <rdfs:comment xml:lang="en">Relates a player to other players they play games with.</rdfs:comment>
  <rdfs:label xml:lang="en">plays With</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property playsWith: Required for CQ03</vaem:rationale>
  <dc:source>(competency_question) CQ03: Who are the friends that play other games as well with this player?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAchievement">
  <rdfs:comment xml:lang="en">Relates a player to the achievements they have obtained.</rdfs:comment>
  <rdfs:label xml:lang="en">has Achievement</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property hasAchievement: Required for CQ05, CQ07, CQ24, CQ27</vaem:rationale>
  <dc:source>(competency_question) CQ05: What are the achievements of my friends?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#definesAchievement">
  <rdfs:comment xml:lang="en">Relates a game to the achievements it contains.</rdfs:comment>
  <rdfs:label xml:lang="en">defines Achievement</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property definesAchievement: Required for CQ08</vaem:rationale>
  <dc:source>(competency_question) CQ08: What achievements does a game have?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasType">
  <rdfs:comment xml:lang="en">Relates an achievement to its type.</rdfs:comment>
  <rdfs:label xml:lang="en">has Type</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property hasType: Required for CQ10, CQ11, CQ27</vaem:rationale>
  <dc:source>(competency_question) CQ10: What are the types of achievements in this game?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAchievementType">
  <rdfs:comment xml:lang="en">Relates a game to the types of achievements it supports.</rdfs:comment>
  <rdfs:label xml:lang="en">has Achievement Type</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property hasAchievementType: Required for CQ10, CQ11</vaem:rationale>
  <dc:source>(competency_question) CQ11: What are the types of achievements a game can have?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGenre">
  <rdfs:comment xml:lang="en">Relates a game to its genre.</rdfs:comment>
  <rdfs:label xml:lang="en">has Genre</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property hasGenre: Required for CQ12, CQ17</vaem:rationale>
  <dc:source>(competency_question) CQ12: What is the genre of the game?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Genre"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasItem">
  <rdfs:comment xml:lang="en">Relates a game to the items that exist within it.</rdfs:comment>
  <rdfs:label xml:lang="en">has Item</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property hasItem: Required for CQ13</vaem:rationale>
  <dc:source>(competency_question) CQ13: What items exist in a game?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPlayed">
  <rdfs:comment xml:lang="en">Relates a player to the games they have played.</rdfs:comment>
  <rdfs:label xml:lang="en">has Played</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property hasPlayed: Required for CQ25, CQ29</vaem:rationale>
  <dc:source>(competency_question) CQ25: What games has the player played?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasItemOwned">
  <rdfs:comment xml:lang="en">Relates a player to the items they currently possess.</rdfs:comment>
  <rdfs:label xml:lang="en">has Item Owned</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property hasItemOwned: Required for CQ26</vaem:rationale>
  <dc:source>(competency_question) CQ26: What items does the player have?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasLastPlayedGame">
  <rdfs:comment xml:lang="en">Relates a player to the most recent game they played.</rdfs:comment>
  <rdfs:label xml:lang="en">has Last Played Game</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property hasLastPlayedGame: Required for CQ29</vaem:rationale>
  <dc:source>(competency_question) CQ29: What is the last game a player has played?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasEquipment">
  <rdfs:comment xml:lang="en">Relates a player to the equipment they have in a game.</rdfs:comment>
  <rdfs:label xml:lang="en">has Equipment</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property hasEquipment: Required for CQ52</vaem:rationale>
  <dc:source>(competency_question) CQ52: What equipment does a player have in a game?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Equipment"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usableInGame">
  <rdfs:comment xml:lang="en">Relates an item to the games where it can be used.</rdfs:comment>
  <rdfs:label xml:lang="en">usable In Game</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property usableInGame: Required for CQ55</vaem:rationale>
  <dc:source>(competency_question) CQ55: What are the games where a player can use this item?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Item"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasMadePurchase">
  <rdfs:comment xml:lang="en">Relates a player to the in-app purchases they have made.</rdfs:comment>
  <rdfs:label xml:lang="en">has Made Purchase</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property hasMadePurchase: Required for CQ56, CQ57, CQ62, CQ64, CQ66</vaem:rationale>
  <dc:source>(competency_question) CQ56: How many players have made in app purchases?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#livesIn">
  <rdfs:comment xml:lang="en">Relates a player to their geographical location.</rdfs:comment>
  <rdfs:label xml:lang="en">lives In</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property livesIn: Required for CQ63, CQ65, CQ66</vaem:rationale>
  <dc:source>(competency_question) CQ63: Where do the most paying customers live?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Location"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPlayingArea">
  <rdfs:comment xml:lang="en">Relates a game to its playing areas or maps.</rdfs:comment>
  <rdfs:label xml:lang="en">has Playing Area</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property hasPlayingArea: Required for New CQ1</vaem:rationale>
  <dc:source>(competency_question) New CQ1: What playing areas does a game have?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAbility">
  <rdfs:comment xml:lang="en">Relates an item to the abilities it provides.</rdfs:comment>
  <rdfs:label xml:lang="en">has Ability</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property hasAbility: Required for CQ19</vaem:rationale>
  <dc:source>(competency_question) CQ19: What abilities does an item have?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Item"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Ability"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasUsername">
  <rdfs:comment xml:lang="en">The unique identifier or name of a player.</rdfs:comment>
  <rdfs:label xml:lang="en">has Username</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property hasUsername: Required for CQ01</vaem:rationale>
  <dc:source>(competency_question) CQ01: What is the username of the player?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasTotalPlayTime">
  <rdfs:comment xml:lang="en">The total number of hours a game has been played.</rdfs:comment>
  <rdfs:label xml:lang="en">has Total Play Time</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property hasTotalPlayTime: Required for CQ09</vaem:rationale>
  <dc:source>(competency_question) CQ09: How many hours has this game been played in total?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:decimal"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasReleaseDate">
  <rdfs:comment xml:lang="en">The date when a game was released.</rdfs:comment>
  <rdfs:label xml:lang="en">has Release Date</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property hasReleaseDate: Required for CQ15</vaem:rationale>
  <dc:source>(competency_question) CQ15: What is the release date of the game?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:date"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasKillCount">
  <rdfs:comment xml:lang="en">The number of kills a player has achieved in a game.</rdfs:comment>
  <rdfs:label xml:lang="en">has Kill Count</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property hasKillCount: Required for CQ22</vaem:rationale>
  <dc:source>(competency_question) CQ22: Who has the best kill count in the game?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:integer"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasAmount">
  <rdfs:comment xml:lang="en">The monetary value of an in-app purchase.</rdfs:comment>
  <rdfs:label xml:lang="en">has Amount</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property hasAmount: Required for CQ57</vaem:rationale>
  <dc:source>(competency_question) CQ57: How many players who have already spent money, spend money again?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:decimal"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasTimestamp">
  <rdfs:comment xml:lang="en">The date and time when an in-app purchase was made.</rdfs:comment>
  <rdfs:label xml:lang="en">has Timestamp</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property hasTimestamp: Required for CQ62, CQ64</vaem:rationale>
  <dc:source>(competency_question) CQ62: What time are most of the in app purchases done?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:dateTime"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasTimeToFirstIAP">
  <rdfs:comment xml:lang="en">The duration a player spends in a game before making their first in-app purchase.</rdfs:comment>
  <rdfs:label xml:lang="en">has Time To First IAP</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property hasTimeToFirstIAP: Required for CQ64</vaem:rationale>
  <dc:source>(competency_question) CQ64: How long does a player spend in the game before making first IAP?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:decimal"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

</rdf:RDF>