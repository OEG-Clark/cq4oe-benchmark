<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#SoftwareTool">
  <rdfs:comment xml:lang="en">A software application, library, API, or service designed to perform specific computational tasks.</rdfs:comment>
  <rdfs:label xml:lang="en">Software Tool</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created core class representing software entities: Required to answer CQ07, CQ08, CQ11, CQ14, CQ15, CQ16, CQ26, CQ30, CQ32, CQ36, CQ37, CQ38, CQ40, CQ45, CQ46, CQ54, CQ55, CQ57, CQ58, CQ59, CQ60, CQ65, CQ68, CQ73, CQ84, CQ85</vaem:rationale>
  <dc:source>(competency_question) CQ07, CQ08, CQ11, CQ14, CQ15, CQ16, CQ26, CQ30, CQ32, CQ36, CQ37, CQ38, CQ40, CQ45, CQ46, CQ54, CQ55, CQ57, CQ58, CQ59, CQ60, CQ65, CQ68, CQ73, CQ84, CQ85</dc:source>
  <owl:disjointWith rdf:resource='http://www.semanticweb.org/myontology#DataFormat'/>
  <owl:disjointWith rdf:resource='http://www.semanticweb.org/myontology#Algorithm'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#SoftwareType">
  <rdfs:comment xml:lang="en">Categorization of software delivery or execution model, such as API, Desktop Application, Web Service, or CLI.</rdfs:comment>
  <rdfs:label xml:lang="en">Software Type</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class to classify software deployment models: Required to answer CQ07 and CQ11</vaem:rationale>
  <dc:source>(competency_question) CQ07, CQ11</dc:source>
  <owl:disjointWith rdf:resource='http://www.semanticweb.org/myontology#Task'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Task">
  <rdfs:comment xml:lang="en">A specific computational or operational goal that software is designed to accomplish.</rdfs:comment>
  <rdfs:label xml:lang="en">Task</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class to represent functional requirements: Required to answer CQ08, CQ14, CQ16</vaem:rationale>
  <dc:source>(competency_question) CQ08, CQ14, CQ16</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Algorithm">
  <rdfs:comment xml:lang="en">A named, published, or standard computational procedure used by software.</rdfs:comment>
  <rdfs:label xml:lang="en">Algorithm</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class to capture algorithmic foundations: Required to answer CQ04 and CQ05</vaem:rationale>
  <dc:source>(competency_question) CQ04, CQ05</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#AlgorithmModification">
  <rdfs:comment xml:lang="en">A specific alteration, optimization, or customization applied to a base algorithm.</rdfs:comment>
  <rdfs:label xml:lang="en">Algorithm Modification</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class to track deviations from standard algorithms: Required to answer CQ05</vaem:rationale>
  <dc:source>(competency_question) CQ05</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#DataFormat">
  <rdfs:comment xml:lang="en">A standardized or proprietary structure for encoding, storing, or transmitting data.</rdfs:comment>
  <rdfs:label xml:lang="en">Data Format</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class to represent input/output specifications: Required to answer CQ06, CQ17, CQ19, CQ21, CQ22, CQ23, CQ26, CQ29</vaem:rationale>
  <dc:source>(competency_question) CQ06, CQ17, CQ19, CQ21, CQ22, CQ23, CQ26, CQ29</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#SoftwareVersion">
  <rdfs:comment xml:lang="en">A specific release iteration of a software tool, identified by version numbers and release dates.</rdfs:comment>
  <rdfs:label xml:lang="en">Software Version</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class to track release history and features: Required to answer CQ29, CQ54, CQ55, CQ57</vaem:rationale>
  <dc:source>(competency_question) CQ29, CQ54, CQ55, CQ57</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Feature">
  <rdfs:comment xml:lang="en">A distinct capability, function, or improvement introduced in a software version.</rdfs:comment>
  <rdfs:label xml:lang="en">Feature</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class to catalog version-specific additions: Required to answer CQ55</vaem:rationale>
  <dc:source>(competency_question) CQ55</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#License">
  <rdfs:comment xml:lang="en">A legal instrument defining the terms under which software may be used, modified, and distributed.</rdfs:comment>
  <rdfs:label xml:lang="en">License</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class to represent software licensing terms: Required to answer CQ59, CQ60, CQ65, CQ68</vaem:rationale>
  <dc:source>(competency_question) CQ59, CQ60, CQ65, CQ68</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Developer">
  <rdfs:comment xml:lang="en">An individual, organization, or community responsible for creating or maintaining software.</rdfs:comment>
  <rdfs:label xml:lang="en">Developer</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class to attribute software authorship: Required to answer CQ36, CQ38</vaem:rationale>
  <dc:source>(competency_question) CQ36, CQ38</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Platform">
  <rdfs:comment xml:lang="en">An operating system, runtime environment, or hardware architecture on which software executes.</rdfs:comment>
  <rdfs:label xml:lang="en">Platform</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class to specify execution environments: Required to answer CQ85</vaem:rationale>
  <dc:source>(competency_question) CQ85</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ProgrammingLanguage">
  <rdfs:comment xml:lang="en">A formal language used to write instructions for software implementation.</rdfs:comment>
  <rdfs:label xml:lang="en">Programming Language</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class to track implementation technologies: Required to answer CQ84</vaem:rationale>
  <dc:source>(competency_question) CQ84</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Documentation">
  <rdfs:comment xml:lang="en">Official guides, manuals, or reference materials describing software usage and architecture.</rdfs:comment>
  <rdfs:label xml:lang="en">Documentation</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class to link software to its reference materials: Required to answer CQ73</vaem:rationale>
  <dc:source>(competency_question) CQ73</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#HelpResource">
  <rdfs:comment xml:lang="en">Support channels, forums, FAQs, or contact points for obtaining assistance with software.</rdfs:comment>
  <rdfs:label xml:lang="en">Help Resource</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class to represent user support mechanisms: Required to answer CQ32</vaem:rationale>
  <dc:source>(competency_question) CQ32</dc:source>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasSoftwareType">
  <rdfs:comment xml:lang="en">Links a software tool to its deployment or execution category.</rdfs:comment>
  <rdfs:label xml:lang="en">has Software Type</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Defined object property for software classification: Maps CQ07 and CQ11</vaem:rationale>
  <dc:source>(competency_question) CQ07, CQ11</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareType"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#performsTask">
  <rdfs:comment xml:lang="en">Associates a software tool with the computational tasks it is designed to execute.</rdfs:comment>
  <rdfs:label xml:lang="en">performs Task</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Defined object property for functional capabilities: Maps CQ08, CQ14, CQ16</vaem:rationale>
  <dc:source>(competency_question) CQ08, CQ14, CQ16</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Task"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usesAlgorithm">
  <rdfs:comment xml:lang="en">Indicates which named or published algorithms are implemented by the software.</rdfs:comment>
  <rdfs:label xml:lang="en">uses Algorithm</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Defined object property for algorithmic dependencies: Maps CQ04</vaem:rationale>
  <dc:source>(competency_question) CQ04</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAlgorithmModification">
  <rdfs:comment xml:lang="en">Links an algorithm to specific customizations or optimizations applied to it.</rdfs:comment>
  <rdfs:label xml:lang="en">has Algorithm Modification</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Defined object property for tracking algorithm changes: Maps CQ05</vaem:rationale>
  <dc:source>(competency_question) CQ05</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#AlgorithmModification"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#supportsInputFormat">
  <rdfs:comment xml:lang="en">Specifies the data formats that the software can read or accept as input.</rdfs:comment>
  <rdfs:label xml:lang="en">supports Input Format</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Defined object property for input compatibility: Maps CQ17, CQ19, CQ21, CQ26</vaem:rationale>
  <dc:source>(competency_question) CQ17, CQ19, CQ21, CQ26</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#supportsOutputFormat">
  <rdfs:comment xml:lang="en">Specifies the data formats that the software can generate or export.</rdfs:comment>
  <rdfs:label xml:lang="en">supports Output Format</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Defined object property for output compatibility: Maps CQ17, CQ22</vaem:rationale>
  <dc:source>(competency_question) CQ17, CQ22</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasVersion">
  <rdfs:comment xml:lang="en">Links a software tool to its specific release iterations.</rdfs:comment>
  <rdfs:label xml:lang="en">has Version</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Defined object property for version tracking: Maps CQ29, CQ54, CQ55, CQ57</vaem:rationale>
  <dc:source>(competency_question) CQ29, CQ54, CQ55, CQ57</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareVersion"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasLicense">
  <rdfs:comment xml:lang="en">Associates a software tool with its legal distribution terms.</rdfs:comment>
  <rdfs:label xml:lang="en">has License</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Defined object property for licensing information: Maps CQ59, CQ60, CQ65, CQ68</vaem:rationale>
  <dc:source>(competency_question) CQ59, CQ60, CQ65, CQ68</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#License"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isDevelopedBy">
  <rdfs:comment xml:lang="en">Identifies the individual, organization, or community responsible for the software.</rdfs:comment>
  <rdfs:label xml:lang="en">is Developed By</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Defined object property for authorship attribution: Maps CQ36, CQ38</vaem:rationale>
  <dc:source>(competency_question) CQ36, CQ38</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Developer"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#runsOnPlatform">
  <rdfs:comment xml:lang="en">Specifies the operating systems or environments where the software can execute.</rdfs:comment>
  <rdfs:label xml:lang="en">runs On Platform</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Defined object property for platform compatibility: Maps CQ85</vaem:rationale>
  <dc:source>(competency_question) CQ85</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Platform"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#implementedInLanguage">
  <rdfs:comment xml:lang="en">Indicates the programming language(s) used to write the software.</rdfs:comment>
  <rdfs:label xml:lang="en">implemented In Language</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Defined object property for implementation technology: Maps CQ84</vaem:rationale>
  <dc:source>(competency_question) CQ84</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#ProgrammingLanguage"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasDocumentation">
  <rdfs:comment xml:lang="en">Links software to its official guides, manuals, or reference materials.</rdfs:comment>
  <rdfs:label xml:lang="en">has Documentation</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Defined object property for reference materials: Maps CQ73</vaem:rationale>
  <dc:source>(competency_question) CQ73</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Documentation"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasHelpResource">
  <rdfs:comment xml:lang="en">Points to support channels, forums, or contact methods for user assistance.</rdfs:comment>
  <rdfs:label xml:lang="en">has Help Resource</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Defined object property for user support: Maps CQ32</vaem:rationale>
  <dc:source>(competency_question) CQ32</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#HelpResource"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasFeature">
  <rdfs:comment xml:lang="en">Associates a software version with the specific capabilities or improvements it introduces.</rdfs:comment>
  <rdfs:label xml:lang="en">has Feature</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Defined object property for version changelogs: Maps CQ55</vaem:rationale>
  <dc:source>(competency_question) CQ55</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareVersion"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Feature"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasExportFormat">
  <rdfs:comment xml:lang="en">Specifies the data formats that a specific software version can export given certain inputs.</rdfs:comment>
  <rdfs:label xml:lang="en">has Export Format</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Defined object property for version-specific exports: Maps CQ29</vaem:rationale>
  <dc:source>(competency_question) CQ29</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareVersion"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#compatibleWithOutputOf">
  <rdfs:comment xml:lang="en">Indicates that a software tool can process data generated by another software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">compatible With Output Of</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Defined object property for cross-software data compatibility: Maps CQ23</vaem:rationale>
  <dc:source>(competency_question) CQ23</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#createdDataInFormat">
  <rdfs:comment xml:lang="en">Links a software tool to the data format it originally produced.</rdfs:comment>
  <rdfs:label xml:lang="en">created Data In Format</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Defined object property for data provenance: Maps CQ15</vaem:rationale>
  <dc:source>(competency_question) CQ15</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasHomepage">
  <rdfs:comment xml:lang="en">The official web address for the software project.</rdfs:comment>
  <rdfs:label xml:lang="en">has Homepage</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Defined datatype property for project URL: Maps CQ37</vaem:rationale>
  <dc:source>(competency_question) CQ37</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:anyURI"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasDownloadURL">
  <rdfs:comment xml:lang="en">The direct web address from which the software can be obtained.</rdfs:comment>
  <rdfs:label xml:lang="en">has Download URL</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Defined datatype property for acquisition links: Maps CQ30, CQ40</vaem:rationale>
  <dc:source>(competency_question) CQ30, CQ40</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:anyURI"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isFree">
  <rdfs:comment xml:lang="en">Indicates whether the software can be used without monetary cost.</rdfs:comment>
  <rdfs:label xml:lang="en">is Free</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Defined boolean datatype property for pricing model: Maps CQ68</vaem:rationale>
  <dc:source>(competency_question) CQ68</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:boolean"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isFOSS">
  <rdfs:comment xml:lang="en">Indicates whether the software qualifies as Free and Open Source Software.</rdfs:comment>
  <rdfs:label xml:lang="en">is FOSS</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Defined boolean datatype property for FOSS status: Maps CQ65</vaem:rationale>
  <dc:source>(competency_question) CQ65</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:boolean"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isOpenSource">
  <rdfs:comment xml:lang="en">Indicates whether the source code is publicly accessible and modifiable.</rdfs:comment>
  <rdfs:label xml:lang="en">is Open Source</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Defined boolean datatype property for source availability: Maps CQ58, CQ60</vaem:rationale>
  <dc:source>(competency_question) CQ58, CQ60</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:boolean"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isActivelyDeveloped">
  <rdfs:comment xml:lang="en">Indicates whether the software receives regular updates and maintenance.</rdfs:comment>
  <rdfs:label xml:lang="en">is Actively Developed</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Defined boolean datatype property for maintenance status: Maps CQ26, CQ46, CQ58</vaem:rationale>
  <dc:source>(competency_question) CQ26, CQ46, CQ58</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:boolean"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasReleaseDate">
  <rdfs:comment xml:lang="en">The calendar date when a specific software version was published.</rdfs:comment>
  <rdfs:label xml:lang="en">has Release Date</rdfs:label>
