  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure">
  <rdfs:comment xml:lang="en">Infrastructure designed for the distribution of water to consumers.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Distribution Infrastructure</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class WaterDistributionInfrastructure: Required by CQ01, CQ04, CQ05, CQ06 to model the core infrastructure entity.</vaem:rationale>
  <dc:source>(competency_question) CQ01: Which assets compose a water distribution infrastructure?
    (competency_question) CQ04: Which types of sensors are used in water infrastructures?
    (competency_question) CQ05: Which types of actuators are used in water infrastructures?
    (competency_question) CQ06: A water meter is a device that measures different aspects of a water infrastructure.</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Asset">
  <rdfs:comment xml:lang="en">A tangible or intangible resource owned by a water distribution infrastructure.</rdfs:comment>
  <rdfs:label xml:lang="en">Asset</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Asset: Required by CQ01 to model components of the infrastructure.</vaem:rationale>
  <dc:source>(competency_question) CQ01: Which assets compose a water distribution infrastructure?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Sensor">
  <rdfs:comment xml:lang="en">A device used to detect or measure physical properties in water infrastructures.</rdfs:comment>
  <rdfs:label xml:lang="en">Sensor</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Sensor: Required by CQ04 to model sensing devices.</vaem:rationale>
  <dc:source>(competency_question) CQ04: Which types of sensors are used in water infrastructures?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Actuator">
  <rdfs:comment xml:lang="en">A device used to control or manipulate physical mechanisms in water infrastructures.</rdfs:comment>
  <rdfs:label xml:lang="en">Actuator</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Actuator: Required by CQ05 to model control devices.</vaem:rationale>
  <dc:source>(competency_question) CQ05: Which types of actuators are used in water infrastructures?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Device">
  <rdfs:comment xml:lang="en">A piece of equipment or machinery used in the infrastructure.</rdfs:comment>
  <rdfs:label xml:lang="en">Device</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Device: Required by CQ06 as a superclass for WaterMeter.</vaem:rationale>
  <dc:source>(competency_question) CQ06: A water meter is a device that measures different aspects of a water infrastructure.</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterMeter">
  <rdfs:comment xml:lang="en">A device that measures different aspects of a water infrastructure.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Meter</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class WaterMeter with subclass axiom: Required by CQ06 and multiple attribute questions (CQ08-CQ20, CQ25, CQ38-CQ43).</vaem:rationale>
  <dc:source>(competency_question) CQ06: A water meter is a device that measures different aspects of a water infrastructure.</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Device"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Measurement">
  <rdfs:comment xml:lang="en">A quantified observation provided by a water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">Measurement</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Measurement: Required by CQ25 to model measurement outputs.</vaem:rationale>
  <dc:source>(competency_question) CQ25: Water meters can provide measurements according to different temporal settings.</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#TemporalSetting">
  <rdfs:comment xml:lang="en">A configuration defining the time interval or schedule for measurements.</rdfs:comment>
  <rdfs:label xml:lang="en">Temporal Setting</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class TemporalSetting: Required by CQ25 to model temporal configurations.</vaem:rationale>
  <dc:source>(competency_question) CQ25: Water meters can provide measurements according to different temporal settings.</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Water">
  <rdfs:comment xml:lang="en">The substance being distributed and measured.</rdfs:comment>
  <rdfs:label xml:lang="en">Water</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Water: Required by CQ33 and CQ34 to model properties of water.</vaem:rationale>
  <dc:source>(competency_question) CQ33: What are the physical properties of water?
    (competency_question) CQ34: What are the chemical properties of water?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PhysicalProperty">
  <rdfs:comment xml:lang="en">A characteristic of water that can be observed or measured without changing its chemical identity.</rdfs:comment>
  <rdfs:label xml:lang="en">Physical Property</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class PhysicalProperty: Required by CQ33.</vaem:rationale>
  <dc:source>(competency_question) CQ33: What are the physical properties of water?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ChemicalProperty">
  <rdfs:comment xml:lang="en">A characteristic of water that describes its ability to undergo chemical changes.</rdfs:comment>
  <rdfs:label xml:lang="en">Chemical Property</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class ChemicalProperty: Required by CQ34.</vaem:rationale>
  <dc:source>(competency_question) CQ34: What are the chemical properties of water?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterIndicator">
  <rdfs:comment xml:lang="en">A metric or sign used to evaluate water quality or status in a specific location.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Indicator</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class WaterIndicator: Required by CQ37.</vaem:rationale>
  <dc:source>(competency_question) CQ37: Which water indicators are defined for Burgos?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#City">
  <rdfs:comment xml:lang="en">An urban area where water indicators are defined.</rdfs:comment>
  <rdfs:label xml:lang="en">City</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class City: Required by CQ37 to model locations like Burgos.</vaem:rationale>
  <dc:source>(competency_question) CQ37: Which water indicators are defined for Burgos?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Tariff">
  <rdfs:comment xml:lang="en">A schedule of charges for water usage.</rdfs:comment>
  <rdfs:label xml:lang="en">Tariff</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Tariff: Required by CQ38 and CQ39.</vaem:rationale>
  <dc:source>(competency_question) CQ38: What is the start date and time of the tariff in use in the water meter?
    (competency_question) CQ39: What is the duration of the current tariff of the water meter?</dc:source>
</owl:Class>

