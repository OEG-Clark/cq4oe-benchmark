<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Organism">
  <rdfs:comment xml:lang="en">A living entity capable of biological processes, including feeding and consumption.</rdfs:comment>
  <rdfs:label xml:lang="en">Organism</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created base class for living entities: To provide a common domain for the eats property covering both animals and plants (CQ6)</vaem:rationale>
  <dc:source>(competency_question) CQ6: Which plants eat animals?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Animal">
  <rdfs:comment xml:lang="en">A multicellular eukaryotic organism that typically consumes organic material for energy.</rdfs:comment>
  <rdfs:label xml:lang="en">Animal</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created as subclass of Organism: To model entities that eat other animals or plants (CQ1, CQ2, CQ3, CQ4, CQ7, CQ14)</vaem:rationale>
  <dc:source>(competency_question) CQ1: Which animal eats which other animal?
    (competency_question) CQ2: Is [this animal] a herbivore?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Organism'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Plant">
  <rdfs:comment xml:lang="en">A multicellular organism that typically produces its own food through photosynthesis, though some species consume animals.</rdfs:comment>
  <rdfs:label xml:lang="en">Plant</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created as subclass of Organism: To model flora that can be eaten or can eat animals (CQ3, CQ4, CQ6)</vaem:rationale>
  <dc:source>(competency_question) CQ3: Which plant parts does [this omnivorous or herbivorourus animal] eat?
    (competency_question) CQ6: Which plants eat animals?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Organism'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlantPart">
  <rdfs:comment xml:lang="en">A distinct structural component of a plant, such as leaves, roots, stems, or fruits.</rdfs:comment>
  <rdfs:label xml:lang="en">Plant Part</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to represent consumable plant components: To specifically address queries about animals consuming parts of plants rather than whole plants (CQ3, CQ4, CQ14)</vaem:rationale>
  <dc:source>(competency_question) CQ3: Which plant parts does [this omnivorous or herbivorourus animal] eat?
    (competency_question) CQ4: Does a lion eat plants or plant parts?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Herbivore">
  <rdfs:comment xml:lang="en">An animal that primarily consumes plant material.</rdfs:comment>
  <rdfs:label xml:lang="en">Herbivore</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created as subclass of Animal: To classify animals by diet and answer direct herbivore queries (CQ2, CQ3)</vaem:rationale>
  <dc:source>(competency_question) CQ2: Is [this animal] a herbivore?
    (competency_question) CQ3: Which plant parts does [this omnivorous or herbivorourus animal] eat?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Animal'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Carnivore">
  <rdfs:comment xml:lang="en">An animal that primarily consumes other animals, though may occasionally eat plants.</rdfs:comment>
  <rdfs:label xml:lang="en">Carnivore</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created as subclass of Animal: To classify meat-eating animals and address CQ14 regarding carnivores that also eat plants</vaem:rationale>
  <dc:source>(competency_question) CQ14: Are there animals that are carnivore but still eat some plants or parts of plants?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Animal'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Omnivore">
  <rdfs:comment xml:lang="en">An animal that consumes both plant and animal matter.</rdfs:comment>
  <rdfs:label xml:lang="en">Omnivore</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created as subclass of Animal: To classify animals with mixed diets as referenced in CQ3</vaem:rationale>
  <dc:source>(competency_question) CQ3: Which plant parts does [this omnivorous or herbivorourus animal] eat?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Animal'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Lion">
  <rdfs:comment xml:lang="en">A large wild cat species, taxonomically classified as a carnivore.</rdfs:comment>
  <rdfs:label xml:lang="en">Lion</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created as subclass of Carnivore: To specifically model the lion entity mentioned in CQ4</vaem:rationale>
  <dc:source>(competency_question) CQ4: Does a lion eat plants or plant parts?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Carnivore'/>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#eats">
  <rdfs:comment xml:lang="en">A feeding relationship where one organism consumes another organism or a part of a plant.</rdfs:comment>
  <rdfs:label xml:lang="en">eats</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property to model consumption: To link consumers to consumed entities across all competency questions</vaem:rationale>
  <dc:source>(competency_question) CQ1: Which animal eats which other animal?
    (competency_question) CQ6: Which plants eat animals?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Organism"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Thing"/>
</owl:ObjectProperty>

</rdf:RDF>