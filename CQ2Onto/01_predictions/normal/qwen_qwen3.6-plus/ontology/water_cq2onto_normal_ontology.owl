<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure">
  <rdfs:comment xml:lang="en">A system comprising interconnected components designed for the collection, treatment, storage, and distribution of water.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Distribution Infrastructure</rdfs:label>
  <dc:source>(competency_question) CQ01: Which assets compose a water distribution infrastructure?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Asset">
  <rdfs:comment xml:lang="en">A tangible or intangible component that forms part of a water infrastructure system.</rdfs:comment>
  <rdfs:label xml:lang="en">Asset</rdfs:label>
  <dc:source>(competency_question) CQ01: Which assets compose a water distribution infrastructure?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Sensor">
  <rdfs:comment xml:lang="en">A device that detects or measures a physical property and records, indicates, or otherwise responds to it.</rdfs:comment>
  <rdfs:label xml:lang="en">Sensor</rdfs:label>
  <dc:source>(competency_question) CQ04: Which types of sensors are used in water infrastructures?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Actuator">
  <rdfs:comment xml:lang="en">A component responsible for moving or controlling a mechanism or system in a water infrastructure.</rdfs:comment>
  <rdfs:label xml:lang="en">Actuator</rdfs:label>
  <dc:source>(competency_question) CQ05: Which types of actuators are used in water infrastructures?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Device">
  <rdfs:comment xml:lang="en">A piece of equipment or a mechanism designed to serve a special purpose or perform a special function.</rdfs:comment>
  <rdfs:label xml:lang="en">Device</rdfs:label>
  <dc:source>(competency_question) CQ06: A water meter is a device that measures different aspects of a water infrastructure.</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterMeter">
  <rdfs:comment xml:lang="en">A specialized device used to measure the volume of water delivered to a property or used within a water infrastructure.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Meter</rdfs:label>
  <dc:source>(competency_question) CQ06: A water meter is a device that measures different aspects of a water infrastructure.
    (competency_question) CQ08-CQ12, CQ18-CQ20, CQ25, CQ38-CQ40, CQ42-CQ43</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Device'/>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Sensor'/>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Asset'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Measurement">
  <rdfs:comment xml:lang="en">A quantified observation or reading obtained from a sensor or meter.</rdfs:comment>
  <rdfs:label xml:lang="en">Measurement</rdfs:label>
  <dc:source>(competency_question) CQ25: Water meters can provide measurements according to different temporal settings.</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#TemporalSetting">
  <rdfs:comment xml:lang="en">A configuration defining the time intervals or schedules at which measurements are collected or reported.</rdfs:comment>
  <rdfs:label xml:lang="en">Temporal Setting</rdfs:label>
  <dc:source>(competency_question) CQ25: Water meters can provide measurements according to different temporal settings.</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Water">
  <rdfs:comment xml:lang="en">The chemical substance H2O, whose physical and chemical properties are monitored in water infrastructure systems.</rdfs:comment>
  <rdfs:label xml:lang="en">Water</rdfs:label>
  <dc:source>(competency_question) CQ33: What are the physical properties of water?
    (competency_question) CQ34: What are the chemical properties of water?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PhysicalProperty">
  <rdfs:comment xml:lang="en">A characteristic of water that can be observed or measured without changing its chemical identity (e.g., temperature, turbidity).</rdfs:comment>
  <rdfs:label xml:lang="en">Physical Property</rdfs:label>
  <dc:source>(competency_question) CQ33: What are the physical properties of water?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ChemicalProperty">
  <rdfs:comment xml:lang="en">A characteristic of water that becomes evident during a chemical reaction (e.g., pH, chlorine concentration).</rdfs:comment>
  <rdfs:label xml:lang="en">Chemical Property</rdfs:label>
  <dc:source>(competency_question) CQ34: What are the chemical properties of water?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterIndicator">
  <rdfs:comment xml:lang="en">A metric or parameter used to assess the status, quality, or performance of water systems in a specific location.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Indicator</rdfs:label>
  <dc:source>(competency_question) CQ37: Which water indicators are defined for Burgos?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Location">
  <rdfs:comment xml:lang="en">A geographical place or administrative area where water infrastructure or indicators are situated.</rdfs:comment>
  <rdfs:label xml:lang="en">Location</rdfs:label>
  <dc:source>(competency_question) CQ37: Which water indicators are defined for Burgos?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Tariff">
  <rdfs:comment xml:lang="en">A pricing scheme or rate structure applied to water consumption, defined by specific temporal and billing parameters.</rdfs:comment>
  <rdfs:label xml:lang="en">Tariff</rdfs:label>
  <dc:source>(competency_question) CQ38: What is the start date and time of the tariff in use in the water meter?
    (competency_question) CQ39: What is the duration of the current tariff of the water meter?
    (competency_question) CQ40: What is the tariff period of the water meter?</dc:source>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAsset">
  <rdfs:comment xml:lang="en">Relates a water distribution infrastructure to the assets that compose it.</rdfs:comment>
  <rdfs:label xml:lang="en">has asset</rdfs:label>
  <dc:source>(competency_question) CQ01: Which assets compose a water distribution infrastructure?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Asset"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasSensor">
  <rdfs:comment xml:lang="en">Relates a water infrastructure to the sensors deployed within it.</rdfs:comment>
  <rdfs:label xml:lang="en">has sensor</rdfs:label>
  <dc:source>(competency_question) CQ04: Which types of sensors are used in water infrastructures?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Sensor"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasActuator">
  <rdfs:comment xml:lang="en">Relates a water infrastructure to the actuators deployed within it.</rdfs:comment>
  <rdfs:label xml:lang="en">has actuator</rdfs:label>
  <dc:source>(competency_question) CQ05: Which types of actuators are used in water infrastructures?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Actuator"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#measures">
  <rdfs:comment xml:lang="en">Relates a water meter to the specific aspects or parameters it measures.</rdfs:comment>
  <rdfs:label xml:lang="en">measures</rdfs:label>
  <dc:source>(competency_question) CQ06: A water meter is a device that measures different aspects of a water infrastructure.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Measurement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasTemporalSetting">
  <rdfs:comment xml:lang="en">Relates a water meter to the temporal configuration governing its measurement collection.</rdfs:comment>
  <rdfs:label xml:lang="en">has temporal setting</rdfs:label>
  <dc:source>(competency_question) CQ25: Water meters can provide measurements according to different temporal settings.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#TemporalSetting"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPhysicalProperty">
  <rdfs:comment xml:lang="en">Relates water to its measurable physical characteristics.</rdfs:comment>
  <rdfs:label xml:lang="en">has physical property</rdfs:label>
  <dc:source>(competency_question) CQ33: What are the physical properties of water?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Water"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PhysicalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasChemicalProperty">
  <rdfs:comment xml:lang="en">Relates water to its measurable chemical characteristics.</rdfs:comment>
  <rdfs:label xml:lang="en">has chemical property</rdfs:label>
  <dc:source>(competency_question) CQ34: What are the chemical properties of water?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Water"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#ChemicalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isDefinedFor">
  <rdfs:comment xml:lang="en">Relates a water indicator to the geographical location or administrative area it applies to.</rdfs:comment>
  <rdfs:label xml:lang="en">is defined for</rdfs:label>
  <dc:source>(competency_question) CQ37: Which water indicators are defined for Burgos?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterIndicator"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Location"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasTariff">
  <rdfs:comment xml:lang="en">Relates a water meter to the active pricing or billing scheme applied to it.</rdfs:comment>
  <rdfs:label xml:lang="en">has tariff</rdfs:label>
  <dc:source>(competency_question) CQ38: What is the start date and time of the tariff in use in the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Tariff"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasFabricationNumber">
  <rdfs:comment xml:lang="en">The unique serial or manufacturing identifier assigned to a water meter during production.</rdfs:comment>
  <rdfs:label xml:lang="en">has fabrication number</rdfs:label>
  <dc:source>(competency_question) CQ08: What is the fabrication number of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasManufacturer">
  <rdfs:comment xml:lang="en">The name of the company or entity that produced the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">has manufacturer</rdfs:label>
  <dc:source>(competency_question) CQ09: What are the manufacturer and the model of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasModel">
  <rdfs:comment xml:lang="en">The specific product model designation of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">has model</rdfs:label>
  <dc:source>(competency_question) CQ09: What are the manufacturer and the model of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasVersion">
  <rdfs:comment xml:lang="en">The general version identifier of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">has version</rdfs:label>
  <dc:source>(competency_question) CQ10: What is the version of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasHardwareVersion">
  <rdfs:comment xml:lang="en">The specific version number of the physical hardware components of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">has hardware version</rdfs:label>
  <dc:source>(competency_question) CQ11: What is the hardware version number of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasFirmwareVersion">
  <rdfs:comment xml:lang="en">The version of the embedded software or firmware running on the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">has firmware version</rdfs:label>
  <dc:source>(competency_question) CQ12: What firmware version is the water meter using?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasPower">
  <rdfs:comment xml:lang="en">The electrical power consumption or rating of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">has power</rdfs:label>
  <dc:source>(competency_question) CQ18: What is the power of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:decimal"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasRadioFrequencyLevel">
  <rdfs:comment xml:lang="en">The signal strength or operating frequency level used for wireless communication by the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">has radio frequency level</rdfs:label>
  <dc:source>(competency_question) CQ19: What is the radio frequency level of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:decimal"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasGeolocation">
  <rdfs:comment xml:lang="en">The geographical coordinates or address specifying the physical installation location of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">has geolocation</rdfs:label>
  <dc:source>(competency_question) CQ20: What is the geolocation of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasStartDate">
  <rdfs:comment xml:lang="en">The exact date and time when a specific tariff becomes active.</rdfs:comment>
  <rdfs:label xml:lang="en">has start date</rdfs:label>
  <dc:source>(competency_question) CQ38: What is the start date and time of the tariff in use in the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tariff"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:dateTime"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasDuration">
  <rdfs:comment xml:lang="en">The total time span for which a tariff remains valid or active.</rdfs:comment>
  <rdfs:label xml:lang="en">has duration</rdfs:label>
  <dc:source>(competency_question) CQ39: What is the duration of the current tariff of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tariff"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:duration"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasTariffPeriod">
  <rdfs:comment xml:lang="en">The recurring time interval or cycle associated with a tariff (e.g., monthly, quarterly).</rdfs:comment>
  <rdfs:label xml:lang="en">has tariff period</rdfs:label>
  <dc:source>(competency_question) CQ40: What is the tariff period of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tariff"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasBillingDate">
  <rdfs:comment xml:lang="en">The specific calendar date on which a billing cycle is generated or charged for the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">has billing date</rdfs:label>
  <dc:source>(competency_question) CQ42: What is the billing date of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:date"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasBillingDatePeriod">
  <rdfs:comment xml:lang="en">The time interval or cycle defining how frequently billing dates occur for the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">has billing date period</rdfs:label>
  <dc:source>(competency_question) CQ43: What is the billing date period of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

</rdf:RDF>