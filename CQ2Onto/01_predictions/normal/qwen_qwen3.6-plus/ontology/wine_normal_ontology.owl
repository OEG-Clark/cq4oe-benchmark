<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Wine">
  <rdfs:comment xml:lang="en">A beverage made from fermented grapes, characterized by various attributes such as color, body, bouquet, and vintage.</rdfs:comment>
  <rdfs:label xml:lang="en">Wine</rdfs:label>
  <dc:source>(competency_question) CQ1: Which wine characteristics should I consider when choosing a wine?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Grape">
  <rdfs:comment xml:lang="en">A fruit variety used in the production of wine.</rdfs:comment>
  <rdfs:label xml:lang="en">Grape</rdfs:label>
  <dc:source>(competency_question) CQnew1: What grapes are used to make Bordeaux wine?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WineRegion">
  <rdfs:comment xml:lang="en">A geographical area known for wine production.</rdfs:comment>
  <rdfs:label xml:lang="en">Wine Region</rdfs:label>
  <dc:source>(competency_question) CQ7: What were good vintages for Napa Zinfandel?
    (competency_question) CQnew1: What grapes are used to make Bordeaux wine?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Vintage">
  <rdfs:comment xml:lang="en">A specific year's harvest and production batch of a wine, which may exhibit distinct characteristics.</rdfs:comment>
  <rdfs:label xml:lang="en">Vintage</rdfs:label>
  <dc:source>(competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?
    (competency_question) CQ7: What were good vintages for Napa Zinfandel?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#BordeauxWine">
  <rdfs:comment xml:lang="en">A wine produced in the Bordeaux region of France.</rdfs:comment>
  <rdfs:label xml:lang="en">Bordeaux Wine</rdfs:label>
  <dc:source>(competency_question) CQ2: Is Bordeaux a red or white wine?
    (competency_question) CQnew1: What grapes are used to make Bordeaux wine?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Wine'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#NapaZinfandel">
  <rdfs:comment xml:lang="en">A Zinfandel wine produced in the Napa Valley region.</rdfs:comment>
  <rdfs:label xml:lang="en">Napa Zinfandel</rdfs:label>
  <dc:source>(competency_question) CQ7: What were good vintages for Napa Zinfandel?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Wine'/>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#madeFromGrape">
  <rdfs:comment xml:lang="en">Links a wine to the grape variety or varieties used to produce it.</rdfs:comment>
  <rdfs:label xml:lang="en">made from grape</rdfs:label>
  <dc:source>(competency_question) CQnew1: What grapes are used to make Bordeaux wine?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Grape"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#producedInRegion">
  <rdfs:comment xml:lang="en">Links a wine to its geographical region of origin.</rdfs:comment>
  <rdfs:label xml:lang="en">produced in region</rdfs:label>
  <dc:source>(competency_question) CQ7: What were good vintages for Napa Zinfandel?
    (competency_question) CQnew1: What grapes are used to make Bordeaux wine?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WineRegion"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasVintage">
  <rdfs:comment xml:lang="en">Links a wine to a specific vintage year production batch.</rdfs:comment>
  <rdfs:label xml:lang="en">has vintage</rdfs:label>
  <dc:source>(competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?
    (competency_question) CQ7: What were good vintages for Napa Zinfandel?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Vintage"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasYear">
  <rdfs:comment xml:lang="en">The calendar year of the harvest for a specific vintage.</rdfs:comment>
  <rdfs:label xml:lang="en">has year</rdfs:label>
  <dc:source>(competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?
    (competency_question) CQ7: What were good vintages for Napa Zinfandel?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Vintage"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:gYear"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasBody">
  <rdfs:comment xml:lang="en">Describes the weight, texture, and mouthfeel of the wine.</rdfs:comment>
  <rdfs:label xml:lang="en">has body</rdfs:label>
  <dc:source>(competency_question) CQ1: Which wine characteristics should I consider when choosing a wine?
    (competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Vintage"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasBouquet">
  <rdfs:comment xml:lang="en">Describes the aroma profile and olfactory characteristics of the wine.</rdfs:comment>
  <rdfs:label xml:lang="en">has bouquet</rdfs:label>
  <dc:source>(competency_question) CQ1: Which wine characteristics should I consider when choosing a wine?
    (competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Vintage"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasColor">
  <rdfs:comment xml:lang="en">The visual color classification of the wine (e.g., red, white, rosé).</rdfs:comment>
  <rdfs:label xml:lang="en">has color</rdfs:label>
  <dc:source>(competency_question) CQ1: Which wine characteristics should I consider when choosing a wine?
    (competency_question) CQ2: Is Bordeaux a red or white wine?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isGoodVintage">
  <rdfs:comment xml:lang="en">A boolean indicator specifying whether a particular vintage year is considered of high quality or recommended.</rdfs:comment>
  <rdfs:label xml:lang="en">is good vintage</rdfs:label>
  <dc:source>(competency_question) CQ7: What were good vintages for Napa Zinfandel?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Vintage"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:boolean"/>
</owl:DatatypeProperty>

</rdf:RDF>