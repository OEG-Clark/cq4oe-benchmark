<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Player">
  <rdfs:comment xml:lang="en">Represents a user or participant in the gaming ecosystem.</rdfs:comment>
  <rdfs:label xml:lang="en">Player</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Required to model user attributes, relationships, and gameplay history across multiple CQs.</vaem:rationale>
  <dc:source>(competency_question) CQ01, CQ02, CQ03, CQ05, CQ07, CQ22, CQ24, CQ25, CQ26, CQ27, CQ29, CQ35, CQ52, CQ56, CQ57, CQ63, CQ64, CQ65, CQ66</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Game">
  <rdfs:comment xml:lang="en">A software application or title that players interact with.</rdfs:comment>
  <rdfs:label xml:lang="en">Game</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Central entity for tracking playtime, achievements, items, genres, and playing areas.</vaem:rationale>
  <dc:source>(competency_question) CQ03, CQ08, CQ09, CQ10, CQ11, CQ12, CQ13, CQ15, CQ17, CQ22, CQ25, CQ29, CQ35, CQ52, CQ55, New CQ1</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Achievement">
  <rdfs:comment xml:lang="en">A specific goal or milestone within a game that players can unlock.</rdfs:comment>
  <rdfs:label xml:lang="en">Achievement</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Needed to track player progress and game-specific milestones.</vaem:rationale>
  <dc:source>(competency_question) CQ05, CQ07, CQ08, CQ10, CQ11, CQ24, CQ27, CQ35</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#AchievementType">
  <rdfs:comment xml:lang="en">Categorization of achievements based on their nature or requirements.</rdfs:comment>
  <rdfs:label xml:lang="en">Achievement Type</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Required to classify achievements and filter them by type.</vaem:rationale>
  <dc:source>(competency_question) CQ10, CQ11, CQ27</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Genre">
  <rdfs:comment xml:lang="en">A category that describes the gameplay style or theme of a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Genre</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Needed to categorize games and support genre-based queries.</vaem:rationale>
  <dc:source>(competency_question) CQ12, CQ17</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Item">
  <rdfs:comment xml:lang="en">A virtual object that exists within a game and can be used or owned by players.</rdfs:comment>
  <rdfs:label xml:lang="en">Item</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Required to model in-game objects, their abilities, and player ownership.</vaem:rationale>
  <dc:source>(competency_question) CQ13, CQ19, CQ26, CQ55</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Equipment">
  <rdfs:comment xml:lang="en">A specialized type of item that players can equip for gameplay advantages.</rdfs:comment>
  <rdfs:label xml:lang="en">Equipment</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class and added subclass axiom: Needed to distinguish equippable items from general items.</vaem:rationale>
  <dc:source>(competency_question) CQ52</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Item'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Ability">
  <rdfs:comment xml:lang="en">A special power or skill associated with an item or character.</rdfs:comment>
  <rdfs:label xml:lang="en">Ability</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Required to describe functional properties of items.</vaem:rationale>
  <dc:source>(competency_question) CQ19</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#InAppPurchase">
  <rdfs:comment xml:lang="en">A transaction record representing a monetary purchase made within a game.</rdfs:comment>
  <rdfs:label xml:lang="en">In-App Purchase</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Needed to track purchase timestamps, amounts, and player spending behavior.</vaem:rationale>
  <dc:source>(competency_question) CQ56, CQ57, CQ62, CQ63, CQ64, CQ65, CQ66</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Location">
  <rdfs:comment xml:lang="en">A geographical place where a player resides.</rdfs:comment>
  <rdfs:label xml:lang="en">Location</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Required to analyze player demographics and spending patterns by region.</vaem:rationale>
  <dc:source>(competency_question) CQ63, CQ65, CQ66</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayingArea">
  <rdfs:comment xml:lang="en">A specific zone, map, or environment within a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Playing Area</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class: Needed to model spatial or level-based components of games.</vaem:rationale>
  <dc:source>(competency_question) New CQ1</dc:source>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasFriend">
  <rdfs:comment xml:lang="en">Links a player to their friends within the gaming network.</rdfs:comment>
  <rdfs:label xml:lang="en">has Friend</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Required to model social connections between players.</vaem:rationale>
  <dc:source>(competency_question) CQ02, CQ03</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#playsGame">
  <rdfs:comment xml:lang="en">Indicates that a player engages with a specific game.</rdfs:comment>
  <rdfs:label xml:lang="en">plays Game</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Needed to track player-game interactions and shared gameplay.</vaem:rationale>
  <dc:source>(competency_question) CQ03, CQ25</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasObtainedAchievement">
  <rdfs:comment xml:lang="en">Links a player to an achievement they have successfully unlocked.</rdfs:comment>
  <rdfs:label xml:lang="en">has Obtained Achievement</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Required to track player progress and achievement completion.</vaem:rationale>
  <dc:source>(competency_question) CQ05, CQ07, CQ24, CQ27</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAvailableAchievement">
  <rdfs:comment xml:lang="en">Links a game to the achievements that can be earned within it.</rdfs:comment>
  <rdfs:label xml:lang="en">has Available Achievement</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Needed to define the achievement pool for each game.</vaem:rationale>
  <dc:source>(competency_question) CQ08</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAchievementType">
  <rdfs:comment xml:lang="en">Associates an achievement with its specific category or type.</rdfs:comment>
  <rdfs:label xml:lang="en">has Achievement Type</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Required to classify achievements and support type-based filtering.</vaem:rationale>
  <dc:source>(competency_question) CQ10, CQ11, CQ27</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGenre">
  <rdfs:comment xml:lang="en">Assigns a genre classification to a game.</rdfs:comment>
  <rdfs:label xml:lang="en">has Genre</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Needed to categorize games and enable genre-based queries.</vaem:rationale>
  <dc:source>(competency_question) CQ12, CQ17</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Genre"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasItem">
  <rdfs:comment xml:lang="en">Indicates that a game contains a specific virtual item.</rdfs:comment>
  <rdfs:label xml:lang="en">has Item</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Required to model the item catalog available within a game.</vaem:rationale>
  <dc:source>(competency_question) CQ13</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#ownsItem">
  <rdfs:comment xml:lang="en">Links a player to an item they currently possess.</rdfs:comment>
  <rdfs:label xml:lang="en">owns Item</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Needed to track player inventory and item ownership.</vaem:rationale>
  <dc:source>(competency_question) CQ26</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAbility">
  <rdfs:comment xml:lang="en">Associates an item with a specific gameplay ability or effect.</rdfs:comment>
  <rdfs:label xml:lang="en">has Ability</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Required to describe the functional properties of items.</vaem:rationale>
  <dc:source>(competency_question) CQ19</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Item"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Ability"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#lastPlayedGame">
  <rdfs:comment xml:lang="en">Identifies the most recent game a player has engaged with.</rdfs:comment>
  <rdfs:label xml:lang="en">last Played Game</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property and marked as functional: Needed to track the latest gameplay session per player.</vaem:rationale>
  <dc:source>(competency_question) CQ29</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasEquippedItem">
  <rdfs:comment xml:lang="en">Links a player to an equipment item they are currently using.</rdfs:comment>
  <rdfs:label xml:lang="en">has Equipped Item</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Required to model active equipment loadouts per player.</vaem:rationale>
  <dc:source>(competency_question) CQ52</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Equipment"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usableInGame">
  <rdfs:comment xml:lang="en">Indicates that an item can be utilized within a specific game.</rdfs:comment>
  <rdfs:label xml:lang="en">usable In Game</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Needed to define cross-game item compatibility.</vaem:rationale>
  <dc:source>(competency_question) CQ55</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Item"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#madePurchase">
  <rdfs:comment xml:lang="en">Links a player to a specific in-app purchase transaction.</rdfs:comment>
  <rdfs:label xml:lang="en">made Purchase</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Required to track individual purchase events and timestamps.</vaem:rationale>
  <dc:source>(competency_question) CQ56, CQ57, CQ62</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#livesIn">
  <rdfs:comment xml:lang="en">Associates a player with their geographical location.</rdfs:comment>
  <rdfs:label xml:lang="en">lives In</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Needed for demographic and regional spending analysis.</vaem:rationale>
  <dc:source>(competency_question) CQ63, CQ65, CQ66</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Location"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPlayingArea">
  <rdfs:comment xml:lang="en">Links a game to its internal zones, maps, or environments.</rdfs:comment>
  <rdfs:label xml:lang="en">has Playing Area</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Required to model spatial components of games.</vaem:rationale>
  <dc:source>(competency_question) New CQ1</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasUsername">
  <rdfs:comment xml:lang="en">Stores the unique display name or identifier of a player.</rdfs:comment>
  <rdfs:label xml:lang="en">has Username</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Required to identify players by name.</vaem:rationale>
  <dc:source>(competency_question) CQ01</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#totalPlayHours">
  <rdfs:comment xml:lang="en">Records the cumulative number of hours a game has been played.</rdfs:comment>
  <rdfs:label xml:lang="en">total Play Hours</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Needed to measure game popularity and engagement.</vaem:rationale>
  <dc:source>(competency_question) CQ09</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#releaseDate">
  <rdfs:comment xml:lang="en">Indicates the official launch date of a game.</rdfs:comment>
  <rdfs:label xml:lang="en">release Date</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Required for temporal tracking and game cataloging.</vaem:rationale>
  <dc:source>(competency_question) CQ15</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:date"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#killCount">
  <rdfs:comment xml:lang="en">Tracks the total number of eliminations achieved by a player.</rdfs:comment>
  <rdfs:label xml:lang="en">kill Count</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Needed to rank players by combat performance.</vaem:rationale>
  <dc:source>(competency_question) CQ22</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasMadeInAppPurchase">
  <rdfs:comment xml:lang="en">Boolean flag indicating whether a player has ever spent money in-game.</rdfs:comment>
  <rdfs:label xml:lang="en">has Made In-App Purchase</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Required to segment paying vs non-paying customers.</vaem:rationale>
  <dc:source>(competency_question) CQ56, CQ65</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#totalIAPAmount">
  <rdfs:comment xml:lang="en">Stores the cumulative monetary value spent by a player on in-app purchases.</rdfs:comment>
  <rdfs:label xml:lang="en">total IAP Amount</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Needed to identify high-value customers and repeat spenders.</vaem:rationale>
  <dc:source>(competency_question) CQ57, CQ66</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#purchaseTimestamp">
  <rdfs:comment xml:lang="en">Records the exact date and time an in-app purchase occurred.</rdfs:comment>
  <rdfs:label xml:lang="en">purchase Timestamp</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Required to analyze peak purchasing times.</vaem:rationale>
  <dc:source>(competency_question) CQ62</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#locationName">
  <rdfs:comment xml:lang="en">Stores the human-readable name of a geographical location.</rdfs:comment>
  <rdfs:label xml:lang="en">location Name</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Needed to label and query player residence data.</vaem:rationale>
  <dc:source>(competency_question) CQ63, CQ65, CQ66</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Location"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#timeBeforeFirstIAP">
  <rdfs:comment xml:lang="en">Measures the duration a player spends in a game before making their first purchase.</rdfs:comment>
  <rdfs:label xml:lang="en">time Before First IAP</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Required to analyze conversion latency and player onboarding.</vaem:rationale>
  <dc:source>(competency_question) CQ64</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:duration"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#completedGamesCount">
  <rdfs:comment xml:lang="en">Tracks the number of games in which a player has unlocked all available achievements.</rdfs:comment>
  <rdfs:label xml:lang="en">completed Games Count</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property: Needed to quantify full game completion across a player's library.</vaem:rationale>
  <dc:source>(competency_question) CQ35</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:integer"/>
</owl:DatatypeProperty>

</rdf:RDF>