<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#SoftwareTool">
  <rdfs:comment xml:lang="en">A software application, library, API, or service that processes data, performs computational tasks, or provides specific functionalities.</rdfs:comment>
  <rdfs:label xml:lang="en">Software Tool</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created as the central domain class.: Primary subject of all competency questions.</vaem:rationale>
  <dc:source>(competency_question) CQ04, CQ05, CQ06, CQ07, CQ08, CQ11, CQ14, CQ15, CQ16, CQ17, CQ19, CQ21, CQ22, CQ23, CQ26, CQ29, CQ30, CQ32, CQ36, CQ37, CQ38, CQ40, CQ45, CQ46, CQ54, CQ55, CQ57, CQ58, CQ59, CQ60, CQ65, CQ68, CQ73, CQ84, CQ85</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Algorithm">
  <rdfs:comment xml:lang="en">A well-defined computational procedure or set of rules used by a software tool to process data or solve problems.</rdfs:comment>
  <rdfs:label xml:lang="en">Algorithm</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to model computational methods.: Addresses CQ04 and CQ05 regarding named/published algorithms and their modifications.</vaem:rationale>
  <dc:source>(competency_question) CQ04, CQ05</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#SoftwareType">
  <rdfs:comment xml:lang="en">A classification of software based on its deployment or interaction model (e.g., API, Desktop, Web Service, Library).</rdfs:comment>
  <rdfs:label xml:lang="en">Software Type</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created as a superclass for software categories.: Addresses CQ07 and CQ11 by providing a structured way to classify software types.</vaem:rationale>
  <dc:source>(competency_question) CQ07, CQ11</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#API">
  <rdfs:comment xml:lang="en">Application Programming Interface software type.</rdfs:comment>
  <rdfs:label xml:lang="en">API</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created as a subclass of SoftwareType.: Explicitly mentioned in CQ07.</vaem:rationale>
  <dc:source>(competency_question) CQ07</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#SoftwareType'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#DesktopApplication">
  <rdfs:comment xml:lang="en">Software designed to run locally on a user's computer.</rdfs:comment>
  <rdfs:label xml:lang="en">Desktop Application</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created as a subclass of SoftwareType.: Explicitly mentioned in CQ07.</vaem:rationale>
  <dc:source>(competency_question) CQ07</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#SoftwareType'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WebService">
  <rdfs:comment xml:lang="en">Software accessible over a network via standard web protocols.</rdfs:comment>
  <rdfs:label xml:lang="en">Web Service</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created as a subclass of SoftwareType.: Addresses CQ11 regarding web service availability.</vaem:rationale>
  <dc:source>(competency_question) CQ11</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#SoftwareType'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Task">
  <rdfs:comment xml:lang="en">A specific computational or data processing activity that a software tool can perform.</rdfs:comment>
  <rdfs:label xml:lang="en">Task</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to model user goals and software capabilities.: Addresses CQ08, CQ14, and CQ16.</vaem:rationale>
  <dc:source>(competency_question) CQ08, CQ14, CQ16</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Data">
  <rdfs:comment xml:lang="en">Structured or unstructured information that is processed, generated, or consumed by software.</rdfs:comment>
  <rdfs:label xml:lang="en">Data</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to represent datasets and files.: Addresses CQ15, CQ16, and CQ23.</vaem:rationale>
  <dc:source>(competency_question) CQ15, CQ16, CQ23</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#DataFormat">
  <rdfs:comment xml:lang="en">A standardized structure or encoding for data files (e.g., CSV, XML, CEL, GIF).</rdfs:comment>
  <rdfs:label xml:lang="en">Data Format</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to model input/output specifications.: Addresses CQ17, CQ19, CQ21, CQ22, CQ26, and CQ29.</vaem:rationale>
  <dc:source>(competency_question) CQ17, CQ19, CQ21, CQ22, CQ26, CQ29</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#SoftwareVersion">
  <rdfs:comment xml:lang="en">A specific release or iteration of a software tool with distinct features and release metadata.</rdfs:comment>
  <rdfs:label xml:lang="en">Software Version</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to track version-specific attributes.: Addresses CQ29, CQ54, CQ55, and CQ57.</vaem:rationale>
  <dc:source>(competency_question) CQ29, CQ54, CQ55, CQ57</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Agent">
  <rdfs:comment xml:lang="en">An individual, organization, or group responsible for developing or maintaining software.</rdfs:comment>
  <rdfs:label xml:lang="en">Agent</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to model developers and maintainers.: Addresses CQ36 and CQ38.</vaem:rationale>
  <dc:source>(competency_question) CQ36, CQ38</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#License">
  <rdfs:comment xml:lang="en">A legal agreement governing the use, modification, and distribution of software.</rdfs:comment>
  <rdfs:label xml:lang="en">License</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to model software licensing terms.: Addresses CQ59.</vaem:rationale>
  <dc:source>(competency_question) CQ59</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ProgrammingLanguage">
  <rdfs:comment xml:lang="en">A formal language used to implement software source code.</rdfs:comment>
  <rdfs:label xml:lang="en">Programming Language</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to track implementation details.: Addresses CQ84.</vaem:rationale>
  <dc:source>(competency_question) CQ84</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Platform">
  <rdfs:comment xml:lang="en">An operating system or hardware environment on which software can execute.</rdfs:comment>
  <rdfs:label xml:lang="en">Platform</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to model runtime environments.: Addresses CQ85.</vaem:rationale>
  <dc:source>(competency_question) CQ85</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Feature">
  <rdfs:comment xml:lang="en">A specific capability or functionality provided by a software tool or version.</rdfs:comment>
  <rdfs:label xml:lang="en">Feature</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to model software capabilities.: Addresses CQ06, CQ14, and CQ55.</vaem:rationale>
  <dc:source>(competency_question) CQ06, CQ14, CQ55</dc:source>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usesAlgorithm">
  <rdfs:comment xml:lang="en">Relates a software tool to the algorithm it employs for processing.</rdfs:comment>
  <rdfs:label xml:lang="en">uses algorithm</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to link tools to algorithms.: Directly answers CQ04.</vaem:rationale>
  <dc:source>(competency_question) CQ04</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasSoftwareType">
  <rdfs:comment xml:lang="en">Indicates the category or deployment model of a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">has software type</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to classify software.: Answers CQ07.</vaem:rationale>
  <dc:source>(competency_question) CQ07</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareType"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#performsTask">
  <rdfs:comment xml:lang="en">Relates a software tool to a specific computational or data processing task it can execute.</rdfs:comment>
  <rdfs:label xml:lang="en">performs task</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to map tools to user goals.: Answers CQ08 and CQ14.</vaem:rationale>
  <dc:source>(competency_question) CQ08, CQ14</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Task"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#createdBy">
  <rdfs:comment xml:lang="en">Indicates which software tool generated or produced a specific dataset.</rdfs:comment>
  <rdfs:label xml:lang="en">created by</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to track data provenance.: Answers CQ15.</vaem:rationale>
  <dc:source>(competency_question) CQ15</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Data"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#supportsData">
  <rdfs:comment xml:lang="en">Indicates that a software tool can process or work with a specific type of data.</rdfs:comment>
  <rdfs:label xml:lang="en">supports data</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to link tools to compatible data.: Answers CQ16.</vaem:rationale>
  <dc:source>(competency_question) CQ16</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Data"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasInputFormat">
  <rdfs:comment xml:lang="en">Specifies the data formats that a software tool accepts as input.</rdfs:comment>
  <rdfs:label xml:lang="en">has input format</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to model input specifications.: Answers CQ17 and CQ21.</vaem:rationale>
  <dc:source>(competency_question) CQ17, CQ21</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasOutputFormat">
  <rdfs:comment xml:lang="en">Specifies the data formats that a software tool produces as output.</rdfs:comment>
  <rdfs:label xml:lang="en">has output format</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to model output specifications.: Answers CQ17 and CQ29.</vaem:rationale>
  <dc:source>(competency_question) CQ17, CQ29</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#canReadFormat">
  <rdfs:comment xml:lang="en">Indicates that a software tool is capable of parsing or reading a specific data format.</rdfs:comment>
  <rdfs:label xml:lang="en">can read format</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to model format compatibility.: Answers CQ19.</vaem:rationale>
  <dc:source>(competency_question) CQ19</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#canExportToFormat">
  <rdfs:comment xml:lang="en">Indicates that a software tool can convert and export data to a specific target format.</rdfs:comment>
  <rdfs:label xml:lang="en">can export to format</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to model export capabilities.: Answers CQ22.</vaem:rationale>
  <dc:source>(competency_question) CQ22</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isCompatibleWith">
  <rdfs:comment xml:lang="en">Indicates that two software tools can interoperate or exchange data seamlessly.</rdfs:comment>
  <rdfs:label xml:lang="en">is compatible with</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to model tool interoperability.: Answers CQ23.</vaem:rationale>
  <dc:source>(competency_question) CQ23</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#isCompatibleWith'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasVersion">
  <rdfs:comment xml:lang="en">Relates a software tool to its specific version releases.</rdfs:comment>
  <rdfs:label xml:lang="en">has version</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to track software iterations.: Answers CQ29 and CQ54.</vaem:rationale>
  <dc:source>(competency_question) CQ29, CQ54</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareVersion"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#developedBy">
  <rdfs:comment xml:lang="en">Indicates the agent or organization responsible for creating the software.</rdfs:comment>
  <rdfs:label xml:lang="en">developed by</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to track authorship.: Answers CQ36.</vaem:rationale>
  <dc:source>(competency_question) CQ36</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Agent"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasLicense">
  <rdfs:comment xml:lang="en">Specifies the legal license under which the software is distributed.</rdfs:comment>
  <rdfs:label xml:lang="en">has license</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to model licensing terms.: Answers CQ59.</vaem:rationale>
  <dc:source>(competency_question) CQ59</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#License"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#implementedIn">
  <rdfs:comment xml:lang="en">Indicates the programming language used to write the software source code.</rdfs:comment>
  <rdfs:label xml:lang="en">implemented in</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to track implementation details.: Answers CQ84.</vaem:rationale>
  <dc:source>(competency_question) CQ84</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#ProgrammingLanguage"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#runsOnPlatform">
  <rdfs:comment xml:lang="en">Indicates the operating system or hardware environment where the software can execute.</rdfs:comment>
  <rdfs:label xml:lang="en">runs on platform</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to model runtime compatibility.: Answers CQ85.</vaem:rationale>
  <dc:source>(competency_question) CQ85</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Platform"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasFeature">
  <rdfs:comment xml:lang="en">Relates a software tool to a specific capability or functionality it provides.</rdfs:comment>
  <rdfs:label xml:lang="en">has feature</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to model general capabilities.: Answers CQ06 and CQ14.</vaem:rationale>
  <dc:source>(competency_question) CQ06, CQ14</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Feature"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#versionHasFeature">
  <rdfs:comment xml:lang="en">Relates a specific software version to the new features introduced in that release.</rdfs:comment>
  <rdfs:label xml:lang="en">version has feature</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to track version-specific additions.: Answers CQ55.</vaem:rationale>
  <dc:source>(competency_question) CQ55</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareVersion"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Feature"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasAlgorithmModification">
  <rdfs:comment xml:lang="en">Describes any customizations or alterations made to the standard algorithm used by the tool.</rdfs:comment>
  <rdfs:label xml:lang="en">has algorithm modification</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to capture algorithm tweaks.: Answers CQ05.</vaem:rationale>
  <dc:source>(competency_question) CQ05</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isAvailableAsWebService">
  <rdfs:comment xml:lang="en">Boolean flag indicating whether the software is accessible as a web service.</rdfs:comment>
  <rdfs:label xml:lang="en">is available as web service</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to model deployment accessibility.: Answers CQ11.</vaem:rationale>
  <dc:source>(competency_question) CQ11</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isOpenSource">
  <rdfs:comment xml:lang="en">Boolean flag indicating whether the software source code is publicly available under an open source license.</rdfs:comment>
  <rdfs:label xml:lang="en">is open source</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to model licensing openness.: Answers CQ26, CQ58, and CQ60.</vaem:rationale>
  <dc:source>(competency_question) CQ26, CQ58, CQ60</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isFOSS">
  <rdfs:comment xml:lang="en">Boolean flag indicating whether the software qualifies as Free and Open Source Software.</rdfs:comment>
  <rdfs:label xml:lang="en">is FOSS</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to explicitly track FOSS status.: Answers CQ65.</vaem:rationale>
  <dc:source>(competency_question) CQ65</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isFree">
  <rdfs:comment xml:lang="en">Boolean flag indicating whether the software can be used without monetary cost.</rdfs:comment>
  <rdfs:label xml:lang="en">is free</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to model cost accessibility.: Answers CQ68.</vaem:rationale>
  <dc:source>(competency_question) CQ68</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isMaintained">
  <rdfs:comment xml:lang="en">Boolean flag indicating whether the software is actively updated and supported.</rdfs:comment>
  <rdfs:label xml:lang="en">is maintained</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to track software lifecycle status.: Answers CQ26.</vaem:rationale>
  <dc:source>(competency_question) CQ26</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#acceptsCollaboration">
  <rdfs:comment xml:lang="en">Boolean flag indicating whether the developers are open to external collaboration or contributions.</rdfs:comment>
  <rdfs:label xml:lang="en">accepts collaboration</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to model community engagement.: Answers CQ38.</vaem:rationale>
  <dc:source>(competency_question) CQ38</dc:source>
