<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Policy">
  <rdfs:comment xml:lang="en">A policy is a collection of rules that define permissions, duties, and prohibitions.</rdfs:comment>
  <rdfs:label xml:lang="en">Policy</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Policy: Required to answer New CQ1 and New CQ2 about policies and their properties</vaem:rationale>
  <dc:source>(competency_question) New CQ1: Which policy is directly linked to a given asset?
    (competency_question) New CQ2: What conflict resolution strategy is specified by a policy?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Rule">
  <rdfs:comment xml:lang="en">A rule is an abstract concept that can be a permission, duty, or prohibition.</rdfs:comment>
  <rdfs:label xml:lang="en">Rule</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Rule as superclass of Permission, Duty, Prohibition: Required to model different types of rules and their relationships</vaem:rationale>
  <dc:source>(competency_question) CQ06: Expressing the various roles of contract parties within the Permission/Duty element.
    (competency_question) CQ10: How are rights and duties supported for all contract parties?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.w3.org/2002/07/owl#Thing'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Permission">
  <rdfs:comment xml:lang="en">A permission grants the right to perform an action on an asset.</rdfs:comment>
  <rdfs:label xml:lang="en">Permission</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Permission as subclass of Rule: Required to answer CQ03, CQ24 about permissions and exclusive permissions</vaem:rationale>
  <dc:source>(competency_question) CQ03: Shall the permissions 'Aggregation' and 'Disaggregation' be of the type Transfer Rights?
    (competency_question) CQ24: How to express exclusive permissions?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Rule'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Duty">
  <rdfs:comment xml:lang="en">A duty specifies an obligation that must be fulfilled.</rdfs:comment>
  <rdfs:label xml:lang="en">Duty</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Duty as subclass of Rule: Required to answer New CQ3, New CQ5 about duties as remedies and consequences</vaem:rationale>
  <dc:source>(competency_question) New CQ3: What duty is specified as a remedy for the violation of a prohibition?
    (competency_question) New CQ5: What duty is specified as a consequence of another duty?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Rule'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Prohibition">
  <rdfs:comment xml:lang="en">A prohibition specifies actions that are not allowed.</rdfs:comment>
  <rdfs:label xml:lang="en">Prohibition</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Prohibition as subclass of Rule: Required to answer New CQ3 about remedies for prohibition violations and New CQ6 about constraint operators</vaem:rationale>
  <dc:source>(competency_question) New CQ3: What duty is specified as a remedy for the violation of a prohibition?
    (competency_question) New CQ6: What operator is used in the constraints of a prohibition?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Rule'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#TransferPermission">
  <rdfs:comment xml:lang="en">A permission that involves transfer rights, such as aggregation or disaggregation.</rdfs:comment>
  <rdfs:label xml:lang="en">Transfer Permission</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class TransferPermission as subclass of Permission: Required to answer CQ03 about transfer rights for aggregation and disaggregation</vaem:rationale>
  <dc:source>(competency_question) CQ03: Shall the permissions 'Aggregation' and 'Disaggregation' be of the type Transfer Rights?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Permission'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ExclusivePermission">
  <rdfs:comment xml:lang="en">A permission that is exclusive, meaning it cannot be combined with other permissions.</rdfs:comment>
  <rdfs:label xml:lang="en">Exclusive Permission</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class ExclusivePermission as subclass of Permission: Required to answer CQ24 about expressing exclusive permissions</vaem:rationale>
  <dc:source>(competency_question) CQ24: How to express exclusive permissions?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Permission'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Asset">
  <rdfs:comment xml:lang="en">An asset is the target of a rule, such as digital content or service.</rdfs:comment>
  <rdfs:label xml:lang="en">Asset</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Asset: Required to answer New CQ1 about policies linked to assets</vaem:rationale>
  <dc:source>(competency_question) New CQ1: Which policy is directly linked to a given asset?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Party">
  <rdfs:comment xml:lang="en">A party is an entity (person, organization) that plays a role in a policy.</rdfs:comment>
  <rdfs:label xml:lang="en">Party</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Party: Required to answer CQ06 about roles of contract parties</vaem:rationale>
  <dc:source>(competency_question) CQ06: Expressing the various roles of contract parties within the Permission/Duty element.</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Constraint">
  <rdfs:comment xml:lang="en">A constraint specifies conditions or limitations on a rule.</rdfs:comment>
  <rdfs:label xml:lang="en">Constraint</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Constraint: Required to answer CQ13, CQ14, CQ21, CQ26 about constraints and their operators</vaem:rationale>
  <dc:source>(competency_question) CQ13: Shall ODRLv2 allow for nested constraints?
    (competency_question) CQ14: How do we express 'and', 'or', 'xor' constraints?
    (competency_question) CQ21: How to express constraints on requirements?
    (competency_question) CQ26: How to express Condition via Constraints?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Operator">
  <rdfs:comment xml:lang="en">An operator defines the logical operation used in constraints.</rdfs:comment>
  <rdfs:label xml:lang="en">Operator</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Operator: Required to answer CQ14 and New CQ6 about logical operators in constraints</vaem:rationale>
  <dc:source>(competency_question) CQ14: How do we express 'and', 'or', 'xor' constraints?
    (competency_question) New CQ6: What operator is used in the constraints of a prohibition?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#LogicalOperator">
  <rdfs:comment xml:lang="en">A logical operator such as AND, OR, XOR, NOT.</rdfs:comment>
  <rdfs:label xml:lang="en">Logical Operator</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class LogicalOperator as subclass of Operator: Required to answer CQ08 and CQ14 about NOT, AND, OR, XOR expressions</vaem:rationale>
  <dc:source>(competency_question) CQ08: How to provide a 'NOT' expression?
    (competency_question) CQ14: How do we express 'and', 'or', 'xor' constraints?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Operator'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ConflictResolutionStrategy">
  <rdfs:comment xml:lang="en">A strategy for resolving conflicts between rules in a policy.</rdfs:comment>
  <rdfs:label xml:lang="en">Conflict Resolution Strategy</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class ConflictResolutionStrategy: Required to answer New CQ2 about conflict resolution strategies specified by policies</vaem:rationale>
  <dc:source>(competency_question) New CQ2: What conflict resolution strategy is specified by a policy?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Container">
  <rdfs:comment xml:lang="en">A container is a grouping mechanism for policies or rules (mentioned in CQ30).</rdfs:comment>
  <rdfs:label xml:lang="en">Container</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Container: Required to address CQ30 about containers in ODRL</vaem:rationale>
  <dc:source>(competency_question) CQ30: What do we lose if containers are no longer part of ODRL?</dc:source>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasRule">
  <rdfs:comment xml:lang="en">Links a policy to its rules (permissions, duties, prohibitions).</rdfs:comment>
  <rdfs:label xml:lang="en">has rule</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property hasRule: Required to connect policies to their constituent rules</vaem:rationale>
  <dc:source>(competency_question) CQ10: How are rights and duties supported for all contract parties?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAsset">
  <rdfs:comment xml:lang="en">Links a rule or policy to an asset.</rdfs:comment>
  <rdfs:label xml:lang="en">has asset</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property hasAsset: Required to answer New CQ1 about policies linked to assets</vaem:rationale>
  <dc:source>(competency_question) New CQ1: Which policy is directly linked to a given asset?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Asset"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasParty">
  <rdfs:comment xml:lang="en">Links a rule to a party involved in the rule.</rdfs:comment>
  <rdfs:label xml:lang="en">has party</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property hasParty: Required to answer CQ06 about roles of contract parties</vaem:rationale>
  <dc:source>(competency_question) CQ06: Expressing the various roles of contract parties within the Permission/Duty element.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Party"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasConstraint">
  <rdfs:comment xml:lang="en">Links a rule to its constraints.</rdfs:comment>
  <rdfs:label xml:lang="en">has constraint</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property hasConstraint: Required to answer CQ13, CQ21, CQ26 about constraints on rules</vaem:rationale>
  <dc:source>(competency_question) CQ13: Shall ODRLv2 allow for nested constraints?
    (competency_question) CQ21: How to express constraints on requirements?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasOperator">
  <rdfs:comment xml:lang="en">Links a constraint to its operator.</rdfs:comment>
  <rdfs:label xml:lang="en">has operator</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property hasOperator: Required to answer CQ14 and New CQ6 about operators in constraints</vaem:rationale>
  <dc:source>(competency_question) CQ14: How do we express 'and', 'or', 'xor' constraints?
    (competency_question) New CQ6: What operator is used in the constraints of a prohibition?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Operator"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasRemedy">
  <rdfs:comment xml:lang="en">Links a prohibition to a duty that serves as a remedy for its violation.</rdfs:comment>
  <rdfs:label xml:lang="en">has remedy</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property hasRemedy: Required to answer New CQ3 about duties as remedies for prohibition violations</vaem:rationale>
  <dc:source>(competency_question) New CQ3: What duty is specified as a remedy for the violation of a prohibition?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Prohibition"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Duty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasConsequence">
  <rdfs:comment xml:lang="en">Links a duty to another duty that is a consequence of it.</rdfs:comment>
  <rdfs:label xml:lang="en">has consequence</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property hasConsequence: Required to answer New CQ5 about duties as consequences of other duties</vaem:rationale>
  <dc:source>(competency_question) New CQ5: What duty is specified as a consequence of another duty?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Duty"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Duty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#activatesUponFailure">
  <rdfs:comment xml:lang="en">Links a rule to another rule that activates upon the failure of the first rule.</rdfs:comment>
  <rdfs:label xml:lang="en">activates upon failure</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property activatesUponFailure: Required to answer New CQ4 about rules activating upon failure of other rules</vaem:rationale>
  <dc:source>(competency_question) New CQ4: Which rule is activated upon the failure of another rule?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasConflictResolutionStrategy">
  <rdfs:comment xml:lang="en">Links a policy to its conflict resolution strategy.</rdfs:comment>
  <rdfs:label xml:lang="en">has conflict resolution strategy</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property hasConflictResolutionStrategy: Required to answer New CQ2 about conflict resolution strategies specified by policies</vaem:rationale>
  <dc:source>(competency_question) New CQ2: What conflict resolution strategy is specified by a policy?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#ConflictResolutionStrategy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasSubConstraint">
  <rdfs:comment xml:lang="en">Links a constraint to its nested sub-constraints, enabling constraint nesting.</rdfs:comment>
  <rdfs:label xml:lang="en">has sub constraint</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property hasSubConstraint: Required to answer CQ13 about nested constraints</vaem:rationale>
  <dc:source>(competency_question) CQ13: Shall ODRLv2 allow for nested constraints?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isInheritedFrom">
  <rdfs:comment xml:lang="en">Links a policy or rule to another policy or rule from which it inherits properties.</rdfs:comment>
  <rdfs:label xml:lang="en">is inherited from</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property isInheritedFrom: Required to answer CQ33 about inheritance in the data model</vaem:rationale>
  <dc:source>(competency_question) CQ33: Can the new data model express inheritance?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasSequencing">
  <rdfs:comment xml:lang="en">Links a policy or rule to sequencing information (mentioned in CQ31).</rdfs:comment>
  <rdfs:label xml:lang="en">has sequencing</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property hasSequencing: Required to address CQ31 about sequencing as part of the REL</vaem:rationale>
  <dc:source>(competency_question) CQ31: Do we need 'Sequencing' as part of the REL?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isContainedIn">
  <rdfs:comment xml:lang="en">Links a policy or rule to a container that contains it.</rdfs:comment>
  <rdfs:label xml:lang="en">is contained in</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property isContainedIn: Required to address CQ30 about containers in ODRL</vaem:rationale>
  <dc:source>(competency_question) CQ30: What do we lose if containers are no longer part of ODRL?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Container"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasPolicyId">
  <rdfs:comment xml:lang="en">A unique identifier for a policy.</rdfs:comment>
  <rdfs:label xml:lang="en">has policy ID</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created datatype property hasPolicyId: Useful for identifying policies, though not explicitly required by competency questions</vaem:rationale>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasRuleId">
  <rdfs:comment xml:lang="en">A unique identifier for a rule.</rdfs:comment>
  <rdfs:label xml:lang="en">has rule ID</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created datatype property hasRuleId: Useful for identifying rules, though not explicitly required by competency questions</vaem:rationale>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

</rdf:RDF>