  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#tariffPeriod">
  <rdfs:comment xml:lang="en">The periodicity of the tariff, e.g., daily, monthly, or annually.</rdfs:comment>
  <rdfs:label xml:lang="en">tariff period</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created datatype property tariffPeriod: To capture the tariff period (CQ40).</vaem:rationale>
