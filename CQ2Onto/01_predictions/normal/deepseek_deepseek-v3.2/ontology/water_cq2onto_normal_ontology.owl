<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure">
  <rdfs:comment xml:lang="en">A system that distributes water, composed of various assets.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Distribution Infrastructure</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class WaterDistributionInfrastructure: To represent the infrastructure system mentioned in CQ01.</vaem:rationale>
  <dc:source>(competency_question) CQ01: Which assets compose a water distribution infrastructure?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Asset">
  <rdfs:comment xml:lang="en">A physical or logical component that is part of a water distribution infrastructure.</rdfs:comment>
  <rdfs:label xml:lang="en">Asset</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Asset: To represent the general concept of assets composing the infrastructure (CQ01).</vaem:rationale>
  <dc:source>(competency_question) CQ01: Which assets compose a water distribution infrastructure?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Thing'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Device">
  <rdfs:comment xml:lang="en">A type of asset that is a physical instrument, such as a sensor, actuator, or meter.</rdfs:comment>
  <rdfs:label xml:lang="en">Device</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Device: To group sensors, actuators, and water meters as devices (CQ04, CQ05, CQ06).</vaem:rationale>
  <dc:source>(competency_question) CQ04: Which types of sensors are used in water infrastructures?
    (competency_question) CQ05: Which types of actuators are used in water infrastructures?
    (competency_question) CQ06: A water meter is a device that measures different aspects of a water infrastructure.</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Asset'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Sensor">
  <rdfs:comment xml:lang="en">A device that detects or measures a physical property and converts it into a signal.</rdfs:comment>
  <rdfs:label xml:lang="en">Sensor</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Sensor: To represent sensors used in water infrastructures (CQ04).</vaem:rationale>
  <dc:source>(competency_question) CQ04: Which types of sensors are used in water infrastructures?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Device'/>
  <owl:disjointWith rdf:resource='http://www.semanticweb.org/myontology#Actuator'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Actuator">
  <rdfs:comment xml:lang="en">A device that controls or moves a mechanism in the water infrastructure.</rdfs:comment>
  <rdfs:label xml:lang="en">Actuator</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Actuator: To represent actuators used in water infrastructures (CQ05).</vaem:rationale>
  <dc:source>(competency_question) CQ05: Which types of actuators are used in water infrastructures?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Device'/>
  <owl:disjointWith rdf:resource='http://www.semanticweb.org/myontology#Sensor'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterMeter">
  <rdfs:comment xml:lang="en">A device that measures different aspects of a water infrastructure, such as flow, volume, or quality.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Meter</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class WaterMeter: To represent water meters as a key device (CQ06).</vaem:rationale>
  <dc:source>(competency_question) CQ06: A water meter is a device that measures different aspects of a water infrastructure.</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Device'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterProperty">
  <rdfs:comment xml:lang="en">A characteristic of water, which can be physical or chemical.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Property</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class WaterProperty: To represent properties of water (CQ33, CQ34).</vaem:rationale>
  <dc:source>(competency_question) CQ33: What are the physical properties of water?
    (competency_question) CQ34: What are the chemical properties of water?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Thing'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PhysicalProperty">
  <rdfs:comment xml:lang="en">A physical characteristic of water, such as temperature, pressure, or turbidity.</rdfs:comment>
  <rdfs:label xml:lang="en">Physical Property</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class PhysicalProperty: To represent physical properties of water (CQ33).</vaem:rationale>
  <dc:source>(competency_question) CQ33: What are the physical properties of water?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#WaterProperty'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ChemicalProperty">
  <rdfs:comment xml:lang="en">A chemical characteristic of water, such as pH, chlorine level, or hardness.</rdfs:comment>
  <rdfs:label xml:lang="en">Chemical Property</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class ChemicalProperty: To represent chemical properties of water (CQ34).</vaem:rationale>
  <dc:source>(competency_question) CQ34: What are the chemical properties of water?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#WaterProperty'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterIndicator">
  <rdfs:comment xml:lang="en">A defined metric or parameter for water quality or quantity, possibly specific to a location like Burgos.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Indicator</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class WaterIndicator: To represent water indicators (CQ37).</vaem:rationale>
  <dc:source>(competency_question) CQ37: Which water indicators are defined for Burgos?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Thing'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Tariff">
  <rdfs:comment xml:lang="en">A pricing scheme applied to water usage, with a start time, duration, and period.</rdfs:comment>
  <rdfs:label xml:lang="en">Tariff</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Tariff: To represent tariffs associated with water meters (CQ38, CQ39, CQ40).</vaem:rationale>
  <dc:source>(competency_question) CQ38: What is the start date and time of the tariff in use in the water meter?
    (competency_question) CQ39: What is the duration of the current tariff of the water meter?
    (competency_question) CQ40: What is the tariff period of the water meter?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Thing'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Billing">
  <rdfs:comment xml:lang="en">The process or record of charging for water usage, with a billing date and period.</rdfs:comment>
  <rdfs:label xml:lang="en">Billing</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Billing: To represent billing information for water meters (CQ42, CQ43).</vaem:rationale>
  <dc:source>(competency_question) CQ42: What is the billing date of the water meter?
    (competency_question) CQ43: What is the billing date period of the water meter?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Thing'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Measurement">
  <rdfs:comment xml:lang="en">A value obtained from a device at a specific time, reflecting a property or indicator.</rdfs:comment>
  <rdfs:label xml:lang="en">Measurement</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Measurement: To represent measurements provided by water meters (CQ25).</vaem:rationale>
  <dc:source>(competency_question) CQ25: Water meters can provide measurements according to different temporal settings.</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Thing'/>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#composes">
  <rdfs:comment xml:lang="en">Links an asset to the water distribution infrastructure it is part of.</rdfs:comment>
  <rdfs:label xml:lang="en">composes</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property composes: To relate assets to the infrastructure they compose (CQ01).</vaem:rationale>
  <dc:source>(competency_question) CQ01: Which assets compose a water distribution infrastructure?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Asset"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasWaterMeter">
  <rdfs:comment xml:lang="en">Links a water distribution infrastructure to a water meter installed in it.</rdfs:comment>
  <rdfs:label xml:lang="en">has water meter</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property hasWaterMeter: To associate infrastructure with water meters (implied by CQ06).</vaem:rationale>
  <dc:source>(competency_question) CQ06: A water meter is a device that measures different aspects of a water infrastructure.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasSensor">
  <rdfs:comment xml:lang="en">Links a water distribution infrastructure to a sensor used in it.</rdfs:comment>
  <rdfs:label xml:lang="en">has sensor</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property hasSensor: To associate infrastructure with sensors (CQ04).</vaem:rationale>
  <dc:source>(competency_question) CQ04: Which types of sensors are used in water infrastructures?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Sensor"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasActuator">
  <rdfs:comment xml:lang="en">Links a water distribution infrastructure to an actuator used in it.</rdfs:comment>
  <rdfs:label xml:lang="en">has actuator</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property hasActuator: To associate infrastructure with actuators (CQ05).</vaem:rationale>
  <dc:source>(competency_question) CQ05: Which types of actuators are used in water infrastructures?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Actuator"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#measures">
  <rdfs:comment xml:lang="en">Links a water meter to a measurement it provides.</rdfs:comment>
  <rdfs:label xml:lang="en">measures</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property measures: To relate water meters to their measurements (CQ25).</vaem:rationale>
  <dc:source>(competency_question) CQ25: Water meters can provide measurements according to different temporal settings.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Measurement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasTariff">
  <rdfs:comment xml:lang="en">Links a water meter to the tariff currently applied to it.</rdfs:comment>
  <rdfs:label xml:lang="en">has tariff</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property hasTariff: To associate water meters with tariffs (CQ38, CQ39, CQ40).</vaem:rationale>
  <dc:source>(competency_question) CQ38: What is the start date and time of the tariff in use in the water meter?
    (competency_question) CQ39: What is the duration of the current tariff of the water meter?
    (competency_question) CQ40: What is the tariff period of the water meter?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Tariff"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasBilling">
  <rdfs:comment xml:lang="en">Links a water meter to its billing information.</rdfs:comment>
  <rdfs:label xml:lang="en">has billing</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property hasBilling: To associate water meters with billing (CQ42, CQ43).</vaem:rationale>
