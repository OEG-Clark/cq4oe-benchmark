</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#duration">
  <rdfs:comment xml:lang="en">The length of time a tariff is valid, e.g., in hours, days, or months.</rdfs:comment>
