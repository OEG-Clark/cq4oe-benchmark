<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Player">
  <rdfs:comment xml:lang="en">A person who plays games.</rdfs:comment>
  <rdfs:label xml:lang="en">Player</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Player.: Required by CQ01, CQ02, CQ03, CQ05, CQ07, CQ22, CQ24, CQ25, CQ26, CQ27, CQ29, CQ35, CQ52, CQ56, CQ57, CQ64, CQ65, CQ66 to represent users of the gaming platform.</vaem:rationale>
  <dc:source>(competency_question) CQ01: What is the username of the player?
    (competency_question) CQ02: Who are the friends of the player?
    (competency_question) CQ24: What achievements has a player obtained?
    (competency_question) CQ56: How many players have made in app purchases?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Game">
  <rdfs:comment xml:lang="en">A video game that can be played by players.</rdfs:comment>
  <rdfs:label xml:lang="en">Game</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Game.: Required by CQ03, CQ08, CQ09, CQ10, CQ11, CQ12, CQ13, CQ15, CQ17, CQ22, CQ25, CQ29, CQ35, CQ52, CQ55, New CQ1 to represent individual games.</vaem:rationale>
  <dc:source>(competency_question) CQ08: What achievements does a game have?
    (competency_question) CQ09: How many hours has this game been played in total?
    (competency_question) CQ12: What is the genre of the game?
    (competency_question) CQ17: List all games of a certain Genre?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Achievement">
  <rdfs:comment xml:lang="en">An accomplishment or milestone within a game that a player can earn.</rdfs:comment>
  <rdfs:label xml:lang="en">Achievement</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Achievement.: Required by CQ05, CQ07, CQ08, CQ10, CQ11, CQ24, CQ27, CQ35 to represent in-game achievements.</vaem:rationale>
  <dc:source>(competency_question) CQ05: What are the achievements of my friends?
    (competency_question) CQ08: What achievements does a game have?
    (competency_question) CQ24: What achievements has a player obtained?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Item">
  <rdfs:comment xml:lang="en">An object within a game that a player can possess or use, such as equipment or tools.</rdfs:comment>
  <rdfs:label xml:lang="en">Item</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Item.: Required by CQ13, CQ19, CQ26, CQ52, CQ55 to represent in-game items.</vaem:rationale>
  <dc:source>(competency_question) CQ13: What items exist in a game?
    (competency_question) CQ19: What abilities does an item have?
    (competency_question) CQ26: What items does the player have?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#InAppPurchase">
  <rdfs:comment xml:lang="en">A transaction where a player spends real money within a game.</rdfs:comment>
  <rdfs:label xml:lang="en">In-App Purchase</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class InAppPurchase.: Required by CQ56, CQ57, CQ62, CQ64, CQ65, CQ66 to model monetary transactions.</vaem:rationale>
  <dc:source>(competency_question) CQ56: How many players have made in app purchases?
    (competency_question) CQ62: What time are most of the in app purchases done?
    (competency_question) CQ64: How long does a player spend in the game before making first IAP?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Genre">
  <rdfs:comment xml:lang="en">A category or style of game, such as action, role-playing, or strategy.</rdfs:comment>
  <rdfs:label xml:lang="en">Genre</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Genre.: Required by CQ12, CQ17 to classify games.</vaem:rationale>
  <dc:source>(competency_question) CQ12: What is the genre of the game?
    (competency_question) CQ17: List all games of a certain Genre?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#AchievementType">
  <rdfs:comment xml:lang="en">A classification of achievements, such as bronze, silver, gold, or based on criteria.</rdfs:comment>
  <rdfs:label xml:lang="en">Achievement Type</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class AchievementType.: Required by CQ10, CQ11, CQ27 to categorize achievements.</vaem:rationale>
  <dc:source>(competency_question) CQ10: What are the types of achievements in this game?
    (competency_question) CQ11: What are the types of achievements a game can have?
    (competency_question) CQ27: What achievements of a certain type does the player have?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Location">
  <rdfs:comment xml:lang="en">A geographical area where a player resides.</rdfs:comment>
  <rdfs:label xml:lang="en">Location</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Location.: Required by CQ63, CQ65, CQ66 to represent player demographics.</vaem:rationale>
  <dc:source>(competency_question) CQ63: Where do the most paying customers live?
    (competency_question) CQ65: Where do the players live who have not made any IAP?
    (competency_question) CQ66: Where do the players who have done the most IAP live?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayingArea">
  <rdfs:comment xml:lang="en">A distinct region, level, or map within a game where gameplay occurs.</rdfs:comment>
  <rdfs:label xml:lang="en">Playing Area</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class PlayingArea.: Required by New CQ1: 'What playing areas does a game have?'</vaem:rationale>
  <dc:source>(competency_question) New CQ1: What playing areas does a game have?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Ability">
  <rdfs:comment xml:lang="en">A capability or effect that an item provides.</rdfs:comment>
  <rdfs:label xml:lang="en">Ability</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Ability.: Required as range for itemHasAbility property from CQ19.</vaem:rationale>
  <dc:source>(competency_question) CQ19: What abilities does an item have?</dc:source>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasFriend">
  <rdfs:comment xml:lang="en">Links a player to another player who is their friend.</rdfs:comment>
  <rdfs:label xml:lang="en">has friend</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property hasFriend.: Required by CQ02, CQ03, CQ05, CQ07 to model social connections.</vaem:rationale>
  <dc:source>(competency_question) CQ02: Who are the friends of the player?
    (competency_question) CQ03: Who are the friends that play other games as well with this player?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#playsGame">
  <rdfs:comment xml:lang="en">Links a player to a game they have played.</rdfs:comment>
  <rdfs:label xml:lang="en">plays game</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property playsGame.: Required by CQ03, CQ25, CQ29, CQ35, CQ52 to associate players with games.</vaem:rationale>
  <dc:source>(competency_question) CQ03: Who are the friends that play other games as well with this player?
    (competency_question) CQ25: What games has the player played?
    (competency_question) CQ29: What is the last game a player has played?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAchievement">
  <rdfs:comment xml:lang="en">Links a player to an achievement they have obtained.</rdfs:comment>
  <rdfs:label xml:lang="en">has achievement</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property hasAchievement.: Required by CQ05, CQ07, CQ24, CQ27, CQ35 to track player achievements.</vaem:rationale>
  <dc:source>(competency_question) CQ05: What are the achievements of my friends?
    (competency_question) CQ24: What achievements has a player obtained?
    (competency_question) CQ27: What achievements of a certain type does the player have?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasItem">
  <rdfs:comment xml:lang="en">Links a player to an item they possess.</rdfs:comment>
  <rdfs:label xml:lang="en">has item</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property hasItem.: Required by CQ26, CQ52 to represent player inventory.</vaem:rationale>
  <dc:source>(competency_question) CQ26: What items does the player have?
    (competency_question) CQ52: What equipment does a player have in a game?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#gameHasAchievement">
  <rdfs:comment xml:lang="en">Links a game to an achievement that can be earned in that game.</rdfs:comment>
  <rdfs:label xml:lang="en">game has achievement</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property gameHasAchievement.: Required by CQ08, CQ10, CQ11 to associate games with their achievements.</vaem:rationale>
  <dc:source>(competency_question) CQ08: What achievements does a game have?
    (competency_question) CQ10: What are the types of achievements in this game?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGenre">
  <rdfs:comment xml:lang="en">Links a game to its genre.</rdfs:comment>
  <rdfs:label xml:lang="en">has genre</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property hasGenre.: Required by CQ12, CQ17 to classify games by genre.</vaem:rationale>
  <dc:source>(competency_question) CQ12: What is the genre of the game?
    (competency_question) CQ17: List all games of a certain Genre?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Genre"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#gameHasItem">
  <rdfs:comment xml:lang="en">Links a game to items that exist within that game.</rdfs:comment>
  <rdfs:label xml:lang="en">game has item</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property gameHasItem.: Required by CQ13, CQ55 to define items available in a game.</vaem:rationale>
  <dc:source>(competency_question) CQ13: What items exist in a game?
    (competency_question) CQ55: What are the games where a player can use this item?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#achievementHasType">
  <rdfs:comment xml:lang="en">Links an achievement to its type.</rdfs:comment>
  <rdfs:label xml:lang="en">achievement has type</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property achievementHasType.: Required by CQ10, CQ11, CQ27 to categorize achievements.</vaem:rationale>
  <dc:source>(competency_question) CQ10: What are the types of achievements in this game?
    (competency_question) CQ27: What achievements of a certain type does the player have?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#itemHasAbility">
  <rdfs:comment xml:lang="en">Links an item to its abilities or effects.</rdfs:comment>
  <rdfs:label xml:lang="en">item has ability</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property itemHasAbility.: Required by CQ19 to describe item capabilities.</vaem:rationale>
  <dc:source>(competency_question) CQ19: What abilities does an item have?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Item"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Ability"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasInAppPurchase">
  <rdfs:comment xml:lang="en">Links a player to an in-app purchase they have made.</rdfs:comment>
  <rdfs:label xml:lang="en">has in-app purchase</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property hasInAppPurchase.: Required by CQ56, CQ57, CQ62, CQ64, CQ65, CQ66 to track player purchases.</vaem:rationale>
  <dc:source>(competency_question) CQ56: How many players have made in app purchases?
    (competency_question) CQ57: How many players who have already spent money, spend money again?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#locatedIn">
  <rdfs:comment xml:lang="en">Links a player to their geographical location.</rdfs:comment>
  <rdfs:label xml:lang="en">located in</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property locatedIn.: Required by CQ63, CQ65, CQ66 to associate players with locations.</vaem:rationale>
  <dc:source>(competency_question) CQ63: Where do the most paying customers live?
    (competency_question) CQ65: Where do the players live who have not made any IAP?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Location"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#gameHasPlayingArea">
  <rdfs:comment xml:lang="en">Links a game to its playing areas.</rdfs:comment>
  <rdfs:label xml:lang="en">game has playing area</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property gameHasPlayingArea.: Required by New CQ1 to associate games with their playing areas.</vaem:rationale>
  <dc:source>(competency_question) New CQ1: What playing areas does a game have?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#username">
  <rdfs:comment xml:lang="en">The unique identifier or screen name of a player.</rdfs:comment>
  <rdfs:label xml:lang="en">username</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created datatype property username.: Required by CQ01 to store player usernames.</vaem:rationale>
  <dc:source>(competency_question) CQ01: What is the username of the player?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#totalHoursPlayed">
  <rdfs:comment xml:lang="en">The total number of hours a game has been played by all players.</rdfs:comment>
  <rdfs:label xml:lang="en">total hours played</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created datatype property totalHoursPlayed.: Required by CQ09 to quantify game playtime.</vaem:rationale>
  <dc:source>(competency_question) CQ09: How many hours has this game been played in total?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#releaseDate">
  <rdfs:comment xml:lang="en">The date when a game was released.</rdfs:comment>
  <rdfs:label xml:lang="en">release date</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created datatype property releaseDate.: Required by CQ15 to store game release dates.</vaem:rationale>
  <dc:source>(competency_question) CQ15: What is the release date of the game?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#killCount">
  <rdfs:comment xml:lang="en">The number of kills a player has achieved in a game.</rdfs:comment>
  <rdfs:label xml:lang="en">kill count</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created datatype property killCount.: Required by CQ22 to compare player performance.</vaem:rationale>
  <dc:source>(competency_question) CQ22: Who has the best kill count in the game?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#purchaseTime">
  <rdfs:comment xml:lang="en">The timestamp when an in-app purchase was made.</rdfs:comment>
  <rdfs:label xml:lang="en">purchase time</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created datatype property purchaseTime.: Required by CQ62 to analyze purchase timing patterns.</vaem:rationale>
  <dc:source>(competency_question) CQ62: What time are most of the in app purchases done?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#timeBeforeFirstIAP">
  <rdfs:comment xml:lang="en">The duration a player spent in a game before making their first in-app purchase.</rdfs:comment>
  <rdfs:label xml:lang="en">time before first IAP</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created datatype property timeBeforeFirstIAP.: Required by CQ64 to measure player engagement prior to purchase.</vaem:rationale>
  <dc:source>(competency_question) CQ64: How long does a player spend in the game before making first IAP?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#duration"/>
</owl:DatatypeProperty>

</rdf:RDF>