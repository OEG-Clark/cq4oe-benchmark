<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Animal">
  <rdfs:comment xml:lang="en">An organism of the kingdom Animalia, typically capable of movement and heterotrophic nutrition.</rdfs:comment>
  <rdfs:label xml:lang="en">Animal</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Animal: Required to represent animals mentioned in all competency questions</vaem:rationale>
  <dc:source>(competency_question) CQ1: Which animal eats which other animal?
    (competency_question) CQ2: Is [this animal] a herbivore?
    (competency_question) CQ3: Which plant parts does [this omnivorous or herbivorourus animal] eat?
    (competency_question) CQ4: Does a lion eat plants or plant parts?
    (competency_question) CQ7: Which animals eat [these animals]?
    (competency_question) CQ14: Are there animals that are carnivore but still eat some plants or parts of plants?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Plant">
  <rdfs:comment xml:lang="en">An organism of the kingdom Plantae, typically photosynthetic and autotrophic.</rdfs:comment>
  <rdfs:label xml:lang="en">Plant</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Plant: Required to represent plants that animals eat (CQ3, CQ4, CQ6, CQ14)</vaem:rationale>
  <dc:source>(competency_question) CQ3: Which plant parts does [this omnivorous or herbivorourus animal] eat?
    (competency_question) CQ4: Does a lion eat plants or plant parts?
    (competency_question) CQ6: Which plants eat animals?
    (competency_question) CQ14: Are there animals that are carnivore but still eat some plants or parts of plants?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlantPart">
  <rdfs:comment xml:lang="en">A part of a plant, such as leaf, fruit, stem, root, or seed.</rdfs:comment>
  <rdfs:label xml:lang="en">Plant Part</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class PlantPart: Required to represent plant parts that animals eat (CQ3, CQ4, CQ14)</vaem:rationale>
  <dc:source>(competency_question) CQ3: Which plant parts does [this omnivorous or herbivorourus animal] eat?
    (competency_question) CQ4: Does a lion eat plants or plant parts?
    (competency_question) CQ14: Are there animals that are carnivore but still eat some plants or parts of plants?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Plant'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Herbivore">
  <rdfs:comment xml:lang="en">An animal that eats primarily plants or plant parts.</rdfs:comment>
  <rdfs:label xml:lang="en">Herbivore</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Herbivore: Required to answer CQ2 and classify animals based on diet</vaem:rationale>
  <dc:source>(competency_question) CQ2: Is [this animal] a herbivore?
    (competency_question) CQ3: Which plant parts does [this omnivorous or herbivorourus animal] eat?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Animal'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Carnivore">
  <rdfs:comment xml:lang="en">An animal that eats primarily other animals.</rdfs:comment>
  <rdfs:label xml:lang="en">Carnivore</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Carnivore: Required to answer CQ14 and classify animals based on diet</vaem:rationale>
  <dc:source>(competency_question) CQ14: Are there animals that are carnivore but still eat some plants or parts of plants?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Animal'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Omnivore">
  <rdfs:comment xml:lang="en">An animal that eats both plants/plant parts and other animals.</rdfs:comment>
  <rdfs:label xml:lang="en">Omnivore</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Omnivore: Required to answer CQ3 and classify animals based on diet</vaem:rationale>
  <dc:source>(competency_question) CQ3: Which plant parts does [this omnivorous or herbivorourus animal] eat?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Animal'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#CarnivorousPlant">
  <rdfs:comment xml:lang="en">A plant that captures and digests animals, typically insects, for nutrients.</rdfs:comment>
  <rdfs:label xml:lang="en">Carnivorous Plant</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class CarnivorousPlant: Required to answer CQ6 about plants that eat animals</vaem:rationale>
  <dc:source>(competency_question) CQ6: Which plants eat animals?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Plant'/>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#eats">
  <rdfs:comment xml:lang="en">Relationship where an animal consumes another animal.</rdfs:comment>
  <rdfs:label xml:lang="en">eats</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property eats: Required to answer CQ1 and CQ7 about which animal eats which other animal</vaem:rationale>
  <dc:source>(competency_question) CQ1: Which animal eats which other animal?
    (competency_question) CQ7: Which animals eat [these animals]?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#eatsPlant">
  <rdfs:comment xml:lang="en">Relationship where an animal consumes a plant or plant part.</rdfs:comment>
  <rdfs:label xml:lang="en">eats plant</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property eatsPlant: Required to answer CQ3, CQ4, and CQ14 about animals eating plants or plant parts</vaem:rationale>
  <dc:source>(competency_question) CQ3: Which plant parts does [this omnivorous or herbivorourus animal] eat?
    (competency_question) CQ4: Does a lion eat plants or plant parts?
    (competency_question) CQ14: Are there animals that are carnivore but still eat some plants or parts of plants?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Plant"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#eatenBy">
  <rdfs:comment xml:lang="en">Inverse relationship of eats: the animal that is consumed by another animal.</rdfs:comment>
  <rdfs:label xml:lang="en">eaten by</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property eatenBy: Useful inverse property for querying which animals are prey</vaem:rationale>
  <dc:source>(competency_question) CQ1: Which animal eats which other animal?
    (competency_question) CQ7: Which animals eat [these animals]?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#eats'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#eatenByAnimal">
  <rdfs:comment xml:lang="en">Inverse relationship of eatsPlant: the plant or plant part that is consumed by an animal.</rdfs:comment>
  <rdfs:label xml:lang="en">eaten by animal</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property eatenByAnimal: Useful inverse property for querying which plants are eaten by which animals</vaem:rationale>
  <dc:source>(competency_question) CQ3: Which plant parts does [this omnivorous or herbivorourus animal] eat?
    (competency_question) CQ4: Does a lion eat plants or plant parts?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Plant"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#eatsPlant'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#plantEats">
  <rdfs:comment xml:lang="en">Relationship where a plant (specifically a carnivorous plant) consumes an animal.</rdfs:comment>
  <rdfs:label xml:lang="en">plant eats</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property plantEats: Required to answer CQ6 about plants that eat animals</vaem:rationale>
  <dc:source>(competency_question) CQ6: Which plants eat animals?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#CarnivorousPlant"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#scientificName">
  <rdfs:comment xml:lang="en">The scientific name (binomial nomenclature) of an organism.</rdfs:comment>
  <rdfs:label xml:lang="en">scientific name</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created datatype property scientificName: Useful for identifying organisms precisely</vaem:rationale>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#commonName">
  <rdfs:comment xml:lang="en">The common or vernacular name of an organism.</rdfs:comment>
  <rdfs:label xml:lang="en">common name</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created datatype property commonName: Useful for identifying organisms by their everyday names</vaem:rationale>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

</rdf:RDF>