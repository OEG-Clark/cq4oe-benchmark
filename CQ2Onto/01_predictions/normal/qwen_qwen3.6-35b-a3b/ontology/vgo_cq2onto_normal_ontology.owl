<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Player">
  <rdfs:comment xml:lang="en">An individual who plays games, makes in-app purchases, and interacts with other players.</rdfs:comment>
  <rdfs:label xml:lang="en">Player</rdfs:label>
  <dc:source>(competency_question) CQ01, CQ02, CQ03, CQ05, CQ07, CQ22, CQ24, CQ25, CQ26, CQ27, CQ29, CQ35, CQ52, CQ56, CQ57, CQ63, CQ64, CQ65, CQ66</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Game">
  <rdfs:comment xml:lang="en">A playable software application or video game.</rdfs:comment>
  <rdfs:label xml:lang="en">Game</rdfs:label>
  <dc:source>(competency_question) CQ03, CQ08, CQ09, CQ10, CQ11, CQ12, CQ13, CQ15, CQ17, CQ25, CQ29, CQ35, CQ55, New CQ1</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Achievement">
  <rdfs:comment xml:lang="en">A milestone or reward earned by a player or associated with a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Achievement</rdfs:label>
  <dc:source>(competency_question) CQ05, CQ07, CQ08, CQ10, CQ11, CQ24, CQ27, CQ35</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#AchievementType">
  <rdfs:comment xml:lang="en">A category or classification for achievements.</rdfs:comment>
  <rdfs:label xml:lang="en">Achievement Type</rdfs:label>
  <dc:source>(competency_question) CQ10, CQ11, CQ27</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Genre">
  <rdfs:comment xml:lang="en">A category or style of game (e.g., RPG, FPS, Strategy).</rdfs:comment>
  <rdfs:label xml:lang="en">Genre</rdfs:label>
  <dc:source>(competency_question) CQ12, CQ17</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Item">
  <rdfs:comment xml:lang="en">A virtual object or resource existing within a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Item</rdfs:label>
  <dc:source>(competency_question) CQ13, CQ19, CQ26, CQ55</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Equipment">
  <rdfs:comment xml:lang="en">A specific type of item used by players for gameplay purposes.</rdfs:comment>
  <rdfs:label xml:lang="en">Equipment</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Added Equipment class: CQ52 specifically asks about equipment, which is a specialized subset of items.</vaem:rationale>
  <dc:source>(competency_question) CQ52</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Item'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Ability">
  <rdfs:comment xml:lang="en">A skill, effect, or capability associated with an item.</rdfs:comment>
  <rdfs:label xml:lang="en">Ability</rdfs:label>
  <dc:source>(competency_question) CQ19</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#InAppPurchase">
  <rdfs:comment xml:lang="en">A transaction where a player buys virtual goods or services within a game.</rdfs:comment>
  <rdfs:label xml:lang="en">In-App Purchase</rdfs:label>
  <dc:source>(competency_question) CQ56, CQ57, CQ62, CQ64</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Location">
  <rdfs:comment xml:lang="en">A geographical region, city, or country where a player resides.</rdfs:comment>
  <rdfs:label xml:lang="en">Location</rdfs:label>
  <dc:source>(competency_question) CQ63, CQ65, CQ66</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayingArea">
  <rdfs:comment xml:lang="en">A designated zone or map section within a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Playing Area</rdfs:label>
  <dc:source>(competency_question) New CQ1</dc:source>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasFriend">
  <rdfs:comment xml:lang="en">A social connection between two players.</rdfs:comment>
  <rdfs:label xml:lang="en">has friend</rdfs:label>
  <dc:source>(competency_question) CQ02, CQ03, CQ05, CQ07</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#playsGame">
  <rdfs:comment xml:lang="en">Indicates that a player has played a specific game.</rdfs:comment>
  <rdfs:label xml:lang="en">plays game</rdfs:label>
  <dc:source>(competency_question) CQ03, CQ25, CQ29, CQ35</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#playerHasAchievement">
  <rdfs:comment xml:lang="en">Indicates that a player has obtained a specific achievement.</rdfs:comment>
  <rdfs:label xml:lang="en">player has achievement</rdfs:label>
  <dc:source>(competency_question) CQ05, CQ07, CQ24, CQ27, CQ35</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#gameHasAchievement">
  <rdfs:comment xml:lang="en">Indicates that a game contains or offers a specific achievement.</rdfs:comment>
  <rdfs:label xml:lang="en">game has achievement</rdfs:label>
  <dc:source>(competency_question) CQ08</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasType">
  <rdfs:comment xml:lang="en">Categorizes an achievement into a specific type.</rdfs:comment>
  <rdfs:label xml:lang="en">has type</rdfs:label>
  <dc:source>(competency_question) CQ10, CQ27</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#gameHasAchievementType">
  <rdfs:comment xml:lang="en">Indicates the categories of achievements available in a game.</rdfs:comment>
  <rdfs:label xml:lang="en">game has achievement type</rdfs:label>
  <dc:source>(competency_question) CQ11</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGenre">
  <rdfs:comment xml:lang="en">Associates a game with its genre category.</rdfs:comment>
  <rdfs:label xml:lang="en">has genre</rdfs:label>
  <dc:source>(competency_question) CQ12, CQ17</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Genre"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#gameHasItem">
  <rdfs:comment xml:lang="en">Indicates that a game contains or features a specific item.</rdfs:comment>
  <rdfs:label xml:lang="en">game has item</rdfs:label>
  <dc:source>(competency_question) CQ13</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#playerHasItem">
  <rdfs:comment xml:lang="en">Indicates that a player possesses a specific item.</rdfs:comment>
  <rdfs:label xml:lang="en">player has item</rdfs:label>
  <dc:source>(competency_question) CQ26</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAbility">
  <rdfs:comment xml:lang="en">Associates an item with a specific skill or effect it provides.</rdfs:comment>
  <rdfs:label xml:lang="en">has ability</rdfs:label>
  <dc:source>(competency_question) CQ19</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Item"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Ability"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#lastPlayedGame">
  <rdfs:comment xml:lang="en">The most recent game a player has played.</rdfs:comment>
  <rdfs:label xml:lang="en">last played game</rdfs:label>
  <dc:source>(competency_question) CQ29</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#playerHasEquipment">
  <rdfs:comment xml:lang="en">Indicates that a player possesses specific equipment within a game context.</rdfs:comment>
  <rdfs:label xml:lang="en">player has equipment</rdfs:label>
  <dc:source>(competency_question) CQ52</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Equipment"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usableInGame">
  <rdfs:comment xml:lang="en">Indicates that an item can be used within a specific game.</rdfs:comment>
  <rdfs:label xml:lang="en">usable in game</rdfs:label>
  <dc:source>(competency_question) CQ55</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Item"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#playerHasIAP">
  <rdfs:comment xml:lang="en">Links a player to their specific in-app purchase transactions.</rdfs:comment>
  <rdfs:label xml:lang="en">player has in-app purchase</rdfs:label>
  <dc:source>(competency_question) CQ56, CQ57, CQ62, CQ64</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#livesIn">
  <rdfs:comment xml:lang="en">Indicates the geographical location where a player resides.</rdfs:comment>
  <rdfs:label xml:lang="en">lives in</rdfs:label>
  <dc:source>(competency_question) CQ63, CQ65, CQ66</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Location"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#gameHasPlayingArea">
  <rdfs:comment xml:lang="en">Indicates the designated zones or maps available in a game.</rdfs:comment>
  <rdfs:label xml:lang="en">game has playing area</rdfs:label>
  <dc:source>(competency_question) New CQ1</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasUsername">
  <rdfs:comment xml:lang="en">The unique identifier or display name of a player.</rdfs:comment>
  <rdfs:label xml:lang="en">has username</rdfs:label>
  <dc:source>(competency_question) CQ01</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#releaseDate">
  <rdfs:comment xml:lang="en">The date when a game was officially released.</rdfs:comment>
  <rdfs:label xml:lang="en">release date</rdfs:label>
  <dc:source>(competency_question) CQ15</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:date"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasKillCount">
  <rdfs:comment xml:lang="en">The total number of kills recorded for a player in a game.</rdfs:comment>
  <rdfs:label xml:lang="en">has kill count</rdfs:label>
  <dc:source>(competency_question) CQ22</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:integer"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasMadeIAP">
  <rdfs:comment xml:lang="en">Indicates whether a player has completed at least one in-app purchase.</rdfs:comment>
  <rdfs:label xml:lang="en">has made in-app purchase</rdfs:label>
  <dc:source>(competency_question) CQ56, CQ65</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:boolean"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#totalIAPAmount">
  <rdfs:comment xml:lang="en">The cumulative monetary value spent by a player on in-app purchases.</rdfs:comment>
  <rdfs:label xml:lang="en">total IAP amount</rdfs:label>
  <dc:source>(competency_question) CQ57, CQ66</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:float"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasTime">
  <rdfs:comment xml:lang="en">The timestamp or time of day when an in-app purchase occurred.</rdfs:comment>
  <rdfs:label xml:lang="en">has time</rdfs:label>
  <dc:source>(competency_question) CQ62</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:time"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#timeToFirstIAP">
  <rdfs:comment xml:lang="en">The duration a player spends in the game before making their first in-app purchase.</rdfs:comment>
  <rdfs:label xml:lang="en">time to first IAP</rdfs:label>
  <dc:source>(competency_question) CQ64</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:duration"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#totalPlaytime">
  <rdfs:comment xml:lang="en">The cumulative number of hours a game has been played.</rdfs:comment>
  <rdfs:label xml:lang="en">total playtime</rdfs:label>
  <dc:source>(competency_question) CQ09</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:integer"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

</rdf:RDF>