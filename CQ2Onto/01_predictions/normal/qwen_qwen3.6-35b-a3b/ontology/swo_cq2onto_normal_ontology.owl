  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#MaintenanceStatus"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasVersionString">
  <rdfs:comment xml:lang="en">The version identifier string (e.g., '1.0.2', 'v2.1').</rdfs:comment>
  <rdfs:label xml:lang="en">has version string</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created hasVersionString property.: Needed to store version identifiers (CQ54).</vaem:rationale>
  <dc:source>(competency_question) CQ54</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareVersion"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasReleaseDate">
  <rdfs:comment xml:lang="en">The date when the software or a specific version was released.</rdfs:comment>
  <rdfs:label xml:lang="en">has release date</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created hasReleaseDate property.: Answers CQ45 and CQ57 about software age and version release dates.</vaem:rationale>
  <dc:source>(competency_question) CQ45, CQ57</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:date"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isFree">
  <rdfs:comment xml:lang="en">Indicates whether the software is free of charge.</rdfs:comment>
  <rdfs:label xml:lang="en">is free</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created isFree property.: Answers CQ68 about cost.</vaem:rationale>
  <dc:source>(competency_question) CQ68</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:boolean"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isOpenSource">
  <rdfs:comment xml:lang="en">Indicates whether the software source code is publicly available.</rdfs:comment>
  <rdfs:label xml:lang="en">is open source</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created isOpenSource property.: Answers CQ60 about open source status.</vaem:rationale>
  <dc:source>(competency_question) CQ60</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:boolean"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isFoss">
  <rdfs:comment xml:lang="en">Indicates whether the software is Free and Open Source Software.</rdfs:comment>
  <rdfs:label xml:lang="en">is FOSS</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created isFoss property.: Answers CQ65 about FOSS status.</vaem:rationale>
  <dc:source>(competency_question) CQ65</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:boolean"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasDevelopmentActivity">
  <rdfs:comment xml:lang="en">Describes how actively the software is being developed or updated.</rdfs:comment>
  <rdfs:label xml:lang="en">has development activity</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created hasDevelopmentActivity property.: Answers CQ46 about development activity level.</vaem:rationale>
  <dc:source>(competency_question) CQ46</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasDocumentationUrl">
  <rdfs:comment xml:lang="en">The URL where software documentation can be found.</rdfs:comment>
  <rdfs:label xml:lang="en">has documentation URL</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created hasDocumentationUrl property.: Answers CQ73 about documentation location.</vaem:rationale>
  <dc:source>(competency_question) CQ73</dc:source>
