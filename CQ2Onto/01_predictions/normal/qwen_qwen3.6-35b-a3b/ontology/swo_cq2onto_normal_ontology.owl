  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasHomepageUrl">
  <rdfs:comment xml:lang="en">The official homepage URL of the software.</rdfs:comment>
  <rdfs:label xml:lang="en">has homepage URL</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created hasHomepageUrl property.: Answers CQ37 about the homepage.</vaem:rationale>
  <dc:source>(competency_question) CQ37</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:anyURI"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasDownloadUrl">
  <rdfs:comment xml:lang="en">The URL from which the software can be downloaded.</rdfs:comment>
  <rdfs:label xml:lang="en">has download URL</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created hasDownloadUrl property.: Answers CQ30 and CQ40 about acquisition URLs.</vaem:rationale>
  <dc:source>(competency_question) CQ30, CQ40</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Software"/>
