<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure">
  <rdfs:comment xml:lang="en">Represents the physical and logical components that make up a water distribution network.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Distribution Infrastructure</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class to model water infrastructure assets.: Addresses CQ01 regarding infrastructure composition.</vaem:rationale>
  <dc:source>(competency_question) CQ01: Which assets compose a water distribution infrastructure?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Asset">
  <rdfs:comment xml:lang="en">A physical component or resource within the water infrastructure.</rdfs:comment>
  <rdfs:label xml:lang="en">Asset</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class to represent infrastructure components.: Addresses CQ01 regarding infrastructure composition.</vaem:rationale>
  <dc:source>(competency_question) CQ01: Which assets compose a water distribution infrastructure?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Sensor">
  <rdfs:comment xml:lang="en">A device used to detect or measure physical properties within the infrastructure.</rdfs:comment>
  <rdfs:label xml:lang="en">Sensor</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class for measurement devices.: Addresses CQ04 regarding sensor types.</vaem:rationale>
  <dc:source>(competency_question) CQ04: Which types of sensors are used in water infrastructures?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Actuator">
  <rdfs:comment xml:lang="en">A device used to control or regulate a physical process within the infrastructure.</rdfs:comment>
  <rdfs:label xml:lang="en">Actuator</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class for control devices.: Addresses CQ05 regarding actuator types.</vaem:rationale>
  <dc:source>(competency_question) CQ05: Which types of actuators are used in water infrastructures?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Device">
  <rdfs:comment xml:lang="en">A general class for manufactured tools or instruments used in the domain.</rdfs:comment>
  <rdfs:label xml:lang="en">Device</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created superclass for hardware instruments.: Addresses CQ06 which defines water meter as a device.</vaem:rationale>
  <dc:source>(competency_question) CQ06: A water meter is a device that measures different aspects of a water infrastructure.</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterMeter">
  <rdfs:comment xml:lang="en">A device that measures water usage and related parameters.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Meter</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class and added subclass axiom.: Addresses CQ06 and subsequent CQs (08-20, 25, 38-43) regarding meter attributes.</vaem:rationale>
  <dc:source>(competency_question) CQ06: A water meter is a device that measures different aspects of a water infrastructure.</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Device'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Water">
  <rdfs:comment xml:lang="en">The chemical substance H2O, central to the domain.</rdfs:comment>
  <rdfs:label xml:lang="en">Water</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class for the measured substance.: Addresses CQ33 and CQ34 regarding water properties.</vaem:rationale>
  <dc:source>(competency_question) CQ33: What are the physical properties of water? CQ34: What are the chemical properties of water?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PhysicalProperty">
  <rdfs:comment xml:lang="en">Attributes describing the physical state of water.</rdfs:comment>
  <rdfs:label xml:lang="en">Physical Property</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class for physical attributes.: Addresses CQ33 regarding physical properties.</vaem:rationale>
  <dc:source>(competency_question) CQ33: What are the physical properties of water?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ChemicalProperty">
  <rdfs:comment xml:lang="en">Attributes describing the chemical composition of water.</rdfs:comment>
  <rdfs:label xml:lang="en">Chemical Property</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class for chemical attributes.: Addresses CQ34 regarding chemical properties.</vaem:rationale>
  <dc:source>(competency_question) CQ34: What are the chemical properties of water?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterIndicator">
  <rdfs:comment xml:lang="en">Metrics or indicators used to assess water quality or usage.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Indicator</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class for water metrics.: Addresses CQ37 regarding water indicators.</vaem:rationale>
  <dc:source>(competency_question) CQ37: Which water indicators are defined for Burgos?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Location">
  <rdfs:comment xml:lang="en">A geographical place or area.</rdfs:comment>
  <rdfs:label xml:lang="en">Location</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class for geographical entities.: Addresses CQ37 regarding location-based indicators.</vaem:rationale>
  <dc:source>(competency_question) CQ37: Which water indicators are defined for Burgos?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#City">
  <rdfs:comment xml:lang="en">An urban administrative division.</rdfs:comment>
  <rdfs:label xml:lang="en">City</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class and added subclass axiom.: Addresses CQ37 and provides hierarchy for Burgos.</vaem:rationale>
  <dc:source>(competency_question) CQ37: Which water indicators are defined for Burgos?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Location'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Burgos">
  <rdfs:comment xml:lang="en">A city in Spain where water indicators are defined.</rdfs:comment>
  <rdfs:label xml:lang="en">Burgos</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class and added subclass axiom.: Addresses CQ37 explicitly mentioning Burgos.</vaem:rationale>
  <dc:source>(competency_question) CQ37: Which water indicators are defined for Burgos?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#City'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Tariff">
  <rdfs:comment xml:lang="en">A pricing scheme for water usage.</rdfs:comment>
  <rdfs:label xml:lang="en">Tariff</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class for pricing periods.: Addresses CQ38, CQ39, CQ40 regarding tariff attributes.</vaem:rationale>
  <dc:source>(competency_question) CQ38: What is the start date and time of the tariff in use in the water meter? CQ39: What is the duration of the current tariff of the water meter? CQ40: What is the tariff period of the water meter?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#BillingPeriod">
  <rdfs:comment xml:lang="en">A specific time interval for billing purposes.</rdfs:comment>
  <rdfs:label xml:lang="en">Billing Period</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class for billing intervals.: Addresses CQ42 and CQ43 regarding billing dates.</vaem:rationale>
  <dc:source>(competency_question) CQ42: What is the billing date of the water meter? CQ43: What is the billing date period of the water meter?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#TemporalSetting">
  <rdfs:comment xml:lang="en">Configuration defining time intervals for measurements or operations.</rdfs:comment>
  <rdfs:label xml:lang="en">Temporal Setting</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class for time configurations.: Addresses CQ25 regarding temporal settings.</vaem:rationale>
  <dc:source>(competency_question) CQ25: Water meters can provide measurements according to different temporal settings.</dc:source>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAsset">
  <rdfs:comment xml:lang="en">Links an infrastructure to its constituent assets.</rdfs:comment>
  <rdfs:label xml:lang="en">has asset</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created object property.: Addresses CQ01.</vaem:rationale>
  <dc:source>(competency_question) CQ01: Which assets compose a water distribution infrastructure?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Asset"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasSensor">
  <rdfs:comment xml:lang="en">Links an infrastructure to its sensors.</rdfs:comment>
