<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Wine">
  <rdfs:comment xml:lang="en">A beverage made from fermented grapes.</rdfs:comment>
  <rdfs:label xml:lang="en">Wine</rdfs:label>
  <dc:source>(competency_question) CQ1, CQ2, CQ6, CQ7, CQnew1</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#RedWine">
  <rdfs:comment xml:lang="en">Wine made from red grapes or with skin contact.</rdfs:comment>
  <rdfs:label xml:lang="en">Red Wine</rdfs:label>
  <dc:source>(competency_question) CQ2</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#WhiteWine"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WhiteWine">
  <rdfs:comment xml:lang="en">Wine made from white grapes or without skin contact.</rdfs:comment>
  <rdfs:label xml:lang="en">White Wine</rdfs:label>
  <dc:source>(competency_question) CQ2</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WineCharacteristic">
  <rdfs:comment xml:lang="en">A general property or trait of a wine (e.g., body, bouquet, acidity).</rdfs:comment>
  <rdfs:label xml:lang="en">Wine Characteristic</rdfs:label>
  <dc:source>(competency_question) CQ1</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Bouquet">
  <rdfs:comment xml:lang="en">The aroma of a wine, often developed through aging.</rdfs:comment>
  <rdfs:label xml:lang="en">Bouquet</rdfs:label>
  <dc:source>(competency_question) CQ6</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#WineCharacteristic"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Body">
  <rdfs:comment xml:lang="en">The feel of the wine in the mouth (light, medium, full).</rdfs:comment>
  <rdfs:label xml:lang="en">Body</rdfs:label>
  <dc:source>(competency_question) CQ6</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#WineCharacteristic"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Vintage">
  <rdfs:comment xml:lang="en">The year in which the grapes for a wine were harvested.</rdfs:comment>
  <rdfs:label xml:lang="en">Vintage</rdfs:label>
  <dc:source>(competency_question) CQ6, CQ7</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Grape">
  <rdfs:comment xml:lang="en">The variety of grape used in the production of wine.</rdfs:comment>
  <rdfs:label xml:lang="en">Grape</rdfs:label>
  <dc:source>(competency_question) CQnew1</dc:source>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasCharacteristic">
  <rdfs:comment xml:lang="en">Links a wine to its characteristics.</rdfs:comment>
  <rdfs:label xml:lang="en">has characteristic</rdfs:label>
  <dc:source>(competency_question) CQ1</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WineCharacteristic"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#madeFrom">
  <rdfs:comment xml:lang="en">Links a wine to the grape variety used to produce it.</rdfs:comment>
  <rdfs:label xml:lang="en">made from</rdfs:label>
  <dc:source>(competency_question) CQnew1</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Grape"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasVintage">
  <rdfs:comment xml:lang="en">Links a wine to its specific vintage year.</rdfs:comment>
  <rdfs:label xml:lang="en">has vintage</rdfs:label>
  <dc:source>(competency_question) CQ6, CQ7</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Vintage"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#vintageCharacteristic">
  <rdfs:comment xml:lang="en">Links a specific vintage of a wine to a characteristic value.</rdfs:comment>
  <rdfs:label xml:lang="en">vintage characteristic</rdfs:label>
  <dc:source>(competency_question) CQ6</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Vintage"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WineCharacteristic"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#vintageYear">
  <rdfs:comment xml:lang="en">The numerical year of the vintage.</rdfs:comment>
  <rdfs:label xml:lang="en">vintage year</rdfs:label>
  <dc:source>(competency_question) CQ6, CQ7</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Vintage"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#vintageQuality">
  <rdfs:comment xml:lang="en">The quality rating of a specific vintage (e.g., 'Good', 'Excellent').</rdfs:comment>
  <rdfs:label xml:lang="en">vintage quality</rdfs:label>
  <dc:source>(competency_question) CQ7</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Vintage"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

</rdf:RDF>