<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Policy">
  <rdfs:comment xml:lang="en">A policy is a collection of rules that define rights, obligations, and prohibitions.</rdfs:comment>
  <rdfs:label xml:lang="en">Policy</rdfs:label>
  <dc:source>(competency_question) New CQ1: Which policy is directly linked to a given asset?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Rule">
  <rdfs:comment xml:lang="en">A rule is a component of a policy that specifies a permission, prohibition, or duty.</rdfs:comment>
  <rdfs:label xml:lang="en">Rule</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Permission">
  <rdfs:comment xml:lang="en">A permission allows an action to be performed.</rdfs:comment>
  <rdfs:label xml:lang="en">Permission</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#TransferRights">
  <rdfs:comment xml:lang="en">A type of permission that allows the transfer of rights.</rdfs:comment>
  <rdfs:label xml:lang="en">Transfer Rights</rdfs:label>
  <dc:source>(competency_question) CQ03: Shall the permissions 'Aggregation' and 'Disaggregation' be of the type Transfer Rights?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Permission'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Prohibition">
  <rdfs:comment xml:lang="en">A prohibition forbids an action from being performed.</rdfs:comment>
  <rdfs:label xml:lang="en">Prohibition</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Duty">
  <rdfs:comment xml:lang="en">A duty specifies an obligation that must be fulfilled.</rdfs:comment>
  <rdfs:label xml:lang="en">Duty</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Asset">
  <rdfs:comment xml:lang="en">The digital object or resource that the policy governs.</rdfs:comment>
  <rdfs:label xml:lang="en">Asset</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Party">
  <rdfs:comment xml:lang="en">An entity (person, organization, or system) involved in the policy.</rdfs:comment>
  <rdfs:label xml:lang="en">Party</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Constraint">
  <rdfs:comment xml:lang="en">A condition that must be met for a rule to apply.</rdfs:comment>
  <rdfs:label xml:lang="en">Constraint</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#LogicalConstraint">
  <rdfs:comment xml:lang="en">A constraint that uses logical operators.</rdfs:comment>
  <rdfs:label xml:lang="en">Logical Constraint</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Constraint'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#AndConstraint">
  <rdfs:comment xml:lang="en">A logical AND constraint.</rdfs:comment>
  <rdfs:label xml:lang="en">AND Constraint</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#LogicalConstraint'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#OrConstraint">
  <rdfs:comment xml:lang="en">A logical OR constraint.</rdfs:comment>
  <rdfs:label xml:lang="en">OR Constraint</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#LogicalConstraint'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#NotConstraint">
  <rdfs:comment xml:lang="en">A logical NOT constraint.</rdfs:comment>
  <rdfs:label xml:lang="en">NOT Constraint</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#LogicalConstraint'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#XorConstraint">
  <rdfs:comment xml:lang="en">A logical XOR constraint.</rdfs:comment>
  <rdfs:label xml:lang="en">XOR Constraint</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#LogicalConstraint'/>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAsset">
  <rdfs:comment xml:lang="en">Links a policy to the asset it governs.</rdfs:comment>
  <rdfs:label xml:lang="en">has asset</rdfs:label>
  <dc:source>(competency_question) New CQ1: Which policy is directly linked to a given asset?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Asset"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasConflictResolutionStrategy">
  <rdfs:comment xml:lang="en">Specifies the strategy used to resolve conflicts within a policy.</rdfs:comment>
  <rdfs:label xml:lang="en">has conflict resolution strategy</rdfs:label>
  <dc:source>(competency_question) New CQ2: What conflict resolution strategy is specified by a policy?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#string"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasRemedy">
  <rdfs:comment xml:lang="en">Links a prohibition to a duty that acts as a remedy for its violation.</rdfs:comment>
  <rdfs:label xml:lang="en">has remedy</rdfs:label>
  <dc:source>(competency_question) New CQ3: What duty is specified as a remedy for the violation of a prohibition?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Prohibition"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Duty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#activates">
  <rdfs:comment xml:lang="en">Links a rule to another rule that is activated upon its failure or completion.</rdfs:comment>
  <rdfs:label xml:lang="en">activates</rdfs:label>
  <dc:source>(competency_question) New CQ4: Which rule is activated upon the failure of another rule?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasConsequence">
  <rdfs:comment xml:lang="en">Links a duty to another duty that is a consequence of the first.</rdfs:comment>
  <rdfs:label xml:lang="en">has consequence</rdfs:label>
  <dc:source>(competency_question) New CQ5: What duty is specified as a consequence of another duty?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Duty"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Duty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasConstraint">
  <rdfs:comment xml:lang="en">Links a rule element to a constraint.</rdfs:comment>
  <rdfs:label xml:lang="en">has constraint</rdfs:label>
  <dc:source>(competency_question) New CQ6: What operator is used in the constraints of a prohibition?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasRole">
  <rdfs:comment xml:lang="en">Assigns a specific role to a party within a rule.</rdfs:comment>
  <rdfs:label xml:lang="en">has role</rdfs:label>
  <dc:source>(competency_question) CQ06: Expressing the various roles of contract parties within the Permission/Duty element.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Party"/>
</owl:ObjectProperty>

</rdf:RDF>