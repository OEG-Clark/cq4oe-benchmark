<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Organism">
  <rdfs:comment xml:lang="en">The base class for all living organisms in this domain.</rdfs:comment>
  <rdfs:label xml:lang="en">Organism</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Animal">
  <rdfs:comment xml:lang="en">An organism that belongs to the animal kingdom.</rdfs:comment>
  <rdfs:label xml:lang="en">Animal</rdfs:label>
  <dc:source>(competency_question) CQ1: Which animal eats which other animal?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Organism'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Plant">
  <rdfs:comment xml:lang="en">An organism that belongs to the plant kingdom.</rdfs:comment>
  <rdfs:label xml:lang="en">Plant</rdfs:label>
  <dc:source>(competency_question) CQ4: Does a lion eat plants or plant parts?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Organism'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlantPart">
  <rdfs:comment xml:lang="en">A specific part of a plant, such as a leaf, stem, or fruit.</rdfs:comment>
  <rdfs:label xml:lang="en">Plant Part</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Herbivore">
  <rdfs:comment xml:lang="en">An animal that primarily eats plants.</rdfs:comment>
  <rdfs:label xml:lang="en">Herbivore</rdfs:label>
  <dc:source>(competency_question) CQ2: Is [this animal] a herbivore?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Animal'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Carnivore">
  <rdfs:comment xml:lang="en">An animal that primarily eats other animals.</rdfs:comment>
  <rdfs:label xml:lang="en">Carnivore</rdfs:label>
  <dc:source>(competency_question) CQ14: Are there animals that are carnivore but still eat some plants or parts of plants?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Animal'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Omnivore">
  <rdfs:comment xml:lang="en">An animal that eats both plants and animals.</rdfs:comment>
  <rdfs:label xml:lang="en">Omnivore</rdfs:label>
  <dc:source>(competency_question) CQ3: Which plant parts does [this omnivorous or herbivorous animal] eat?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Animal'/>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#eatsAnimal">
  <rdfs:comment xml:lang="en">Relates an organism to the animal it consumes.</rdfs:comment>
  <rdfs:label xml:lang="en">eats animal</rdfs:label>
  <dc:source>(competency_question) CQ1: Which animal eats which other animal?
    (competency_question) CQ6: Which plants eat animals?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Organism"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#eatsPlant">
  <rdfs:comment xml:lang="en">Relates an organism to the plant it consumes.</rdfs:comment>
  <rdfs:label xml:lang="en">eats plant</rdfs:label>
  <dc:source>(competency_question) CQ4: Does a lion eat plants or plant parts?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Organism"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Plant"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#eatsPlantPart">
  <rdfs:comment xml:lang="en">Relates an organism to a specific part of a plant it consumes.</rdfs:comment>
  <rdfs:label xml:lang="en">eats plant part</rdfs:label>
  <dc:source>(competency_question) CQ3: Which plant parts does [this omnivorous or herbivorous animal] eat?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Organism"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PlantPart"/>
</owl:ObjectProperty>

</rdf:RDF>