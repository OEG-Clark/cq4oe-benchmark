<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#SoftwareTool">
  <rdfs:comment xml:lang="en">A software application, tool, or system.</rdfs:comment>
  <rdfs:label xml:lang="en">Software Tool</rdfs:label>
  <dc:source>(competency_question) All CQs related to software characteristics</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Algorithm">
  <rdfs:comment xml:lang="en">A named and published mathematical or computational procedure.</rdfs:comment>
  <rdfs:label xml:lang="en">Algorithm</rdfs:label>
  <dc:source>(competency_question) CQ04: Which of the named and published algorithms does this tool use?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#DataFormat">
  <rdfs:comment xml:lang="en">A specific format for data representation, e.g., .cel, .csv, .txt, .gif.</rdfs:comment>
  <rdfs:label xml:lang="en">Data Format</rdfs:label>
  <dc:source>(competency_question) CQ17, CQ19, CQ22</dc:source>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usesAlgorithm">
  <rdfs:comment xml:lang="en">The algorithm used by the software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">uses algorithm</rdfs:label>
  <dc:source>(competency_question) CQ04: Which of the named and published algorithms does this tool use?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAlgorithmModification">
  <rdfs:comment xml:lang="en">Describes modifications made to the base algorithm.</rdfs:comment>
  <rdfs:label xml:lang="en">has algorithm modification</rdfs:label>
  <dc:source>(competency_question) CQ05: Are there any modifications to the algorithm the tool uses?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasInputFormat">
  <rdfs:comment xml:lang="en">The format of the data that can be read by the software.</rdfs:comment>
  <rdfs:label xml:lang="en">has input format</rdfs:label>
  <dc:source>(competency_question) CQ17, CQ19, CQ21</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasOutputFormat">
  <rdfs:comment xml:lang="en">The format of the data that can be exported or produced by the software.</rdfs:comment>
  <rdfs:label xml:lang="en">has output format</rdfs:label>
  <dc:source>(competency_question) CQ17, CQ22, CQ29</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isCompatibleWith">
  <rdfs:comment xml:lang="en">Indicates if software can work with data from another software.</rdfs:comment>
  <rdfs:label xml:lang="en">is compatible with</rdfs:label>
  <dc:source>(competency_question) CQ23: Can software A work with data that are output from software B?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasVersion">
  <rdfs:comment xml:lang="en">The current version of the software.</rdfs:comment>
  <rdfs:label xml:lang="en">has version</rdfs:label>
  <dc:source>(competency_question) CQ54: What is the version of this software?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasLicense">
  <rdfs:comment xml:lang="en">The license governing the use of the software.</rdfs:comment>
  <rdfs:label xml:lang="en">has license</rdfs:label>
  <dc:source>(competency_question) CQ59, CQ60, CQ65</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasImplementationLanguage">
  <rdfs:comment xml:lang="en">The programming language used to implement the software.</rdfs:comment>
  <rdfs:label xml:lang="en">has implementation language</rdfs:label>
  <dc:source>(competency_question) CQ84: In what language was it implemented?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasPlatform">
  <rdfs:comment xml:lang="en">The operating system or platform the software runs on.</rdfs:comment>
  <rdfs:label xml:lang="en">has platform</rdfs:label>
  <dc:source>(competency_question) CQ85: What platform does the software run on?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasHomepage">
  <rdfs:comment xml:lang="en">The URL of the software's homepage.</rdfs:comment>
  <rdfs:label xml:lang="en">has homepage</rdfs:label>
  <dc:source>(competency_question) CQ37: What is the homepage of the software?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasDocumentationURL">
  <rdfs:comment xml:lang="en">The URL where documentation can be found.</rdfs:comment>
  <rdfs:label xml:lang="en">has documentation URL</rdfs:label>
  <dc:source>(competency_question) CQ73: Where is the documentation?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasDeploymentType">
  <rdfs:comment xml:lang="en">The type of software deployment (e.g., API, Desktop, Web Service).</rdfs:comment>
  <rdfs:label xml:lang="en">has deployment type</rdfs:label>
  <dc:source>(competency_question) CQ07, CQ11</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasDevelopmentActivity">
  <rdfs:comment xml:lang="en">Description of how actively the software is being developed.</rdfs:comment>
  <rdfs:label xml:lang="en">has development activity</rdfs:label>
  <dc:source>(competency_question) CQ46: How actively developed is it?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasDeveloper">
  <rdfs:comment xml:lang="en">The person or organization that developed the software.</rdfs:comment>
  <rdfs:label xml:lang="en">has developer</rdfs:label>
  <dc:source>(competency_question) CQ36: Who developed it?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SoftwareTool"/>
</owl:DatatypeProperty>

</rdf:RDF>