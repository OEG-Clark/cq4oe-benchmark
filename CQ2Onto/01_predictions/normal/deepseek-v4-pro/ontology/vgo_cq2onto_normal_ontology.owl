<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Player">
  <rdfs:comment xml:lang="en">A person who plays games.</rdfs:comment>
  <rdfs:label xml:lang="en">Player</rdfs:label>
  <dc:source>(competency_question) CQ01: What is the username of the player? CQ02: Who are the friends of the player? CQ03: Who are the friends that play other games as well with this player? CQ05: What are the achievements of my friends? CQ07: What are the achievements your friend has received? CQ24: What achievements has a player obtained? CQ25: What games has the player played? CQ26: What items does the player have? CQ27: What achievements of a certain type does the player have? CQ29: What is the last game a player has played? CQ35: In how many games does the player have all the achievements? CQ52: What equipment does a player have in a game? CQ55: What are the games where a player can use this item? CQ56: How many players have made in app purchases? CQ57: How many players who have already spent money, spend money again? CQ62: What time are most of the in app purchases done? CQ63: Where do the most paying customers live? CQ64: How long does a player spend in the game before making first IAP? CQ65: Where do the players live who have not made any IAP? CQ66: Where do the players who have done the most IAP live?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Game">
  <rdfs:comment xml:lang="en">A video game.</rdfs:comment>
  <rdfs:label xml:lang="en">Game</rdfs:label>
  <dc:source>(competency_question) CQ03: Who are the friends that play other games as well with this player? CQ08: What achievements does a game have? CQ09: How many hours has this game been played in total? CQ10: What are the types of achievements in this game? CQ11: What are the types of achievements a game can have? CQ12: What is the genre of the game? CQ13: What items exist in a game? CQ15: What is the release date of the game? CQ17: List all games of a certain Genre? CQ22: Who has the best kill count in the game? CQ25: What games has the player played? CQ29: What is the last game a player has played? CQ35: In how many games does the player have all the achievements? CQ52: What equipment does a player have in a game? CQ55: What are the games where a player can use this item? CQ64: How long does a player spend in the game before making first IAP? New CQ1: What playing areas does a game have?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Achievement">
  <rdfs:comment xml:lang="en">An achievement that can be earned in a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Achievement</rdfs:label>
  <dc:source>(competency_question) CQ05: What are the achievements of my friends? CQ07: What are the achievements your friend has received? CQ08: What achievements does a game have? CQ10: What are the types of achievements in this game? CQ11: What are the types of achievements a game can have? CQ24: What achievements has a player obtained? CQ27: What achievements of a certain type does the player have? CQ35: In how many games does the player have all the achievements?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#AchievementType">
  <rdfs:comment xml:lang="en">The type or category of an achievement, such as Bronze, Silver, Gold.</rdfs:comment>
  <rdfs:label xml:lang="en">Achievement Type</rdfs:label>
  <dc:source>(competency_question) CQ10: What are the types of achievements in this game? CQ11: What are the types of achievements a game can have? CQ27: What achievements of a certain type does the player have?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Genre">
  <rdfs:comment xml:lang="en">The genre of a game, e.g., Action, RPG.</rdfs:comment>
  <rdfs:label xml:lang="en">Genre</rdfs:label>
  <dc:source>(competency_question) CQ12: What is the genre of the game? CQ17: List all games of a certain Genre?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Item">
  <rdfs:comment xml:lang="en">An item that exists in a game, such as a weapon or potion.</rdfs:comment>
  <rdfs:label xml:lang="en">Item</rdfs:label>
  <dc:source>(competency_question) CQ13: What items exist in a game? CQ19: What abilities does an item have? CQ26: What items does the player have? CQ52: What equipment does a player have in a game? CQ55: What are the games where a player can use this item?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Ability">
  <rdfs:comment xml:lang="en">An ability that an item can provide, e.g., strength boost, fire resistance.</rdfs:comment>
  <rdfs:label xml:lang="en">Ability</rdfs:label>
  <dc:source>(competency_question) CQ19: What abilities does an item have?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#GameSession">
  <rdfs:comment xml:lang="en">A recording of a player's game session, with start and end times.</rdfs:comment>
  <rdfs:label xml:lang="en">Game Session</rdfs:label>
  <dc:source>(competency_question) CQ29: What is the last game a player has played? CQ64: How long does a player spend in the game before making first IAP?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#InAppPurchase">
  <rdfs:comment xml:lang="en">A purchase made by a player within a game, typically for virtual goods.</rdfs:comment>
  <rdfs:label xml:lang="en">In-App Purchase</rdfs:label>
  <dc:source>(competency_question) CQ56: How many players have made in app purchases? CQ57: How many players who have already spent money, spend money again? CQ62: What time are most of the in app purchases done? CQ63: Where do the most paying customers live? CQ64: How long does a player spend in the game before making first IAP? CQ65: Where do the players live who have not made any IAP? CQ66: Where do the players who have done the most IAP live?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayerGameStat">
  <rdfs:comment xml:lang="en">Statistics for a player in a specific game, such as kills.</rdfs:comment>
  <rdfs:label xml:lang="en">Player Game Stat</rdfs:label>
  <dc:source>(competency_question) CQ22: Who has the best kill count in the game?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayingArea">
  <rdfs:comment xml:lang="en">An area or map within a game where gameplay occurs.</rdfs:comment>
  <rdfs:label xml:lang="en">Playing Area</rdfs:label>
  <dc:source>(competency_question) New CQ1: What playing areas does a game have?</dc:source>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasFriend">
  <rdfs:comment xml:lang="en">Indicates that two players are friends.</rdfs:comment>
  <rdfs:label xml:lang="en">has friend</rdfs:label>
  <dc:source>(competency_question) CQ02: Who are the friends of the player? CQ03: Who are the friends that play other games as well with this player? CQ05: What are the achievements of my friends?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#playsGame">
  <rdfs:comment xml:lang="en">Indicates that a player has played a game.</rdfs:comment>
  <rdfs:label xml:lang="en">plays game</rdfs:label>
  <dc:source>(competency_question) CQ03: Who are the friends that play other games as well with this player? CQ25: What games has the player played?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#earnedAchievement">
  <rdfs:comment xml:lang="en">Indicates that a player has earned an achievement.</rdfs:comment>
  <rdfs:label xml:lang="en">earned achievement</rdfs:label>
  <dc:source>(competency_question) CQ05: What are the achievements of my friends? CQ07: What are the achievements your friend has received? CQ24: What achievements has a player obtained? CQ27: What achievements of a certain type does the player have? CQ35: In how many games does the player have all the achievements?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#includesAchievement">
  <rdfs:comment xml:lang="en">Indicates that a game includes an achievement.</rdfs:comment>
  <rdfs:label xml:lang="en">includes achievement</rdfs:label>
  <dc:source>(competency_question) CQ08: What achievements does a game have? CQ10: What are the types of achievements in this game? CQ11: What are the types of achievements a game can have? CQ35: In how many games does the player have all the achievements?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasType">
  <rdfs:comment xml:lang="en">Specifies the type of an achievement.</rdfs:comment>
  <rdfs:label xml:lang="en">has type</rdfs:label>
  <dc:source>(competency_question) CQ10: What are the types of achievements in this game? CQ11: What are the types of achievements a game can have? CQ27: What achievements of a certain type does the player have?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGenre">
  <rdfs:comment xml:lang="en">Specifies the genre of a game.</rdfs:comment>
  <rdfs:label xml:lang="en">has genre</rdfs:label>
  <dc:source>(competency_question) CQ12: What is the genre of the game? CQ17: List all games of a certain Genre?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Genre"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasItem">
  <rdfs:comment xml:lang="en">Specifies an item that is available in a game.</rdfs:comment>
  <rdfs:label xml:lang="en">has item</rdfs:label>
  <dc:source>(competency_question) CQ13: What items exist in a game?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAbility">
  <rdfs:comment xml:lang="en">Specifies an ability provided by an item.</rdfs:comment>
  <rdfs:label xml:lang="en">has ability</rdfs:label>
  <dc:source>(competency_question) CQ19: What abilities does an item have?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Item"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Ability"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPlayingArea">
  <rdfs:comment xml:lang="en">Specifies a playing area within a game.</rdfs:comment>
  <rdfs:label xml:lang="en">has playing area</rdfs:label>
  <dc:source>(competency_question) New CQ1: What playing areas does a game have?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#sessionForPlayer">
  <rdfs:comment xml:lang="en">The player who played the session.</rdfs:comment>
  <rdfs:label xml:lang="en">session for player</rdfs:label>
  <dc:source>(competency_question) CQ29: What is the last game a player has played? CQ64: How long does a player spend in the game before making first IAP?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#GameSession"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#sessionForGame">
  <rdfs:comment xml:lang="en">The game that was played in the session.</rdfs:comment>
  <rdfs:label xml:lang="en">session for game</rdfs:label>
  <dc:source>(competency_question) CQ29: What is the last game a player has played? CQ64: How long does a player spend in the game before making first IAP?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#GameSession"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#madePurchase">
  <rdfs:comment xml:lang="en">Indicates a purchase made by a player.</rdfs:comment>
  <rdfs:label xml:lang="en">made purchase</rdfs:label>
  <dc:source>(competency_question) CQ56: How many players have made in app purchases? CQ57: How many players who have already spent money, spend money again? CQ62: What time are most of the in app purchases done? CQ63: Where do the most paying customers live? CQ64: How long does a player spend in the game before making first IAP? CQ65: Where do the players live who have not made any IAP? CQ66: Where do the players who have done the most IAP live?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#purchaseByPlayer"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#purchaseByPlayer">
  <rdfs:comment xml:lang="en">The player who made the purchase.</rdfs:comment>
  <rdfs:label xml:lang="en">purchase by player</rdfs:label>
  <dc:source>(competency_question) CQ56, CQ57, CQ62, CQ63, CQ64, CQ65, CQ66</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#madePurchase"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#purchaseInGame">
  <rdfs:comment xml:lang="en">The game in which the purchase was made.</rdfs:comment>
  <rdfs:label xml:lang="en">purchase in game</rdfs:label>
  <dc:source>(competency_question) CQ62, CQ64</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#ownsItem">
  <rdfs:comment xml:lang="en">Indicates that a player owns an item.</rdfs:comment>
  <rdfs:label xml:lang="en">owns item</rdfs:label>
  <dc:source>(competency_question) CQ26: What items does the player have? CQ52: What equipment does a player have in a game? CQ55: What are the games where a player can use this item?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#belongsToGame">
  <rdfs:comment xml:lang="en">The game to which the item belongs.</rdfs:comment>
  <rdfs:label xml:lang="en">belongs to game</rdfs:label>
  <dc:source>(competency_question) CQ52: What equipment does a player have in a game? CQ55: What are the games where a player can use this item?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Item"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasStat">
  <rdfs:comment xml:lang="en">Links a player to their game statistics record.</rdfs:comment>
  <rdfs:label xml:lang="en">has stat</rdfs:label>
  <dc:source>(competency_question) CQ22: Who has the best kill count in the game?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PlayerGameStat"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#statForPlayer"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#statForGame">
  <rdfs:comment xml:lang="en">The game for which the stat record applies.</rdfs:comment>
  <rdfs:label xml:lang="en">stat for game</rdfs:label>
  <dc:source>(competency_question) CQ22</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameStat"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#statForPlayer">
  <rdfs:comment xml:lang="en">The player associated with this stat record.</rdfs:comment>
  <rdfs:label xml:lang="en">stat for player</rdfs:label>
  <dc:source>(competency_question) CQ22</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameStat"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasStat"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#username">
  <rdfs:comment xml:lang="en">The unique username of a player.</rdfs:comment>
  <rdfs:label xml:lang="en">username</rdfs:label>
  <dc:source>(competency_question) CQ01: What is the username of the player?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#releaseDate">
  <rdfs:comment xml:lang="en">The official release date of the game.</rdfs:comment>
  <rdfs:label xml:lang="en">release date</rdfs:label>
  <dc:source>(competency_question) CQ15: What is the release date of the game?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:date"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#totalPlaytimeHours">
  <rdfs:comment xml:lang="en">The total number of hours the game has been played by all players combined.</rdfs:comment>
  <rdfs:label xml:lang="en">total playtime (hours)</rdfs:label>
  <dc:source>(competency_question) CQ09: How many hours has this game been played in total?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:float"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#kills">
  <rdfs:comment xml:lang="en">The number of kills a player has in a particular game.</rdfs:comment>
  <rdfs:label xml:lang="en">kills</rdfs:label>
  <dc:source>(competency_question) CQ22: Who has the best kill count in the game?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameStat"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:integer"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#startTime">
  <rdfs:comment xml:lang="en">The start time of a game session.</rdfs:comment>
  <rdfs:label xml:lang="en">start time</rdfs:label>
  <dc:source>(competency_question) CQ64: How long does a player spend in the game before making first IAP?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#GameSession"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:dateTime"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#endTime">
  <rdfs:comment xml:lang="en">The end time of a game session.</rdfs:comment>
  <rdfs:label xml:lang="en">end time</rdfs:label>
  <dc:source>(competency_question) CQ64: How long does a player spend in the game before making first IAP?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#GameSession"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:dateTime"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#purchaseTime">
  <rdfs:comment xml:lang="en">The timestamp when the purchase was made.</rdfs:comment>
  <rdfs:label xml:lang="en">purchase time</rdfs:label>
  <dc:source>(competency_question) CQ62: What time are most of the in app purchases done? CQ64: How long does a player spend in the game before making first IAP?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:dateTime"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#amount">
  <rdfs:comment xml:lang="en">The monetary amount of the in-app purchase.</rdfs:comment>
  <rdfs:label xml:lang="en">amount</rdfs:label>
  <dc:source>(competency_question) CQ66: Where do the players who have done the most IAP live?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:decimal"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#country">
  <rdfs:comment xml:lang="en">The country where the player resides.</rdfs:comment>
  <rdfs:label xml:lang="en">country</rdfs:label>
  <dc:source>(competency_question) CQ63: Where do the most paying customers live? CQ65: Where do the players live who have not made any IAP? CQ66: Where do the players who have done the most IAP live?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

</rdf:RDF>