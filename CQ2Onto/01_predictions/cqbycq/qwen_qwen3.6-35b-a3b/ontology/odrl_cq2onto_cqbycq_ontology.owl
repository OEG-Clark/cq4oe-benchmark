<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#TransferRights">
  <rdfs:comment xml:lang="en">Rights related to the transfer of data or resources.</rdfs:comment>
  <rdfs:label xml:lang="en">Transfer Rights</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Aggregation">
  <rdfs:comment xml:lang="en">A permission allowing the aggregation of data or resources.</rdfs:comment>
  <rdfs:label xml:lang="en">Aggregation</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#TransferRights'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Disaggregation">
  <rdfs:comment xml:lang="en">A permission allowing the disaggregation of data or resources.</rdfs:comment>
  <rdfs:label xml:lang="en">Disaggregation</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#TransferRights'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ContractParty">
  <rdfs:comment xml:lang="en">An entity or individual that is a party to a contract.</rdfs:comment>
  <rdfs:label xml:lang="en">Contract Party</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Role">
  <rdfs:comment xml:lang="en">A function, position, or capacity assumed by a contract party.</rdfs:comment>
  <rdfs:label xml:lang="en">Role</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Permission">
  <rdfs:comment xml:lang="en">An authorization or right granted to a party within a contract.</rdfs:comment>
  <rdfs:label xml:lang="en">Permission</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Right'/><rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Requirement'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Duty">
  <rdfs:comment xml:lang="en">An obligation or requirement imposed on a party within a contract.</rdfs:comment>
  <rdfs:label xml:lang="en">Duty</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Requirement'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ContractPartyRole">
  <rdfs:comment xml:lang="en">A pivot class representing the assignment of a role to a contract party within a specific permission or duty context.</rdfs:comment>
  <rdfs:label xml:lang="en">Contract Party Role</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Negation">
  <rdfs:comment xml:lang="en">A logical expression indicating the negation of a permission or duty.</rdfs:comment>
  <rdfs:label xml:lang="en">Negation</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Right">
  <rdfs:comment xml:lang="en">A legal entitlement or claim held by a contract party.</rdfs:comment>
  <rdfs:label xml:lang="en">Right</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ContractPartyRight">
  <rdfs:comment xml:lang="en">A pivot class representing the assignment of a right to a contract party.</rdfs:comment>
  <rdfs:label xml:lang="en">Contract Party Right</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ContractPartyDuty">
  <rdfs:comment xml:lang="en">A pivot class representing the assignment of a duty to a contract party.</rdfs:comment>
  <rdfs:label xml:lang="en">Contract Party Duty</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Constraint">
  <rdfs:comment xml:lang="en">A restriction applied to a permission or duty to limit its scope or application.</rdfs:comment>
  <rdfs:label xml:lang="en">Constraint</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#AndConstraint">
  <rdfs:comment xml:lang="en">A logical constraint requiring that all specified conditions or sub-constraints must be satisfied simultaneously.</rdfs:comment>
  <rdfs:label xml:lang="en">And Constraint</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Constraint'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#OrConstraint">
  <rdfs:comment xml:lang="en">A logical constraint requiring that at least one of the specified conditions or sub-constraints must be satisfied.</rdfs:comment>
  <rdfs:label xml:lang="en">Or Constraint</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Constraint'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#XorConstraint">
  <rdfs:comment xml:lang="en">A logical constraint requiring that exactly one of the specified conditions or sub-constraints must be satisfied.</rdfs:comment>
  <rdfs:label xml:lang="en">Xor Constraint</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Constraint'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Requirement">
  <rdfs:comment xml:lang="en">A requirement imposed on a contract party, which may be a permission or a duty.</rdfs:comment>
  <rdfs:label xml:lang="en">Requirement</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ExclusivePermission">
  <rdfs:comment xml:lang="en">A permission that is mutually exclusive with other permissions, typically enforced via an XOR constraint.</rdfs:comment>
  <rdfs:label xml:lang="en">Exclusive Permission</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Permission'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Condition">
  <rdfs:comment xml:lang="en">A state of affairs, circumstance, or prerequisite that must be satisfied for a constraint or requirement to apply.</rdfs:comment>
  <rdfs:label xml:lang="en">Condition</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ODRL">
  <rdfs:comment xml:lang="en">Open Digital Rights Language, a framework for expressing policies and rights.</rdfs:comment>
  <rdfs:label xml:lang="en">ODRL</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Container">
  <rdfs:comment xml:lang="en">A grouping mechanism for policy elements in ODRL.</rdfs:comment>
  <rdfs:label xml:lang="en">Container</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Sequencing">
  <rdfs:comment xml:lang="en">A constraint specifying the order in which permissions or duties must be executed.</rdfs:comment>
  <rdfs:label xml:lang="en">Sequencing</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Constraint'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Asset">
  <rdfs:comment xml:lang="en">A resource, item, or data object that is subject to policy control or governance.</rdfs:comment>
  <rdfs:label xml:lang="en">Asset</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Policy">
  <rdfs:comment xml:lang="en">A set of rules, permissions, or restrictions that govern the use or access of an asset.</rdfs:comment>
  <rdfs:label xml:lang="en">Policy</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ConflictResolutionStrategy">
  <rdfs:comment xml:lang="en">A strategy used to resolve conflicts between permissions and duties within a policy.</rdfs:comment>
  <rdfs:label xml:lang="en">Conflict Resolution Strategy</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Prohibition">
  <rdfs:comment xml:lang="en">A duty that forbids a specific action or behavior.</rdfs:comment>
  <rdfs:label xml:lang="en">Prohibition</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Duty'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Remedy">
  <rdfs:comment xml:lang="en">A duty imposed as a consequence for violating a prohibition.</rdfs:comment>
  <rdfs:label xml:lang="en">Remedy</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Duty'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Rule">
  <rdfs:comment xml:lang="en">A rule governing actions or conditions within a policy.</rdfs:comment>
  <rdfs:label xml:lang="en">Rule</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Requirement'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Operator">
  <rdfs:comment xml:lang="en">A logical or structural operator applied to constraints.</rdfs:comment>
  <rdfs:label xml:lang="en">Operator</rdfs:label>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasContractParty">
  <rdfs:comment xml:lang="en">Links a contract party role assignment to the specific contract party.</rdfs:comment>
  <rdfs:label xml:lang="en">has Contract Party</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ContractPartyRole"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#ContractParty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasRole">
  <rdfs:comment xml:lang="en">Links a contract party role assignment to the specific role.</rdfs:comment>
  <rdfs:label xml:lang="en">has Role</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ContractPartyRole"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Role"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPermission">
  <rdfs:comment xml:lang="en">Links a contract party role assignment to the specific permission.</rdfs:comment>
  <rdfs:label xml:lang="en">has Permission</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ContractPartyRole"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Permission"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasDuty">
  <rdfs:comment xml:lang="en">Links a contract party role assignment to the specific duty.</rdfs:comment>
  <rdfs:label xml:lang="en">has Duty</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ContractPartyRole"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Duty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasNegation">
  <rdfs:comment xml:lang="en">Links a permission or duty to its negation expression.</rdfs:comment>
  <rdfs:label xml:lang="en">has Negation</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Permission, Duty"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Negation"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasRight">
  <rdfs:comment xml:lang="en">Links a contract party right assignment to the specific right.</rdfs:comment>
  <rdfs:label xml:lang="en">has Right</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ContractPartyRight"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Right"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasContractPartyRight">
  <rdfs:comment xml:lang="en">Links a contract party right assignment to the specific contract party.</rdfs:comment>
  <rdfs:label xml:lang="en">has Contract Party Right</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ContractPartyRight"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#ContractParty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasContractPartyDuty">
  <rdfs:comment xml:lang="en">Links a contract party duty assignment to the specific contract party.</rdfs:comment>
  <rdfs:label xml:lang="en">has Contract Party Duty</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ContractPartyDuty"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#ContractParty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasDutyAssignment">
  <rdfs:comment xml:lang="en">Links a contract party duty assignment to the specific duty.</rdfs:comment>
  <rdfs:label xml:lang="en">has Duty Assignment</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ContractPartyDuty"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Duty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasConstraint">
  <rdfs:comment xml:lang="en">Links a permission to a constraint that restricts its application.</rdfs:comment>
  <rdfs:label xml:lang="en">has Constraint</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Permission"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasNestedConstraint">
  <rdfs:comment xml:lang="en">Links a constraint to another constraint, allowing for nested constraint structures.</rdfs:comment>
  <rdfs:label xml:lang="en">has Nested Constraint</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasConstraintOnRequirement">
  <rdfs:comment xml:lang="en">Links a requirement to a constraint that restricts its application.</rdfs:comment>
  <rdfs:label xml:lang="en">has Constraint On Requirement</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Requirement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasCondition">
  <rdfs:comment xml:lang="en">Links a constraint to a condition that must be satisfied.</rdfs:comment>
  <rdfs:label xml:lang="en">has Condition</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Condition"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPolicy">
  <rdfs:comment xml:lang="en">Links an asset to the policy that governs or applies to it.</rdfs:comment>
  <rdfs:label xml:lang="en">has Policy</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Asset"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAsset">
  <rdfs:comment xml:lang="en">Links a policy to the asset it governs or applies to.</rdfs:comment>
  <rdfs:label xml:lang="en">has Asset</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Asset"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasConflictResolutionStrategy">
  <rdfs:comment xml:lang="en">Links a policy to the conflict resolution strategy it specifies.</rdfs:comment>
  <rdfs:label xml:lang="en">has Conflict Resolution Strategy</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#ConflictResolutionStrategy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasRemedy">
  <rdfs:comment xml:lang="en">Links a prohibition to the duty that serves as a remedy for its violation.</rdfs:comment>
  <rdfs:label xml:lang="en">has Remedy</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Prohibition"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Remedy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#activatedUponFailureOf">
  <rdfs:comment xml:lang="en">Links a rule to the rule whose failure triggers its activation.</rdfs:comment>
  <rdfs:label xml:lang="en">Activated Upon Failure Of</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasConsequenceDuty">
  <rdfs:comment xml:lang="en">Links a duty to another duty that is specified as a consequence of it.</rdfs:comment>
  <rdfs:label xml:lang="en">Has Consequence Duty</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Duty"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Duty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasOperator">
  <rdfs:comment xml:lang="en">Links a constraint to the operator that defines its logical or structural behavior.</rdfs:comment>
  <rdfs:label xml:lang="en">has Operator</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Operator"/>
</owl:ObjectProperty>

</rdf:RDF>