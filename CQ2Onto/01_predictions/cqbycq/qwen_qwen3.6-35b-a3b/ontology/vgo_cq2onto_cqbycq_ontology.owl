<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Player">
  <rdfs:comment xml:lang="en">A person who participates in a game or sport.</rdfs:comment>
  <rdfs:label xml:lang="en">Player</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Game">
  <rdfs:comment xml:lang="en">A structured activity or sport played by players.</rdfs:comment>
  <rdfs:label xml:lang="en">Game</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Achievement">
  <rdfs:comment xml:lang="en">An accomplishment or milestone reached by a player.</rdfs:comment>
  <rdfs:label xml:lang="en">Achievement</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#GamePlaySession">
  <rdfs:comment xml:lang="en">A record capturing a player's participation in a game along with the duration played.</rdfs:comment>
  <rdfs:label xml:lang="en">Game Play Session</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#AchievementType">
  <rdfs:comment xml:lang="en">A category or classification for an achievement.</rdfs:comment>
  <rdfs:label xml:lang="en">Achievement Type</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Genre">
  <rdfs:comment xml:lang="en">A category or style of game.</rdfs:comment>
  <rdfs:label xml:lang="en">Genre</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Item">
  <rdfs:comment xml:lang="en">An item or object that exists within a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Item</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Ability">
  <rdfs:comment xml:lang="en">A capability or skill that an item can provide or perform.</rdfs:comment>
  <rdfs:label xml:lang="en">Ability</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#KillCountRecord">
  <rdfs:comment xml:lang="en">A pivot class representing a specific kill count achieved by a player in a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Kill Count Record</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayerGameAchievement">
  <rdfs:comment xml:lang="en">A pivot class representing a player's completion of all achievements in a specific game.</rdfs:comment>
  <rdfs:label xml:lang="en">Player Game Achievement</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayerGameItem">
  <rdfs:comment xml:lang="en">A pivot class representing an item owned by a player in a specific game.</rdfs:comment>
  <rdfs:label xml:lang="en">Player Game Item</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayerItemUsage">
  <rdfs:comment xml:lang="en">A pivot class representing a player's usage of an item in a specific game.</rdfs:comment>
  <rdfs:label xml:lang="en">Player Item Usage</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#InAppPurchase">
  <rdfs:comment xml:lang="en">A pivot class representing a player's purchase of an item within a game.</rdfs:comment>
  <rdfs:label xml:lang="en">In App Purchase</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Location">
  <rdfs:comment xml:lang="en">A geographical location where a player resides.</rdfs:comment>
  <rdfs:label xml:lang="en">Location</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayerIAPEvent">
  <rdfs:comment xml:lang="en">A pivot class representing a player's game play session and in-app purchase event.</rdfs:comment>
  <rdfs:label xml:lang="en">Player IAP Event</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayingArea">
  <rdfs:comment xml:lang="en">A designated area within a game where players can move or interact.</rdfs:comment>
  <rdfs:label xml:lang="en">Playing Area</rdfs:label>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasFriend">
  <rdfs:comment xml:lang="en">A friend relationship between players.</rdfs:comment>
  <rdfs:label xml:lang="en">has friend</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#playsGame">
  <rdfs:comment xml:lang="en">Indicates that a player participates in a specific game.</rdfs:comment>
  <rdfs:label xml:lang="en">plays game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAchievement">
  <rdfs:comment xml:lang="en">Indicates that a player has achieved a specific milestone or accomplishment.</rdfs:comment>
  <rdfs:label xml:lang="en">has achievement</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#gameHasAchievement">
  <rdfs:comment xml:lang="en">Indicates that a game has a specific achievement.</rdfs:comment>
  <rdfs:label xml:lang="en">game has achievement</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasSession">
  <rdfs:comment xml:lang="en">Links a player to a specific game play session.</rdfs:comment>
  <rdfs:label xml:lang="en">has session</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#GamePlaySession"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#sessionForGame">
  <rdfs:comment xml:lang="en">Links a game play session to the game that was played.</rdfs:comment>
  <rdfs:label xml:lang="en">session for game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#GamePlaySession"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasType">
  <rdfs:comment xml:lang="en">Links an achievement to its type or category.</rdfs:comment>
  <rdfs:label xml:lang="en">has type</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGenre">
  <rdfs:comment xml:lang="en">Indicates the genre of a game.</rdfs:comment>
  <rdfs:label xml:lang="en">has genre</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Genre"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasItem">
  <rdfs:comment xml:lang="en">Indicates that a game contains a specific item.</rdfs:comment>
  <rdfs:label xml:lang="en">has item</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAbility">
  <rdfs:comment xml:lang="en">Indicates that an item possesses a specific ability.</rdfs:comment>
  <rdfs:label xml:lang="en">has ability</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Item"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Ability"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#recordsPlayer">
  <rdfs:comment xml:lang="en">Links a kill count record to the player who achieved it.</rdfs:comment>
  <rdfs:label xml:lang="en">records player</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#KillCountRecord"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#recordsGame">
  <rdfs:comment xml:lang="en">Links a kill count record to the game in which the kills occurred.</rdfs:comment>
  <rdfs:label xml:lang="en">records game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#KillCountRecord"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#ownsItem">
  <rdfs:comment xml:lang="en">Indicates that a player possesses a specific item.</rdfs:comment>
  <rdfs:label xml:lang="en">owns item</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPlayer">
  <rdfs:comment xml:lang="en">Links a player game achievement record to the player.</rdfs:comment>
  <rdfs:label xml:lang="en">has player</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameAchievement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGame">
  <rdfs:comment xml:lang="en">Links a player game achievement record to the game.</rdfs:comment>
  <rdfs:label xml:lang="en">has game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameAchievement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#linksPlayer">
  <rdfs:comment xml:lang="en">Links a player game item record to the player.</rdfs:comment>
  <rdfs:label xml:lang="en">links player</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameItem"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#linksGame">
  <rdfs:comment xml:lang="en">Links a player game item record to the game.</rdfs:comment>
  <rdfs:label xml:lang="en">links game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameItem"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#linksItem">
  <rdfs:comment xml:lang="en">Links a player game item record to the item.</rdfs:comment>
  <rdfs:label xml:lang="en">links item</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameItem"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usesPlayer">
  <rdfs:comment xml:lang="en">Links a player item usage record to the player.</rdfs:comment>
  <rdfs:label xml:lang="en">uses player</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerItemUsage"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usesItem">
  <rdfs:comment xml:lang="en">Links a player item usage record to the item.</rdfs:comment>
  <rdfs:label xml:lang="en">uses item</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerItemUsage"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usesGame">
  <rdfs:comment xml:lang="en">Links a player item usage record to the game.</rdfs:comment>
  <rdfs:label xml:lang="en">uses game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerItemUsage"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#purchasesPlayer">
  <rdfs:comment xml:lang="en">Links an in-app purchase record to the player who made the purchase.</rdfs:comment>
  <rdfs:label xml:lang="en">purchases player</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#purchasesItem">
  <rdfs:comment xml:lang="en">Links an in-app purchase record to the item that was purchased.</rdfs:comment>
  <rdfs:label xml:lang="en">purchases item</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#purchasesGame">
  <rdfs:comment xml:lang="en">Links an in-app purchase record to the game in which the purchase occurred.</rdfs:comment>
  <rdfs:label xml:lang="en">purchases game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPurchase">
  <rdfs:comment xml:lang="en">Links a player to an in-app purchase they made.</rdfs:comment>
  <rdfs:label xml:lang="en">has purchase</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#purchasesPlayer'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasLocation">
  <rdfs:comment xml:lang="en">Links a player to the location where they live.</rdfs:comment>
  <rdfs:label xml:lang="en">has location</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Location"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#linksPlayerToIAP">
  <rdfs:comment xml:lang="en">Links a player IAP event to the player.</rdfs:comment>
  <rdfs:label xml:lang="en">links player to IAP</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerIAPEvent"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#linksSessionToIAP">
  <rdfs:comment xml:lang="en">Links a player IAP event to the game play session.</rdfs:comment>
  <rdfs:label xml:lang="en">links session to IAP</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerIAPEvent"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#GamePlaySession"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#linksPurchaseToIAP">
  <rdfs:comment xml:lang="en">Links a player IAP event to the in-app purchase.</rdfs:comment>
  <rdfs:label xml:lang="en">links purchase to IAP</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerIAPEvent"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPlayingArea">
  <rdfs:comment xml:lang="en">Indicates that a game contains a specific playing area.</rdfs:comment>
  <rdfs:label xml:lang="en">has playing area</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasUsername">
  <rdfs:comment xml:lang="en">The username associated with a player.</rdfs:comment>
  <rdfs:label xml:lang="en">has username</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasPlaytimeHours">
  <rdfs:comment xml:lang="en">The duration of the play session in hours.</rdfs:comment>
  <rdfs:label xml:lang="en">has playtime hours</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#GamePlaySession"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasReleaseDate">
  <rdfs:comment xml:lang="en">The date when the game was released.</rdfs:comment>
  <rdfs:label xml:lang="en">has release date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#date"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasKillCount">
  <rdfs:comment xml:lang="en">The number of kills achieved by a player in a specific game.</rdfs:comment>
  <rdfs:label xml:lang="en">has kill count</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#KillCountRecord"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasSessionDate">
  <rdfs:comment xml:lang="en">The date and time when the game play session occurred.</rdfs:comment>
  <rdfs:label xml:lang="en">has session date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#GamePlaySession"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasAllAchievements">
  <rdfs:comment xml:lang="en">Indicates whether the player has achieved all achievements for the associated game.</rdfs:comment>
  <rdfs:label xml:lang="en">has all achievements</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameAchievement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasPurchaseTime">
  <rdfs:comment xml:lang="en">The date and time when the in-app purchase was made.</rdfs:comment>
  <rdfs:label xml:lang="en">has purchase time</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasPlaytimeBeforePurchase">
  <rdfs:comment xml:lang="en">The cumulative playtime in hours before the in-app purchase.</rdfs:comment>
  <rdfs:label xml:lang="en">has playtime before purchase</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerIAPEvent"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#decimal"/>
</owl:DatatypeProperty>

</rdf:RDF>