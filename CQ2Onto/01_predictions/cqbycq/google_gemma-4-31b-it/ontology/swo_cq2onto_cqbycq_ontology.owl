  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasLanguageName">
  <rdfs:comment xml:lang="en">The name of the programming language (e.g., 'Java', 'Python').</rdfs:comment>
