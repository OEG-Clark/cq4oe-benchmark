</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasPermissiveness">
  <rdfs:comment xml:lang="en">The degree of permissiveness of a license (e.g., 'High' for MIT, 'Low' for Proprietary).</rdfs:comment>
  <rdfs:label xml:lang="en">permissiveness</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#LicenseType"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isOpenSource">
