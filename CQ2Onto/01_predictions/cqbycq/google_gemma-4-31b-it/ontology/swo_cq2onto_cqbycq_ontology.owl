  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasDevelopmentModelName">
  <rdfs:comment xml:lang="en">The name of the development model (e.g., 'Community-driven').</rdfs:comment>
  <rdfs:label xml:lang="en">development model name</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#DevelopmentModel"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
