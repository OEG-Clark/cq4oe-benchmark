  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#VersionFeatureUsage"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasVersionReleaseDate">
  <rdfs:comment xml:lang="en">The specific date when a particular version of the tool was released.</rdfs:comment>
