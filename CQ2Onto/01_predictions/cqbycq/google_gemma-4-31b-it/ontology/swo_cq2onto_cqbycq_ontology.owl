  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasFeatureStatus">
  <rdfs:comment xml:lang="en">The status of a feature in a specific version (e.g., 'New', 'Improved', 'Deprecated').</rdfs:comment>
