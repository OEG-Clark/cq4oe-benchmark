<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Organism">
  <rdfs:comment xml:lang="en">A living system such as an animal, plant, fungus, or microorganism.</rdfs:comment>
  <rdfs:label xml:lang="en">Organism</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Animal">
  <rdfs:comment xml:lang="en">A living organism that feeds on organic matter.</rdfs:comment>
  <rdfs:label xml:lang="en">Animal</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Organism'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Plant">
  <rdfs:comment xml:lang="en">A living organism typically growing in a permanent site, absorbing water and inorganic substances through its roots.</rdfs:comment>
  <rdfs:label xml:lang="en">Plant</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Organism'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Herbivore">
  <rdfs:comment xml:lang="en">An animal that feeds exclusively or mainly on plants.</rdfs:comment>
  <rdfs:label xml:lang="en">Herbivore</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Animal'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Omnivore">
  <rdfs:comment xml:lang="en">An animal that eats both plants and animals.</rdfs:comment>
  <rdfs:label xml:lang="en">Omnivore</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Animal'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Carnivore">
  <rdfs:comment xml:lang="en">An animal that feeds exclusively or mainly on other animals.</rdfs:comment>
  <rdfs:label xml:lang="en">Carnivore</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Animal'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Lion">
  <rdfs:comment xml:lang="en">A large cat species known for being an apex predator.</rdfs:comment>
  <rdfs:label xml:lang="en">Lion</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Carnivore'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlantPart">
  <rdfs:comment xml:lang="en">A specific anatomical part of a plant, such as a leaf, root, or fruit.</rdfs:comment>
  <rdfs:label xml:lang="en">Plant Part</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#FeedingEvent">
  <rdfs:comment xml:lang="en">A pivot class representing the act of an animal consuming a specific part of a plant.</rdfs:comment>
  <rdfs:label xml:lang="en">Feeding Event</rdfs:label>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#eats">
  <rdfs:comment xml:lang="en">A relationship indicating that one organism consumes another organism as food.</rdfs:comment>
  <rdfs:label xml:lang="en">eats</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Organism"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Organism"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasConsumer">
  <rdfs:comment xml:lang="en">Links a feeding event to the animal that is eating.</rdfs:comment>
  <rdfs:label xml:lang="en">has consumer</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#FeedingEvent"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPlantSource">
  <rdfs:comment xml:lang="en">Links a feeding event to the plant being consumed.</rdfs:comment>
  <rdfs:label xml:lang="en">has plant source</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#FeedingEvent"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Plant"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasConsumedPart">
  <rdfs:comment xml:lang="en">Links a feeding event to the specific part of the plant being eaten.</rdfs:comment>
  <rdfs:label xml:lang="en">has consumed part</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#FeedingEvent"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PlantPart"/>
</owl:ObjectProperty>

</rdf:RDF>