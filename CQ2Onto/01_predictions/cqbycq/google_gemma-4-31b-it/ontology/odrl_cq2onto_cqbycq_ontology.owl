<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#TransferRight">
  <rdfs:comment xml:lang="en">A right that allows the transfer or modification of data structures.</rdfs:comment>
  <rdfs:label xml:lang="en">Transfer Right</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Aggregation">
  <rdfs:comment xml:lang="en">A specific type of transfer right that allows combining data elements into a whole.</rdfs:comment>
  <rdfs:label xml:lang="en">Aggregation</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#TransferRight'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Disaggregation">
  <rdfs:comment xml:lang="en">A specific type of transfer right that allows breaking down combined data into individual elements.</rdfs:comment>
  <rdfs:label xml:lang="en">Disaggregation</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#TransferRight'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ContractParty">
  <rdfs:comment xml:lang="en">An entity or person that is a party to a contract.</rdfs:comment>
  <rdfs:label xml:lang="en">Contract Party</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Requirement">
  <rdfs:comment xml:lang="en">A specification of a need or a condition that must be fulfilled within a contract.</rdfs:comment>
  <rdfs:label xml:lang="en">Requirement</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PermissionDuty">
  <rdfs:comment xml:lang="en">An element of a contract that defines either a permission (what a party may do) or a duty (what a party must do).</rdfs:comment>
  <rdfs:label xml:lang="en">Permission/Duty</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Requirement'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ExclusivePermission">
  <rdfs:comment xml:lang="en">A permission that is granted exclusively to a specific party, preventing others from exercising the same right.</rdfs:comment>
  <rdfs:label xml:lang="en">Exclusive Permission</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#PermissionDuty'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Prohibition">
  <rdfs:comment xml:lang="en">A requirement that forbids a party from performing a specific action.</rdfs:comment>
  <rdfs:label xml:lang="en">Prohibition</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#PermissionDuty'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PermissionDutyAssignment">
  <rdfs:comment xml:lang="en">A pivot class that assigns a specific role to a contract party within a Permission or Duty element.</rdfs:comment>
  <rdfs:label xml:lang="en">Permission Duty Assignment</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Negation">
  <rdfs:comment xml:lang="en">A logical operator used to represent the 'NOT' expression, indicating that the associated permission or duty is negated or prohibited.</rdfs:comment>
  <rdfs:label xml:lang="en">Negation</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Constraint">
  <rdfs:comment xml:lang="en">A condition or restriction that must be met for a permission or duty to be valid.</rdfs:comment>
  <rdfs:label xml:lang="en">Constraint</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Condition">
  <rdfs:comment xml:lang="en">A specific type of constraint that acts as a prerequisite or a triggering event for a requirement to become active.</rdfs:comment>
  <rdfs:label xml:lang="en">Condition</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Constraint'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#LogicalConstraint">
  <rdfs:comment xml:lang="en">A constraint that combines multiple other constraints using a logical operator (AND, OR, XOR).</rdfs:comment>
  <rdfs:label xml:lang="en">Logical Constraint</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Constraint'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#LogicalConstraintOperand">
  <rdfs:comment xml:lang="en">A pivot class that links a logical constraint to one of its constituent constraints.</rdfs:comment>
  <rdfs:label xml:lang="en">Logical Constraint Operand</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Container">
  <rdfs:comment xml:lang="en">A logical or physical grouping of assets, rights, or requirements, used to apply policies to a set of items collectively.</rdfs:comment>
  <rdfs:label xml:lang="en">Container</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ContainerMembership">
  <rdfs:comment xml:lang="en">A pivot class representing the relationship between a container and the item it contains, allowing for membership-specific properties.</rdfs:comment>
  <rdfs:label xml:lang="en">Container Membership</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Sequence">
  <rdfs:comment xml:lang="en">A definition of the ordered execution or fulfillment of a set of requirements.</rdfs:comment>
  <rdfs:label xml:lang="en">Sequence</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#SequenceStep">
  <rdfs:comment xml:lang="en">A pivot class that links a specific requirement to a position within a sequence.</rdfs:comment>
  <rdfs:label xml:lang="en">Sequence Step</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Policy">
  <rdfs:comment xml:lang="en">A set of rules or requirements that govern the management and usage of assets.</rdfs:comment>
  <rdfs:label xml:lang="en">Policy</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Asset">
  <rdfs:comment xml:lang="en">A resource or entity that is subject to policies and requirements.</rdfs:comment>
  <rdfs:label xml:lang="en">Asset</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ConflictResolutionStrategy">
  <rdfs:comment xml:lang="en">A defined method or rule used to resolve contradictions or conflicts between different requirements or policies.</rdfs:comment>
  <rdfs:label xml:lang="en">Conflict Resolution Strategy</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Remedy">
  <rdfs:comment xml:lang="en">A requirement, typically a duty, that must be performed as a consequence of the violation of another requirement.</rdfs:comment>
  <rdfs:label xml:lang="en">Remedy</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#PermissionDuty'/>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAssignment">
  <rdfs:comment xml:lang="en">Links a Permission/Duty element to its party assignments.</rdfs:comment>
  <rdfs:label xml:lang="en">has Assignment</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PermissionDuty"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PermissionDutyAssignment"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#assignedParty">
  <rdfs:comment xml:lang="en">Links an assignment to the specific contract party fulfilling the role.</rdfs:comment>
  <rdfs:label xml:lang="en">assigned Party</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PermissionDutyAssignment"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#ContractParty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#negates">
  <rdfs:comment xml:lang="en">Links a Negation entity to the PermissionDuty or expression it negates.</rdfs:comment>
  <rdfs:label xml:lang="en">negates</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Negation"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PermissionDuty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasConstraint">
  <rdfs:comment xml:lang="en">Links a PermissionDuty or another Constraint to a Constraint, allowing for nested constraints.</rdfs:comment>
  <rdfs:label xml:lang="en">has Constraint</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isConstrainedBy">
  <rdfs:comment xml:lang="en">Links a Requirement (including PermissionDuty) to the constraints that restrict it.</rdfs:comment>
  <rdfs:label xml:lang="en">is Constrained By</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Requirement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasOperand">
  <rdfs:comment xml:lang="en">Links a logical constraint to its operands.</rdfs:comment>
  <rdfs:label xml:lang="en">has Operand</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#LogicalConstraint"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#LogicalConstraintOperand"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#operandConstraint">
  <rdfs:comment xml:lang="en">Links a logical operand to the actual constraint it refers to.</rdfs:comment>
  <rdfs:label xml:lang="en">operand Constraint</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#LogicalConstraintOperand"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasMembership">
  <rdfs:comment xml:lang="en">Links a container to its membership records.</rdfs:comment>
  <rdfs:label xml:lang="en">has Membership</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Container"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#ContainerMembership"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#containedItem">
  <rdfs:comment xml:lang="en">Links a membership record to the item (e.g., a Requirement or another Container) being contained.</rdfs:comment>
  <rdfs:label xml:lang="en">contained Item</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ContainerMembership"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Requirement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasSequenceStep">
  <rdfs:comment xml:lang="en">Links a sequence to its individual steps.</rdfs:comment>
  <rdfs:label xml:lang="en">has Sequence Step</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Sequence"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SequenceStep"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#sequencedRequirement">
  <rdfs:comment xml:lang="en">Links a sequence step to the requirement it refers to.</rdfs:comment>
  <rdfs:label xml:lang="en">sequenced Requirement</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SequenceStep"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Requirement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isLinkedToPolicy">
  <rdfs:comment xml:lang="en">Links an asset to the policy that governs it.</rdfs:comment>
  <rdfs:label xml:lang="en">is Linked To Policy</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Asset"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasConflictResolutionStrategy">
  <rdfs:comment xml:lang="en">Links a policy to the strategy used to resolve conflicts within its requirements.</rdfs:comment>
  <rdfs:label xml:lang="en">has Conflict Resolution Strategy</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#ConflictResolutionStrategy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isRemedyFor">
  <rdfs:comment xml:lang="en">Links a remedy (duty) to the requirement (such as a prohibition) whose violation triggers it.</rdfs:comment>
  <rdfs:label xml:lang="en">is Remedy For</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Remedy"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Requirement"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasRole">
  <rdfs:comment xml:lang="en">The specific role the party plays in the permission or duty (e.g., Obligor, Obligee, Grantor).</rdfs:comment>
  <rdfs:label xml:lang="en">has Role</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PermissionDutyAssignment"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#logicalOperator">
  <rdfs:comment xml:lang="en">The logical operator used to combine constraints (e.g., 'AND', 'OR', 'XOR').</rdfs:comment>
  <rdfs:label xml:lang="en">logical Operator</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#LogicalConstraint"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isExclusive">
  <rdfs:comment xml:lang="en">Indicates whether the permission or duty is exclusive to the assigned party.</rdfs:comment>
  <rdfs:label xml:lang="en">is Exclusive</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PermissionDuty"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#stepOrder">
  <rdfs:comment xml:lang="en">The numerical position of the requirement within the sequence.</rdfs:comment>
  <rdfs:label xml:lang="en">step Order</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SequenceStep"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

</rdf:RDF>