<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Player">
  <rdfs:comment xml:lang="en">A person who participates in the game.</rdfs:comment>
  <rdfs:label xml:lang="en">Player</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Game">
  <rdfs:comment xml:lang="en">A specific game that can be played by players.</rdfs:comment>
  <rdfs:label xml:lang="en">Game</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Achievement">
  <rdfs:comment xml:lang="en">A reward or milestone earned by a player in a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Achievement</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#GamePlayRecord">
  <rdfs:comment xml:lang="en">A record of a player's activity in a specific game, used to track metrics like time played.</rdfs:comment>
  <rdfs:label xml:lang="en">Game Play Record</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#AchievementType">
  <rdfs:comment xml:lang="en">A category or classification of achievements, such as Combat, Exploration, or Story.</rdfs:comment>
  <rdfs:label xml:lang="en">Achievement Type</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Genre">
  <rdfs:comment xml:lang="en">A category of games characterized by similar gameplay and themes.</rdfs:comment>
  <rdfs:label xml:lang="en">Genre</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#GameItem">
  <rdfs:comment xml:lang="en">An object or item that exists within the world of a game, such as a weapon, tool, or consumable.</rdfs:comment>
  <rdfs:label xml:lang="en">Game Item</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Ability">
  <rdfs:comment xml:lang="en">A specific power, effect, or capability associated with a game item.</rdfs:comment>
  <rdfs:label xml:lang="en">Ability</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayerGameInventory">
  <rdfs:comment xml:lang="en">A pivot class representing the possession of a specific item by a player within a specific game.</rdfs:comment>
  <rdfs:label xml:lang="en">Player Game Inventory</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#InAppPurchase">
  <rdfs:comment xml:lang="en">A record of a financial transaction made by a player to acquire items or services within a game.</rdfs:comment>
  <rdfs:label xml:lang="en">In-App Purchase</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Location">
  <rdfs:comment xml:lang="en">A geographical place where a player resides, such as a city or country.</rdfs:comment>
  <rdfs:label xml:lang="en">Location</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PurchaseGameplayContext">
  <rdfs:comment xml:lang="en">A pivot class linking an in-app purchase to the gameplay metrics (like hours played) at the time of purchase.</rdfs:comment>
  <rdfs:label xml:lang="en">Purchase Gameplay Context</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayingArea">
  <rdfs:comment xml:lang="en">A specific region, map, or zone within a game world where gameplay occurs.</rdfs:comment>
  <rdfs:label xml:lang="en">Playing Area</rdfs:label>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasFriend">
  <rdfs:comment xml:lang="en">A symmetric relationship indicating that one player is a friend of another player.</rdfs:comment>
  <rdfs:label xml:lang="en">has friend</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <owl:SymmetricProperty rdf:resource='http://www.semanticweb.org/myontology#hasFriend'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#playsGame">
  <rdfs:comment xml:lang="en">A relationship indicating that a player plays a specific game.</rdfs:comment>
  <rdfs:label xml:lang="en">plays game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAchievement">
  <rdfs:comment xml:lang="en">A relationship indicating that a player has earned a specific achievement.</rdfs:comment>
  <rdfs:label xml:lang="en">has achievement</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#gameHasAchievement">
  <rdfs:comment xml:lang="en">A relationship indicating that a specific achievement is available within a specific game.</rdfs:comment>
  <rdfs:label xml:lang="en">game has achievement</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPlayRecord">
  <rdfs:comment xml:lang="en">Links a player to their specific play records.</rdfs:comment>
  <rdfs:label xml:lang="en">has play record</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#GamePlayRecord"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#recordOfGame">
  <rdfs:comment xml:lang="en">Links a play record to the specific game it refers to.</rdfs:comment>
  <rdfs:label xml:lang="en">record of game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#GamePlayRecord"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAchievementType">
  <rdfs:comment xml:lang="en">Links an achievement to its specific type or category.</rdfs:comment>
  <rdfs:label xml:lang="en">has achievement type</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGenre">
  <rdfs:comment xml:lang="en">A relationship indicating the genre of a specific game.</rdfs:comment>
  <rdfs:label xml:lang="en">has genre</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Genre"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#gameContainsItem">
  <rdfs:comment xml:lang="en">A relationship indicating that a specific item exists within a specific game.</rdfs:comment>
  <rdfs:label xml:lang="en">game contains item</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#GameItem"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#itemHasAbility">
  <rdfs:comment xml:lang="en">A relationship indicating that a game item possesses a specific ability.</rdfs:comment>
  <rdfs:label xml:lang="en">item has ability</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#GameItem"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Ability"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasItem">
  <rdfs:comment xml:lang="en">A relationship indicating that a player possesses a specific game item.</rdfs:comment>
  <rdfs:label xml:lang="en">has item</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#GameItem"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#inventoryOfPlayer">
  <rdfs:comment xml:lang="en">Links an inventory record to the player who owns the items.</rdfs:comment>
  <rdfs:label xml:lang="en">inventory of player</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameInventory"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#inventoryOfGame">
  <rdfs:comment xml:lang="en">Links an inventory record to the specific game context.</rdfs:comment>
  <rdfs:label xml:lang="en">inventory of game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameInventory"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#inventoryContainsItem">
  <rdfs:comment xml:lang="en">Links an inventory record to the specific item possessed by the player in that game.</rdfs:comment>
  <rdfs:label xml:lang="en">inventory contains item</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameInventory"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#GameItem"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#purchaseByPlayer">
  <rdfs:comment xml:lang="en">Links a purchase record to the player who made the purchase.</rdfs:comment>
  <rdfs:label xml:lang="en">purchase by player</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#purchaseOfItem">
  <rdfs:comment xml:lang="en">Links a purchase record to the item or service being bought.</rdfs:comment>
  <rdfs:label xml:lang="en">purchase of item</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#GameItem"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasLocation">
  <rdfs:comment xml:lang="en">A relationship indicating the geographical location where a player lives.</rdfs:comment>
  <rdfs:label xml:lang="en">has location</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Location"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#contextOfPurchase">
  <rdfs:comment xml:lang="en">Links a purchase to its gameplay context.</rdfs:comment>
  <rdfs:label xml:lang="en">context of purchase</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PurchaseGameplayContext"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#contextRefersToRecord">
  <rdfs:comment xml:lang="en">Links the purchase context to the specific gameplay record containing the time spent.</rdfs:comment>
  <rdfs:label xml:lang="en">context refers to record</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PurchaseGameplayContext"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#GamePlayRecord"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#gameHasPlayingArea">
  <rdfs:comment xml:lang="en">A relationship indicating that a game contains a specific playing area.</rdfs:comment>
  <rdfs:label xml:lang="en">game has playing area</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasUsername">
  <rdfs:comment xml:lang="en">The unique alphanumeric identifier used by a player to log into the system.</rdfs:comment>
  <rdfs:label xml:lang="en">has username</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasHoursPlayed">
  <rdfs:comment xml:lang="en">The total number of hours a player has spent playing a specific game.</rdfs:comment>
  <rdfs:label xml:lang="en">has hours played</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#GamePlayRecord"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasReleaseDate">
  <rdfs:comment xml:lang="en">The date when the game was officially released.</rdfs:comment>
  <rdfs:label xml:lang="en">has release date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasKillCount">
  <rdfs:comment xml:lang="en">The total number of kills achieved by a player in a specific game record.</rdfs:comment>
  <rdfs:label xml:lang="en">has kill count</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#GamePlayRecord"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasLastPlayedDate">
  <rdfs:comment xml:lang="en">The date and time when the player last played the game associated with this record.</rdfs:comment>
  <rdfs:label xml:lang="en">has last played date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#GamePlayRecord"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasPurchaseAmount">
  <rdfs:comment xml:lang="en">The monetary value of the in-app purchase.</rdfs:comment>
  <rdfs:label xml:lang="en">has purchase amount</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasPurchaseDate">
  <rdfs:comment xml:lang="en">The date and time when the in-app purchase was made.</rdfs:comment>
  <rdfs:label xml:lang="en">has purchase date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

</rdf:RDF>