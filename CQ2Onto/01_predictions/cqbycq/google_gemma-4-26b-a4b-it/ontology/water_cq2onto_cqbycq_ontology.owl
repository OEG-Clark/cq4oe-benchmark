<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure">
  <rdfs:comment xml:lang="en">A system of interconnected components designed to transport water from a source to consumers.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Distribution Infrastructure</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Asset">
  <rdfs:comment xml:lang="en">A physical component or resource that forms part of an infrastructure.</rdfs:comment>
  <rdfs:label xml:lang="en">Asset</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Sensor">
  <rdfs:comment xml:lang="en">A device used to detect or measure physical properties within the water infrastructure.</rdfs:comment>
  <rdfs:label xml:lang="en">Sensor</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Asset'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Actuator">
  <rdfs:comment xml:lang="en">A component that is responsible for moving or controlling a mechanism or system.</rdfs:comment>
  <rdfs:label xml:lang="en">Actuator</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Asset'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Valve">
  <rdfs:comment xml:lang="en">A device that regulates, directs, or controls the flow of a fluid by opening, closing, or partially obstructing various passageways.</rdfs:comment>
  <rdfs:label xml:lang="en">Valve</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Actuator'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Pump">
  <rdfs:comment xml:lang="en">A mechanical device used to move fluids by mechanical action.</rdfs:comment>
  <rdfs:label xml:lang="en">Pump</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Actuator'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterMeter">
  <rdfs:comment xml:lang="en">A device that measures different aspects of a water infrastructure.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Meter</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Sensor'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterMeterMeasurement">
  <rdfs:comment xml:lang="en">A reified observation representing a specific measurement taken by a water meter at a specific point in time.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Meter Measurement</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Water">
  <rdfs:comment xml:lang="en">The chemical substance H2O that flows through the distribution infrastructure.</rdfs:comment>
  <rdfs:label xml:lang="en">Water</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterProperty">
  <rdfs:comment xml:lang="en">A category of physical or chemical characteristics that water can possess.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Property</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterPropertyMeasurement">
  <rdfs:comment xml:lang="en">A reified observation representing a specific physical property of water measured at a certain time.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Property Measurement</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ChemicalProperty">
  <rdfs:comment xml:lang="en">A property related to the chemical composition or reaction potential of water.</rdfs:comment>
  <rdfs:label xml:lang="en">Chemical Property</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#WaterProperty'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Ph">
  <rdfs:comment xml:lang="en">The measure of acidity or alkalinity of the water.</rdfs:comment>
  <rdfs:label xml:lang="en">pH</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#ChemicalProperty'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Salinity">
  <rdfs:comment xml:lang="en">The concentration of dissolved salts in the water.</rdfs:comment>
  <rdfs:label xml:lang="en">Salinity</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#ChemicalProperty'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Location">
  <rdfs:comment xml:lang="en">A physical or geographic place.</rdfs:comment>
  <rdfs:label xml:lang="en">Location</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#City">
  <rdfs:comment xml:lang="en">A large human settlement.</rdfs:comment>
  <rdfs:label xml:lang="en">City</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Location'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Tariff">
  <rdfs:comment xml:lang="en">A schedule of rates or prices for water usage.</rdfs:comment>
  <rdfs:label xml:lang="en">Tariff</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#TariffUsage">
  <rdfs:comment xml:lang="en">A reified relationship capturing the period during which a specific tariff is applied to a water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">Tariff Usage</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#BillingCycle">
  <rdfs:comment xml:lang="en">A record representing a specific billing period for a water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">Billing Cycle</rdfs:label>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#comprisesAsset">
  <rdfs:comment xml:lang="en">Relates a water distribution infrastructure to the assets that compose it.</rdfs:comment>
  <rdfs:label xml:lang="en">comprises asset</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Asset"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isProducedBy">
  <rdfs:comment xml:lang="en">Relates a measurement to the water meter that produced it.</rdfs:comment>
  <rdfs:label xml:lang="en">is produced by</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeterMeasurement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#refersToWater">
  <rdfs:comment xml:lang="en">Relates a property measurement to the specific water substance being measured.</rdfs:comment>
  <rdfs:label xml:lang="en">refers to water</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterPropertyMeasurement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Water"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPropertyType">
  <rdfs:comment xml:lang="en">Relates a property measurement to the type of property (e.g., Temperature, pH) being measured.</rdfs:comment>
  <rdfs:label xml:lang="en">has property type</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterPropertyMeasurement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WaterProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isLocatedIn">
  <rdfs:comment xml:lang="en">Relates an asset or infrastructure to its geographic location.</rdfs:comment>
  <rdfs:label xml:lang="en">is located in</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Asset"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Location"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasIndicator">
  <rdfs:comment xml:lang="en">Relates a location to the water properties that are monitored or defined for it.</rdfs:comment>
  <rdfs:label xml:lang="en">has indicator</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Location"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WaterProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#appliesToMeter">
  <rdfs:comment xml:lang="en">Relates a tariff usage record to the water meter it applies to.</rdfs:comment>
  <rdfs:label xml:lang="en">applies to meter</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#TariffUsage"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usesTariff">
  <rdfs:comment xml:lang="en">Relates a tariff usage record to the specific tariff being used.</rdfs:comment>
  <rdfs:label xml:lang="en">uses tariff</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#TariffUsage"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Tariff"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isBilledBy">
  <rdfs:comment xml:lang="en">Relates a water meter to its billing cycle records.</rdfs:comment>
  <rdfs:label xml:lang="en">is billed by</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#BillingCycle"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasFabricationNumber">
  <rdfs:comment xml:lang="en">The unique fabrication number assigned to a device during manufacturing.</rdfs:comment>
  <rdfs:label xml:lang="en">has fabrication number</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasManufacturer">
  <rdfs:comment xml:lang="en">The name of the company that manufactured the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">has manufacturer</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasModel">
  <rdfs:comment xml:lang="en">The specific model designation of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">has model</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasVersion">
  <rdfs:comment xml:lang="en">The version of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">has version</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasFirmwareVersion">
  <rdfs:comment xml:lang="en">The version of the firmware currently running on the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">has firmware version</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasPower">
  <rdfs:comment xml:lang="en">The power consumption or power rating of the water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">has power</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasRadioFrequencyLevel">
  <rdfs:comment xml:lang="en">The radio frequency level used by the water meter for communication.</rdfs:comment>
  <rdfs:label xml:lang="en">has radio frequency level</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasLatitude">
  <rdfs:comment xml:lang="en">The latitude coordinate of the water meter's location.</rdfs:comment>
  <rdfs:label xml:lang="en">has latitude</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasLongitude">
  <rdfs:comment xml:lang="en">The longitude coordinate of the water meter's location.</rdfs:comment>
  <rdfs:label xml:lang="en">has longitude</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasMeasurementValue">
  <rdfs:comment xml:lang="en">The numerical value of the measurement recorded.</rdfs:comment>
  <rdfs:label xml:lang="en">has measurement value</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeterMeasurement"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasMeasurementTimestamp">
  <rdfs:comment xml:lang="en">The temporal setting or timestamp when the measurement was recorded.</rdfs:comment>
  <rdfs:label xml:lang="en">has measurement timestamp</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeterMeasurement"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasPropertyValue">
  <rdfs:comment xml:lang="en">The numerical value of the water property measurement.</rdfs:comment>
  <rdfs:label xml:lang="en">has property value</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterPropertyMeasurement"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasPropertyTimestamp">
  <rdfs:comment xml:lang="en">The timestamp when the water property was measured.</rdfs:comment>
  <rdfs:label xml:lang="en">has property timestamp</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterPropertyMeasurement"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasTariffStartDate">
  <rdfs:comment xml:lang="en">The start date and time of the tariff in use.</rdfs:comment>
  <rdfs:label xml:lang="en">has tariff start date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#TariffUsage"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasTariffEndDate">
  <rdfs:comment xml:lang="en">The end date and time of the tariff in use.</rdfs:comment>
  <rdfs:label xml:lang="en">has tariff end date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#TariffUsage"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasBillingDate">
  <rdfs:comment xml:lang="en">The specific date on which the billing was issued.</rdfs:comment>
  <rdfs:label xml:lang="en">has billing date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#BillingCycle"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasBillingStartDate">
  <rdfs:comment xml:lang="en">The start date and time of the billing period.</rdfs:comment>
  <rdfs:label xml:lang="en">has billing start date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#BillingCycle"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasBillingEndDate">
  <rdfs:comment xml:lang="en">The end date and time of the billing period.</rdfs:comment>
  <rdfs:label xml:lang="en">has billing end date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#BillingCycle"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
</owl:DatatypeProperty>

</rdf:RDF>