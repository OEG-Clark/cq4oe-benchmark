<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Wine">
  <rdfs:comment xml:lang="en">A fermented alcoholic beverage made from grapes.</rdfs:comment>
  <rdfs:label xml:lang="en">Wine</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Characteristic">
  <rdfs:comment xml:lang="en">A quality or feature that describes a wine.</rdfs:comment>
  <rdfs:label xml:lang="en">Characteristic</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#RedWine">
  <rdfs:comment xml:lang="en">A type of wine that is red in color.</rdfs:comment>
  <rdfs:label xml:lang="en">Red Wine</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Wine'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WhiteWine">
  <rdfs:comment xml:lang="en">A type of wine that is white in color.</rdfs:comment>
  <rdfs:label xml:lang="en">White Wine</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Wine'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WineVintage">
  <rdfs:comment xml:lang="en">Represents a specific wine produced in a specific vintage year.</rdfs:comment>
  <rdfs:label xml:lang="en">Wine Vintage</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#GrapeVariety">
  <rdfs:comment xml:lang="en">A specific type of grape used in winemaking.</rdfs:comment>
  <rdfs:label xml:lang="en">Grape Variety</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Region">
  <rdfs:comment xml:lang="en">A geographical area where wine is produced.</rdfs:comment>
  <rdfs:label xml:lang="en">Region</rdfs:label>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasCharacteristic">
  <rdfs:comment xml:lang="en">Relates a wine to one of its characteristics.</rdfs:comment>
  <rdfs:label xml:lang="en">has characteristic</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Characteristic"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#ofWine">
  <rdfs:comment xml:lang="en">Relates a wine vintage to the specific wine it represents.</rdfs:comment>
  <rdfs:label xml:lang="en">of wine</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WineVintage"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasVintageCharacteristic">
  <rdfs:comment xml:lang="en">Relates a wine vintage to a characteristic it possesses in that specific year.</rdfs:comment>
  <rdfs:label xml:lang="en">has vintage characteristic</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WineVintage"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Characteristic"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGrapeVariety">
  <rdfs:comment xml:lang="en">Relates a wine to the grape variety it is made from.</rdfs:comment>
  <rdfs:label xml:lang="en">has grape variety</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#GrapeVariety"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasOriginRegion">
  <rdfs:comment xml:lang="en">Relates a wine to its region of origin.</rdfs:comment>
  <rdfs:label xml:lang="en">has origin region</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Region"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasVintageYear">
  <rdfs:comment xml:lang="en">The year the wine was produced.</rdfs:comment>
  <rdfs:label xml:lang="en">has vintage year</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WineVintage"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:integer"/>
</owl:DatatypeProperty>

</rdf:RDF>