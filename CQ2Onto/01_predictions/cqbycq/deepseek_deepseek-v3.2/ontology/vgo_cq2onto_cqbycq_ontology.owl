<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Player">
  <rdfs:comment xml:lang="en">An individual who participates in a game or activity.</rdfs:comment>
  <rdfs:label xml:lang="en">Player</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Game">
  <rdfs:comment xml:lang="en">A structured activity or contest with rules, often played for enjoyment.</rdfs:comment>
  <rdfs:label xml:lang="en">Game</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Achievement">
  <rdfs:comment xml:lang="en">A milestone, award, or accomplishment earned by a player in a game or activity.</rdfs:comment>
  <rdfs:label xml:lang="en">Achievement</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#GamePlaySession">
  <rdfs:comment xml:lang="en">An instance of a player engaging with a game for a specific period of time.</rdfs:comment>
  <rdfs:label xml:lang="en">Game Play Session</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#AchievementType">
  <rdfs:comment xml:lang="en">A category or classification of achievements, such as 'combat', 'exploration', or 'crafting'.</rdfs:comment>
  <rdfs:label xml:lang="en">Achievement Type</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Genre">
  <rdfs:comment xml:lang="en">A category or style of a game, such as Action, Role-Playing, Strategy, or Simulation.</rdfs:comment>
  <rdfs:label xml:lang="en">Genre</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Item">
  <rdfs:comment xml:lang="en">A collectible, usable, or interactive object within a game world, such as a weapon, potion, or key.</rdfs:comment>
  <rdfs:label xml:lang="en">Item</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Ability">
  <rdfs:comment xml:lang="en">A power, skill, or effect that an item can grant or perform, such as dealing damage, healing, or unlocking a door.</rdfs:comment>
  <rdfs:label xml:lang="en">Ability</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayerGameStatistic">
  <rdfs:comment xml:lang="en">A record of a specific statistic (e.g., kill count, score, play time) for a player in a particular game.</rdfs:comment>
  <rdfs:label xml:lang="en">Player Game Statistic</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#StatisticType">
  <rdfs:comment xml:lang="en">A category or name of a measurable statistic in a game, such as 'KillCount', 'Score', or 'TimePlayed'.</rdfs:comment>
  <rdfs:label xml:lang="en">Statistic Type</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayerItemPossession">
  <rdfs:comment xml:lang="en">A record representing a player's possession of a specific item, which can include details like quantity or acquisition time.</rdfs:comment>
  <rdfs:label xml:lang="en">Player Item Possession</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayerGameCompletion">
  <rdfs:comment xml:lang="en">A record representing a player's completion status for a specific game, particularly regarding achievements.</rdfs:comment>
  <rdfs:label xml:lang="en">Player Game Completion</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Equipment">
  <rdfs:comment xml:lang="en">A type of item that a player can use or wear to enhance their capabilities in a game, such as weapons, armor, or tools.</rdfs:comment>
  <rdfs:label xml:lang="en">Equipment</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Item'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ItemUsageEvent">
  <rdfs:comment xml:lang="en">An event representing a player using a specific item within a game, potentially during a play session.</rdfs:comment>
  <rdfs:label xml:lang="en">Item Usage Event</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#InAppPurchase">
  <rdfs:comment xml:lang="en">A record of a player making a purchase within a game application, such as buying virtual currency, items, or content.</rdfs:comment>
  <rdfs:label xml:lang="en">In-App Purchase</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayerGameFirstPurchaseTime">
  <rdfs:comment xml:lang="en">A record capturing the cumulative time a player spent in a game before making their first in-app purchase for that game.</rdfs:comment>
  <rdfs:label xml:lang="en">Player Game First Purchase Time</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayingArea">
  <rdfs:comment xml:lang="en">A distinct location, level, map, or region within a game where gameplay occurs.</rdfs:comment>
  <rdfs:label xml:lang="en">Playing Area</rdfs:label>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasFriend">
  <rdfs:comment xml:lang="en">A relationship indicating that one player considers another player a friend.</rdfs:comment>
  <rdfs:label xml:lang="en">has friend</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#playsGame">
  <rdfs:comment xml:lang="en">A relationship indicating that a player participates in or engages with a specific game.</rdfs:comment>
  <rdfs:label xml:lang="en">plays game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAchievement">
  <rdfs:comment xml:lang="en">A relationship indicating that a player has earned a specific achievement.</rdfs:comment>
  <rdfs:label xml:lang="en">has achievement</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#gameHasAchievement">
  <rdfs:comment xml:lang="en">A relationship indicating that a specific game has or offers a particular achievement.</rdfs:comment>
  <rdfs:label xml:lang="en">game has achievement</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPlaySession">
  <rdfs:comment xml:lang="en">A relationship indicating that a player has a recorded play session.</rdfs:comment>
  <rdfs:label xml:lang="en">has play session</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#GamePlaySession"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#sessionOfGame">
  <rdfs:comment xml:lang="en">A relationship indicating that a play session is associated with a specific game.</rdfs:comment>
  <rdfs:label xml:lang="en">session of game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#GamePlaySession"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAchievementType">
  <rdfs:comment xml:lang="en">A relationship indicating that an achievement belongs to a specific type or category.</rdfs:comment>
  <rdfs:label xml:lang="en">has achievement type</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#gameHasAchievementType">
  <rdfs:comment xml:lang="en">A relationship indicating that a game includes achievements of a specific type.</rdfs:comment>
  <rdfs:label xml:lang="en">game has achievement type</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGenre">
  <rdfs:comment xml:lang="en">A relationship indicating that a game belongs to a specific genre.</rdfs:comment>
  <rdfs:label xml:lang="en">has genre</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Genre"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasItem">
  <rdfs:comment xml:lang="en">A relationship indicating that a game contains or features a specific item.</rdfs:comment>
  <rdfs:label xml:lang="en">has item</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAbility">
  <rdfs:comment xml:lang="en">A relationship indicating that an item possesses or grants a specific ability.</rdfs:comment>
  <rdfs:label xml:lang="en">has ability</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Item"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Ability"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasStatistic">
  <rdfs:comment xml:lang="en">A relationship indicating that a player has a recorded statistic for a game.</rdfs:comment>
  <rdfs:label xml:lang="en">has statistic</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PlayerGameStatistic"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#statisticForGame">
  <rdfs:comment xml:lang="en">A relationship indicating that a player game statistic is associated with a specific game.</rdfs:comment>
  <rdfs:label xml:lang="en">statistic for game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameStatistic"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasStatisticType">
  <rdfs:comment xml:lang="en">A relationship indicating that a player game statistic is of a specific type (e.g., KillCount).</rdfs:comment>
  <rdfs:label xml:lang="en">has statistic type</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameStatistic"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#StatisticType"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPossession">
  <rdfs:comment xml:lang="en">A relationship indicating that a player has a record of possessing an item.</rdfs:comment>
  <rdfs:label xml:lang="en">has possession</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PlayerItemPossession"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#possessionOfItem">
  <rdfs:comment xml:lang="en">A relationship indicating that a player item possession record refers to a specific item.</rdfs:comment>
  <rdfs:label xml:lang="en">possession of item</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerItemPossession"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#sessionOfPlayer">
  <rdfs:comment xml:lang="en">A relationship indicating that a game play session is associated with a specific player.</rdfs:comment>
  <rdfs:label xml:lang="en">session of player</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#GamePlaySession"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#hasPlaySession'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasCompletion">
  <rdfs:comment xml:lang="en">A relationship indicating that a player has a completion record for a game.</rdfs:comment>
  <rdfs:label xml:lang="en">has completion</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PlayerGameCompletion"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#completionForGame">
  <rdfs:comment xml:lang="en">A relationship indicating that a player game completion record is for a specific game.</rdfs:comment>
  <rdfs:label xml:lang="en">completion for game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameCompletion"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#possessionInGame">
  <rdfs:comment xml:lang="en">A relationship indicating that a player's possession of an item is associated with a specific game.</rdfs:comment>
  <rdfs:label xml:lang="en">possession in game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerItemPossession"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasUsageEvent">
  <rdfs:comment xml:lang="en">A relationship indicating that a player has a record of using an item.</rdfs:comment>
  <rdfs:label xml:lang="en">has usage event</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#ItemUsageEvent"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usageOfItem">
  <rdfs:comment xml:lang="en">A relationship indicating that an item usage event involves a specific item.</rdfs:comment>
  <rdfs:label xml:lang="en">usage of item</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ItemUsageEvent"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usageInGame">
  <rdfs:comment xml:lang="en">A relationship indicating that an item usage event occurs within a specific game.</rdfs:comment>
  <rdfs:label xml:lang="en">usage in game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ItemUsageEvent"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usageDuringSession">
  <rdfs:comment xml:lang="en">A relationship indicating that an item usage event occurred during a specific game play session.</rdfs:comment>
  <rdfs:label xml:lang="en">usage during session</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ItemUsageEvent"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#GamePlaySession"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPurchase">
  <rdfs:comment xml:lang="en">A relationship indicating that a player has made an in-app purchase.</rdfs:comment>
  <rdfs:label xml:lang="en">has purchase</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#purchaseForGame">
  <rdfs:comment xml:lang="en">A relationship indicating that an in-app purchase is associated with a specific game.</rdfs:comment>
  <rdfs:label xml:lang="en">purchase for game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasFirstPurchaseRecord">
  <rdfs:comment xml:lang="en">A relationship indicating that a player has a record of their first purchase time for a game.</rdfs:comment>
  <rdfs:label xml:lang="en">has first purchase record</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PlayerGameFirstPurchaseTime"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#firstPurchaseRecordForGame">
  <rdfs:comment xml:lang="en">A relationship indicating that a player's first purchase time record is for a specific game.</rdfs:comment>
  <rdfs:label xml:lang="en">first purchase record for game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameFirstPurchaseTime"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#firstPurchaseRecordOfPurchase">
  <rdfs:comment xml:lang="en">A relationship indicating that a player's first purchase time record is associated with a specific in-app purchase event (the first purchase).</rdfs:comment>
  <rdfs:label xml:lang="en">first purchase record of purchase</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameFirstPurchaseTime"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPlayingArea">
  <rdfs:comment xml:lang="en">A relationship indicating that a game contains or is composed of specific playing areas (e.g., levels, maps, zones).</rdfs:comment>
  <rdfs:label xml:lang="en">has playing area</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasUsername">
  <rdfs:comment xml:lang="en">The unique identifier or name chosen by a player.</rdfs:comment>
  <rdfs:label xml:lang="en">has username</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasDurationHours">
  <rdfs:comment xml:lang="en">The length of a game play session measured in hours.</rdfs:comment>
  <rdfs:label xml:lang="en">has duration hours</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#GamePlaySession"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasReleaseDate">
  <rdfs:comment xml:lang="en">The calendar date on which a game was officially released to the public.</rdfs:comment>
  <rdfs:label xml:lang="en">has release date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasStatisticValue">
  <rdfs:comment xml:lang="en">The numeric value of a player game statistic, such as the number of kills.</rdfs:comment>
  <rdfs:label xml:lang="en">has statistic value</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameStatistic"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasQuantity">
  <rdfs:comment xml:lang="en">The number of units of an item that a player possesses.</rdfs:comment>
  <rdfs:label xml:lang="en">has quantity</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerItemPossession"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasSessionStartTime">
  <rdfs:comment xml:lang="en">The date and time when a game play session began.</rdfs:comment>
  <rdfs:label xml:lang="en">has session start time</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#GamePlaySession"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasCompletionStatus">
  <rdfs:comment xml:lang="en">A boolean value indicating whether a player has completed all achievements for a game.</rdfs:comment>
  <rdfs:label xml:lang="en">has completion status</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameCompletion"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasUsageTimestamp">
  <rdfs:comment xml:lang="en">The date and time when an item usage event occurred.</rdfs:comment>
  <rdfs:label xml:lang="en">has usage timestamp</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ItemUsageEvent"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasPurchaseAmount">
  <rdfs:comment xml:lang="en">The monetary amount of an in-app purchase, typically in a currency like USD.</rdfs:comment>
  <rdfs:label xml:lang="en">has purchase amount</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasPurchaseTimestamp">
  <rdfs:comment xml:lang="en">The date and time when an in-app purchase was made.</rdfs:comment>
  <rdfs:label xml:lang="en">has purchase timestamp</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasTotalPurchaseCount">
  <rdfs:comment xml:lang="en">The total number of in-app purchases made by a player across all games.</rdfs:comment>
  <rdfs:label xml:lang="en">has total purchase count</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasPurchaseHour">
  <rdfs:comment xml:lang="en">The hour of the day (0-23) when an in-app purchase was made, derived from the purchase timestamp.</rdfs:comment>
  <rdfs:label xml:lang="en">has purchase hour</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasLocation">
  <rdfs:comment xml:lang="en">The geographical location (e.g., city, country) where a player resides.</rdfs:comment>
  <rdfs:label xml:lang="en">has location</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isFirstPurchase">
  <rdfs:comment xml:lang="en">A boolean flag indicating whether this in-app purchase is the first one made by the player for the associated game.</rdfs:comment>
  <rdfs:label xml:lang="en">is first purchase</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasPrePurchasePlayTimeHours">
  <rdfs:comment xml:lang="en">The cumulative time (in hours) a player spent in a game before making their first in-app purchase for that game.</rdfs:comment>
  <rdfs:label xml:lang="en">has pre-purchase play time hours</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameFirstPurchaseTime"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

</rdf:RDF>