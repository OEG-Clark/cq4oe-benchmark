<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Player">
  <rdfs:comment xml:lang="en">A participant in the game.</rdfs:comment>
  <rdfs:label xml:lang="en">Player</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Game">
  <rdfs:comment xml:lang="en">A game that players can play.</rdfs:comment>
  <rdfs:label xml:lang="en">Game</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Achievement">
  <rdfs:comment xml:lang="en">An achievement earned by a player.</rdfs:comment>
  <rdfs:label xml:lang="en">Achievement</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlaySession">
  <rdfs:comment xml:lang="en">A single play session where a player plays a game for a certain duration.</rdfs:comment>
  <rdfs:label xml:lang="en">Play Session</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ScoreAchievement">
  <rdfs:comment xml:lang="en">An achievement based on reaching a certain score.</rdfs:comment>
  <rdfs:label xml:lang="en">Score Achievement</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Achievement'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#TimeAchievement">
  <rdfs:comment xml:lang="en">An achievement based on playing for a certain amount of time.</rdfs:comment>
  <rdfs:label xml:lang="en">Time Achievement</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Achievement'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ExplorationAchievement">
  <rdfs:comment xml:lang="en">An achievement based on exploring certain areas or content.</rdfs:comment>
  <rdfs:label xml:lang="en">Exploration Achievement</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Achievement'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Item">
  <rdfs:comment xml:lang="en">An item that exists within a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Item</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Ability">
  <rdfs:comment xml:lang="en">An ability that an item can grant or possess.</rdfs:comment>
  <rdfs:label xml:lang="en">Ability</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayerGameStats">
  <rdfs:comment xml:lang="en">Statistics for a player in a specific game, including kill count.</rdfs:comment>
  <rdfs:label xml:lang="en">Player Game Stats</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayerEquipmentInGame">
  <rdfs:comment xml:lang="en">Represents the equipment (items) a player has in a specific game.</rdfs:comment>
  <rdfs:label xml:lang="en">Player Equipment In Game</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayerItemUsage">
  <rdfs:comment xml:lang="en">Represents the fact that a player can use an item in a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Player Item Usage</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#InAppPurchase">
  <rdfs:comment xml:lang="en">A purchase made by a player within a game (in-app purchase).</rdfs:comment>
  <rdfs:label xml:lang="en">In App Purchase</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#FirstIAPContext">
  <rdfs:comment xml:lang="en">Context capturing the first in-app purchase of a player in a game, including the total play time before that purchase.</rdfs:comment>
  <rdfs:label xml:lang="en">First IAP Context</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayerIAPSummary">
  <rdfs:comment xml:lang="en">Aggregated information about a player's in-app purchases, including the total number of purchases made.</rdfs:comment>
  <rdfs:label xml:lang="en">Player IAP Summary</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayingArea">
  <rdfs:comment xml:lang="en">An area within a game where gameplay occurs.</rdfs:comment>
  <rdfs:label xml:lang="en">Playing Area</rdfs:label>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasFriend">
  <rdfs:comment xml:lang="en">A relationship indicating that one player is a friend of another player.</rdfs:comment>
  <rdfs:label xml:lang="en">has friend</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#playsGame">
  <rdfs:comment xml:lang="en">Indicates that a player plays a game.</rdfs:comment>
  <rdfs:label xml:lang="en">plays game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAchievement">
  <rdfs:comment xml:lang="en">Indicates that a player has earned an achievement.</rdfs:comment>
  <rdfs:label xml:lang="en">has achievement</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#gameHasAchievement">
  <rdfs:comment xml:lang="en">Indicates that a game has an achievement that can be earned.</rdfs:comment>
  <rdfs:label xml:lang="en">game has achievement</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#playedBy">
  <rdfs:comment xml:lang="en">Indicates that a play session was played by a specific player.</rdfs:comment>
  <rdfs:label xml:lang="en">played by</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlaySession"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#sessionOf">
  <rdfs:comment xml:lang="en">Indicates the game that a play session belongs to.</rdfs:comment>
  <rdfs:label xml:lang="en">session of</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlaySession"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasItem">
  <rdfs:comment xml:lang="en">Indicates that a game contains an item.</rdfs:comment>
  <rdfs:label xml:lang="en">has item</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAbility">
  <rdfs:comment xml:lang="en">Indicates that an item has an ability.</rdfs:comment>
  <rdfs:label xml:lang="en">has ability</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Item"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Ability"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#forPlayer">
  <rdfs:comment xml:lang="en">Indicates the player associated with these statistics.</rdfs:comment>
  <rdfs:label xml:lang="en">for player</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameStats"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#forGame">
  <rdfs:comment xml:lang="en">Indicates the game associated with these statistics.</rdfs:comment>
  <rdfs:label xml:lang="en">for game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameStats"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#ownsItem">
  <rdfs:comment xml:lang="en">Indicates that a player owns an item.</rdfs:comment>
  <rdfs:label xml:lang="en">owns item</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAllAchievementsInGame">
  <rdfs:comment xml:lang="en">Indicates that a player has earned all achievements in a particular game.</rdfs:comment>
  <rdfs:label xml:lang="en">has all achievements in game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#equippedPlayer">
  <rdfs:comment xml:lang="en">Indicates the player associated with this equipment record.</rdfs:comment>
  <rdfs:label xml:lang="en">equipped player</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerEquipmentInGame"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#equippedGame">
  <rdfs:comment xml:lang="en">Indicates the game associated with this equipment record.</rdfs:comment>
  <rdfs:label xml:lang="en">equipped game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerEquipmentInGame"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#equippedItem">
  <rdfs:comment xml:lang="en">Indicates the item (equipment) in this equipment record.</rdfs:comment>
  <rdfs:label xml:lang="en">equipped item</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerEquipmentInGame"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usagePlayer">
  <rdfs:comment xml:lang="en">Indicates the player who uses the item.</rdfs:comment>
  <rdfs:label xml:lang="en">usage player</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerItemUsage"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usageItem">
  <rdfs:comment xml:lang="en">Indicates the item that is used.</rdfs:comment>
  <rdfs:label xml:lang="en">usage item</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerItemUsage"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usageGame">
  <rdfs:comment xml:lang="en">Indicates the game in which the item is used.</rdfs:comment>
  <rdfs:label xml:lang="en">usage game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerItemUsage"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#purchasedBy">
  <rdfs:comment xml:lang="en">Indicates the player who made an in-app purchase.</rdfs:comment>
  <rdfs:label xml:lang="en">purchased by</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#contextPlayer">
  <rdfs:comment xml:lang="en">Indicates the player associated with a First IAP Context.</rdfs:comment>
  <rdfs:label xml:lang="en">context player</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#FirstIAPContext"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#contextGame">
  <rdfs:comment xml:lang="en">Indicates the game associated with a First IAP Context.</rdfs:comment>
  <rdfs:label xml:lang="en">context game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#FirstIAPContext"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#contextFirstPurchase">
  <rdfs:comment xml:lang="en">Indicates the first in-app purchase in a First IAP Context.</rdfs:comment>
  <rdfs:label xml:lang="en">context first purchase</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#FirstIAPContext"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#summaryPlayer">
  <rdfs:comment xml:lang="en">Indicates the player associated with a Player IAP Summary.</rdfs:comment>
  <rdfs:label xml:lang="en">summary player</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerIAPSummary"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPlayingArea">
  <rdfs:comment xml:lang="en">Indicates that a game has a playing area.</rdfs:comment>
  <rdfs:label xml:lang="en">has playing area</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasUsername">
  <rdfs:comment xml:lang="en">The username associated with a player.</rdfs:comment>
  <rdfs:label xml:lang="en">has username</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#sessionDuration">
  <rdfs:comment xml:lang="en">The duration of a play session in hours.</rdfs:comment>
  <rdfs:label xml:lang="en">session duration</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlaySession"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasGenre">
  <rdfs:comment xml:lang="en">The genre of a game.</rdfs:comment>
  <rdfs:label xml:lang="en">has genre</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasReleaseDate">
  <rdfs:comment xml:lang="en">The release date of a game.</rdfs:comment>
  <rdfs:label xml:lang="en">has release date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#killCount">
  <rdfs:comment xml:lang="en">The kill count of a player in a game.</rdfs:comment>
  <rdfs:label xml:lang="en">kill count</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameStats"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#sessionStartTime">
  <rdfs:comment xml:lang="en">The start time of a play session.</rdfs:comment>
  <rdfs:label xml:lang="en">session start time</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlaySession"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#purchaseDate">
  <rdfs:comment xml:lang="en">The date and time when an in-app purchase was made.</rdfs:comment>
  <rdfs:label xml:lang="en">purchase date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#purchaseAmount">
  <rdfs:comment xml:lang="en">The monetary amount spent in an in-app purchase.</rdfs:comment>
  <rdfs:label xml:lang="en">purchase amount</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasCountry">
  <rdfs:comment xml:lang="en">The country where a player lives.</rdfs:comment>
  <rdfs:label xml:lang="en">has country</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#totalPlayTimeBeforeFirstIAP">
  <rdfs:comment xml:lang="en">The total play time (in hours) before a player made their first in-app purchase in a game.</rdfs:comment>
  <rdfs:label xml:lang="en">total play time before first IAP</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#FirstIAPContext"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#totalIAPCount">
  <rdfs:comment xml:lang="en">The total number of in-app purchases made by the player.</rdfs:comment>
  <rdfs:label xml:lang="en">total IAP count</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerIAPSummary"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

</rdf:RDF>