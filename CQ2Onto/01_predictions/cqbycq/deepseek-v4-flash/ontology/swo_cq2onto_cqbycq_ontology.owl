<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Tool">
  <rdfs:comment xml:lang="en">A tool that uses algorithms.</rdfs:comment>
  <rdfs:label xml:lang="en">Tool</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Algorithm">
  <rdfs:comment xml:lang="en">An algorithm used by tools.</rdfs:comment>
  <rdfs:label xml:lang="en">Algorithm</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#NamedAndPublishedAlgorithm">
  <rdfs:comment xml:lang="en">An algorithm that is named and published.</rdfs:comment>
  <rdfs:label xml:lang="en">Named and Published Algorithm</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Algorithm'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Modification">
  <rdfs:comment xml:lang="en">A modification applied to an algorithm.</rdfs:comment>
  <rdfs:label xml:lang="en">Modification</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Feature">
  <rdfs:comment xml:lang="en">A feature or capability provided by a tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Feature</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#XMLEditing">
  <rdfs:comment xml:lang="en">The ability to edit XML files.</rdfs:comment>
  <rdfs:label xml:lang="en">XML Editing</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Feature'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#API">
  <rdfs:comment xml:lang="en">An application programming interface that provides functionality to other software.</rdfs:comment>
  <rdfs:label xml:lang="en">API</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Tool'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#DesktopApplication">
  <rdfs:comment xml:lang="en">A standalone software application that runs on a desktop computer.</rdfs:comment>
  <rdfs:label xml:lang="en">Desktop Application</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Tool'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Task">
  <rdfs:comment xml:lang="en">A piece of work to be done or undertaken.</rdfs:comment>
  <rdfs:label xml:lang="en">Task</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#GifRendering">
  <rdfs:comment xml:lang="en">The ability to render GIF images.</rdfs:comment>
  <rdfs:label xml:lang="en">GIF Rendering</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Feature'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Data">
  <rdfs:comment xml:lang="en">Data created or processed by a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Data</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#DataFormat">
  <rdfs:comment xml:lang="en">A data format used for input or output of a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Data Format</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#CELFileFormat">
  <rdfs:comment xml:lang="en">The .cel file format.</rdfs:comment>
  <rdfs:label xml:lang="en">CEL File Format</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#DataFormat'/>
<rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#ProprietaryDataFormat'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ProprietaryDataFormat">
  <rdfs:comment xml:lang="en">A data format that is proprietary, owned by a specific entity.</rdfs:comment>
  <rdfs:label xml:lang="en">Proprietary Data Format</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#DataFormat'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#OpenDataFormat">
  <rdfs:comment xml:lang="en">A data format that is open and publicly available.</rdfs:comment>
  <rdfs:label xml:lang="en">Open Data Format</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#DataFormat'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#CSVFileFormat">
  <rdfs:comment xml:lang="en">The .csv file format.</rdfs:comment>
  <rdfs:label xml:lang="en">CSV File Format</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#OpenDataFormat'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#TXTFileFormat">
  <rdfs:comment xml:lang="en">The .txt file format.</rdfs:comment>
  <rdfs:label xml:lang="en">TXT File Format</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#OpenDataFormat'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ExportCapability">
  <rdfs:comment xml:lang="en">The capability of a tool to export data from a source format to a target format.</rdfs:comment>
  <rdfs:label xml:lang="en">Export Capability</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Version">
  <rdfs:comment xml:lang="en">A version of a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Version</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#SoftwareSource">
  <rdfs:comment xml:lang="en">A source or location where software can be obtained.</rdfs:comment>
  <rdfs:label xml:lang="en">Software Source</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#HelpResource">
  <rdfs:comment xml:lang="en">A resource that provides help or support for using a tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Help Resource</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#UserManual">
  <rdfs:comment xml:lang="en">A manual that provides detailed instructions for using a tool.</rdfs:comment>
  <rdfs:label xml:lang="en">User Manual</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#HelpResource'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#FAQ">
  <rdfs:comment xml:lang="en">A list of frequently asked questions and their answers.</rdfs:comment>
  <rdfs:label xml:lang="en">FAQ</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#HelpResource'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Tutorial">
  <rdfs:comment xml:lang="en">A tutorial that guides users through using a tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Tutorial</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#HelpResource'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Developer">
  <rdfs:comment xml:lang="en">A person or organization that develops a tool or algorithm.</rdfs:comment>
  <rdfs:label xml:lang="en">Developer</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#License">
  <rdfs:comment xml:lang="en">A license under which a tool or algorithm is distributed.</rdfs:comment>
  <rdfs:label xml:lang="en">License</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#FOSSLicense">
  <rdfs:comment xml:lang="en">A license that is considered free and open source (e.g., GPL, MIT, BSD).</rdfs:comment>
  <rdfs:label xml:lang="en">FOSS License</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#License'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#FOSSTool">
  <rdfs:comment xml:lang="en">A tool that is free and open source software.</rdfs:comment>
  <rdfs:label xml:lang="en">FOSS Tool</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Tool'/>
<rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource='http://www.semanticweb.org/myontology#hasLicense'/><owl:someValuesFrom rdf:resource='http://www.semanticweb.org/myontology#FOSSLicense'/></owl:Restriction></rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Documentation">
  <rdfs:comment xml:lang="en">Documentation that describes the usage, features, or installation of a tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Documentation</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#HelpResource'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ProgrammingLanguage">
  <rdfs:comment xml:lang="en">A programming language used to implement software tools or algorithms.</rdfs:comment>
  <rdfs:label xml:lang="en">Programming Language</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Platform">
  <rdfs:comment xml:lang="en">A platform on which software can run, such as Windows, macOS, Linux, or web-based.</rdfs:comment>
  <rdfs:label xml:lang="en">Platform</rdfs:label>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usesAlgorithm">
  <rdfs:comment xml:lang="en">Relates a tool to an algorithm it uses.</rdfs:comment>
  <rdfs:label xml:lang="en">uses algorithm</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasModification">
  <rdfs:comment xml:lang="en">Relates an algorithm to a modification it has undergone.</rdfs:comment>
  <rdfs:label xml:lang="en">has modification</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Modification"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#providesFeature">
  <rdfs:comment xml:lang="en">Relates a tool to a feature it provides.</rdfs:comment>
  <rdfs:label xml:lang="en">provides feature</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Feature"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#performsTask">
  <rdfs:comment xml:lang="en">Relates a tool to a task it can perform.</rdfs:comment>
  <rdfs:label xml:lang="en">performs task</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Task"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#createdBy">
  <rdfs:comment xml:lang="en">Relates data to the software tool that created it.</rdfs:comment>
  <rdfs:label xml:lang="en">created by</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Data"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#handlesData">
  <rdfs:comment xml:lang="en">Relates a tool to data that it can handle or process.</rdfs:comment>
  <rdfs:label xml:lang="en">handles data</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Data"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasInputFormat">
  <rdfs:comment xml:lang="en">Relates a tool to a data format it accepts as input.</rdfs:comment>
  <rdfs:label xml:lang="en">has input format</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasOutputFormat">
  <rdfs:comment xml:lang="en">Relates a tool to a data format it produces as output.</rdfs:comment>
  <rdfs:label xml:lang="en">has output format</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasExportCapability">
  <rdfs:comment xml:lang="en">Relates a tool to its export capabilities.</rdfs:comment>
  <rdfs:label xml:lang="en">has export capability</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#ExportCapability"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#exportsFromFormat">
  <rdfs:comment xml:lang="en">Relates an export capability to the source data format.</rdfs:comment>
  <rdfs:label xml:lang="en">exports from format</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ExportCapability"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#exportsToFormat">
  <rdfs:comment xml:lang="en">Relates an export capability to the target data format.</rdfs:comment>
  <rdfs:label xml:lang="en">exports to format</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ExportCapability"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DataFormat"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasVersion">
  <rdfs:comment xml:lang="en">Links a tool to a specific version.</rdfs:comment>
  <rdfs:label xml:lang="en">has version</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Version"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isAvailableInVersion">
  <rdfs:comment xml:lang="en">Links an export capability to the version in which it is available.</rdfs:comment>
  <rdfs:label xml:lang="en">is available in version</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ExportCapability"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Version"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasSource">
  <rdfs:comment xml:lang="en">Relates a tool to its software source.</rdfs:comment>
  <rdfs:label xml:lang="en">has source</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareSource"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasHelpResource">
  <rdfs:comment xml:lang="en">Relates a tool to a help resource.</rdfs:comment>
  <rdfs:label xml:lang="en">has help resource</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#HelpResource"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasDeveloper">
  <rdfs:comment xml:lang="en">Relates a tool to its developer.</rdfs:comment>
  <rdfs:label xml:lang="en">has developer</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Developer"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#introducedInVersion">
  <rdfs:comment xml:lang="en">Relates a feature to the version in which it was introduced.</rdfs:comment>
  <rdfs:label xml:lang="en">introduced in version</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Feature"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Version"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasLicense">
  <rdfs:comment xml:lang="en">Relates a tool to the license under which it is distributed.</rdfs:comment>
  <rdfs:label xml:lang="en">has license</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#License"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasDocumentation">
  <rdfs:comment xml:lang="en">Relates a tool to its documentation.</rdfs:comment>
  <rdfs:label xml:lang="en">has documentation</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Documentation"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#implementedInLanguage">
  <rdfs:comment xml:lang="en">Relates a tool or algorithm to the programming language in which it was implemented.</rdfs:comment>
  <rdfs:label xml:lang="en">implemented in language</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#ProgrammingLanguage"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#runsOn">
  <rdfs:comment xml:lang="en">Relates a tool to the platform on which it runs.</rdfs:comment>
  <rdfs:label xml:lang="en">runs on</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Platform"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasName">
  <rdfs:comment xml:lang="en">The name of an algorithm.</rdfs:comment>
  <rdfs:label xml:lang="en">has name</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isPublished">
  <rdfs:comment xml:lang="en">Indicates whether an algorithm is published.</rdfs:comment>
  <rdfs:label xml:lang="en">is published</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#availableAsWebService">
  <rdfs:comment xml:lang="en">Indicates whether a tool is available as a web service.</rdfs:comment>
  <rdfs:label xml:lang="en">available as web service</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isOpenSource">
  <rdfs:comment xml:lang="en">Indicates whether a tool is open source.</rdfs:comment>
  <rdfs:label xml:lang="en">is open source</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isMaintained">
  <rdfs:comment xml:lang="en">Indicates whether a tool is currently maintained.</rdfs:comment>
  <rdfs:label xml:lang="en">is maintained</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasHomepage">
  <rdfs:comment xml:lang="en">The homepage URL of a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">has homepage</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isOpenToCollaboration">
  <rdfs:comment xml:lang="en">Indicates whether a developer is open to collaboration.</rdfs:comment>
  <rdfs:label xml:lang="en">is open to collaboration</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Developer"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasReleaseDate">
  <rdfs:comment xml:lang="en">The date when the software was first released.</rdfs:comment>
  <rdfs:label xml:lang="en">has release date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#activeDevelopmentScore">
  <rdfs:comment xml:lang="en">A numeric score indicating how actively a tool is being developed (e.g., 0-10).</rdfs:comment>
  <rdfs:label xml:lang="en">active development score</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#versionString">
  <rdfs:comment xml:lang="en">The version string or number of a software version.</rdfs:comment>
  <rdfs:label xml:lang="en">version string</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Version"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#versionReleaseDate">
  <rdfs:comment xml:lang="en">The release date of a specific version.</rdfs:comment>
  <rdfs:label xml:lang="en">version release date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Version"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isOpenSourceDevelopment">
  <rdfs:comment xml:lang="en">Indicates whether the software is developed as an open source project.</rdfs:comment>
  <rdfs:label xml:lang="en">is open source development</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasCommunityDevelopment">
  <rdfs:comment xml:lang="en">Indicates whether there is an active community developing or supporting the software.</rdfs:comment>
  <rdfs:label xml:lang="en">has community development</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isPermissive">
  <rdfs:comment xml:lang="en">Indicates whether a license is permissive (e.g., MIT, BSD) versus copyleft.</rdfs:comment>
  <rdfs:label xml:lang="en">is permissive</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#License"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isFree">
  <rdfs:comment xml:lang="en">Indicates whether a tool is free of charge (gratis).</rdfs:comment>
  <rdfs:label xml:lang="en">is free</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasURL">
  <rdfs:comment xml:lang="en">The URL where the documentation can be found.</rdfs:comment>
  <rdfs:label xml:lang="en">has URL</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Documentation"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
</owl:DatatypeProperty>

</rdf:RDF>