<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Tool">
  <rdfs:comment xml:lang="en">A software application or program designed to perform specific tasks.</rdfs:comment>
  <rdfs:label xml:lang="en">Tool</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Algorithm">
  <rdfs:comment xml:lang="en">A named and published computational procedure or set of rules to be followed in calculations or other problem-solving operations.</rdfs:comment>
  <rdfs:label xml:lang="en">Algorithm</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#AlgorithmModification">
  <rdfs:comment xml:lang="en">A change, adjustment, or alteration made to an algorithm.</rdfs:comment>
  <rdfs:label xml:lang="en">Algorithm Modification</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Capability">
  <rdfs:comment xml:lang="en">A feature or function that a software tool can perform.</rdfs:comment>
  <rdfs:label xml:lang="en">Capability</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#XmlEditing">
  <rdfs:comment xml:lang="en">The capability to create, modify, or manage XML documents.</rdfs:comment>
  <rdfs:label xml:lang="en">XML Editing</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Capability'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#SoftwareType">
  <rdfs:comment xml:lang="en">The category or type of software, such as API, Desktop application, Web application, etc.</rdfs:comment>
  <rdfs:label xml:lang="en">Software Type</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Task">
  <rdfs:comment xml:lang="en">A specific activity or job that a software tool is designed to execute.</rdfs:comment>
  <rdfs:label xml:lang="en">Task</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WebService">
  <rdfs:comment xml:lang="en">A software service that is accessed over a network, typically the internet, providing functionality to other software systems.</rdfs:comment>
  <rdfs:label xml:lang="en">Web Service</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#SoftwareType'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Requirement">
  <rdfs:comment xml:lang="en">A specific need, want, or desired functionality that a user expects from a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Requirement</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Data">
  <rdfs:comment xml:lang="en">A collection of information or facts, typically stored or processed by a computer.</rdfs:comment>
  <rdfs:label xml:lang="en">Data</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Format">
  <rdfs:comment xml:lang="en">A specification of the structure, syntax, and encoding of data, such as XML, JSON, or CSV.</rdfs:comment>
  <rdfs:label xml:lang="en">Format</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#CelFile">
  <rdfs:comment xml:lang="en">A file format used for storing microarray data, typically identified by the .cel extension.</rdfs:comment>
  <rdfs:label xml:lang="en">Cel File</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Format'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ValidInput">
  <rdfs:comment xml:lang="en">A specification of the data format or type that a software tool accepts as valid input.</rdfs:comment>
  <rdfs:label xml:lang="en">Valid Input</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Format'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ExportCapability">
  <rdfs:comment xml:lang="en">A capability of a software tool to convert data from one format to another.</rdfs:comment>
  <rdfs:label xml:lang="en">Export Capability</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Capability'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#OpenFormat">
  <rdfs:comment xml:lang="en">A data format that is publicly documented and freely usable, such as CSV or TXT.</rdfs:comment>
  <rdfs:label xml:lang="en">Open Format</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Format'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ProprietaryFormat">
  <rdfs:comment xml:lang="en">A data format owned or controlled by a specific organization or software vendor, often not publicly documented.</rdfs:comment>
  <rdfs:label xml:lang="en">Proprietary Format</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Format'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#License">
  <rdfs:comment xml:lang="en">A legal agreement that defines the terms under which a software tool can be used, modified, and distributed.</rdfs:comment>
  <rdfs:label xml:lang="en">License</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#OpenSourceLicense">
  <rdfs:comment xml:lang="en">A software license that grants users the freedom to use, study, share, and modify the software.</rdfs:comment>
  <rdfs:label xml:lang="en">Open Source License</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#License'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#MaintenanceStatus">
  <rdfs:comment xml:lang="en">The current development and support status of a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Maintenance Status</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Maintained">
  <rdfs:comment xml:lang="en">Indicates that a software tool is actively updated, supported, and maintained by its developers.</rdfs:comment>
  <rdfs:label xml:lang="en">Maintained</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#MaintenanceStatus'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Version">
  <rdfs:comment xml:lang="en">A specific release or iteration of a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Version</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#DataExport">
  <rdfs:comment xml:lang="en">A record or event representing data that has been exported from a software tool version given a specific input.</rdfs:comment>
  <rdfs:label xml:lang="en">Data Export</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#DownloadSource">
  <rdfs:comment xml:lang="en">A location or repository from which a software tool can be obtained.</rdfs:comment>
  <rdfs:label xml:lang="en">Download Source</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#HelpResource">
  <rdfs:comment xml:lang="en">A resource or channel through which users can obtain assistance, documentation, or support for a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Help Resource</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Developer">
  <rdfs:comment xml:lang="en">An individual or organization responsible for creating or maintaining a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Developer</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#DevelopmentType">
  <rdfs:comment xml:lang="en">The model or approach used to develop and maintain a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Development Type</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#OpenSourceDevelopment">
  <rdfs:comment xml:lang="en">A development model where the source code is openly available and contributions are welcome from the public.</rdfs:comment>
  <rdfs:label xml:lang="en">Open Source Development</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#DevelopmentType'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#CommunityDevelopment">
  <rdfs:comment xml:lang="en">A development model driven by a community of users and contributors, often collaborative and decentralized.</rdfs:comment>
  <rdfs:label xml:lang="en">Community Development</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#DevelopmentType'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Documentation">
  <rdfs:comment xml:lang="en">A resource containing written, electronic, or oral information designed to explain how to use a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Documentation</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#HelpResource'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ProgrammingLanguage">
  <rdfs:comment xml:lang="en">A programming language used to write software code.</rdfs:comment>
  <rdfs:label xml:lang="en">Programming Language</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Platform">
  <rdfs:comment xml:lang="en">A computing environment or operating system on which software can run.</rdfs:comment>
  <rdfs:label xml:lang="en">Platform</rdfs:label>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usesAlgorithm">
  <rdfs:comment xml:lang="en">Relates a software tool to the algorithm it implements or utilizes.</rdfs:comment>
  <rdfs:label xml:lang="en">uses algorithm</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasModification">
  <rdfs:comment xml:lang="en">Relates an algorithm to its modifications.</rdfs:comment>
  <rdfs:label xml:lang="en">has modification</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#AlgorithmModification"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasCapability">
  <rdfs:comment xml:lang="en">Relates a software tool to the capabilities it provides.</rdfs:comment>
  <rdfs:label xml:lang="en">has capability</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Capability"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasSoftwareType">
  <rdfs:comment xml:lang="en">Relates a software tool to its type or category.</rdfs:comment>
  <rdfs:label xml:lang="en">has software type</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareType"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#canPerform">
  <rdfs:comment xml:lang="en">Relates a software tool to the tasks it can perform.</rdfs:comment>
  <rdfs:label xml:lang="en">can perform</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Task"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#satisfiesRequirement">
  <rdfs:comment xml:lang="en">Relates a software tool to the user requirements it fulfills.</rdfs:comment>
  <rdfs:label xml:lang="en">satisfies requirement</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Requirement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#createdByTool">
  <rdfs:comment xml:lang="en">Relates a data entity to the software tool that created it.</rdfs:comment>
  <rdfs:label xml:lang="en">created by tool</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Data"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#canProcessData">
  <rdfs:comment xml:lang="en">Relates a software tool to the data types or formats it can process or accept as input.</rdfs:comment>
  <rdfs:label xml:lang="en">can process data</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Data"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasInputFormat">
  <rdfs:comment xml:lang="en">Relates a software tool to the data formats it accepts as input.</rdfs:comment>
  <rdfs:label xml:lang="en">has input format</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Format"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasOutputFormat">
  <rdfs:comment xml:lang="en">Relates a software tool to the data formats it produces as output.</rdfs:comment>
  <rdfs:label xml:lang="en">has output format</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Format"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasValidInput">
  <rdfs:comment xml:lang="en">Relates a software tool to the valid input formats or data types it accepts.</rdfs:comment>
  <rdfs:label xml:lang="en">has valid input</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#ValidInput"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasExportCapability">
  <rdfs:comment xml:lang="en">Relates a software tool to its export capabilities.</rdfs:comment>
  <rdfs:label xml:lang="en">has export capability</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#ExportCapability"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#exportsFromFormat">
  <rdfs:comment xml:lang="en">Specifies the source format from which data is exported.</rdfs:comment>
  <rdfs:label xml:lang="en">exports from format</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ExportCapability"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Format"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#exportsToFormat">
  <rdfs:comment xml:lang="en">Specifies the target format to which data is exported.</rdfs:comment>
  <rdfs:label xml:lang="en">exports to format</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ExportCapability"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Format"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#canProcessOutputFrom">
  <rdfs:comment xml:lang="en">Relates a software tool to another software tool whose output data it can process or accept as input.</rdfs:comment>
  <rdfs:label xml:lang="en">can process output from</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasLicense">
  <rdfs:comment xml:lang="en">Relates a software tool to its software license.</rdfs:comment>
  <rdfs:label xml:lang="en">has license</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#License"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasMaintenanceStatus">
  <rdfs:comment xml:lang="en">Relates a software tool to its current maintenance status.</rdfs:comment>
  <rdfs:label xml:lang="en">has maintenance status</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#MaintenanceStatus"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasSoftwareVersion">
  <rdfs:comment xml:lang="en">Relates a software tool to a specific version of that tool.</rdfs:comment>
  <rdfs:label xml:lang="en">has software version</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Version"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasInput">
  <rdfs:comment xml:lang="en">Relates a data export event to the input data that was processed.</rdfs:comment>
  <rdfs:label xml:lang="en">has input</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#DataExport"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Data"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#exportedByVersion">
  <rdfs:comment xml:lang="en">Relates a data export event to the software version that produced it.</rdfs:comment>
  <rdfs:label xml:lang="en">exported by version</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#DataExport"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Version"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasExportedData">
  <rdfs:comment xml:lang="en">Relates a data export event to the resulting exported data.</rdfs:comment>
  <rdfs:label xml:lang="en">has exported data</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#DataExport"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Data"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasDownloadSource">
  <rdfs:comment xml:lang="en">Relates a software tool to the source or repository where it can be downloaded.</rdfs:comment>
  <rdfs:label xml:lang="en">has download source</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DownloadSource"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasHelpResource">
  <rdfs:comment xml:lang="en">Relates a software tool to the resources or channels where users can get help or support.</rdfs:comment>
  <rdfs:label xml:lang="en">has help resource</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#HelpResource"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasDeveloper">
  <rdfs:comment xml:lang="en">Relates a software tool to the person or organization that developed it.</rdfs:comment>
  <rdfs:label xml:lang="en">has developer</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Developer"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasNewFeature">
  <rdfs:comment xml:lang="en">Relates a software version to the new features or capabilities introduced in that version.</rdfs:comment>
  <rdfs:label xml:lang="en">has new feature</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Version"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Capability"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasDevelopmentType">
  <rdfs:comment xml:lang="en">Relates a software tool to its development type or model.</rdfs:comment>
  <rdfs:label xml:lang="en">has development type</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#DevelopmentType"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasDocumentation">
  <rdfs:comment xml:lang="en">Relates a software tool to its documentation resource.</rdfs:comment>
  <rdfs:label xml:lang="en">has documentation</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Documentation"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isImplementedIn">
  <rdfs:comment xml:lang="en">Relates a software tool to the programming language it is written in.</rdfs:comment>
  <rdfs:label xml:lang="en">is implemented in</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#ProgrammingLanguage"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#runsOn">
  <rdfs:comment xml:lang="en">Relates a software tool to the platform or operating system it runs on.</rdfs:comment>
  <rdfs:label xml:lang="en">runs on</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Platform"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasModificationDetails">
  <rdfs:comment xml:lang="en">Describes the specific details or nature of an algorithm modification.</rdfs:comment>
  <rdfs:label xml:lang="en">has modification details</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#AlgorithmModification"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasRequirementDescription">
  <rdfs:comment xml:lang="en">Provides a textual description of a user requirement.</rdfs:comment>
  <rdfs:label xml:lang="en">has requirement description</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Requirement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasUrl">
  <rdfs:comment xml:lang="en">Specifies the web address or URL of a download source.</rdfs:comment>
  <rdfs:label xml:lang="en">has URL</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#DownloadSource"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:anyURI"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasHelpUrl">
  <rdfs:comment xml:lang="en">Specifies the web address or URL of a help resource.</rdfs:comment>
  <rdfs:label xml:lang="en">has help URL</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#HelpResource"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:anyURI"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasDeveloperName">
  <rdfs:comment xml:lang="en">Specifies the name of a developer.</rdfs:comment>
  <rdfs:label xml:lang="en">has developer name</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Developer"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasHomepage">
  <rdfs:comment xml:lang="en">Specifies the official homepage URL of a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">has homepage</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:anyURI"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isCollaborationPossible">
  <rdfs:comment xml:lang="en">Indicates whether it is possible to collaborate with the developer of a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">is collaboration possible</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Developer"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:boolean"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasReleaseDate">
  <rdfs:comment xml:lang="en">Specifies the date when the software tool was first released or made publicly available.</rdfs:comment>
  <rdfs:label xml:lang="en">has release date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:date"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasDevelopmentActivity">
  <rdfs:comment xml:lang="en">Indicates the level or frequency of development activity for a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">has development activity</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasVersionString">
  <rdfs:comment xml:lang="en">Specifies the version identifier or number of a software version.</rdfs:comment>
  <rdfs:label xml:lang="en">has version string</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Version"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasVersionReleaseDate">
  <rdfs:comment xml:lang="en">Specifies the date when a specific software version was released.</rdfs:comment>
  <rdfs:label xml:lang="en">has version release date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Version"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:date"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasPermissiveness">
  <rdfs:comment xml:lang="en">Describes the permissiveness level or type of a software license.</rdfs:comment>
  <rdfs:label xml:lang="en">has permissiveness</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#License"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isOpenSource">
  <rdfs:comment xml:lang="en">Indicates whether a software tool is open source or not.</rdfs:comment>
  <rdfs:label xml:lang="en">is open source</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isFOSS">
  <rdfs:comment xml:lang="en">Indicates whether a software tool qualifies as Free and Open Source Software (FOSS).</rdfs:comment>
  <rdfs:label xml:lang="en">is FOSS</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:boolean"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isFree">
  <rdfs:comment xml:lang="en">Indicates whether a software tool is free of charge or requires payment.</rdfs:comment>
  <rdfs:label xml:lang="en">is free</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasDocumentationUrl">
  <rdfs:comment xml:lang="en">Specifies the web address or URL where the documentation can be accessed.</rdfs:comment>
  <rdfs:label xml:lang="en">has documentation URL</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Documentation"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:anyURI"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasLanguageName">
  <rdfs:comment xml:lang="en">Specifies the name of a programming language.</rdfs:comment>
  <rdfs:label xml:lang="en">has language name</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ProgrammingLanguage"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

