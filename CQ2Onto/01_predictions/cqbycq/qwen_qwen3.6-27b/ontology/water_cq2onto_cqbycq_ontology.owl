<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure">
  <rdfs:comment xml:lang="en">A system designed to distribute water to consumers.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Distribution Infrastructure</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Asset">
  <rdfs:comment xml:lang="en">A physical component or resource within the infrastructure.</rdfs:comment>
  <rdfs:label xml:lang="en">Asset</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Sensor">
  <rdfs:comment xml:lang="en">A device that detects or measures a physical property and records, indicates, or otherwise responds to it.</rdfs:comment>
  <rdfs:label xml:lang="en">Sensor</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Asset'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Actuator">
  <rdfs:comment xml:lang="en">A device that moves or controls a mechanism or system.</rdfs:comment>
  <rdfs:label xml:lang="en">Actuator</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Asset'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterMeter">
  <rdfs:comment xml:lang="en">A device that measures different aspects of a water infrastructure.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Meter</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Sensor'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Water">
  <rdfs:comment xml:lang="en">The liquid substance distributed through the infrastructure.</rdfs:comment>
  <rdfs:label xml:lang="en">Water</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PhysicalProperty">
  <rdfs:comment xml:lang="en">A measurable characteristic of a substance, such as temperature, pressure, or pH.</rdfs:comment>
  <rdfs:label xml:lang="en">Physical Property</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ChemicalProperty">
  <rdfs:comment xml:lang="en">A characteristic of a substance that describes its ability to undergo a specific chemical change.</rdfs:comment>
  <rdfs:label xml:lang="en">Chemical Property</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterIndicator">
  <rdfs:comment xml:lang="en">A metric or parameter used to assess water quality or distribution status.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Indicator</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#City">
  <rdfs:comment xml:lang="en">A large human settlement or municipality.</rdfs:comment>
  <rdfs:label xml:lang="en">City</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Tariff">
  <rdfs:comment xml:lang="en">A pricing scheme or rate structure applied to water consumption.</rdfs:comment>
  <rdfs:label xml:lang="en">Tariff</rdfs:label>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#composes">
  <rdfs:comment xml:lang="en">Relates an asset to the water distribution infrastructure it is part of.</rdfs:comment>
  <rdfs:label xml:lang="en">composes</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Asset"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usesSensor">
  <rdfs:comment xml:lang="en">Relates a water distribution infrastructure to the sensors it uses.</rdfs:comment>
  <rdfs:label xml:lang="en">usesSensor</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Sensor"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usesActuator">
  <rdfs:comment xml:lang="en">Relates a water distribution infrastructure to the actuators it uses.</rdfs:comment>
  <rdfs:label xml:lang="en">usesActuator</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Actuator"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPhysicalProperty">
  <rdfs:comment xml:lang="en">Relates water to its physical properties.</rdfs:comment>
  <rdfs:label xml:lang="en">hasPhysicalProperty</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Water"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PhysicalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasChemicalProperty">
  <rdfs:comment xml:lang="en">Relates water to its chemical properties.</rdfs:comment>
  <rdfs:label xml:lang="en">hasChemicalProperty</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Water"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#ChemicalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isDefinedFor">
  <rdfs:comment xml:lang="en">Relates a water indicator to the city for which it is defined.</rdfs:comment>
  <rdfs:label xml:lang="en">isDefinedFor</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterIndicator"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#City"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usesTariff">
  <rdfs:comment xml:lang="en">Relates a water meter to the tariff currently in use.</rdfs:comment>
  <rdfs:label xml:lang="en">usesTariff</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Tariff"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasFabricationNumber">
  <rdfs:comment xml:lang="en">Relates a water meter to its fabrication number.</rdfs:comment>
  <rdfs:label xml:lang="en">hasFabricationNumber</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasManufacturer">
  <rdfs:comment xml:lang="en">Relates a water meter to its manufacturer.</rdfs:comment>
  <rdfs:label xml:lang="en">hasManufacturer</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasModel">
  <rdfs:comment xml:lang="en">Relates a water meter to its model.</rdfs:comment>
  <rdfs:label xml:lang="en">hasModel</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasVersion">
  <rdfs:comment xml:lang="en">Relates a water meter to its version.</rdfs:comment>
  <rdfs:label xml:lang="en">hasVersion</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasHardwareVersionNumber">
  <rdfs:comment xml:lang="en">Relates a water meter to its hardware version number.</rdfs:comment>
  <rdfs:label xml:lang="en">hasHardwareVersionNumber</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasFirmwareVersion">
  <rdfs:comment xml:lang="en">Relates a water meter to its firmware version.</rdfs:comment>
  <rdfs:label xml:lang="en">hasFirmwareVersion</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasPower">
  <rdfs:comment xml:lang="en">Relates a water meter to its power consumption or rating.</rdfs:comment>
  <rdfs:label xml:lang="en">hasPower</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:float"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasRadioFrequencyLevel">
  <rdfs:comment xml:lang="en">Relates a water meter to its radio frequency level.</rdfs:comment>
  <rdfs:label xml:lang="en">hasRadioFrequencyLevel</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasGeolocation">
  <rdfs:comment xml:lang="en">Relates a water meter to its geolocation.</rdfs:comment>
  <rdfs:label xml:lang="en">hasGeolocation</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasTemporalSetting">
  <rdfs:comment xml:lang="en">Relates a water meter to its temporal setting for measurements.</rdfs:comment>
  <rdfs:label xml:lang="en">hasTemporalSetting</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasStartDateAndTime">
  <rdfs:comment xml:lang="en">Relates a tariff to its start date and time.</rdfs:comment>
  <rdfs:label xml:lang="en">hasStartDateAndTime</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tariff"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:dateTime"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasDuration">
  <rdfs:comment xml:lang="en">Relates a tariff to its duration.</rdfs:comment>
  <rdfs:label xml:lang="en">hasDuration</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tariff"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:duration"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasTariffPeriod">
  <rdfs:comment xml:lang="en">Relates a water meter to its tariff period.</rdfs:comment>
  <rdfs:label xml:lang="en">hasTariffPeriod</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasBillingDate">
  <rdfs:comment xml:lang="en">Relates a water meter to its billing date.</rdfs:comment>
  <rdfs:label xml:lang="en">hasBillingDate</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:date"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasBillingDatePeriod">
  <rdfs:comment xml:lang="en">Relates a water meter to its billing date period.</rdfs:comment>
  <rdfs:label xml:lang="en">hasBillingDatePeriod</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

</rdf:RDF>