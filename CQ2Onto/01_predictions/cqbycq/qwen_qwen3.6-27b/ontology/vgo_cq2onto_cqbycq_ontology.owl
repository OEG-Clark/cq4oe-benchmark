<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Player">
  <rdfs:comment xml:lang="en">A person who plays a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Player</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Game">
  <rdfs:comment xml:lang="en">A digital or physical game that players can participate in.</rdfs:comment>
  <rdfs:label xml:lang="en">Game</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Achievement">
  <rdfs:comment xml:lang="en">An accomplishment or milestone reached by a player in a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Achievement</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#AchievementType">
  <rdfs:comment xml:lang="en">A category or classification for an achievement.</rdfs:comment>
  <rdfs:label xml:lang="en">Achievement Type</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Genre">
  <rdfs:comment xml:lang="en">A category or style of a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Genre</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Item">
  <rdfs:comment xml:lang="en">An object or resource that can be found or used within a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Item</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Ability">
  <rdfs:comment xml:lang="en">A capability or power that an item can possess or grant.</rdfs:comment>
  <rdfs:label xml:lang="en">Ability</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayerGameStats">
  <rdfs:comment xml:lang="en">A record of a player's performance statistics in a specific game.</rdfs:comment>
  <rdfs:label xml:lang="en">Player Game Stats</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayerGameAchievement">
  <rdfs:comment xml:lang="en">A record linking a player, a game, and an achievement unlocked by the player in that game.</rdfs:comment>
  <rdfs:label xml:lang="en">Player Game Achievement</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Equipment">
  <rdfs:comment xml:lang="en">A piece of gear or tool that a player can use in a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Equipment</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Item'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayerGameEquipment">
  <rdfs:comment xml:lang="en">A record linking a player, a game, and the equipment the player possesses in that game.</rdfs:comment>
  <rdfs:label xml:lang="en">Player Game Equipment</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayerGameItem">
  <rdfs:comment xml:lang="en">A record linking a player, a game, and an item the player uses in that game.</rdfs:comment>
  <rdfs:label xml:lang="en">Player Game Item</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#InAppPurchase">
  <rdfs:comment xml:lang="en">A transaction representing a purchase made within a game application.</rdfs:comment>
  <rdfs:label xml:lang="en">In App Purchase</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Location">
  <rdfs:comment xml:lang="en">A geographical place where a player resides.</rdfs:comment>
  <rdfs:label xml:lang="en">Location</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayerGameInAppPurchase">
  <rdfs:comment xml:lang="en">A record linking a player, a game, and an in-app purchase made by the player in that game.</rdfs:comment>
  <rdfs:label xml:lang="en">Player Game In App Purchase</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayingArea">
  <rdfs:comment xml:lang="en">A distinct region, map, or zone within a game where players can interact or play.</rdfs:comment>
  <rdfs:label xml:lang="en">Playing Area</rdfs:label>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasFriend">
  <rdfs:comment xml:lang="en">Indicates a friend of a player.</rdfs:comment>
  <rdfs:label xml:lang="en">has friend</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#playsGame">
  <rdfs:comment xml:lang="en">Indicates a game that a player participates in.</rdfs:comment>
  <rdfs:label xml:lang="en">plays game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAchievement">
  <rdfs:comment xml:lang="en">Indicates an achievement that a player has unlocked or reached.</rdfs:comment>
  <rdfs:label xml:lang="en">has achievement</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGameAchievement">
  <rdfs:comment xml:lang="en">Indicates an achievement that is defined or available in a game.</rdfs:comment>
  <rdfs:label xml:lang="en">has game achievement</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAchievementType">
  <rdfs:comment xml:lang="en">Indicates the type or category of an achievement.</rdfs:comment>
  <rdfs:label xml:lang="en">has achievement type</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGameAchievementType">
  <rdfs:comment xml:lang="en">Indicates the types of achievements available in a game.</rdfs:comment>
  <rdfs:label xml:lang="en">has game achievement type</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#AchievementType"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGenre">
  <rdfs:comment xml:lang="en">Indicates the genre of a game.</rdfs:comment>
  <rdfs:label xml:lang="en">has genre</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Genre"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasItem">
  <rdfs:comment xml:lang="en">Indicates an item that exists in a game.</rdfs:comment>
  <rdfs:label xml:lang="en">has item</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAbility">
  <rdfs:comment xml:lang="en">Indicates an ability that an item possesses.</rdfs:comment>
  <rdfs:label xml:lang="en">has ability</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Item"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Ability"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPlayer">
  <rdfs:comment xml:lang="en">Indicates the player associated with a set of game statistics.</rdfs:comment>
  <rdfs:label xml:lang="en">has player</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameStats"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGame">
  <rdfs:comment xml:lang="en">Indicates the game in which the statistics were recorded.</rdfs:comment>
  <rdfs:label xml:lang="en">has game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameStats"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#ownsItem">
  <rdfs:comment xml:lang="en">Indicates an item that a player possesses or has in their inventory.</rdfs:comment>
  <rdfs:label xml:lang="en">owns item</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAchievementPlayer">
  <rdfs:comment xml:lang="en">Indicates the player who unlocked the achievement in the game.</rdfs:comment>
  <rdfs:label xml:lang="en">has achievement player</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameAchievement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAchievementGame">
  <rdfs:comment xml:lang="en">Indicates the game in which the achievement was unlocked.</rdfs:comment>
  <rdfs:label xml:lang="en">has achievement game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameAchievement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasUnlockedAchievement">
  <rdfs:comment xml:lang="en">Indicates the achievement that was unlocked by the player in the game.</rdfs:comment>
  <rdfs:label xml:lang="en">has unlocked achievement</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameAchievement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAchievementRecord">
  <rdfs:comment xml:lang="en">Indicates an achievement record associated with a player.</rdfs:comment>
  <rdfs:label xml:lang="en">has achievement record</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PlayerGameAchievement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasEquipmentPlayer">
  <rdfs:comment xml:lang="en">Indicates the player who possesses the equipment in the game.</rdfs:comment>
  <rdfs:label xml:lang="en">has equipment player</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameEquipment"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasEquipmentGame">
  <rdfs:comment xml:lang="en">Indicates the game in which the player possesses the equipment.</rdfs:comment>
  <rdfs:label xml:lang="en">has equipment game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameEquipment"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasEquipmentItem">
  <rdfs:comment xml:lang="en">Indicates the equipment possessed by the player in the game.</rdfs:comment>
  <rdfs:label xml:lang="en">has equipment item</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameEquipment"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Equipment"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasEquipment">
  <rdfs:comment xml:lang="en">Indicates an equipment record associated with a player.</rdfs:comment>
  <rdfs:label xml:lang="en">has equipment</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PlayerGameEquipment"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasItemPlayer">
  <rdfs:comment xml:lang="en">Indicates the player who uses the item in the game.</rdfs:comment>
  <rdfs:label xml:lang="en">has item player</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameItem"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasItemGame">
  <rdfs:comment xml:lang="en">Indicates the game in which the player uses the item.</rdfs:comment>
  <rdfs:label xml:lang="en">has item game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameItem"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasItemUsed">
  <rdfs:comment xml:lang="en">Indicates the item used by the player in the game.</rdfs:comment>
  <rdfs:label xml:lang="en">has item used</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameItem"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasItemUsage">
  <rdfs:comment xml:lang="en">Indicates an item usage record associated with a player.</rdfs:comment>
  <rdfs:label xml:lang="en">has item usage</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PlayerGameItem"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasInAppPurchase">
  <rdfs:comment xml:lang="en">Indicates an in-app purchase made by a player.</rdfs:comment>
  <rdfs:label xml:lang="en">has in app purchase</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#livesIn">
  <rdfs:comment xml:lang="en">Indicates the location where a player lives.</rdfs:comment>
  <rdfs:label xml:lang="en">lives in</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Location"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasIapPlayer">
  <rdfs:comment xml:lang="en">Indicates the player who made the in-app purchase in the game.</rdfs:comment>
  <rdfs:label xml:lang="en">has IAP player</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameInAppPurchase"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasIapGame">
  <rdfs:comment xml:lang="en">Indicates the game in which the in-app purchase was made.</rdfs:comment>
  <rdfs:label xml:lang="en">has IAP game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameInAppPurchase"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasIapPurchase">
  <rdfs:comment xml:lang="en">Indicates the in-app purchase made by the player in the game.</rdfs:comment>
  <rdfs:label xml:lang="en">has IAP purchase</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameInAppPurchase"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasInAppPurchaseRecord">
  <rdfs:comment xml:lang="en">Indicates an in-app purchase record associated with a player.</rdfs:comment>
  <rdfs:label xml:lang="en">has in app purchase record</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PlayerGameInAppPurchase"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPlayingArea">
  <rdfs:comment xml:lang="en">Indicates a playing area that is part of a game.</rdfs:comment>
  <rdfs:label xml:lang="en">has playing area</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasUsername">
  <rdfs:comment xml:lang="en">The username associated with a player.</rdfs:comment>
  <rdfs:label xml:lang="en">has username</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasTotalPlaytime">
  <rdfs:comment xml:lang="en">The total number of hours a game has been played.</rdfs:comment>
  <rdfs:label xml:lang="en">has total playtime</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasReleaseDate">
  <rdfs:comment xml:lang="en">The date on which a game was released.</rdfs:comment>
  <rdfs:label xml:lang="en">has release date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:date"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasKillCount">
  <rdfs:comment xml:lang="en">The number of kills achieved by a player in a specific game.</rdfs:comment>
  <rdfs:label xml:lang="en">has kill count</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameStats"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasPlayedDate">
  <rdfs:comment xml:lang="en">The date on which a player last played a specific game, recorded in the player's game statistics.</rdfs:comment>
  <rdfs:label xml:lang="en">has played date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameStats"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:date"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasPurchaseDate">
  <rdfs:comment xml:lang="en">The date on which an in-app purchase was made.</rdfs:comment>
  <rdfs:label xml:lang="en">has purchase date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:date"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasPurchaseAmount">
  <rdfs:comment xml:lang="en">The amount of money spent in an in-app purchase.</rdfs:comment>
  <rdfs:label xml:lang="en">has purchase amount</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasPurchaseTime">
  <rdfs:comment xml:lang="en">The time at which an in-app purchase was made.</rdfs:comment>
  <rdfs:label xml:lang="en">has purchase time</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:time"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasPlaytimeBeforeIap">
  <rdfs:comment xml:lang="en">The amount of time a player spent in the game before making the in-app purchase.</rdfs:comment>
  <rdfs:label xml:lang="en">has playtime before IAP</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameInAppPurchase"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:decimal"/>
</owl:DatatypeProperty>

</rdf:RDF>