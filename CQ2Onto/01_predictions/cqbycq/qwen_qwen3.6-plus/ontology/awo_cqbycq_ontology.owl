<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Animal">
  <rdfs:comment xml:lang="en">A multicellular, eukaryotic organism belonging to the biological kingdom Animalia.</rdfs:comment>
  <rdfs:label xml:lang="en">Animal</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Plant">
  <rdfs:comment xml:lang="en">A multicellular, eukaryotic organism belonging to the biological kingdom Plantae, typically capable of photosynthesis.</rdfs:comment>
  <rdfs:label xml:lang="en">Plant</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Herbivore">
  <rdfs:comment xml:lang="en">An animal that feeds primarily on plants.</rdfs:comment>
  <rdfs:label xml:lang="en">Herbivore</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Animal'/><rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource='http://www.semanticweb.org/myontology#eats'/><owl:someValuesFrom rdf:resource='http://www.semanticweb.org/myontology#Plant'/></owl:Restriction></rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlantPart">
  <rdfs:comment xml:lang="en">A distinct structural component or organ of a plant, such as a leaf, root, stem, flower, or fruit.</rdfs:comment>
  <rdfs:label xml:lang="en">Plant Part</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Omnivore">
  <rdfs:comment xml:lang="en">An animal that feeds on both plants and other animals.</rdfs:comment>
  <rdfs:label xml:lang="en">Omnivore</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Animal'/><rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource='http://www.semanticweb.org/myontology#eats'/><owl:someValuesFrom rdf:resource='http://www.semanticweb.org/myontology#Plant'/></owl:Restriction></rdfs:subClassOf><rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource='http://www.semanticweb.org/myontology#eats'/><owl:someValuesFrom rdf:resource='http://www.semanticweb.org/myontology#Animal'/></owl:Restriction></rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Carnivore">
  <rdfs:comment xml:lang="en">An animal that feeds primarily on other animals.</rdfs:comment>
  <rdfs:label xml:lang="en">Carnivore</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Animal'/><rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource='http://www.semanticweb.org/myontology#eats'/><owl:someValuesFrom rdf:resource='http://www.semanticweb.org/myontology#Animal'/></owl:Restriction></rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Lion">
  <rdfs:comment xml:lang="en">A large wild cat native to Africa and India, known for living in prides and hunting cooperatively.</rdfs:comment>
  <rdfs:label xml:lang="en">Lion</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Carnivore'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#CarnivorousPlant">
  <rdfs:comment xml:lang="en">A plant that derives some or most of its nutrients from trapping and consuming animals.</rdfs:comment>
  <rdfs:label xml:lang="en">Carnivorous Plant</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Plant'/><rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource='http://www.semanticweb.org/myontology#consumes'/><owl:someValuesFrom rdf:resource='http://www.semanticweb.org/myontology#Animal'/></owl:Restriction></rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#FacultativeCarnivore">
  <rdfs:comment xml:lang="en">A carnivorous animal that also consumes plants or plant parts as part of its diet.</rdfs:comment>
  <rdfs:label xml:lang="en">Facultative Carnivore</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Carnivore'/><rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource='http://www.semanticweb.org/myontology#eats'/><owl:someValuesFrom rdf:resource='http://www.semanticweb.org/myontology#Plant'/></owl:Restriction></rdfs:subClassOf>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#eats">
  <rdfs:comment xml:lang="en">A relationship indicating that one animal consumes another animal as food.</rdfs:comment>
  <rdfs:label xml:lang="en">eats</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#eatsPlantPart">
  <rdfs:comment xml:lang="en">A relationship indicating that an animal consumes a specific part of a plant.</rdfs:comment>
  <rdfs:label xml:lang="en">eats plant part</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PlantPart"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#consumes">
  <rdfs:comment xml:lang="en">A relationship indicating that a plant traps and consumes an animal for nutrients.</rdfs:comment>
  <rdfs:label xml:lang="en">consumes</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Plant"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
</owl:ObjectProperty>

</rdf:RDF>