<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#TransferRight">
  <rdfs:comment xml:lang="en">A type of permission that grants the ability to transfer, move, or reassign data or resources.</rdfs:comment>
  <rdfs:label xml:lang="en">Transfer Right</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Aggregation">
  <rdfs:comment xml:lang="en">A permission that allows combining multiple data items or resources into a single collection or dataset.</rdfs:comment>
  <rdfs:label xml:lang="en">Aggregation</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#TransferRight'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Disaggregation">
  <rdfs:comment xml:lang="en">A permission that allows separating or breaking down a combined dataset or resource into its constituent parts.</rdfs:comment>
  <rdfs:label xml:lang="en">Disaggregation</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#TransferRight'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ContractParty">
  <rdfs:comment xml:lang="en">An individual or organization that participates in a contract.</rdfs:comment>
  <rdfs:label xml:lang="en">Contract Party</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Role">
  <rdfs:comment xml:lang="en">A function or position assumed by a contract party within a specific legal or operational context.</rdfs:comment>
  <rdfs:label xml:lang="en">Role</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Permission">
  <rdfs:comment xml:lang="en">A right or authorization granted to a party to perform a specific action.</rdfs:comment>
  <rdfs:label xml:lang="en">Permission</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Rule'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Duty">
  <rdfs:comment xml:lang="en">An obligation or requirement imposed on a party to perform or refrain from a specific action.</rdfs:comment>
  <rdfs:label xml:lang="en">Duty</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PartyRoleAssignment">
  <rdfs:comment xml:lang="en">A reified relationship that links a contract party to a specific role within a permission or duty context.</rdfs:comment>
  <rdfs:label xml:lang="en">Party Role Assignment</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Negation">
  <rdfs:comment xml:lang="en">A logical expression that represents the negation or denial of another concept, typically used to specify what is not permitted or required.</rdfs:comment>
  <rdfs:label xml:lang="en">Negation</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PartyRightDutySupport">
  <rdfs:comment xml:lang="en">A reified relationship that captures how a specific right or duty is supported or granted to a contract party.</rdfs:comment>
  <rdfs:label xml:lang="en">Party Right Duty Support</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Constraint">
  <rdfs:comment xml:lang="en">A condition or restriction that limits the scope or applicability of a permission or duty.</rdfs:comment>
  <rdfs:label xml:lang="en">Constraint</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#LogicalConstraint">
  <rdfs:comment xml:lang="en">A constraint that combines multiple sub-constraints using a logical operator, enabling nested constraint structures.</rdfs:comment>
  <rdfs:label xml:lang="en">Logical Constraint</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Constraint'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#AndConstraint">
  <rdfs:comment xml:lang="en">A logical constraint that requires all of its sub-constraints to be satisfied simultaneously.</rdfs:comment>
  <rdfs:label xml:lang="en">And Constraint</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#LogicalConstraint'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#OrConstraint">
  <rdfs:comment xml:lang="en">A logical constraint that requires at least one of its sub-constraints to be satisfied.</rdfs:comment>
  <rdfs:label xml:lang="en">Or Constraint</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#LogicalConstraint'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#XorConstraint">
  <rdfs:comment xml:lang="en">A logical constraint that requires exactly one of its sub-constraints to be satisfied, excluding the others.</rdfs:comment>
  <rdfs:label xml:lang="en">Xor Constraint</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#LogicalConstraint'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Requirement">
  <rdfs:comment xml:lang="en">A stipulation or condition that must be fulfilled or satisfied within a contract or agreement.</rdfs:comment>
  <rdfs:label xml:lang="en">Requirement</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ExclusivePermission">
  <rdfs:comment xml:lang="en">A permission that is granted to a specific party to the exclusion of all others, ensuring that no other party can exercise the same right.</rdfs:comment>
  <rdfs:label xml:lang="en">Exclusive Permission</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Permission'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Condition">
  <rdfs:comment xml:lang="en">A stipulation or state of affairs that must be satisfied for a contractual provision to become active or valid.</rdfs:comment>
  <rdfs:label xml:lang="en">Condition</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Container">
  <rdfs:comment xml:lang="en">A structural grouping mechanism in ODRL that aggregates assets, permissions, duties, and other rules into a single logical unit. Removing containers eliminates the ability to manage and apply rights collectively to grouped resources.</rdfs:comment>
  <rdfs:label xml:lang="en">Container</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Asset">
  <rdfs:comment xml:lang="en">A digital or physical resource that is the subject of permissions, duties, or prohibitions within a rights expression.</rdfs:comment>
  <rdfs:label xml:lang="en">Asset</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Sequencing">
  <rdfs:comment xml:lang="en">A constraint that specifies an ordered sequence of actions, permissions, or duties that must be executed in a particular order.</rdfs:comment>
  <rdfs:label xml:lang="en">Sequencing</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Constraint'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#SequenceStep">
  <rdfs:comment xml:lang="en">A reified element representing a single item and its position within a sequencing constraint.</rdfs:comment>
  <rdfs:label xml:lang="en">Sequence Step</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Inheritance">
  <rdfs:comment xml:lang="en">A reified relationship that captures how one entity derives attributes, rights, or structure from another entity.</rdfs:comment>
  <rdfs:label xml:lang="en">Inheritance</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Policy">
  <rdfs:comment xml:lang="en">A set of rules, permissions, duties, and constraints that govern the use or management of one or more assets.</rdfs:comment>
  <rdfs:label xml:lang="en">Policy</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ConflictResolutionStrategy">
  <rdfs:comment xml:lang="en">A strategy or method used to resolve conflicts between overlapping or contradictory rules, permissions, or duties within a policy.</rdfs:comment>
  <rdfs:label xml:lang="en">Conflict Resolution Strategy</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Prohibition">
  <rdfs:comment xml:lang="en">A rule or constraint that explicitly forbids a specific action or use of an asset, the violation of which may trigger a remedial duty.</rdfs:comment>
  <rdfs:label xml:lang="en">Prohibition</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Rule'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Rule">
  <rdfs:comment xml:lang="en">A generic concept representing a permission, duty, or prohibition that governs actions or obligations within a policy.</rdfs:comment>
  <rdfs:label xml:lang="en">Rule</rdfs:label>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasParty">
  <rdfs:comment xml:lang="en">Links a role assignment to the contract party involved.</rdfs:comment>
  <rdfs:label xml:lang="en">has party</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PartyRoleAssignment"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#ContractParty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasRole">
  <rdfs:comment xml:lang="en">Links a role assignment to the specific role played.</rdfs:comment>
  <rdfs:label xml:lang="en">has role</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PartyRoleAssignment"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Role"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#appliesToPermission">
  <rdfs:comment xml:lang="en">Links a role assignment to the permission it concerns.</rdfs:comment>
  <rdfs:label xml:lang="en">applies to permission</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PartyRoleAssignment"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Permission"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#appliesToDuty">
  <rdfs:comment xml:lang="en">Links a role assignment to the duty it concerns.</rdfs:comment>
  <rdfs:label xml:lang="en">applies to duty</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PartyRoleAssignment"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Duty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#negates">
  <rdfs:comment xml:lang="en">Links a negation expression to the specific permission, duty, or concept that is being denied or negated.</rdfs:comment>
  <rdfs:label xml:lang="en">negates</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Negation"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Permission"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasSupportingParty">
  <rdfs:comment xml:lang="en">Links a right or duty support instance to the contract party that is being supported.</rdfs:comment>
  <rdfs:label xml:lang="en">has supporting party</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PartyRightDutySupport"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#ContractParty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#supportsRight">
  <rdfs:comment xml:lang="en">Links a support instance to the specific permission or right being supported.</rdfs:comment>
  <rdfs:label xml:lang="en">supports right</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PartyRightDutySupport"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Permission"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#supportsDuty">
  <rdfs:comment xml:lang="en">Links a support instance to the specific duty or obligation being supported.</rdfs:comment>
  <rdfs:label xml:lang="en">supports duty</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PartyRightDutySupport"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Duty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasConstraint">
  <rdfs:comment xml:lang="en">Links a rule (permission, duty, or prohibition) to the constraints that apply to it.</rdfs:comment>
  <rdfs:label xml:lang="en">has constraint</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasSubConstraint">
  <rdfs:comment xml:lang="en">Links a logical constraint to its nested sub-constraints, allowing recursive composition.</rdfs:comment>
  <rdfs:label xml:lang="en">has sub constraint</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#LogicalConstraint"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#expressesCondition">
  <rdfs:comment xml:lang="en">Links a constraint to the specific condition it defines or expresses.</rdfs:comment>
  <rdfs:label xml:lang="en">expresses condition</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Constraint"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Condition"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#containsAsset">
  <rdfs:comment xml:lang="en">Links a container to the assets it groups.</rdfs:comment>
  <rdfs:label xml:lang="en">contains asset</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Container"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Asset"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#containsPermission">
  <rdfs:comment xml:lang="en">Links a container to the permissions it groups.</rdfs:comment>
  <rdfs:label xml:lang="en">contains permission</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Container"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Permission"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#containsDuty">
  <rdfs:comment xml:lang="en">Links a container to the duties it groups.</rdfs:comment>
  <rdfs:label xml:lang="en">contains duty</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Container"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Duty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasSequenceStep">
  <rdfs:comment xml:lang="en">Links a sequencing constraint to its individual sequence steps.</rdfs:comment>
  <rdfs:label xml:lang="en">has sequence step</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Sequencing"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SequenceStep"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#stepTarget">
  <rdfs:comment xml:lang="en">Links a sequence step to the specific permission or duty that is being sequenced.</rdfs:comment>
  <rdfs:label xml:lang="en">step target</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SequenceStep"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Permission"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#inheritsFrom">
  <rdfs:comment xml:lang="en">Links an entity to another entity from which it inherits characteristics, permissions, or structure.</rdfs:comment>
  <rdfs:label xml:lang="en">inherits from</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#inheritedBy">
  <rdfs:comment xml:lang="en">Links an entity to another entity that inherits characteristics, permissions, or structure from it.</rdfs:comment>
  <rdfs:label xml:lang="en">inherited by</rdfs:label>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#inheritsFrom'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAsset">
  <rdfs:comment xml:lang="en">Links a policy to the asset it governs or applies to.</rdfs:comment>
  <rdfs:label xml:lang="en">has asset</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Asset"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasConflictResolutionStrategy">
  <rdfs:comment xml:lang="en">Links a policy to the conflict resolution strategy it employs to handle rule conflicts.</rdfs:comment>
  <rdfs:label xml:lang="en">has conflict resolution strategy</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Policy"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#ConflictResolutionStrategy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasRemedyDuty">
  <rdfs:comment xml:lang="en">Links a prohibition to the duty that must be performed as a remedy if the prohibition is violated.</rdfs:comment>
  <rdfs:label xml:lang="en">has remedy duty</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Prohibition"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Duty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#activatesUponFailure">
  <rdfs:comment xml:lang="en">Links a rule to another rule that becomes active or enforceable when the first rule is violated or fails.</rdfs:comment>
  <rdfs:label xml:lang="en">activates upon failure</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Rule"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasConsequenceDuty">
  <rdfs:comment xml:lang="en">Links a duty to another duty that is specified as its consequence.</rdfs:comment>
  <rdfs:label xml:lang="en">has consequence duty</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Duty"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Duty"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#constraintOperator">
  <rdfs:comment xml:lang="en">Specifies the logical operator (e.g., 'and', 'or', 'not') used to combine sub-constraints within a logical constraint.</rdfs:comment>
  <rdfs:label xml:lang="en">constraint operator</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#LogicalConstraint"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#stepIndex">
  <rdfs:comment xml:lang="en">Specifies the numerical order or position of a step within a sequence.</rdfs:comment>
  <rdfs:label xml:lang="en">step index</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#SequenceStep"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

</rdf:RDF>