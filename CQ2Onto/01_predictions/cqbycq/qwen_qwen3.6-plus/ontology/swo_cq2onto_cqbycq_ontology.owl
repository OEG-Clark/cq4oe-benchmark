<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Tool">
  <rdfs:comment xml:lang="en">A software or hardware instrument designed to perform specific computational or analytical tasks.</rdfs:comment>
  <rdfs:label xml:lang="en">Tool</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Algorithm">
  <rdfs:comment xml:lang="en">A well-defined, named, and published computational procedure or set of rules that takes input and produces output.</rdfs:comment>
  <rdfs:label xml:lang="en">Algorithm</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#AlgorithmModification">
  <rdfs:comment xml:lang="en">A record of changes or updates made to an algorithm, particularly in the context of its use by a tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Algorithm Modification</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Capability">
  <rdfs:comment xml:lang="en">A specific function or feature that a software tool can perform or offer.</rdfs:comment>
  <rdfs:label xml:lang="en">Capability</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#XmlEditing">
  <rdfs:comment xml:lang="en">The capability to create, modify, and validate XML documents.</rdfs:comment>
  <rdfs:label xml:lang="en">XML Editing</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Capability'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#SoftwareType">
  <rdfs:comment xml:lang="en">A category or classification describing the deployment or interface style of a software tool, such as API, Desktop application, or Web application.</rdfs:comment>
  <rdfs:label xml:lang="en">Software Type</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Task">
  <rdfs:comment xml:lang="en">A specific activity, objective, or goal that a user aims to accomplish, potentially with the help of software.</rdfs:comment>
  <rdfs:label xml:lang="en">Task</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WebService">
  <rdfs:comment xml:lang="en">A software type that indicates the tool is deployed and accessible over the web as a service.</rdfs:comment>
  <rdfs:label xml:lang="en">Web Service</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#SoftwareType'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#GifRendering">
  <rdfs:comment xml:lang="en">The capability to process, decode, and render Graphics Interchange Format (GIF) images or animations.</rdfs:comment>
  <rdfs:label xml:lang="en">GIF Rendering</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Capability'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Data">
  <rdfs:comment xml:lang="en">A collection of information, records, or digital content generated or processed by software tools.</rdfs:comment>
  <rdfs:label xml:lang="en">Data</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ToolDataTaskUsage">
  <rdfs:comment xml:lang="en">A reified relationship capturing the context in which a specific software tool utilizes particular data to support a given task.</rdfs:comment>
  <rdfs:label xml:lang="en">Tool Data Task Usage</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Format">
  <rdfs:comment xml:lang="en">A specific data representation, file structure, or encoding standard used for exchanging information with a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Format</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#CelFormat">
  <rdfs:comment xml:lang="en">A file format used for storing microarray intensity data, typically identified by the .cel extension.</rdfs:comment>
  <rdfs:label xml:lang="en">CEL Format</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Format'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#FormatConversion">
  <rdfs:comment xml:lang="en">A reified relationship capturing the capability or action of a software tool to convert or export data from a source format to a target format.</rdfs:comment>
  <rdfs:label xml:lang="en">Format Conversion</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#CsvFormat">
  <rdfs:comment xml:lang="en">A comma-separated values file format used for storing tabular data, widely supported as an open standard.</rdfs:comment>
  <rdfs:label xml:lang="en">CSV Format</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Format'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#TxtFormat">
  <rdfs:comment xml:lang="en">A plain text file format containing unformatted character data, commonly used for open data exchange.</rdfs:comment>
  <rdfs:label xml:lang="en">TXT Format</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Format'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ToolDataCompatibility">
  <rdfs:comment xml:lang="en">A reified relationship capturing the interoperability between two software tools, indicating that a target tool can process or utilize data generated by a source tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Tool Data Compatibility</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#License">
  <rdfs:comment xml:lang="en">A legal agreement or set of rights governing the use, modification, and distribution of software.</rdfs:comment>
  <rdfs:label xml:lang="en">License</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#MaintenanceStatus">
  <rdfs:comment xml:lang="en">The current state of active development, support, or updates for a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Maintenance Status</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ToolVersion">
  <rdfs:comment xml:lang="en">A specific release or iteration of a software tool, typically identified by a version number or tag.</rdfs:comment>
  <rdfs:label xml:lang="en">Tool Version</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#HelpResource">
  <rdfs:comment xml:lang="en">A resource, such as documentation, a forum, or a contact point, that provides assistance or guidance for using a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Help Resource</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Developer">
  <rdfs:comment xml:lang="en">An individual, group, or organization responsible for creating or maintaining a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Developer</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Collaboration">
  <rdfs:comment xml:lang="en">A record or opportunity for collaborating with a software developer or organization, capturing contact details and status.</rdfs:comment>
  <rdfs:label xml:lang="en">Collaboration</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ProgrammingLanguage">
  <rdfs:comment xml:lang="en">A formal language used to write source code for software tools or algorithms.</rdfs:comment>
  <rdfs:label xml:lang="en">Programming Language</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Platform">
  <rdfs:comment xml:lang="en">A computing environment, operating system, or hardware architecture on which a software tool can be executed.</rdfs:comment>
  <rdfs:label xml:lang="en">Platform</rdfs:label>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usesAlgorithm">
  <rdfs:comment xml:lang="en">Relates a tool to the algorithm(s) it employs or implements.</rdfs:comment>
  <rdfs:label xml:lang="en">uses algorithm</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#modifiesAlgorithm">
  <rdfs:comment xml:lang="en">Relates a modification record to the algorithm it alters.</rdfs:comment>
  <rdfs:label xml:lang="en">modifies algorithm</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#AlgorithmModification"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usedByTool">
  <rdfs:comment xml:lang="en">Relates a modification record to the tool that employs the modified algorithm.</rdfs:comment>
  <rdfs:label xml:lang="en">used by tool</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#AlgorithmModification"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#providesCapability">
  <rdfs:comment xml:lang="en">Relates a tool to the specific capabilities or features it provides.</rdfs:comment>
  <rdfs:label xml:lang="en">provides capability</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Capability"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasSoftwareType">
  <rdfs:comment xml:lang="en">Relates a tool to its specific software type or deployment category.</rdfs:comment>
  <rdfs:label xml:lang="en">has software type</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareType"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#performsTask">
  <rdfs:comment xml:lang="en">Relates a software tool to the task(s) it is capable of performing or supporting.</rdfs:comment>
  <rdfs:label xml:lang="en">performs task</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Task"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#createsData">
  <rdfs:comment xml:lang="en">Relates a software tool to the data it generates or produces.</rdfs:comment>
  <rdfs:label xml:lang="en">creates data</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Data"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#involvesTool">
  <rdfs:comment xml:lang="en">Relates a tool-data-task usage instance to the software tool involved.</rdfs:comment>
  <rdfs:label xml:lang="en">involves tool</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ToolDataTaskUsage"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#involvesData">
  <rdfs:comment xml:lang="en">Relates a tool-data-task usage instance to the data being used.</rdfs:comment>
  <rdfs:label xml:lang="en">involves data</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ToolDataTaskUsage"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Data"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#involvesTask">
  <rdfs:comment xml:lang="en">Relates a tool-data-task usage instance to the task being supported.</rdfs:comment>
  <rdfs:label xml:lang="en">involves task</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ToolDataTaskUsage"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Task"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasInputFormat">
  <rdfs:comment xml:lang="en">Relates a software tool to the data formats it accepts as input.</rdfs:comment>
  <rdfs:label xml:lang="en">has input format</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Format"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasOutputFormat">
  <rdfs:comment xml:lang="en">Relates a software tool to the data formats it produces or exports.</rdfs:comment>
  <rdfs:label xml:lang="en">has output format</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Format"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#performedByTool">
  <rdfs:comment xml:lang="en">Relates a format conversion instance to the software tool that performs it.</rdfs:comment>
  <rdfs:label xml:lang="en">performed by tool</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#FormatConversion"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#sourceFormat">
  <rdfs:comment xml:lang="en">Relates a format conversion instance to the original data format being converted from.</rdfs:comment>
  <rdfs:label xml:lang="en">source format</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#FormatConversion"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Format"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#targetFormat">
  <rdfs:comment xml:lang="en">Relates a format conversion instance to the destination data format being converted to.</rdfs:comment>
  <rdfs:label xml:lang="en">target format</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#FormatConversion"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Format"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#sourceTool">
  <rdfs:comment xml:lang="en">Relates a tool data compatibility instance to the software tool that generates or outputs the data.</rdfs:comment>
  <rdfs:label xml:lang="en">source tool</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ToolDataCompatibility"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#targetTool">
  <rdfs:comment xml:lang="en">Relates a tool data compatibility instance to the software tool that consumes or works with the data.</rdfs:comment>
  <rdfs:label xml:lang="en">target tool</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ToolDataCompatibility"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#exchangedData">
  <rdfs:comment xml:lang="en">Relates a tool data compatibility instance to the specific data that is output by the source tool and consumed by the target tool.</rdfs:comment>
  <rdfs:label xml:lang="en">exchanged data</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ToolDataCompatibility"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Data"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasLicense">
  <rdfs:comment xml:lang="en">Relates a software tool to the license under which it is distributed.</rdfs:comment>
  <rdfs:label xml:lang="en">has license</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#License"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasMaintenanceStatus">
  <rdfs:comment xml:lang="en">Relates a software tool to its current maintenance or development status.</rdfs:comment>
  <rdfs:label xml:lang="en">has maintenance status</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#MaintenanceStatus"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasVersion">
  <rdfs:comment xml:lang="en">Relates a software tool to its specific version or release.</rdfs:comment>
  <rdfs:label xml:lang="en">has version</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#ToolVersion"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#exportsData">
  <rdfs:comment xml:lang="en">Relates a specific tool version to the data it can generate or export.</rdfs:comment>
  <rdfs:label xml:lang="en">exports data</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ToolVersion"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Data"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasHelpResource">
  <rdfs:comment xml:lang="en">Relates a software tool to a resource that provides help or support.</rdfs:comment>
  <rdfs:label xml:lang="en">has help resource</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#HelpResource"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#developedBy">
  <rdfs:comment xml:lang="en">Relates a software tool to the developer or organization that created it.</rdfs:comment>
  <rdfs:label xml:lang="en">developed by</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Developer"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#involvesDeveloper">
  <rdfs:comment xml:lang="en">Relates a collaboration instance to the developer or organization involved.</rdfs:comment>
  <rdfs:label xml:lang="en">involves developer</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Collaboration"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Developer"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#introducesCapability">
  <rdfs:comment xml:lang="en">Relates a specific tool version to the new capabilities or features it introduces.</rdfs:comment>
  <rdfs:label xml:lang="en">introduces capability</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ToolVersion"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Capability"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#implementedInLanguage">
  <rdfs:comment xml:lang="en">Relates a software tool to the programming language in which it was implemented.</rdfs:comment>
  <rdfs:label xml:lang="en">implemented in language</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#ProgrammingLanguage"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#runsOnPlatform">
  <rdfs:comment xml:lang="en">Relates a software tool to the computing platform or operating system it is designed to run on.</rdfs:comment>
  <rdfs:label xml:lang="en">runs on platform</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Platform"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#modificationDate">
  <rdfs:comment xml:lang="en">The date and time when the algorithm modification was made.</rdfs:comment>
  <rdfs:label xml:lang="en">modification date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#AlgorithmModification"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#modificationDescription">
  <rdfs:comment xml:lang="en">A textual description of the changes made to the algorithm.</rdfs:comment>
  <rdfs:label xml:lang="en">modification description</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#AlgorithmModification"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#versionIdentifier">
  <rdfs:comment xml:lang="en">The alphanumeric string or number identifying a specific tool version.</rdfs:comment>
  <rdfs:label xml:lang="en">version identifier</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ToolVersion"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#downloadUrl">
  <rdfs:comment xml:lang="en">The URL or web address where the software tool can be downloaded or accessed.</rdfs:comment>
  <rdfs:label xml:lang="en">download URL</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#helpUrl">
  <rdfs:comment xml:lang="en">The web address where the help resource can be accessed.</rdfs:comment>
  <rdfs:label xml:lang="en">help URL</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#HelpResource"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#helpDescription">
  <rdfs:comment xml:lang="en">A brief description of the type of help or support provided by the resource.</rdfs:comment>
  <rdfs:label xml:lang="en">help description</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#HelpResource"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#homepageUrl">
  <rdfs:comment xml:lang="en">The URL or web address of the official homepage for the software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">homepage URL</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#collaborationContact">
  <rdfs:comment xml:lang="en">The contact information (e.g., email, URL) for initiating collaboration with a developer.</rdfs:comment>
  <rdfs:label xml:lang="en">collaboration contact</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Collaboration"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#collaborationType">
  <rdfs:comment xml:lang="en">The type or nature of the collaboration, such as research partnership, open-source contribution, or commercial licensing.</rdfs:comment>
  <rdfs:label xml:lang="en">collaboration type</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Collaboration"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#collaborationStatus">
  <rdfs:comment xml:lang="en">The current status of the collaboration opportunity, e.g., open, closed, or under negotiation.</rdfs:comment>
  <rdfs:label xml:lang="en">collaboration status</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Collaboration"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#creationDate">
  <rdfs:comment xml:lang="en">The date when the software tool was initially created or first released.</rdfs:comment>
  <rdfs:label xml:lang="en">creation date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#releaseDate">
  <rdfs:comment xml:lang="en">The date and time when a specific tool version was officially released.</rdfs:comment>
  <rdfs:label xml:lang="en">release date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ToolVersion"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isOpenSource">
  <rdfs:comment xml:lang="en">Indicates whether the software tool is developed and distributed under an open source license.</rdfs:comment>
  <rdfs:label xml:lang="en">is open source</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasCommunityDevelopment">
  <rdfs:comment xml:lang="en">Indicates whether the software tool is developed collaboratively by a community of contributors.</rdfs:comment>
  <rdfs:label xml:lang="en">has community development</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasPermissiveness">
  <rdfs:comment xml:lang="en">Indicates the level of permissiveness of a software license, describing how freely the software can be used, modified, and distributed.</rdfs:comment>
  <rdfs:label xml:lang="en">has permissiveness</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#License"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isFoss">
  <rdfs:comment xml:lang="en">Indicates whether the software tool is classified as Free and Open Source Software (FOSS).</rdfs:comment>
  <rdfs:label xml:lang="en">is FOSS</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isFree">
  <rdfs:comment xml:lang="en">Indicates whether the software tool is available free of charge.</rdfs:comment>
  <rdfs:label xml:lang="en">is free</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:boolean"/>
</owl:DatatypeProperty>

</rdf:RDF>