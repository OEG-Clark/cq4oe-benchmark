<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Wine">
  <rdfs:comment xml:lang="en">A beverage made from fermented grapes.</rdfs:comment>
  <rdfs:label xml:lang="en">Wine</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WineCharacteristic">
  <rdfs:comment xml:lang="en">A feature or attribute of a wine, such as taste, aroma, or color.</rdfs:comment>
  <rdfs:label xml:lang="en">Wine Characteristic</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#RedWine">
  <rdfs:comment xml:lang="en">A type of wine that is red in color.</rdfs:comment>
  <rdfs:label xml:lang="en">Red Wine</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Wine'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WhiteWine">
  <rdfs:comment xml:lang="en">A type of wine that is white in color.</rdfs:comment>
  <rdfs:label xml:lang="en">White Wine</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Wine'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Bordeaux">
  <rdfs:comment xml:lang="en">A wine region in France known for producing red and white wines, primarily red.</rdfs:comment>
  <rdfs:label xml:lang="en">Bordeaux</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#RedWine'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#VintageYear">
  <rdfs:comment xml:lang="en">A specific year in which a wine was produced.</rdfs:comment>
  <rdfs:label xml:lang="en">Vintage Year</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WineCharacteristicInstance">
  <rdfs:comment xml:lang="en">A specific instance of a wine characteristic for a wine at a specific vintage year.</rdfs:comment>
  <rdfs:label xml:lang="en">Wine Characteristic Instance</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WineRegion">
  <rdfs:comment xml:lang="en">A geographical area known for wine production.</rdfs:comment>
  <rdfs:label xml:lang="en">Wine Region</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#GrapeVariety">
  <rdfs:comment xml:lang="en">A specific variety of grape used in winemaking.</rdfs:comment>
  <rdfs:label xml:lang="en">Grape Variety</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Napa">
  <rdfs:comment xml:lang="en">A renowned wine region in California, USA.</rdfs:comment>
  <rdfs:label xml:lang="en">Napa</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#WineRegion'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Zinfandel">
  <rdfs:comment xml:lang="en">A dark-skinned grape variety used to make red wine.</rdfs:comment>
  <rdfs:label xml:lang="en">Zinfandel</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#GrapeVariety'/>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasCharacteristic">
  <rdfs:comment xml:lang="en">Relates a wine to its characteristics.</rdfs:comment>
  <rdfs:label xml:lang="en">has characteristic</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WineCharacteristic"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#relatesToWine">
  <rdfs:comment xml:lang="en">Relates a wine characteristic instance to the wine it describes.</rdfs:comment>
  <rdfs:label xml:lang="en">relates to wine</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WineCharacteristicInstance"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasCharacteristicType">
  <rdfs:comment xml:lang="en">Relates a wine characteristic instance to its characteristic type.</rdfs:comment>
  <rdfs:label xml:lang="en">has characteristic type</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WineCharacteristicInstance"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WineCharacteristic"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasVintageYear">
  <rdfs:comment xml:lang="en">Relates a wine characteristic instance to the vintage year it applies to.</rdfs:comment>
  <rdfs:label xml:lang="en">has vintage year</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WineCharacteristicInstance"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#VintageYear"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasRegion">
  <rdfs:comment xml:lang="en">Relates a wine to its region of origin.</rdfs:comment>
  <rdfs:label xml:lang="en">has region</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WineRegion"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGrapeVariety">
  <rdfs:comment xml:lang="en">Relates a wine to the grape variety it is made from.</rdfs:comment>
  <rdfs:label xml:lang="en">has grape variety</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#GrapeVariety"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasQuality">
  <rdfs:comment xml:lang="en">Relates a wine characteristic instance to its quality rating.</rdfs:comment>
  <rdfs:label xml:lang="en">has quality</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WineCharacteristicInstance"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

</rdf:RDF>