<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Tool">
  <rdfs:comment xml:lang="en">A software application or system.</rdfs:comment>
  <rdfs:label xml:lang="en">Tool</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Algorithm">
  <rdfs:comment xml:lang="en">A named and published procedure for solving a problem.</rdfs:comment>
  <rdfs:label xml:lang="en">Algorithm</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#AlgorithmUsage">
  <rdfs:comment xml:lang="en">Represents a specific instance of a tool employing an algorithm, allowing for tracking of usage-specific attributes such as modifications.</rdfs:comment>
  <rdfs:label xml:lang="en">Algorithm Usage</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Feature">
  <rdfs:comment xml:lang="en">A capability or function provided by a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Feature</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#XMLEditing">
  <rdfs:comment xml:lang="en">A feature that allows users to edit XML documents.</rdfs:comment>
  <rdfs:label xml:lang="en">XML Editing</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Feature'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#SoftwareType">
  <rdfs:comment xml:lang="en">The category or type of software, e.g., API, Desktop application, Web service.</rdfs:comment>
  <rdfs:label xml:lang="en">Software Type</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Task">
  <rdfs:comment xml:lang="en">A specific activity or operation that software can perform.</rdfs:comment>
  <rdfs:label xml:lang="en">Task</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WebService">
  <rdfs:comment xml:lang="en">A software type that provides functionality over a network via web protocols.</rdfs:comment>
  <rdfs:label xml:lang="en">Web Service</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#SoftwareType'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Data">
  <rdfs:comment xml:lang="en">Represents data, output, or artifacts generated by software tools.</rdfs:comment>
  <rdfs:label xml:lang="en">Data</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ToolDataTaskUsage">
  <rdfs:comment xml:lang="en">Represents a specific usage of a software tool with a particular data artifact to support a specific task.</rdfs:comment>
  <rdfs:label xml:lang="en">Tool Data Task Usage</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Format">
  <rdfs:comment xml:lang="en">A standardized way of encoding data, such as XML, JSON, or CSV.</rdfs:comment>
  <rdfs:label xml:lang="en">Format</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#CelFormat">
  <rdfs:comment xml:lang="en">A specific file format used for storing microarray data.</rdfs:comment>
  <rdfs:label xml:lang="en">CEL Format</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Format'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ProprietaryFormat">
  <rdfs:comment xml:lang="en">A data format that is owned or controlled by a specific vendor or organization.</rdfs:comment>
  <rdfs:label xml:lang="en">Proprietary Format</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Format'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#OpenFormat">
  <rdfs:comment xml:lang="en">A data format that is publicly available and not restricted by proprietary controls.</rdfs:comment>
  <rdfs:label xml:lang="en">Open Format</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Format'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#CsvFormat">
  <rdfs:comment xml:lang="en">A plain text file format for storing tabular data, using commas as delimiters.</rdfs:comment>
  <rdfs:label xml:lang="en">CSV Format</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#OpenFormat'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#TxtFormat">
  <rdfs:comment xml:lang="en">A plain text file format for storing unformatted text.</rdfs:comment>
  <rdfs:label xml:lang="en">TXT Format</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#OpenFormat'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Export">
  <rdfs:comment xml:lang="en">Represents the capability or act of exporting data from a source format to a target format.</rdfs:comment>
  <rdfs:label xml:lang="en">Export</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#DataFlow">
  <rdfs:comment xml:lang="en">Represents the flow or transfer of data from a producing software tool to a consuming software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Data Flow</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Version">
  <rdfs:comment xml:lang="en">A specific release or iteration of a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Version</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Help">
  <rdfs:comment xml:lang="en">Information or resources provided to assist users in using a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Help</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Developer">
  <rdfs:comment xml:lang="en">A person or organization that develops a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Developer</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#User">
  <rdfs:comment xml:lang="en">A person or organization interested in collaborating on software development.</rdfs:comment>
  <rdfs:label xml:lang="en">User</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Collaboration">
  <rdfs:comment xml:lang="en">Represents a collaborative effort involving a user, a developer, and potentially a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">Collaboration</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#License">
  <rdfs:comment xml:lang="en">A legal instrument by which a right is vested and an obligation constituted.</rdfs:comment>
  <rdfs:label xml:lang="en">License</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ProgrammingLanguage">
  <rdfs:comment xml:lang="en">A programming language in which a software tool is implemented.</rdfs:comment>
  <rdfs:label xml:lang="en">Programming Language</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Platform">
  <rdfs:comment xml:lang="en">The operating system or environment on which a software tool runs.</rdfs:comment>
  <rdfs:label xml:lang="en">Platform</rdfs:label>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#uses">
  <rdfs:comment xml:lang="en">Indicates that a tool employs a specific algorithm.</rdfs:comment>
  <rdfs:label xml:lang="en">uses</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasTool">
  <rdfs:comment xml:lang="en">Links an algorithm usage instance to the tool that employs it.</rdfs:comment>
  <rdfs:label xml:lang="en">has tool</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#AlgorithmUsage"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAlgorithm">
  <rdfs:comment xml:lang="en">Links an algorithm usage instance to the algorithm being employed.</rdfs:comment>
  <rdfs:label xml:lang="en">has algorithm</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#AlgorithmUsage"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Algorithm"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasFeature">
  <rdfs:comment xml:lang="en">Indicates that a tool provides a specific feature.</rdfs:comment>
  <rdfs:label xml:lang="en">has feature</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Feature"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasSoftwareType">
  <rdfs:comment xml:lang="en">Indicates the type or category of a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">has software type</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#SoftwareType"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#performsTask">
  <rdfs:comment xml:lang="en">Indicates that a software tool performs a specific task.</rdfs:comment>
  <rdfs:label xml:lang="en">performs task</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Task"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#produces">
  <rdfs:comment xml:lang="en">Indicates that a software tool creates or produces a specific data artifact.</rdfs:comment>
  <rdfs:label xml:lang="en">produces</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Data"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasToolForTask">
  <rdfs:comment xml:lang="en">Links a tool-data-task usage instance to the software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">has tool for task</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ToolDataTaskUsage"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#usesData">
  <rdfs:comment xml:lang="en">Links a tool-data-task usage instance to the data artifact being used.</rdfs:comment>
  <rdfs:label xml:lang="en">uses data</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ToolDataTaskUsage"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Data"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#supportsTask">
  <rdfs:comment xml:lang="en">Links a tool-data-task usage instance to the task being supported.</rdfs:comment>
  <rdfs:label xml:lang="en">supports task</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#ToolDataTaskUsage"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Task"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasInputFormat">
  <rdfs:comment xml:lang="en">Indicates the data format(s) that a software tool accepts as input.</rdfs:comment>
  <rdfs:label xml:lang="en">has input format</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Format"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasOutputFormat">
  <rdfs:comment xml:lang="en">Indicates the data format(s) that a software tool produces as output.</rdfs:comment>
  <rdfs:label xml:lang="en">has output format</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Format"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#supportsExport">
  <rdfs:comment xml:lang="en">Indicates that a software tool supports exporting data in a specific manner.</rdfs:comment>
  <rdfs:label xml:lang="en">supports export</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Export"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#exportFrom">
  <rdfs:comment xml:lang="en">Indicates the source format of an export operation.</rdfs:comment>
  <rdfs:label xml:lang="en">export from</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Export"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Format"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#exportTo">
  <rdfs:comment xml:lang="en">Indicates the target format of an export operation.</rdfs:comment>
  <rdfs:label xml:lang="en">export to</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Export"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Format"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#sourceTool">
  <rdfs:comment xml:lang="en">Indicates the software tool that produces the data in a data flow.</rdfs:comment>
  <rdfs:label xml:lang="en">source tool</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#DataFlow"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#targetTool">
  <rdfs:comment xml:lang="en">Indicates the software tool that consumes or works with the data in a data flow.</rdfs:comment>
  <rdfs:label xml:lang="en">target tool</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#DataFlow"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasData">
  <rdfs:comment xml:lang="en">Indicates the data artifact being transferred or used in a data flow.</rdfs:comment>
  <rdfs:label xml:lang="en">has data</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#DataFlow"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Data"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasVersion">
  <rdfs:comment xml:lang="en">Indicates that a software tool has a specific version.</rdfs:comment>
  <rdfs:label xml:lang="en">has version</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Version"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasExport">
  <rdfs:comment xml:lang="en">Indicates that a specific version of a tool supports a particular data export.</rdfs:comment>
  <rdfs:label xml:lang="en">has export</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Version"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Export"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasHelp">
  <rdfs:comment xml:lang="en">Indicates that a software tool provides help or support resources.</rdfs:comment>
  <rdfs:label xml:lang="en">has help</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Help"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasDeveloper">
  <rdfs:comment xml:lang="en">Indicates the developer (person or organization) responsible for creating the software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">has developer</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Developer"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasCollaborator">
  <rdfs:comment xml:lang="en">Links a collaboration instance to the user involved.</rdfs:comment>
  <rdfs:label xml:lang="en">has collaborator</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Collaboration"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#User"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#involvesDeveloper">
  <rdfs:comment xml:lang="en">Links a collaboration instance to the developer involved.</rdfs:comment>
  <rdfs:label xml:lang="en">involves developer</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Collaboration"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Developer"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#involvesTool">
  <rdfs:comment xml:lang="en">Links a collaboration instance to the software tool being collaborated on.</rdfs:comment>
  <rdfs:label xml:lang="en">involves tool</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Collaboration"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#versionHasFeature">
  <rdfs:comment xml:lang="en">Indicates that a specific version of a software tool includes a particular feature.</rdfs:comment>
  <rdfs:label xml:lang="en">version has feature</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Version"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Feature"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasLicense">
  <rdfs:comment xml:lang="en">Indicates the license under which a software tool is distributed.</rdfs:comment>
  <rdfs:label xml:lang="en">has license</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#License"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasProgrammingLanguage">
  <rdfs:comment xml:lang="en">Indicates the programming language in which a software tool is implemented.</rdfs:comment>
  <rdfs:label xml:lang="en">has programming language</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#ProgrammingLanguage"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#runsOnPlatform">
  <rdfs:comment xml:lang="en">Indicates the platform or operating system on which a software tool runs.</rdfs:comment>
  <rdfs:label xml:lang="en">runs on platform</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Platform"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasModification">
  <rdfs:comment xml:lang="en">Describes any modifications made to the algorithm in a specific usage context.</rdfs:comment>
  <rdfs:label xml:lang="en">has modification</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#AlgorithmUsage"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isOpenSource">
  <rdfs:comment xml:lang="en">Indicates whether the software tool is open source.</rdfs:comment>
  <rdfs:label xml:lang="en">is open source</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isMaintained">
  <rdfs:comment xml:lang="en">Indicates whether the software tool is actively maintained.</rdfs:comment>
  <rdfs:label xml:lang="en">is maintained</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasAcquisitionUrl">
  <rdfs:comment xml:lang="en">Indicates the URL or location where the software tool can be acquired or downloaded.</rdfs:comment>
  <rdfs:label xml:lang="en">has acquisition url</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:anyURI"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasHomepage">
  <rdfs:comment xml:lang="en">Indicates the homepage URL of the software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">has homepage</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:anyURI"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasCreationDate">
  <rdfs:comment xml:lang="en">Indicates the date when the software tool was first created or released.</rdfs:comment>
  <rdfs:label xml:lang="en">has creation date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:date"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#developmentActivityLevel">
  <rdfs:comment xml:lang="en">Indicates the level or degree of active development for a software tool.</rdfs:comment>
  <rdfs:label xml:lang="en">development activity level</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasReleaseDate">
  <rdfs:comment xml:lang="en">Indicates the date when a specific version of a software tool was released.</rdfs:comment>
  <rdfs:label xml:lang="en">has release date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Version"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:date"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isCommunityDriven">
  <rdfs:comment xml:lang="en">Indicates whether the software tool is developed by a community.</rdfs:comment>
  <rdfs:label xml:lang="en">is community driven</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasPermissiveness">
  <rdfs:comment xml:lang="en">Indicates the permissiveness level of a software license (e.g., permissive, copyleft).</rdfs:comment>
  <rdfs:label xml:lang="en">has permissiveness</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#License"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#isFOSS">
  <rdfs:comment xml:lang="en">Indicates whether the software tool is Free and Open Source Software (FOSS).</rdfs:comment>
  <rdfs:label xml:lang="en">is FOSS</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasDocumentationUrl">
  <rdfs:comment xml:lang="en">Indicates the URL or location where the documentation for the software tool can be found.</rdfs:comment>
  <rdfs:label xml:lang="en">has documentation url</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tool"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:anyURI"/>
</owl:DatatypeProperty>

</rdf:RDF>