<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Player">
  <rdfs:comment xml:lang="en">A person who plays a game or sport.</rdfs:comment>
  <rdfs:label xml:lang="en">Player</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Game">
  <rdfs:comment xml:lang="en">A game or sport that players participate in.</rdfs:comment>
  <rdfs:label xml:lang="en">Game</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Achievement">
  <rdfs:comment xml:lang="en">An accomplishment or milestone reached by a player.</rdfs:comment>
  <rdfs:label xml:lang="en">Achievement</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Milestone">
  <rdfs:comment xml:lang="en">A type of achievement representing a significant point or stage in gameplay.</rdfs:comment>
  <rdfs:label xml:lang="en">Milestone</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Achievement'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Badge">
  <rdfs:comment xml:lang="en">A type of achievement representing a visual token or emblem awarded for accomplishments.</rdfs:comment>
  <rdfs:label xml:lang="en">Badge</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Achievement'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Trophy">
  <rdfs:comment xml:lang="en">A type of achievement representing a high-level award or recognition.</rdfs:comment>
  <rdfs:label xml:lang="en">Trophy</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Achievement'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Genre">
  <rdfs:comment xml:lang="en">A category or style of game.</rdfs:comment>
  <rdfs:label xml:lang="en">Genre</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Item">
  <rdfs:comment xml:lang="en">A collectible, equipment, or usable object that exists within a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Item</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Ability">
  <rdfs:comment xml:lang="en">A special capability or effect that an item can provide within a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Ability</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#KillCount">
  <rdfs:comment xml:lang="en">A record of the number of kills a player has achieved in a specific game.</rdfs:comment>
  <rdfs:label xml:lang="en">Kill Count</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#GamePlaySession">
  <rdfs:comment xml:lang="en">A session or instance of a player playing a specific game at a particular time.</rdfs:comment>
  <rdfs:label xml:lang="en">Game Play Session</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayerGameAchievement">
  <rdfs:comment xml:lang="en">A pivot class representing the relationship between a player, a game, and an achievement.</rdfs:comment>
  <rdfs:label xml:lang="en">Player Game Achievement</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Equipment">
  <rdfs:comment xml:lang="en">A type of item that serves as gear or tools for a player in a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Equipment</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Item'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayerGameItem">
  <rdfs:comment xml:lang="en">A pivot class representing the relationship between a player, a game, and an item (equipment).</rdfs:comment>
  <rdfs:label xml:lang="en">Player Game Item</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#InAppPurchase">
  <rdfs:comment xml:lang="en">A record of an in-app purchase made by a player for an item.</rdfs:comment>
  <rdfs:label xml:lang="en">In App Purchase</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Location">
  <rdfs:comment xml:lang="en">A geographical location such as a city, region, or country.</rdfs:comment>
  <rdfs:label xml:lang="en">Location</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayerGameIAP">
  <rdfs:comment xml:lang="en">A pivot class representing the relationship between a player, a game, a game play session, and an in-app purchase.</rdfs:comment>
  <rdfs:label xml:lang="en">Player Game IAP</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlayingArea">
  <rdfs:comment xml:lang="en">A specific area or zone within a game where gameplay occurs.</rdfs:comment>
  <rdfs:label xml:lang="en">Playing Area</rdfs:label>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasFriend">
  <rdfs:comment xml:lang="en">A friend relationship between players.</rdfs:comment>
  <rdfs:label xml:lang="en">Friend</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#playsGame">
  <rdfs:comment xml:lang="en">Indicates that a player participates in a specific game.</rdfs:comment>
  <rdfs:label xml:lang="en">Plays Game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAchievement">
  <rdfs:comment xml:lang="en">Indicates that a player or game has a specific milestone or accomplishment.</rdfs:comment>
  <rdfs:label xml:lang="en">Has Achievement</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGenre">
  <rdfs:comment xml:lang="en">Indicates the genre of a game.</rdfs:comment>
  <rdfs:label xml:lang="en">Has Genre</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Genre"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasItem">
  <rdfs:comment xml:lang="en">Indicates that a game contains a specific item.</rdfs:comment>
  <rdfs:label xml:lang="en">Has Item</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAbility">
  <rdfs:comment xml:lang="en">Indicates that an item provides a specific ability.</rdfs:comment>
  <rdfs:label xml:lang="en">Has Ability</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Item"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Ability"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPlayer">
  <rdfs:comment xml:lang="en">The player associated with a kill count record.</rdfs:comment>
  <rdfs:label xml:lang="en">Player</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#KillCount"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGame">
  <rdfs:comment xml:lang="en">The game associated with a kill count record.</rdfs:comment>
  <rdfs:label xml:lang="en">Game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#KillCount"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#ownsItem">
  <rdfs:comment xml:lang="en">Indicates that a player possesses a specific item.</rdfs:comment>
  <rdfs:label xml:lang="en">Owns Item</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPlayer">
  <rdfs:comment xml:lang="en">The player involved in a game play session.</rdfs:comment>
  <rdfs:label xml:lang="en">Player</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#GamePlaySession"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGame">
  <rdfs:comment xml:lang="en">The game involved in a game play session.</rdfs:comment>
  <rdfs:label xml:lang="en">Game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#GamePlaySession"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#pivotHasPlayer">
  <rdfs:comment xml:lang="en">Links a player-game-achievement record to the player.</rdfs:comment>
  <rdfs:label xml:lang="en">Pivot Has Player</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameAchievement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#pivotHasGame">
  <rdfs:comment xml:lang="en">Links a player-game-achievement record to the game.</rdfs:comment>
  <rdfs:label xml:lang="en">Pivot Has Game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameAchievement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#pivotHasAchievement">
  <rdfs:comment xml:lang="en">Links a player-game-achievement record to the achievement.</rdfs:comment>
  <rdfs:label xml:lang="en">Pivot Has Achievement</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameAchievement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Achievement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#pivotHasPlayer">
  <rdfs:comment xml:lang="en">Links a player-game-item record to the player.</rdfs:comment>
  <rdfs:label xml:lang="en">Pivot Has Player</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameItem"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#pivotHasGame">
  <rdfs:comment xml:lang="en">Links a player-game-item record to the game.</rdfs:comment>
  <rdfs:label xml:lang="en">Pivot Has Game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameItem"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#pivotHasItem">
  <rdfs:comment xml:lang="en">Links a player-game-item record to the item.</rdfs:comment>
  <rdfs:label xml:lang="en">Pivot Has Item</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameItem"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#purchaseHasPlayer">
  <rdfs:comment xml:lang="en">Links an in-app purchase record to the player who made it.</rdfs:comment>
  <rdfs:label xml:lang="en">Purchase Has Player</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#purchaseHasGame">
  <rdfs:comment xml:lang="en">Links an in-app purchase record to the game in which the purchase was made.</rdfs:comment>
  <rdfs:label xml:lang="en">Purchase Has Game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#purchaseHasItem">
  <rdfs:comment xml:lang="en">Links an in-app purchase record to the item that was purchased.</rdfs:comment>
  <rdfs:label xml:lang="en">Purchase Has Item</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Item"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#livesIn">
  <rdfs:comment xml:lang="en">Indicates the geographical location where a player resides.</rdfs:comment>
  <rdfs:label xml:lang="en">Lives In</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Location"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#pivotHasPlayer">
  <rdfs:comment xml:lang="en">Links a player-game-IAP record to the player.</rdfs:comment>
  <rdfs:label xml:lang="en">Pivot Has Player</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameIAP"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Player"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#pivotHasGame">
  <rdfs:comment xml:lang="en">Links a player-game-IAP record to the game.</rdfs:comment>
  <rdfs:label xml:lang="en">Pivot Has Game</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameIAP"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Game"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#pivotHasSession">
  <rdfs:comment xml:lang="en">Links a player-game-IAP record to the game play session.</rdfs:comment>
  <rdfs:label xml:lang="en">Pivot Has Session</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameIAP"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#GamePlaySession"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#pivotHasIAP">
  <rdfs:comment xml:lang="en">Links a player-game-IAP record to the in-app purchase.</rdfs:comment>
  <rdfs:label xml:lang="en">Pivot Has IAP</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlayerGameIAP"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPlayingArea">
  <rdfs:comment xml:lang="en">Indicates that a game contains a specific playing area.</rdfs:comment>
  <rdfs:label xml:lang="en">Has Playing Area</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PlayingArea"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasUsername">
  <rdfs:comment xml:lang="en">The username associated with a player.</rdfs:comment>
  <rdfs:label xml:lang="en">Username</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Player"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasTotalPlayTime">
  <rdfs:comment xml:lang="en">The total number of hours the game has been played.</rdfs:comment>
  <rdfs:label xml:lang="en">Total Play Time</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasReleaseDate">
  <rdfs:comment xml:lang="en">The date the game was released.</rdfs:comment>
  <rdfs:label xml:lang="en">Release Date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Game"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:date"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasValue">
  <rdfs:comment xml:lang="en">The numerical value of the kill count.</rdfs:comment>
  <rdfs:label xml:lang="en">Value</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#KillCount"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#integer"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#playedOn">
  <rdfs:comment xml:lang="en">The date and time when the game play session occurred.</rdfs:comment>
  <rdfs:label xml:lang="en">Played On</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#GamePlaySession"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#purchaseTimestamp">
  <rdfs:comment xml:lang="en">The date and time when the in-app purchase occurred.</rdfs:comment>
  <rdfs:label xml:lang="en">Purchase Timestamp</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#InAppPurchase"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:dateTime"/>
</owl:DatatypeProperty>

</rdf:RDF>