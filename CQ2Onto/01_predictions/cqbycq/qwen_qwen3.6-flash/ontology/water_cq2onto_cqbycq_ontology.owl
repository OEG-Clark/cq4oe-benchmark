<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure">
  <rdfs:comment xml:lang="en">A system of interconnected components designed to distribute water.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Distribution Infrastructure</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Asset">
  <rdfs:comment xml:lang="en">A physical component or piece of equipment that is part of an infrastructure.</rdfs:comment>
  <rdfs:label xml:lang="en">Asset</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Sensor">
  <rdfs:comment xml:lang="en">A device used to detect or measure physical properties and record, indicate, or respond to the data.</rdfs:comment>
  <rdfs:label xml:lang="en">Sensor</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Asset'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Actuator">
  <rdfs:comment xml:lang="en">A device that moves or controls a mechanism or system.</rdfs:comment>
  <rdfs:label xml:lang="en">Actuator</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Asset'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterMeter">
  <rdfs:comment xml:lang="en">A device used to measure different aspects of a water infrastructure.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Meter</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Measurement">
  <rdfs:comment xml:lang="en">An instance of data collected by a water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">Measurement</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Water">
  <rdfs:comment xml:lang="en">The chemical substance H2O, central to the distribution infrastructure.</rdfs:comment>
  <rdfs:label xml:lang="en">Water</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PhysicalProperty">
  <rdfs:comment xml:lang="en">A measurable characteristic or attribute of water.</rdfs:comment>
  <rdfs:label xml:lang="en">Physical Property</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ChemicalProperty">
  <rdfs:comment xml:lang="en">A measurable characteristic or attribute of water related to its chemical composition.</rdfs:comment>
  <rdfs:label xml:lang="en">Chemical Property</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WaterIndicator">
  <rdfs:comment xml:lang="en">A measurable or observable characteristic used to assess the quality or status of water.</rdfs:comment>
  <rdfs:label xml:lang="en">Water Indicator</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#City">
  <rdfs:comment xml:lang="en">A large or important town or city.</rdfs:comment>
  <rdfs:label xml:lang="en">City</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Tariff">
  <rdfs:comment xml:lang="en">A pricing structure or rate applied to water consumption.</rdfs:comment>
  <rdfs:label xml:lang="en">Tariff</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#BillingPeriod">
  <rdfs:comment xml:lang="en">A period defining the billing dates for a water meter.</rdfs:comment>
  <rdfs:label xml:lang="en">Billing Period</rdfs:label>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAsset">
  <rdfs:comment xml:lang="en">Links an infrastructure to its constituent assets.</rdfs:comment>
  <rdfs:label xml:lang="en">has asset</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Asset"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#measures">
  <rdfs:comment xml:lang="en">Links a water meter to the infrastructure it measures.</rdfs:comment>
  <rdfs:label xml:lang="en">measures</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WaterDistributionInfrastructure"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#providesMeasurement">
  <rdfs:comment xml:lang="en">Links a water meter to the measurements it provides.</rdfs:comment>
  <rdfs:label xml:lang="en">provides measurement</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Measurement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasPhysicalProperty">
  <rdfs:comment xml:lang="en">Links water to its physical properties.</rdfs:comment>
  <rdfs:label xml:lang="en">has physical property</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Water"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PhysicalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasChemicalProperty">
  <rdfs:comment xml:lang="en">Links water to its chemical properties.</rdfs:comment>
  <rdfs:label xml:lang="en">has chemical property</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Water"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#ChemicalProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasLocation">
  <rdfs:comment xml:lang="en">Links a water indicator to the city or location it is defined for.</rdfs:comment>
  <rdfs:label xml:lang="en">has location</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterIndicator"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#City"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasTariff">
  <rdfs:comment xml:lang="en">Links a water meter to the tariff it uses.</rdfs:comment>
  <rdfs:label xml:lang="en">has tariff</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Tariff"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasTariffPeriod">
  <rdfs:comment xml:lang="en">Links a water meter to the tariff period it is subject to.</rdfs:comment>
  <rdfs:label xml:lang="en">has tariff period</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Tariff"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasBillingPeriod">
  <rdfs:comment xml:lang="en">Links a water meter to its billing period.</rdfs:comment>
  <rdfs:label xml:lang="en">has billing period</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#BillingPeriod"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasFabricationNumber">
  <rdfs:comment xml:lang="en">Links a water meter to its fabrication number.</rdfs:comment>
  <rdfs:label xml:lang="en">has fabrication number</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasManufacturer">
  <rdfs:comment xml:lang="en">Links a water meter to its manufacturer.</rdfs:comment>
  <rdfs:label xml:lang="en">has manufacturer</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasModel">
  <rdfs:comment xml:lang="en">Links a water meter to its model.</rdfs:comment>
  <rdfs:label xml:lang="en">has model</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasVersion">
  <rdfs:comment xml:lang="en">Links a water meter to its version.</rdfs:comment>
  <rdfs:label xml:lang="en">has version</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasHardwareVersion">
  <rdfs:comment xml:lang="en">Links a water meter to its hardware version number.</rdfs:comment>
  <rdfs:label xml:lang="en">has hardware version number</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasFirmwareVersion">
  <rdfs:comment xml:lang="en">Links a water meter to its firmware version.</rdfs:comment>
  <rdfs:label xml:lang="en">has firmware version</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasPower">
  <rdfs:comment xml:lang="en">Links a water meter to its power rating.</rdfs:comment>
  <rdfs:label xml:lang="en">has power</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:decimal"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasRadioFrequencyLevel">
  <rdfs:comment xml:lang="en">Links a water meter to its radio frequency level.</rdfs:comment>
  <rdfs:label xml:lang="en">has radio frequency level</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:decimal"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasGeolocation">
  <rdfs:comment xml:lang="en">Links a water meter to its geolocation.</rdfs:comment>
  <rdfs:label xml:lang="en">has geolocation</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasTemporalSetting">
  <rdfs:comment xml:lang="en">Links a measurement to its temporal setting (e.g., frequency or interval).</rdfs:comment>
  <rdfs:label xml:lang="en">has temporal setting</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Measurement"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasStartDate">
  <rdfs:comment xml:lang="en">The start date and time of the tariff.</rdfs:comment>
  <rdfs:label xml:lang="en">has start date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tariff"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:dateTime"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasEndDate">
  <rdfs:comment xml:lang="en">The end date and time of the tariff.</rdfs:comment>
  <rdfs:label xml:lang="en">has end date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Tariff"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:dateTime"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasBillingDate">
  <rdfs:comment xml:lang="en">Links a water meter to its billing date.</rdfs:comment>
  <rdfs:label xml:lang="en">has billing date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WaterMeter"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:dateTime"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasBillingStartDate">
  <rdfs:comment xml:lang="en">The start date and time of the billing period.</rdfs:comment>
  <rdfs:label xml:lang="en">has billing start date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#BillingPeriod"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:dateTime"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasBillingEndDate">
  <rdfs:comment xml:lang="en">The end date and time of the billing period.</rdfs:comment>
  <rdfs:label xml:lang="en">has billing end date</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#BillingPeriod"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#xsd:dateTime"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

</rdf:RDF>